{
  "Tfs": {
    "Url": "http://your-tfs-server:8080/tfs/DefaultCollection",
    "Project": "YourProject",
    "DefaultAreaPath": "YourProject",
    "UseDefaultCredentials": true,
    "TimeoutSeconds": 30,
    "ApiVersion": "7.0"
  },
  "TfsRetrievalValidator": {
    "RootWorkItemId": 1
  },
  "RevisionIngestionPagination": {
    "MaxEmptyPages": 50,
    "MaxProgressWithoutDataPages": 3,
    "MaxTotalPages": 5000,
    "MaxPageRetries": 2,
    "RetryBackoffSeconds": 2,
    "RetryBackoffJitterSeconds": 1,
    "AnomalyPolicy": "FailFast",
    "FallbackBatchSize": 25,
    "MaxTotalRows": 500000
  }
}
