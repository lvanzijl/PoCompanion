{
  "Tfs": {
    "Url": "http://your-tfs-server:8080/tfs/DefaultCollection",
    "Project": "YourProject",
    "DefaultAreaPath": "YourProject",
    "UseDefaultCredentials": true,
    "TimeoutSeconds": 30,
    "ApiVersion": "7.0",
    "AnalyticsODataBaseUrl": "http://your-tfs-server:8080/tfs/DefaultCollection/YourProject/_odata/v3.0-preview",
    "AnalyticsODataEntitySetPath": "WorkItemRevisions"
  },
  "TfsRetrievalValidator": {
    "RootWorkItemId": 1
  },
  "RevisionIngestionPagination": {
    "ODataTop": 200,
    "ODataSeekPageSize": 200,
    "ODataSelectMode": "Minimal",
    "ODataOrderByEnabled": true,
    "ODataUseQuotedDateLiterals": true,
    "ODataEnableSeekPagingFallback": true,
    "ODataScopeMode": "Range",
    "ODataMaxUrlLength": 1800,
    "MaxNoProgressPages": 2,
    "MaxEmptyPages": 50,
    "MaxProgressWithoutDataPages": 3,
    "MaxTotalPages": 5000,
    "MaxPageRetries": 2,
    "RetryBackoffSeconds": 2,
    "RetryBackoffJitterSeconds": 1,
    "AnomalyPolicy": "FailFast",
    "FallbackBatchSize": 25,
    "MaxTotalRows": 500000
  }
}
