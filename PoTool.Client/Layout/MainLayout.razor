@using PoTool.Client.Components.Settings
@using PoTool.Client.Components.Onboarding
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Services
@using PoTool.Client.Models
@inject IOnboardingService OnboardingService
@inject IStartupOrchestratorService StartupOrchestrator
@inject GlobalFilterStore GlobalFilterStore
@inject IProfileService ProfileService
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inject GlobalFilterCorrectionService GlobalFilterCorrectionService
@inject GlobalFilterDefaultsService GlobalFilterDefaultsService
@inject GlobalFilterRouteService GlobalFilterRouteService
@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider Theme="_darkTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page workspace-layout" @onkeydown="HandleGlobalKeyDown" tabindex="-1">
    <main class="workspace-main">
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="top-row__left d-flex align-items-center">
                <MudTooltip Text="Return to Home">
                    <CompactIconButton Icon="@Icons.Material.Filled.Home" 
                                   Color="Color.Inherit" 
                                   OnClick="NavigateToHome" 
                                  Title="Home" 
                                  AriaLabel="Return to home page" />
                </MudTooltip>
                <ProfileSelector @ref="_profileSelector" OnProfileChanged="HandleProfileChanged" />
            </div>
            <div class="top-row__workspace-nav">
                <WorkspaceNavigationBar OnNavigate="NavigateToWorkspaceAsync" />
            </div>
            <div class="top-row__right d-flex align-items-center">
                <CompactIconButton Icon="@Icons.Material.Filled.Help" 
                              Color="Color.Inherit" 
                              OnClick="OpenOnboardingWizard" 
                              Title="Getting Started" 
                              AriaLabel="Open getting started wizard" />
                <MudTooltip Text="Keyboard Shortcuts (Press ?)">
                    <CompactIconButton Icon="@Icons.Material.Filled.Keyboard" 
                                  Color="Color.Inherit" 
                                  OnClick="OpenKeyboardShortcuts" 
                                  Title="Keyboard Shortcuts" 
                                  AriaLabel="Open keyboard shortcuts" />
                </MudTooltip>
                <CompactIconButton Icon="@Icons.Material.Filled.Settings" 
                              Color="Color.Inherit" 
                              OnClick="NavigateToSettings" 
                              Title="Settings" 
                              AriaLabel="Open settings" />
            </div>
        </div>

        <article class="content px-4">
            <FilterSummaryBar />
            <StartupGuard>
                @Body
            </StartupGuard>
            <GlobalFilterControls />
        </article>
    </main>
</div>

@code {
    private bool _hasCheckedOnboarding = false;
    private ProfileSelector? _profileSelector;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        
        if (firstRender && !_hasCheckedOnboarding)
        {
            _hasCheckedOnboarding = true;
            ObserveCurrentRoute();
            
            // Subscribe to navigation changes to refresh profile selector when needed
            NavigationManager.LocationChanged += OnLocationChanged;
        }
    }
    
    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            // Refresh profile selector when navigating to profiles page or back from profile edit
            var path = NavigationManager.ToBaseRelativePath(e.Location).TrimStart('/');
            if (path.StartsWith("profiles", StringComparison.OrdinalIgnoreCase) || 
                path.StartsWith("settings/productowner", StringComparison.OrdinalIgnoreCase))
            {
                if (_profileSelector != null)
                {
                    await _profileSelector.RefreshAsync();
                }
            }

            ObserveCurrentRoute(e.Location);
        }
        catch (Exception ex)
        {
            // Log error but don't throw - navigation should continue
            Console.WriteLine($"[MainLayout] Error refreshing profile selector: {ex.Message}");
        }
    }
    
    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
    
    private void NavigateToSettings()
    {
        NavigationManager.NavigateTo("/settings");
    }

    private void NavigateToHome()
    {
        _ = NavigateWithCurrentStateAsync(WorkspaceRoutes.Home);
    }

    private async Task NavigateToWorkspaceAsync(string route)
    {
        var activeProfile = await ProfileService.GetActiveProfileAsync();
        if (activeProfile == null)
        {
            NavigationManager.NavigateTo($"{WorkspaceRoutes.Home}?noProfile=true");
            return;
        }

        await NavigateWithCurrentStateAsync(route);
    }

    private async Task OpenOnboardingWizard()
    {
        var options = new DialogOptions 
        { 
            CloseButton = false,
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        
        await DialogService.ShowAsync<OnboardingWizard>("Getting Started", options);
    }

    private async Task OpenKeyboardShortcuts()
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };
        
        await DialogService.ShowAsync<KeyboardShortcutsDialog>("Keyboard Shortcuts", options);
    }

    private void HandleProfileChanged()
    {
        // Refresh the current page when profile changes by forcing navigation
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    private void ObserveCurrentRoute(string? uri = null)
    {
        _ = ObserveCurrentRouteAsync(uri ?? NavigationManager.Uri);
    }

    private async Task ObserveCurrentRouteAsync(string uri)
    {
        var activeProfileId = ProfileService.GetActiveProfileId();
        if (!activeProfileId.HasValue)
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            activeProfileId = activeProfile?.Id;
            ProfileService.SetCachedActiveProfileId(activeProfileId);
        }

        await GlobalFilterStore.TrackNavigationAsync(uri, activeProfileId);
        var defaultedUri = await GlobalFilterDefaultsService.BuildDefaultedUriAsync(uri, activeProfileId);
        if (!string.IsNullOrWhiteSpace(defaultedUri) && GlobalFilterStore.TryPrepareNavigation(uri, defaultedUri))
        {
            NavigationManager.NavigateTo(defaultedUri, forceLoad: false);
            return;
        }

        var correctedUri = await GlobalFilterCorrectionService.BuildCorrectedUriAsync(uri);
        if (!string.IsNullOrWhiteSpace(correctedUri) && GlobalFilterStore.TryPrepareNavigation(uri, correctedUri))
        {
            NavigationManager.NavigateTo(correctedUri, forceLoad: false);
        }
    }

    private async Task NavigateWithCurrentStateAsync(string route)
    {
        var additionalParams = WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri);
        var targetUri = await GlobalFilterRouteService.BuildUriAsync(route, GlobalFilterStore.GetState(), additionalParams);
        if (GlobalFilterStore.TryPrepareNavigation(NavigationManager.Uri, targetUri))
        {
            NavigationManager.NavigateTo(targetUri);
        }
    }

    private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        // Open keyboard shortcuts help with "?" key
        if (e.Key == "?")
        {
            await OpenKeyboardShortcuts();
        }
    }

    private readonly MudTheme _darkTheme = new()
    {
        PaletteLight = new PaletteLight(),
        PaletteDark = new PaletteDark
        {
            Primary = "#0078D4",
            Secondary = "#2D7D9A",
            AppbarBackground = "#202225",
            Background = "#1B1C1E",
            BackgroundGray = "#252627",
            Surface = "#252627",
            DrawerBackground = "#1E1F21",
            DrawerText = "#F3F3F3",
            DrawerIcon = "#F3F3F3",
            TextPrimary = "#F3F3F3",
            TextSecondary = "#C8C8C8",
            ActionDefault = "#adadad",
            ActionDisabled = "rgba(255,255,255, 0.26)",
            ActionDisabledBackground = "rgba(255,255,255, 0.12)",
            Divider = "rgba(255,255,255, 0.12)",
            DividerLight = "rgba(255,255,255, 0.06)",
            TableLines = "rgba(255,255,255, 0.12)",
            LinesDefault = "rgba(255,255,255, 0.12)",
            LinesInputs = "rgba(255,255,255, 0.42)",
            TextDisabled = "rgba(255,255,255, 0.38)",
            Info = "#2196f3",
            Success = "#4caf50",
            Warning = "#ff9800",
            Error = "#f44336",
            Dark = "#111315"
        }
    };
}
