@using PoTool.Client.Components.Settings
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center">
            <button class="btn btn-link p-0 settings-top-right" @onclick="OpenSettings" title="Settings" aria-label="Open settings">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 8.4a3.6 3.6 0 1 0 0 7.2 3.6 3.6 0 0 0 0-7.2zM19.4 12a7.4 7.4 0 0 0-.1-1l2.1-1.6a.5.5 0 0 0 .1-.7l-2-3.4a.5.5 0 0 0-.7-.2l-2.5 1a7.5 7.5 0 0 0-1.7-.9l-.4-2.6A.5.5 0 0 0 13.8 1h-3.6a.5.5 0 0 0-.5.4l-.4 2.6a7.5 7.5 0 0 0-1.7.9l-2.5-1a.5.5 0 0 0-.7.2l-2 3.4a.5.5 0 0 0 .1.7L4.7 11a7.4 7.4 0 0 0 0 2l-2.1 1.6a.5.5 0 0 0-.1.7l2 3.4a.5.5 0 0 0 .7.2l2.5-1c.5.3 1 .6 1.7.9l.4 2.6c.1.3.4.4.5.4h3.6c.2 0 .4-.1.5-.4l.4-2.6c.6-.3 1.2-.6 1.7-.9l2.5 1a.5.5 0 0 0 .7-.2l2-3.4a.5.5 0 0 0-.1-.7L19.4 13a7.4 7.4 0 0 0 .1-1z"/>
                </svg>
            </button>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<SettingsModal @bind-Visible="_settingsVisible" />

@code {
    private bool _settingsVisible = false;

    private void OpenSettings()
    {
        _settingsVisible = true;
    }
}
