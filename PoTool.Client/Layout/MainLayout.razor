@using PoTool.Client.Components.Settings
@using PoTool.Client.Components.Onboarding
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@inject IOnboardingService OnboardingService
@inject IStartupOrchestratorService StartupOrchestrator
@inject IDialogService DialogService
@inject NavigationManager NavigationManager
@inherits LayoutComponentBase
@implements IDisposable

<MudThemeProvider Theme="_darkTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page" @onkeydown="HandleGlobalKeyDown" tabindex="-1">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <ProfileSelector @ref="_profileSelector" OnProfileChanged="HandleProfileChanged" />
            </div>
            <div class="d-flex align-items-center">
                <CompactIconButton Icon="@Icons.Material.Filled.Help" 
                              Color="Color.Inherit" 
                              OnClick="OpenOnboardingWizard" 
                              Title="Getting Started" 
                              AriaLabel="Open getting started wizard" />
                <MudTooltip Text="Keyboard Shortcuts (Press ?)">
                    <CompactIconButton Icon="@Icons.Material.Filled.Keyboard" 
                                  Color="Color.Inherit" 
                                  OnClick="OpenKeyboardShortcuts" 
                                  Title="Keyboard Shortcuts" 
                                  AriaLabel="Open keyboard shortcuts" />
                </MudTooltip>
                <CompactIconButton Icon="@Icons.Material.Filled.Settings" 
                              Color="Color.Inherit" 
                              OnClick="OpenSettings" 
                              Title="Settings" 
                              AriaLabel="Open settings" />
            </div>
        </div>

        <article class="content px-4">
            <StartupGuard>
                @Body
            </StartupGuard>
        </article>
    </main>
</div>

<SettingsModal @bind-Visible="_settingsVisible" />

@code {
    private bool _settingsVisible = false;
    private bool _hasCheckedOnboarding = false;
    private bool _hasCheckedStartupRouting = false;
    private ProfileSelector? _profileSelector;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        
        if (firstRender && !_hasCheckedOnboarding)
        {
            _hasCheckedOnboarding = true;
            
            // Check if user needs onboarding
            if (!await OnboardingService.HasCompletedOnboardingAsync())
            {
                await OpenOnboardingWizard();
            }
            
            // Subscribe to navigation changes to refresh profile selector when needed
            NavigationManager.LocationChanged += OnLocationChanged;
        }
        
        // Perform startup routing on first render (only for root path)
        if (firstRender && !_hasCheckedStartupRouting)
        {
            _hasCheckedStartupRouting = true;
            await PerformStartupRoutingAsync();
        }
    }
    
    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Refresh profile selector when navigating to profiles page or back from profile edit
        var path = NavigationManager.ToBaseRelativePath(e.Location).TrimStart('/');
        if (path.StartsWith("profiles", StringComparison.OrdinalIgnoreCase) || 
            path.StartsWith("settings/productowner", StringComparison.OrdinalIgnoreCase))
        {
            if (_profileSelector != null)
            {
                await _profileSelector.RefreshAsync();
            }
        }
    }
    
    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
    
    private async Task PerformStartupRoutingAsync()
    {
        // Only perform startup routing when on the root path
        var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        // Normalize: trim leading/trailing slashes and check if empty (root path)
        var normalizedPath = currentPath.Trim('/');
        if (!string.IsNullOrEmpty(normalizedPath))
        {
            return;
        }
        
        try
        {
            var readiness = await StartupOrchestrator.GetStartupReadinessAsync();
            if (readiness == null)
            {
                return; // Graceful degradation
            }
            
            var routingResult = StartupOrchestrator.DetermineRoute(readiness);
            
            // Route based on startup readiness
            switch (routingResult.Route)
            {
                case StartupRoute.Configuration:
                    NavigationManager.NavigateTo("/tfsconfig");
                    break;
                case StartupRoute.CreateFirstProfile:
                case StartupRoute.ProfilesHome:
                    // Always navigate to /profiles on startup (root path)
                    // User can select a profile to continue to ProductHome
                    NavigationManager.NavigateTo("/profiles");
                    break;
            }
        }
        catch (Exception)
        {
            // Graceful degradation - don't block the app
        }
    }

    private void OpenSettings()
    {
        _settingsVisible = true;
    }

    private async Task OpenOnboardingWizard()
    {
        var options = new DialogOptions 
        { 
            CloseButton = false,
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        
        await DialogService.ShowAsync<OnboardingWizard>("Getting Started", options);
    }

    private async Task OpenKeyboardShortcuts()
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };
        
        await DialogService.ShowAsync<KeyboardShortcutsDialog>("Keyboard Shortcuts", options);
    }

    private void HandleProfileChanged()
    {
        // Refresh the current page when profile changes by forcing navigation
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }

    private async Task HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        // Open keyboard shortcuts help with "?" key
        if (e.Key == "?")
        {
            await OpenKeyboardShortcuts();
        }
    }

    private readonly MudTheme _darkTheme = new()
    {
        PaletteLight = new PaletteLight(),
        PaletteDark = new PaletteDark
        {
            Primary = "#7c4dff",
            Secondary = "#00bcd4",
            AppbarBackground = "#1e1e1e",
            Background = "#121212",
            BackgroundGray = "#1e1e1e",
            Surface = "#1e1e1e",
            DrawerBackground = "#1e1e1e",
            DrawerText = "rgba(255,255,255, 0.87)",
            DrawerIcon = "rgba(255,255,255, 0.87)",
            TextPrimary = "rgba(255,255,255, 0.87)",
            TextSecondary = "rgba(255,255,255, 0.60)",
            ActionDefault = "#adadad",
            ActionDisabled = "rgba(255,255,255, 0.26)",
            ActionDisabledBackground = "rgba(255,255,255, 0.12)",
            Divider = "rgba(255,255,255, 0.12)",
            DividerLight = "rgba(255,255,255, 0.06)",
            TableLines = "rgba(255,255,255, 0.12)",
            LinesDefault = "rgba(255,255,255, 0.12)",
            LinesInputs = "rgba(255,255,255, 0.42)",
            TextDisabled = "rgba(255,255,255, 0.38)",
            Info = "#2196f3",
            Success = "#4caf50",
            Warning = "#ff9800",
            Error = "#f44336",
            Dark = "#121212"
        }
    };
}
