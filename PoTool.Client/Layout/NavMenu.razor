@using PoTool.Client.Components.Settings

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">PoTool.Client</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="profiles">
                <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Profiles
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="workitems">
                <span class="bi bi-diagram-3-nav-menu" aria-hidden="true"></span> Work Items
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="backlog-health">
                <span class="bi bi-heart-pulse-nav-menu" aria-hidden="true"></span> Backlog Health
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="effort-distribution">
                <span class="bi bi-grid-3x3-gap-nav-menu" aria-hidden="true"></span> Effort Distribution
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pr-insights">
                <span class="bi bi-graph-up-nav-menu" aria-hidden="true"></span> PR Insights
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pipeline-insights">
                <span class="bi bi-gear-wide-connected-nav-menu" aria-hidden="true"></span> Pipeline Insights
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="state-timeline">
                <span class="bi bi-clock-history-nav-menu" aria-hidden="true"></span> State Timeline
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="epic-forecast">
                <span class="bi bi-graph-up-arrow-nav-menu" aria-hidden="true"></span> Epic Forecast
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="release-planning">
                <span class="bi bi-kanban-nav-menu" aria-hidden="true"></span> Release Planning
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="velocity">
                <span class="bi bi-speedometer2-nav-menu" aria-hidden="true"></span> Velocity
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dependency-graph">
                <span class="bi bi-diagram-3-nav-menu" aria-hidden="true"></span> Dependencies
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tfsconfig">
                <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> TFS Config
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
