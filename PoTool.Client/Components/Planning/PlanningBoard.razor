    private async Task<RowTypeSelection?> ShowRowTypeSelectionDialog()
    {
        // First dialog: Choose between Normal row or Marker row
        var dialog = await DialogService.ShowMessageBox(
            "Add Row",
            "What type of row would you like to add?",
            yesText: "Normal Row",
            noText: "Marker Row",
            cancelText: "Cancel",
            options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small }
        );
        
        if (dialog == true)
        {
            // Normal row selected
            return new RowTypeSelection { IsMarker = false };
        }
        else if (dialog == false)
        {
            // Marker row selected - show second dialog for type
            var markerDialog = await DialogService.ShowMessageBox(
                "Select Marker Type",
                "What type of marker line?",
                yesText: "Iteration",
                noText: "Release",
                cancelText: "Back",
                options: new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small }
            );
            
            if (markerDialog == true)
            {
                return new RowTypeSelection 
                { 
                    IsMarker = true, 
                    MarkerType = PlanningDtos.MarkerRowType.Iteration 
                };
            }
            else if (markerDialog == false)
            {
                return new RowTypeSelection 
                { 
                    IsMarker = true, 
                    MarkerType = PlanningDtos.MarkerRowType.Release 
                };
            }
            else
            {
                // User clicked "Back" or cancelled - return to first dialog
                return await ShowRowTypeSelectionDialog();
            }
        }
        
        return null; // Cancelled from first dialog
    }
    
    private class RowTypeSelection
    {
        public bool IsMarker { get; set; }
        public PlanningDtos.MarkerRowType? MarkerType { get; set; }
    }
    
    private async Task DeleteRow(int rowId)
    {
        var row = _rows.FirstOrDefault(r => r.Id == rowId);
        if (row == null) return;
        
        // Check if row is empty
        var hasEpics = _placements.Any(p => p.RowId == row.Id);
        
        if (hasEpics)
        {
            // Show informational message - row cannot be deleted
            await DialogService.ShowMessageBox(
                "Cannot Delete Row",
                "This row contains epics and cannot be deleted. Remove epics first.",
                yesText: "OK"
            );
            return;
        }
        
        // Show delete confirmation dialog
        var options = new DialogOptions 
        { 
            CloseButton = true, 
            MaxWidth = MaxWidth.Small 
        };
        
        var dialog = await DialogService.ShowMessageBox(
            "Delete Row",
            "Are you sure you want to delete this row?",
            yesText: "Delete",
            cancelText: "Cancel",
            options: options
        );
        
        // If user cancelled, don't delete
        if (dialog != true)
        {
            return;
        }
        
        _isSaving = true;
        StateHasChanged();
        
        try
        {
            var result = await PlanningService.DeleteRowAsync(row.Id);
            
            if (result?.Success == true)
            {
                // Reload board to get updated rows
                await LoadBoardDataAsync();
            }
            else
            {
                Snackbar.Add(result?.ErrorMessage ?? "Failed to delete row", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete row {RowId}", row.Id);
            Snackbar.Add("Failed to delete row", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
    
    private void StartMarkerLabelEdit(int rowId)
    {
        var row = _rows.FirstOrDefault(r => r.Id == rowId);
        if (row == null || row.RowType != PlanningDtos.BoardRowType.Marker) return;
        
        _editingMarkerRowId = rowId;
        _editingMarkerLabel = row.MarkerLabel ?? string.Empty;
        StateHasChanged();
    }
    
