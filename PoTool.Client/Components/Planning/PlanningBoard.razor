    #region Drag and Drop
    
    private void HandleEpicDragStart(PlanningDtos.UnplannedEpicDto epic)
    {
        _isDragging = true;
        _dragEpicId = epic.EpicId;
        _dragProductId = epic.ProductId;
        _dragPlacementId = null;
        _dragMarkerRowId = null;
    }
    
    private void HandlePlacementDragStart(PlanningDtos.EpicPlacementDto placement)
    {
        _isDragging = true;
        _dragEpicId = placement.EpicId;
        _dragProductId = placement.ProductId;
        _dragPlacementId = placement.Id;
        _dragMarkerRowId = null;
    }
    
    private void HandleMarkerDragStart(PlanningDtos.BoardRowDto row)
    {
        _isDragging = true;
        _dragMarkerRowId = row.Id;
        _dragEpicId = null;
        _dragProductId = null;
        _dragPlacementId = null;
    }
    
    private void HandleDragEnd()
    {
        _isDragging = false;
        _dragEpicId = null;
        _dragProductId = null;
        _dragPlacementId = null;
        _dragMarkerRowId = null;
    }
    
    private void HandleCellDragOver(int rowId, int productId)
    {
        // Only allow drop if the product matches
        if (_dragProductId != productId)
        {
            // Cross-product drop is forbidden
            return;
        }
    }
    
    private async Task HandleCellDrop(int rowId, int productId)
    {
        if (!_isDragging) return;
        
        // Check for cross-product drop
        if (_dragProductId != productId)
        {
            Snackbar.Add("Cannot move epic to a different product column", Severity.Warning);
            HandleDragEnd();
            return;
        }
        
        _isSaving = true;
        StateHasChanged();
        
        try
        {
            // Handle unplanned epic drop
            if (_dragEpicId.HasValue && !_dragPlacementId.HasValue)
            {
                var epic = _unplannedEpics.FirstOrDefault(e => e.EpicId == _dragEpicId);
                if (epic != null)
                {
                    var orderInCell = _placements.Count(p => p.RowId == rowId && p.ProductId == productId);
                    
                    var request = new PlanningDtos.CreateEpicPlacementRequest
                    {
                        EpicId = epic.EpicId,
                        RowId = rowId,
                        OrderInCell = orderInCell
                    };
                    
                    var result = await PlanningService.CreatePlacementAsync(request);
                    
                    if (result?.Success == true)
                    {
                        // Reload board to get updated placements
                        await LoadBoardDataAsync();
                    }
                    else
                    {
                        Snackbar.Add(result?.ErrorMessage ?? "Failed to place epic", Severity.Error);
                    }
                }
            }
            // Handle existing placement move
            else if (_dragPlacementId.HasValue)
            {
                var placement = _placements.FirstOrDefault(p => p.Id == _dragPlacementId);
                if (placement != null)
                {
                    var orderInCell = _placements.Count(p => p.RowId == rowId && p.ProductId == productId && p.Id != placement.Id);
                    
                    var request = new PlanningDtos.MovePlanningEpicRequest
                    {
                        NewRowId = rowId,
                        NewOrderInCell = orderInCell
                    };
                    
                    var result = await PlanningService.MovePlacementAsync(_dragPlacementId.Value, request);
                    
                    if (result?.Success == true)
                    {
                        // Reload board to get updated placements
                        await LoadBoardDataAsync();
                    }
                    else
                    {
                        Snackbar.Add(result?.ErrorMessage ?? "Failed to move epic", Severity.Error);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle drop");
            Snackbar.Add("Failed to complete operation", Severity.Error);
        }
        finally
        {
            HandleDragEnd();
            _isSaving = false;
            StateHasChanged();
        }
    }
    
    private async Task HandleMarkerDrop(int targetRowId, bool insertBelow)
    {
        if (!_isDragging || !_dragMarkerRowId.HasValue) return;
        
        // Don't allow dropping on itself
        if (_dragMarkerRowId == targetRowId) 
        {
            HandleDragEnd();
            return;
        }
        
        _isSaving = true;
        StateHasChanged();
        
        try
        {
            var request = new PlanningDtos.MoveRowRequest
            {
                TargetRowId = targetRowId,
                InsertBelow = insertBelow
            };
            
            var result = await PlanningService.MoveRowAsync(_dragMarkerRowId.Value, request);
            
            if (result?.Success == true)
            {
                // Reload board to get updated row order
                await LoadBoardDataAsync();
            }
            else
            {
                Snackbar.Add(result?.ErrorMessage ?? "Failed to move row", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to move marker row");
            Snackbar.Add("Failed to move row", Severity.Error);
        }
        finally
        {
            HandleDragEnd();
            _isSaving = false;
            StateHasChanged();
        }
    }
    
