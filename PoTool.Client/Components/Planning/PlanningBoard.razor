@using PlanningDtos = PoTool.Shared.Planning
@using PoTool.Client.ApiClient
@inject ISnackbar Snackbar
@inject ILogger<PlanningBoard> Logger

<div class="planning-board" @onkeydown="HandleKeyDown" tabindex="0" @ref="_boardElement">
    @* Board Header: Scope Selector and Column Picker *@
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h5">
                <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                Planning Board
            </MudText>
            
            @* Scope Selector *@
            <MudToggleGroup T="PlanningDtos.BoardScope" 
                            Value="_scope"
                            ValueChanged="OnScopeChanged"
                            Size="Size.Small"
                            Color="Color.Primary"
                            Outlined="true">
                <MudToggleItem Value="PlanningDtos.BoardScope.AllProducts" Text="All Products" />
                <MudToggleItem Value="PlanningDtos.BoardScope.SingleProduct" Text="Single Product" />
            </MudToggleGroup>
            
            @* Product Dropdown (only visible in SingleProduct scope) *@
            @if (_scope == PlanningDtos.BoardScope.SingleProduct)
            {
                <MudSelect T="int?" 
                           Value="_selectedProductId"
                           ValueChanged="OnSingleProductChanged"
                           Label="Product"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 200px;">
                    @foreach (var product in Products)
                    {
                        <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
        
        @* Column Picker (only in AllProducts scope) *@
        @if (_scope == PlanningDtos.BoardScope.AllProducts)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @if (_hiddenProductCount > 0)
                {
                    <MudChip T="string" 
                             Size="Size.Small" 
                             Color="Color.Warning"
                             Icon="@Icons.Material.Filled.VisibilityOff">
                        @_hiddenProductCount hidden
                    </MudChip>
                }
                
                <MudMenu Icon="@Icons.Material.Filled.ViewColumn" 
                         Label="Columns"
                         Size="Size.Small"
                         Variant="Variant.Outlined">
                    @foreach (var product in Products)
                    {
                        var isVisible = _visibleProductIds.Contains(product.Id);
                        var hasSelectedEpics = _selectedPlacementIds.Any(p => GetProductForPlacement(p) == product.Id);
                        
                        <MudMenuItem OnClick="@(() => ToggleProductVisibility(product.Id))"
                                     Disabled="@(hasSelectedEpics && isVisible)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@(isVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)" 
                                         Size="Size.Small"
                                         Color="@(isVisible ? Color.Success : Color.Default)" />
                                <MudText>@product.Name</MudText>
                                @if (hasSelectedEpics && isVisible)
                                {
                                    <MudTooltip Text="Cannot hide: contains selected epics">
                                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Warning" />
                                    </MudTooltip>
                                }
                            </MudStack>
                        </MudMenuItem>
                    }
                </MudMenu>
            </MudStack>
        }
    </MudStack>
    
    @* Main Board Layout *@
    <MudStack Row="true" Spacing="3">
        @* Unplanned Epics Panel *@
        <MudPaper Elevation="1" Class="unplanned-panel pa-3" Style="width: 280px; max-height: 600px; overflow-y: auto;">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-1" Size="Size.Small" />
                Unplanned Epics
            </MudText>
            
            @if (_unplannedEpics.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    All epics are planned.
                </MudText>
            }
            else
            {
                @if (_scope == PlanningDtos.BoardScope.AllProducts)
                {
                    @* Group by product *@
                    @foreach (var productGroup in _unplannedEpics.GroupBy(e => e.ProductId))
                    {
                        var productName = Products.FirstOrDefault(p => p.Id == productGroup.Key)?.Name ?? "Unknown";
                        <MudExpansionPanels Dense="true" Class="mb-1">
                            <MudExpansionPanel Dense="true" Expanded="true">
                                <TitleContent>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@productName (@productGroup.Count())</MudText>
                                </TitleContent>
                                <ChildContent>
                                    @foreach (var epic in productGroup)
                                    {
                                        <div class="unplanned-epic-card mb-1 pa-2"
                                             draggable="true"
                                             @ondragstart="@(() => HandleEpicDragStart(epic))"
                                             @ondragend="HandleDragEnd">
                                            <MudText Typo="Typo.body2">@epic.Title</MudText>
                                            @if (epic.Effort.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@epic.Effort pts</MudText>
                                            }
                                        </div>
                                    }
                                </ChildContent>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                }
                else
                {
                    @* Single product - just list epics *@
                    var filteredEpics = _unplannedEpics.Where(e => e.ProductId == _selectedProductId);
                    @foreach (var epic in filteredEpics)
                    {
                        <div class="unplanned-epic-card mb-1 pa-2"
                             draggable="true"
                             @ondragstart="@(() => HandleEpicDragStart(epic))"
                             @ondragend="HandleDragEnd">
                            <MudText Typo="Typo.body2">@epic.Title</MudText>
                            @if (epic.Effort.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@epic.Effort pts</MudText>
                            }
                        </div>
                    }
                }
            }
        </MudPaper>
        
        @* Board Grid *@
        <MudPaper Elevation="1" Class="board-grid-container flex-grow-1" Style="overflow: auto; max-height: 600px;">
            <table class="planning-board-table">
                @* Header row with product columns *@
                <thead>
                    <tr>
                        <th class="row-controls-header" style="width: 40px;"></th>
                        @foreach (var column in GetVisibleColumns())
                        {
                            <th class="product-column-header pa-2">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold">@column.ProductName</MudText>
                            </th>
                        }
                    </tr>
                </thead>
                
                <tbody>
                    @foreach (var row in _rows)
                    {
                        @if (row.RowType == PlanningDtos.BoardRowType.Marker)
                        {
                            @* Marker row - spans all columns *@
                            <tr class="@GetMarkerRowClass(row)" 
                                draggable="true"
                                @ondragstart="@(() => HandleMarkerDragStart(row))"
                                @ondragend="HandleDragEnd">
                                <td class="row-controls pa-1">
                                    @* Row controls on the left *@
                                    <MudStack Spacing="0">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                                       Size="Size.Small" 
                                                       OnClick="@(() => AddRowAbove(row.Id))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                                       Size="Size.Small" 
                                                       OnClick="@(() => AddRowBelow(row.Id))" />
                                    </MudStack>
                                </td>
                                <td colspan="@GetVisibleColumns().Count()" class="marker-row-cell pa-2">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center">
                                        <MudIcon Icon="@GetMarkerIcon(row)" 
                                                 Size="Size.Small"
                                                 Color="@GetMarkerColor(row)" />
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">
                                            @(row.MarkerLabel ?? (row.MarkerType == PlanningDtos.MarkerRowType.Release ? "Release Line" : "Iteration Line"))
                                        </MudText>
                                    </MudStack>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @* Normal row with cells *@
                            <tr class="board-row"
                                @oncontextmenu="@(e => HandleRowContextMenu(e, row))"
                                @oncontextmenu:preventDefault>
                                <td class="row-controls pa-1">
                                    @* Row controls on the left - visible on hover *@
                                    <div class="row-control-buttons">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                                       Size="Size.Small" 
                                                       OnClick="@(() => AddRowAbove(row.Id))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" 
                                                       Size="Size.Small" 
                                                       OnClick="@(() => AddRowBelow(row.Id))" />
                                    </div>
                                </td>
                                
                                @foreach (var column in GetVisibleColumns())
                                {
                                    var cellPlacements = GetPlacementsForCell(row.Id, column.ProductId);
                                    var isDropTarget = _isDragging && _dragProductId == column.ProductId;
                                    
                                    <td class="board-cell pa-2 @(isDropTarget ? "drop-target" : "")"
                                        @ondragover:preventDefault
                                        @ondragover="@(() => HandleCellDragOver(row.Id, column.ProductId))"
                                        @ondrop="@(() => HandleCellDrop(row.Id, column.ProductId))">
                                        @foreach (var placement in cellPlacements)
                                        {
                                            <div class="epic-card @(placement.IsSelected || _selectedPlacementIds.Contains(placement.Id) ? "selected" : "")"
                                                 @onclick="@(e => HandleEpicClick(e, placement))"
                                                 @onclick:stopPropagation
                                                 draggable="true"
                                                 @ondragstart="@(() => HandlePlacementDragStart(placement))"
                                                 @ondragend="HandleDragEnd">
                                                <MudText Typo="Typo.body2">@placement.EpicTitle</MudText>
                                                @if (placement.Effort.HasValue)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @placement.Effort pts
                                                    </MudText>
                                                }
                                            </div>
                                        }
                                        
                                        @if (cellPlacements.Count == 0 && isDropTarget)
                                        {
                                            <div class="drop-placeholder">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Drop here</MudText>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </MudPaper>
    </MudStack>
</div>

@code {
    /// <summary>
    /// All available products for the current profile.
    /// </summary>
    [Parameter]
    public List<ProductDto> Products { get; set; } = new();
    
    /// <summary>
    /// Currently selected product ID (from navigation context).
    /// </summary>
    [Parameter]
    public int? SelectedProductId { get; set; }
    
    /// <summary>
    /// Callback when product selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<int?> OnProductSelectionChanged { get; set; }
    
    private ElementReference _boardElement;
    
    // Board state
    private PlanningDtos.BoardScope _scope = PlanningDtos.BoardScope.AllProducts;
    private int? _selectedProductId;
    private HashSet<int> _visibleProductIds = new();
    private int _hiddenProductCount;
    
    // Data
    private List<PlanningDtos.BoardRowDto> _rows = new();
    private List<PlanningDtos.EpicPlacementDto> _placements = new();
    private List<PlanningDtos.UnplannedEpicDto> _unplannedEpics = new();
    
    // Selection
    private HashSet<int> _selectedPlacementIds = new();
    
    // Drag state
    private bool _isDragging;
    private int? _dragEpicId;
    private int? _dragProductId;
    private int? _dragPlacementId;
    private int? _dragMarkerRowId;
    
    protected override async Task OnInitializedAsync()
    {
        // Initialize scope from parameter
        if (SelectedProductId.HasValue)
        {
            _scope = PlanningDtos.BoardScope.SingleProduct;
            _selectedProductId = SelectedProductId;
        }
        else
        {
            _scope = PlanningDtos.BoardScope.AllProducts;
        }
        
        // Initialize visible products
        foreach (var product in Products)
        {
            _visibleProductIds.Add(product.Id);
        }
        
        // Initialize default board layout if no data
        await InitializeDefaultBoard();
        
        // Load mock unplanned epics for now
        LoadMockUnplannedEpics();
    }
    
    private async Task InitializeDefaultBoard()
    {
        // Default layout: 3 empty rows, Iteration line, 3 empty rows, Release line, 3 empty rows
        _rows = new List<PlanningDtos.BoardRowDto>
        {
            new() { Id = 1, DisplayOrder = 0, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 2, DisplayOrder = 1, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 3, DisplayOrder = 2, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 4, DisplayOrder = 3, RowType = PlanningDtos.BoardRowType.Marker, MarkerType = PlanningDtos.MarkerRowType.Iteration, MarkerLabel = "Iteration Line" },
            new() { Id = 5, DisplayOrder = 4, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 6, DisplayOrder = 5, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 7, DisplayOrder = 6, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 8, DisplayOrder = 7, RowType = PlanningDtos.BoardRowType.Marker, MarkerType = PlanningDtos.MarkerRowType.Release, MarkerLabel = "Release Line" },
            new() { Id = 9, DisplayOrder = 8, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 10, DisplayOrder = 9, RowType = PlanningDtos.BoardRowType.Normal },
            new() { Id = 11, DisplayOrder = 10, RowType = PlanningDtos.BoardRowType.Normal }
        };
        
        _placements = new List<PlanningDtos.EpicPlacementDto>();
        
        await Task.CompletedTask;
    }
    
    private void LoadMockUnplannedEpics()
    {
        // Generate mock unplanned epics based on products
        var epicId = 1000;
        _unplannedEpics = Products.SelectMany(p => Enumerable.Range(0, 3).Select(i => new PlanningDtos.UnplannedEpicDto
        {
            EpicId = epicId++,
            Title = $"Epic {epicId} for {p.Name}",
            ProductId = p.Id,
            ProductName = p.Name,
            Effort = (epicId % 5 + 1) * 5,
            State = "New"
        })).ToList();
    }
    
    private IEnumerable<PlanningDtos.ProductColumnDto> GetVisibleColumns()
    {
        if (_scope == PlanningDtos.BoardScope.SingleProduct && _selectedProductId.HasValue)
        {
            var product = Products.FirstOrDefault(p => p.Id == _selectedProductId);
            if (product != null)
            {
                yield return new PlanningDtos.ProductColumnDto
                {
                    ProductId = product.Id,
                    ProductName = product.Name,
                    IsVisible = true,
                    DisplayOrder = 0
                };
            }
        }
        else
        {
            var order = 0;
            foreach (var product in Products.Where(p => _visibleProductIds.Contains(p.Id)))
            {
                yield return new PlanningDtos.ProductColumnDto
                {
                    ProductId = product.Id,
                    ProductName = product.Name,
                    IsVisible = true,
                    DisplayOrder = order++
                };
            }
        }
    }
    
    private List<PlanningDtos.EpicPlacementDto> GetPlacementsForCell(int rowId, int productId)
    {
        return _placements
            .Where(p => p.RowId == rowId && p.ProductId == productId)
            .OrderBy(p => p.OrderInCell)
            .ToList();
    }
    
    private int? GetProductForPlacement(int placementId)
    {
        return _placements.FirstOrDefault(p => p.Id == placementId)?.ProductId;
    }
    
    private string GetMarkerRowClass(PlanningDtos.BoardRowDto row)
    {
        return row.MarkerType == PlanningDtos.MarkerRowType.Release 
            ? "marker-row marker-release" 
            : "marker-row marker-iteration";
    }
    
    private string GetMarkerIcon(PlanningDtos.BoardRowDto row)
    {
        return row.MarkerType == PlanningDtos.MarkerRowType.Release 
            ? Icons.Material.Filled.Flag 
            : Icons.Material.Filled.Schedule;
    }
    
    private Color GetMarkerColor(PlanningDtos.BoardRowDto row)
    {
        return row.MarkerType == PlanningDtos.MarkerRowType.Release 
            ? Color.Error 
            : Color.Info;
    }
    
    #region Scope and Visibility
    
    private async Task OnScopeChanged(PlanningDtos.BoardScope newScope)
    {
        _scope = newScope;
        
        if (_scope == PlanningDtos.BoardScope.SingleProduct && !_selectedProductId.HasValue && Products.Count > 0)
        {
            _selectedProductId = Products.First().Id;
        }
        
        await OnProductSelectionChanged.InvokeAsync(_scope == PlanningDtos.BoardScope.SingleProduct ? _selectedProductId : null);
        StateHasChanged();
    }
    
    private async Task OnSingleProductChanged(int? productId)
    {
        _selectedProductId = productId;
        await OnProductSelectionChanged.InvokeAsync(productId);
        StateHasChanged();
    }
    
    private void ToggleProductVisibility(int productId)
    {
        // Check if this product has selected epics
        var hasSelectedEpics = _selectedPlacementIds.Any(p => GetProductForPlacement(p) == productId);
        
        if (_visibleProductIds.Contains(productId))
        {
            if (hasSelectedEpics)
            {
                Snackbar.Add("Cannot hide product column: contains selected epics", Severity.Warning);
                return;
            }
            
            _visibleProductIds.Remove(productId);
        }
        else
        {
            _visibleProductIds.Add(productId);
        }
        
        _hiddenProductCount = Products.Count - _visibleProductIds.Count;
        StateHasChanged();
    }
    
    #endregion
    
    #region Row Management
    
    private async Task AddRowAbove(int rowId)
    {
        var row = _rows.FirstOrDefault(r => r.Id == rowId);
        if (row == null) return;
        
        var newRowId = _rows.Max(r => r.Id) + 1;
        var newRow = new PlanningDtos.BoardRowDto
        {
            Id = newRowId,
            DisplayOrder = row.DisplayOrder,
            RowType = PlanningDtos.BoardRowType.Normal
        };
        
        // Shift all rows at and after this position down
        foreach (var r in _rows.Where(r => r.DisplayOrder >= row.DisplayOrder))
        {
            _rows[_rows.IndexOf(r)] = r with { DisplayOrder = r.DisplayOrder + 1 };
        }
        
        _rows.Add(newRow);
        _rows = _rows.OrderBy(r => r.DisplayOrder).ToList();
        
        await Task.CompletedTask;
        StateHasChanged();
    }
    
    private async Task AddRowBelow(int rowId)
    {
        var row = _rows.FirstOrDefault(r => r.Id == rowId);
        if (row == null) return;
        
        var newRowId = _rows.Max(r => r.Id) + 1;
        var insertOrder = row.DisplayOrder + 1;
        
        var newRow = new PlanningDtos.BoardRowDto
        {
            Id = newRowId,
            DisplayOrder = insertOrder,
            RowType = PlanningDtos.BoardRowType.Normal
        };
        
        // Shift all rows after this position down
        foreach (var r in _rows.Where(r => r.DisplayOrder >= insertOrder))
        {
            _rows[_rows.IndexOf(r)] = r with { DisplayOrder = r.DisplayOrder + 1 };
        }
        
        _rows.Add(newRow);
        _rows = _rows.OrderBy(r => r.DisplayOrder).ToList();
        
        await Task.CompletedTask;
        StateHasChanged();
    }
    
    private async Task HandleRowContextMenu(MouseEventArgs e, PlanningDtos.BoardRowDto row)
    {
        // Check if row is empty
        var hasEpics = _placements.Any(p => p.RowId == row.Id);
        
        if (hasEpics)
        {
            Snackbar.Add("Cannot delete row: contains epics. Remove epics first.", Severity.Warning);
            return;
        }
        
        // For now, just delete the row (in real implementation, show context menu)
        _rows.Remove(row);
        
        // Reorder remaining rows
        var order = 0;
        _rows = _rows.OrderBy(r => r.DisplayOrder)
                     .Select(r => r with { DisplayOrder = order++ })
                     .ToList();
        
        await Task.CompletedTask;
        StateHasChanged();
    }
    
    #endregion
    
    #region Drag and Drop
    
    private void HandleEpicDragStart(PlanningDtos.UnplannedEpicDto epic)
    {
        _isDragging = true;
        _dragEpicId = epic.EpicId;
        _dragProductId = epic.ProductId;
        _dragPlacementId = null;
        _dragMarkerRowId = null;
    }
    
    private void HandlePlacementDragStart(PlanningDtos.EpicPlacementDto placement)
    {
        _isDragging = true;
        _dragEpicId = placement.EpicId;
        _dragProductId = placement.ProductId;
        _dragPlacementId = placement.Id;
        _dragMarkerRowId = null;
    }
    
    private void HandleMarkerDragStart(PlanningDtos.BoardRowDto row)
    {
        _isDragging = true;
        _dragMarkerRowId = row.Id;
        _dragEpicId = null;
        _dragProductId = null;
        _dragPlacementId = null;
    }
    
    private void HandleDragEnd()
    {
        _isDragging = false;
        _dragEpicId = null;
        _dragProductId = null;
        _dragPlacementId = null;
        _dragMarkerRowId = null;
    }
    
    private void HandleCellDragOver(int rowId, int productId)
    {
        // Only allow drop if the product matches
        if (_dragProductId != productId)
        {
            // Cross-product drop is forbidden
            return;
        }
    }
    
    private async Task HandleCellDrop(int rowId, int productId)
    {
        if (!_isDragging) return;
        
        // Check for cross-product drop
        if (_dragProductId != productId)
        {
            Snackbar.Add("Cannot move epic to a different product column", Severity.Warning);
            HandleDragEnd();
            return;
        }
        
        // Handle unplanned epic drop
        if (_dragEpicId.HasValue && !_dragPlacementId.HasValue)
        {
            var epic = _unplannedEpics.FirstOrDefault(e => e.EpicId == _dragEpicId);
            if (epic != null)
            {
                // Create new placement
                var newPlacementId = _placements.Count > 0 ? _placements.Max(p => p.Id) + 1 : 1;
                var orderInCell = _placements.Count(p => p.RowId == rowId && p.ProductId == productId);
                
                _placements.Add(new PlanningDtos.EpicPlacementDto
                {
                    Id = newPlacementId,
                    EpicId = epic.EpicId,
                    EpicTitle = epic.Title,
                    ProductId = epic.ProductId,
                    RowId = rowId,
                    OrderInCell = orderInCell,
                    Effort = epic.Effort,
                    State = epic.State
                });
                
                // Remove from unplanned
                _unplannedEpics.Remove(epic);
            }
        }
        // Handle existing placement move
        else if (_dragPlacementId.HasValue)
        {
            var placement = _placements.FirstOrDefault(p => p.Id == _dragPlacementId);
            if (placement != null)
            {
                var orderInCell = _placements.Count(p => p.RowId == rowId && p.ProductId == productId && p.Id != placement.Id);
                
                _placements[_placements.IndexOf(placement)] = placement with
                {
                    RowId = rowId,
                    OrderInCell = orderInCell
                };
            }
        }
        
        HandleDragEnd();
        await Task.CompletedTask;
        StateHasChanged();
    }
    
    #endregion
    
    #region Selection and Keyboard
    
    private void HandleEpicClick(MouseEventArgs e, PlanningDtos.EpicPlacementDto placement)
    {
        if (e.CtrlKey)
        {
            // Toggle selection
            if (_selectedPlacementIds.Contains(placement.Id))
            {
                _selectedPlacementIds.Remove(placement.Id);
            }
            else
            {
                _selectedPlacementIds.Add(placement.Id);
            }
        }
        else if (e.ShiftKey)
        {
            // Add to selection
            _selectedPlacementIds.Add(placement.Id);
        }
        else
        {
            // Single select
            _selectedPlacementIds.Clear();
            _selectedPlacementIds.Add(placement.Id);
        }
        
        StateHasChanged();
    }
    
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Delete" && _selectedPlacementIds.Count > 0)
        {
            // Remove selected epics from board, return to unplanned
            foreach (var placementId in _selectedPlacementIds.ToList())
            {
                var placement = _placements.FirstOrDefault(p => p.Id == placementId);
                if (placement != null)
                {
                    // Add back to unplanned
                    var product = Products.FirstOrDefault(p => p.Id == placement.ProductId);
                    _unplannedEpics.Add(new PlanningDtos.UnplannedEpicDto
                    {
                        EpicId = placement.EpicId,
                        Title = placement.EpicTitle,
                        ProductId = placement.ProductId,
                        ProductName = product?.Name ?? "Unknown",
                        Effort = placement.Effort,
                        State = placement.State
                    });
                    
                    // Remove placement
                    _placements.Remove(placement);
                }
            }
            
            _selectedPlacementIds.Clear();
            await Task.CompletedTask;
            StateHasChanged();
        }
    }
    
    #endregion
}
