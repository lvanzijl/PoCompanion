    {
        if (_editingMarkerRowId != rowId) return;
        
        var row = _rows.FirstOrDefault(r => r.Id == rowId);
        if (row == null) return;
        
        // TODO: Implement backend API for updating marker labels
        // Need: UpdateMarkerRowRequest DTO, UpdateMarkerRowCommand, API endpoint
        // Required: PlanningService.UpdateMarkerRowAsync(int rowId, string label)
        // For now, just cancel the edit and show a message
        Snackbar.Add("Marker label update - backend API not yet implemented", Severity.Info);
        
