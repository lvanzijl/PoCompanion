    #region Selection and Keyboard
    
    private void HandleEpicClick(MouseEventArgs e, PlanningDtos.EpicPlacementDto placement)
    {
        if (e.CtrlKey)
        {
            // Toggle selection
            if (_selectedPlacementIds.Contains(placement.Id))
            {
                _selectedPlacementIds.Remove(placement.Id);
            }
            else
            {
                _selectedPlacementIds.Add(placement.Id);
            }
        }
        else if (e.ShiftKey)
        {
            // Add to selection
            _selectedPlacementIds.Add(placement.Id);
        }
        else
        {
            // Single select
            _selectedPlacementIds.Clear();
            _selectedPlacementIds.Add(placement.Id);
        }
        
        StateHasChanged();
    }
    
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Delete" && _selectedPlacementIds.Count > 0)
        {
            _isSaving = true;
            StateHasChanged();
            
            try
            {
                // Delete selected placements via API
                var result = await PlanningService.DeletePlacementsAsync(_selectedPlacementIds.ToList());
                
                if (result?.Success == true)
                {
                    _selectedPlacementIds.Clear();
                    // Reload board to get updated state
                    await LoadBoardDataAsync();
                }
                else
                {
                    Snackbar.Add(result?.ErrorMessage ?? "Failed to delete placements", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to delete placements");
                Snackbar.Add("Failed to delete placements", Severity.Error);
            }
            finally
            {
                _isSaving = false;
                StateHasChanged();
            }
        }
    }
    
