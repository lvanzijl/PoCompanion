@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@inject IMetricsClient MetricsClient
@inject ErrorMessageService ErrorMessageService

@* Forecast Panel - Reusable component for embedding epic forecast into workspaces *@

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-2" />
        Epic/Feature Forecast Calculator
    </MudText>
    
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
        <MudNumericField @bind-Value="_selectedEpicId" 
                         Label="Epic/Feature ID" 
                         Variant="Variant.Outlined"
                         Min="1"
                         Style="max-width: 200px;" />
        <MudNumericField @bind-Value="_maxSprintsForVelocity" 
                         Label="Historical Sprints" 
                         Variant="Variant.Outlined"
                         Min="1" Max="20"
                         Style="max-width: 150px;" />
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="LoadForecast"
                   Disabled="@(!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0 || _isLoading)"
                   StartIcon="@Icons.Material.Filled.Calculate">
            Calculate
        </MudButton>
    </MudStack>
</MudPaper>

<LoadingIndicator IsLoading="@_isLoading" />

@if (!_isLoading && _forecastData != null)
{
    <ErrorDisplay ErrorResponse="@_errorResponse" 
                  Class="mb-4"
                  OnDismiss="ClearError" />

    @* Epic Summary Card *@
    <MudCard Elevation="2" Class="mb-4">
        <MudCardContent>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h6">@_forecastData.Title</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        ID: @_forecastData.EpicId | Type: @_forecastData.Type | Area: @_forecastData.AreaPath
                    </MudText>
                </div>
                <MudChip T="string" Size="Size.Medium" Color="@GetConfidenceColor(_forecastData.Confidence)">
                    @_forecastData.Confidence Confidence
                </MudChip>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @* Progress Summary *@
    <MudGrid Class="mb-4">
        <MetricSummaryCard Label="Total Story Points"
                          Value="@_forecastData.TotalEffort.ToString()"
                          Icon="@Icons.Material.Filled.Flag"
                          IconColor="Color.Primary" />
        
        <MetricSummaryCard Label="Delivered Story Points"
                          Value="@_forecastData.CompletedEffort.ToString()"
                          Icon="@Icons.Material.Filled.CheckCircle"
                          IconColor="Color.Success" />
        
        <MetricSummaryCard Label="Remaining Story Points"
                          Value="@_forecastData.RemainingEffort.ToString()"
                          Icon="@Icons.Material.Filled.Schedule"
                          IconColor="Color.Warning" />
        
        <MetricSummaryCard Label="Est. Velocity"
                          Value="@_forecastData.EstimatedVelocity.ToString("F1")"
                          Icon="@Icons.Material.Filled.Speed"
                          IconColor="Color.Info" />
    </MudGrid>

    @* Forecast Summary *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">Forecast Summary</MudText>
        <MudSimpleTable Dense="true" Hover="true">
            <thead>
                <tr>
                    <th>Metric</th>
                    <th>Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Sprints Remaining</strong></td>
                    <td>@_forecastData.SprintsRemaining</td>
                </tr>
                <tr>
                    <td><strong>Estimated Completion</strong></td>
                    <td>
                        @if (_forecastData.EstimatedCompletionDate.HasValue)
                        {
                            @_forecastData.EstimatedCompletionDate.Value.LocalDateTime.ToString("MMM dd, yyyy")
                        }
                        else
                        {
                            <span>TBD</span>
                        }
                    </td>
                </tr>
                <tr>
                    <td><strong>Confidence</strong></td>
                    <td>
                        <MudChip T="string" Size="Size.Small" Color="@GetConfidenceColor(_forecastData.Confidence)">
                            @_forecastData.Confidence
                        </MudChip>
                    </td>
                </tr>
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}
else if (!_isLoading && !_hasAttemptedLoad)
{
    <MudAlert Severity="Severity.Info">Enter an Epic or Feature ID and click Calculate to see forecast.</MudAlert>
}

@code {
    [Parameter]
    public int? InitialEpicId { get; set; }

    private bool _isLoading = false;
    private bool _hasAttemptedLoad = false;
    private int? _selectedEpicId;
    private int _maxSprintsForVelocity = 6;
    private EpicCompletionForecastDto? _forecastData;
    private ErrorResponse? _errorResponse;

    protected override async Task OnInitializedAsync()
    {
        if (InitialEpicId.HasValue)
        {
            _selectedEpicId = InitialEpicId;
            await LoadForecast();
        }
    }

    private async Task LoadForecast()
    {
        if (!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0)
            return;

        _isLoading = true;
        _hasAttemptedLoad = true;
        StateHasChanged();

        try
        {
            ClearError();
            _forecastData = await MetricsClient.GetEpicForecastAsync(_selectedEpicId.Value, _maxSprintsForVelocity);
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, "Error loading forecast");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ClearError() => _errorResponse = null;

    private Color GetConfidenceColor(ForecastConfidence confidence)
    {
        return confidence switch
        {
            ForecastConfidence.High => Color.Success,
            ForecastConfidence.Medium => Color.Warning,
            ForecastConfidence.Low => Color.Error,
            _ => Color.Default
        };
    }
}
