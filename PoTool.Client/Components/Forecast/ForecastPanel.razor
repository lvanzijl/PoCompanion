@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@using PoTool.Client.Services
@inject MetricsStateService MetricsStateService

@* Forecast Panel - Reusable component for embedding epic forecast into workspaces *@

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Calculate" Class="mr-2" />
        Epic/Feature Forecast Calculator
    </MudText>
    
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-4">
        <MudNumericField @bind-Value="_selectedEpicId" 
                         Label="Epic/Feature ID" 
                         Variant="Variant.Outlined"
                         Min="1"
                         Style="max-width: 200px;" />
        <MudNumericField @bind-Value="_maxSprintsForVelocity" 
                         Label="Historical Sprints" 
                         Variant="Variant.Outlined"
                         Min="1" Max="20"
                         Style="max-width: 150px;" />
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="LoadForecast"
                   Disabled="@(!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0 || _isLoading)"
                   StartIcon="@Icons.Material.Filled.Calculate">
            Calculate
        </MudButton>
    </MudStack>
</MudPaper>

<LoadingIndicator IsLoading="@_isLoading" />

@if (!_hasAttemptedLoad)
{
    <MudAlert Severity="Severity.Info">Enter an Epic or Feature ID and click Calculate to see forecast.</MudAlert>
}
else
{
    <DataStateView TData="EpicCompletionForecastDto"
                   State="@_forecastState"
                   IsLoading="@_isLoading"
                   EmptyTitle="No forecast data available"
                   EmptyMessage="No forecast data is available for this epic or feature."
                   NotReadyTitle="Forecast is syncing"
                   NotReadyMessage="Forecast data will load once the cache is ready."
                   FailedTitle="Forecast failed to load">
        <ChildContent Context="forecast">
            @* Epic Summary Card *@
            <MudCard Elevation="2" Class="mb-4">
                <MudCardContent>
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h6">@forecast.Title</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                ID: @forecast.EpicId | Type: @forecast.Type | Area: @forecast.AreaPath
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Medium" Color="@GetConfidenceColor(forecast.Confidence)">
                            @forecast.Confidence Confidence
                        </MudChip>
                    </MudStack>
                </MudCardContent>
            </MudCard>

            <MudGrid Class="mb-4">
                <MetricSummaryCard Label="Total Story Points"
                                   Value="@forecast.TotalStoryPoints.ToString()"
                                   Icon="@Icons.Material.Filled.Flag"
                                   IconColor="Color.Primary" />
                <MetricSummaryCard Label="Delivered Story Points"
                                   Value="@forecast.DeliveredStoryPoints.ToString()"
                                   Icon="@Icons.Material.Filled.CheckCircle"
                                   IconColor="Color.Success" />
                <MetricSummaryCard Label="Remaining Story Points"
                                   Value="@forecast.RemainingStoryPoints.ToString()"
                                   Icon="@Icons.Material.Filled.Schedule"
                                   IconColor="Color.Warning" />
                <MetricSummaryCard Label="Est. Velocity"
                                   Value="@forecast.EstimatedVelocity.ToString("F1")"
                                   Icon="@Icons.Material.Filled.Speed"
                                   IconColor="Color.Info" />
            </MudGrid>

            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Forecast Summary</MudText>
                <MudSimpleTable Dense="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Metric</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Sprints Remaining</strong></td>
                            <td>@forecast.SprintsRemaining</td>
                        </tr>
                        <tr>
                            <td><strong>Estimated Completion</strong></td>
                            <td>
                                @if (forecast.EstimatedCompletionDate.HasValue)
                                {
                                    @forecast.EstimatedCompletionDate.Value.LocalDateTime.ToString("MMM dd, yyyy")
                                }
                                else
                                {
                                    <span>TBD</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Confidence</strong></td>
                            <td>
                                <MudChip T="string" Size="Size.Small" Color="@GetConfidenceColor(forecast.Confidence)">
                                    @forecast.Confidence
                                </MudChip>
                            </td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        </ChildContent>
    </DataStateView>
}

@code {
    [Parameter]
    public int? InitialEpicId { get; set; }

    private bool _isLoading = false;
    private bool _hasAttemptedLoad = false;
    private int? _selectedEpicId;
    private int _maxSprintsForVelocity = 6;
    private DataStateViewModel<EpicCompletionForecastDto> _forecastState = DataStateViewModel<EpicCompletionForecastDto>.NotRequested();

    protected override async Task OnInitializedAsync()
    {
        if (InitialEpicId.HasValue)
        {
            _selectedEpicId = InitialEpicId;
            await LoadForecast();
        }
    }

    private async Task LoadForecast()
    {
        if (!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0)
            return;

        _isLoading = true;
        _hasAttemptedLoad = true;
        _forecastState = DataStateViewModel<EpicCompletionForecastDto>.Loading();
        StateHasChanged();

        var response = await MetricsStateService.GetEpicForecastStateAsync(
            _selectedEpicId.Value,
            _maxSprintsForVelocity,
            CancellationToken.None);
        _forecastState = DataStateViewModel<EpicCompletionForecastDto>.FromResponse(
            response,
            "Forecast data could not be loaded right now.");
        _isLoading = false;
        StateHasChanged();
    }

    private Color GetConfidenceColor(ForecastConfidence confidence)
    {
        return confidence switch
        {
            ForecastConfidence.High => Color.Success,
            ForecastConfidence.Medium => Color.Warning,
            ForecastConfidence.Low => Color.Error,
            _ => Color.Default
        };
    }
}
