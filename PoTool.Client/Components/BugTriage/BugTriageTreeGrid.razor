@using PoTool.Client.Models
@using MudBlazor
@using PoTool.Shared.WorkItems
@inject IDialogService DialogService

@* TreeGrid component using MudDataGrid for Bug Triage display *@

<div class="tree-grid-container">
    @if (IsLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body2" Class="mt-2">Loading bugs...</MudText>
    }
    else if (!TreeRoots.Any())
    {
        <div class="empty-state pa-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-2" />
            <MudText Typo="Typo.h6" Class="mb-2">No bugs found</MudText>
            <MudText Typo="Typo.body2">There are no bug work items in your backlog, or they have all been resolved.</MudText>
        </div>
    }
    else
    {
        <MudDataGrid T="FlatNode" 
                     Items="@GetFlatNodeList()" 
                     Dense="true"
                     Hover="true"
                     Class="tree-grid"
                     Virtualize="true"
                     FixedHeader="true"
                     Height="var(--tree-grid-height, calc(100vh - 300px))">
            <Columns>
                @* Id Column *@
                <TemplateColumn Title="Id" Class="id-column" Sortable="false">
                    <CellTemplate>
                        @if (context.Item.Node.Type != "(group)")
                        {
                            <span>@context.Item.Node.Id</span>
                        }
                    </CellTemplate>
                </TemplateColumn>

                @* Title Column with tree structure *@
                <TemplateColumn Title="Title" Class="title-column" Sortable="false">
                    <CellTemplate>
                        <div class="title-cell" style="padding-left:@(context.Item.Level * 20)px">
                            @* Expand/Collapse Chevron *@
                            @if (context.Item.Node.Children.Any())
                            {
                                <MudIconButton 
                                    Icon="@(context.Item.Node.IsExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                    Size="Size.Small" 
                                    OnClick="() => OnNodeToggled.InvokeAsync(context.Item.Node)"
                                    Class="expand-button" />
                            }
                            else
                            {
                                <span class="leaf-spacer"></span>
                            }

                            @* Type Icon Block or Group Label *@
                            @if (context.Item.Node.Type == "(group)")
                            {
                                <span class="group-label">@context.Item.Node.Title</span>
                            }
                            else
                            {
                                <span class="type-icon-block @(context.Item.Node.IsDone ? "done-state" : "")" 
                                      style="background-color: @context.Item.Node.TypeColor" 
                                      title="@context.Item.Node.Type">
                                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Size="Size.Small" />
                                </span>

                                @* Title Text *@
                                <MudTooltip Text="@context.Item.Node.Title">
                                    <span class="@GetTitleClass(context.Item.Node)" 
                                          @onclick="() => HandleNodeClick(context.Item.Node)"
                                          @onclick:stopPropagation="false">
                                        @context.Item.Node.Title
                                    </span>
                                </MudTooltip>

                                @* Self Issue Indicators *@
                                @if (context.Item.Node.SelfErrorCount > 0 || context.Item.Node.SelfWarningCount > 0)
                                {
                                    <MudTooltip Text="@GetSelfIssueTooltip(context.Item.Node)">
                                        <MudIcon Icon="@GetSelfIssueIcon(context.Item.Node)" 
                                                 Size="Size.Small" 
                                                 Color="@GetSelfIssueColor(context.Item.Node)" 
                                                 Class="self-issue-icon" />
                                    </MudTooltip>
                                }

                                @* Descendant Issue Indicators *@
                                @if (context.Item.Node.HasDescendantIssues)
                                {
                                    <MudTooltip Text="@GetDescendantIssueTooltip(context.Item.Node)">
                                        <MudIcon Icon="@Icons.Material.Filled.SubdirectoryArrowRight" 
                                                 Size="Size.Small" 
                                                 Color="Color.Warning" 
                                                 Class="descendant-issue-icon" />
                                    </MudTooltip>
                                }
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>

                @* State Column *@
                @if (IsColumnVisible("state"))
                {
                    <TemplateColumn Title="State" Class="state-column" Sortable="false">
                        <CellTemplate>
                            @if (context.Item.Node.Type != "(group)")
                            {
                                <span>@context.Item.Node.State</span>
                            }
                        </CellTemplate>
                    </TemplateColumn>
                }
            </Columns>
        </MudDataGrid>
    }
</div>

@code {
   [Parameter]
   public bool IsLoading { get; set; }

   [Parameter, EditorRequired]
   public List<TreeNode> TreeRoots { get; set; } = null!;

   [Parameter]
   public int? SelectedId { get; set; }

   [Parameter]
   public EventCallback<TreeNode> OnNodeToggled { get; set; }

   [Parameter]
   public EventCallback<TreeNode> OnNodeSelected { get; set; }

   private async Task HandleNodeClick(TreeNode node)
   {
       if (node.Type != "(group)")
       {
           await OnNodeSelected.InvokeAsync(node);
       }
   }

   /// <summary>
   /// Represents a flattened node for grid display.
   /// </summary>
   public record FlatNode(TreeNode Node, int Level);

   // Memoization for flat list
   private List<FlatNode>? _cachedFlatList;
   private int _cachedTreeRootsHashCode;

   /// <summary>
   /// Gets a flattened list of visible nodes based on expansion state.
   /// </summary>
   private List<FlatNode> GetFlatNodeList()
   {
      var currentHash = CalculateTreeHash();

      if (_cachedFlatList != null && _cachedTreeRootsHashCode == currentHash)
      {
         return _cachedFlatList;
      }

      var flatList = new List<FlatNode>();
      foreach (var root in TreeRoots)
      {
         AddNodeToFlatList(root, 0, flatList);
      }

      _cachedFlatList = flatList;
      _cachedTreeRootsHashCode = currentHash;

      return flatList;
   }

   private int CalculateTreeHash()
   {
      var hash = new HashCode();
      hash.Add(TreeRoots.Count);
      foreach (var root in TreeRoots)
      {
         AddNodeToHash(root, ref hash);
      }
      return hash.ToHashCode();
   }

   private void AddNodeToHash(TreeNode node, ref HashCode hash)
   {
      hash.Add(node.Id);
      hash.Add(node.IsExpanded);
      hash.Add(node.Children.Count);

      if (node.IsExpanded)
      {
         foreach (var child in node.Children)
         {
            AddNodeToHash(child, ref hash);
         }
      }
   }

   private void AddNodeToFlatList(TreeNode node, int level, List<FlatNode> flatList)
   {
      flatList.Add(new FlatNode(node, level));

      if (node.IsExpanded && node.Children.Any())
      {
         foreach (var child in node.Children)
         {
            AddNodeToFlatList(child, level + 1, flatList);
         }
      }
   }

   private string GetTitleClass(TreeNode node)
   {
      var className = "title-text";
      if (SelectedId.HasValue && SelectedId.Value == node.Id)
      {
         className += " selected";
      }
      return className;
   }

   private string GetSelfIssueTooltip(TreeNode node)
   {
      var parts = new List<string>();
      if (node.SelfErrorCount > 0)
      {
         parts.Add($"{node.SelfErrorCount} error{(node.SelfErrorCount != 1 ? "s" : "")}");
      }
      if (node.SelfWarningCount > 0)
      {
         parts.Add($"{node.SelfWarningCount} warning{(node.SelfWarningCount != 1 ? "s" : "")}");
      }

      var categoryText = node.HighestCategory switch
      {
         ValidationCategory.StructuralIntegrity => " - Structural Integrity",
         ValidationCategory.RefinementReadiness => " - Refinement Readiness",
         ValidationCategory.RefinementCompleteness => " - Refinement Completeness",
         _ => ""
      };

      return $"{string.Join(", ", parts)} (this item){categoryText}";
   }

   private string GetSelfIssueIcon(TreeNode node)
   {
      // Use category-specific icons based on validation category
      return node.HighestCategory switch
      {
         ValidationCategory.StructuralIntegrity => Icons.Material.Filled.Error,
         ValidationCategory.RefinementReadiness => Icons.Material.Filled.Info,
         ValidationCategory.RefinementCompleteness => Icons.Material.Filled.WarningAmber,
         _ => Icons.Material.Filled.Error
      };
   }

   private Color GetSelfIssueColor(TreeNode node)
   {
      // Use category-specific colors
      return node.HighestCategory switch
      {
         ValidationCategory.StructuralIntegrity => Color.Error,
         ValidationCategory.RefinementReadiness => Color.Warning,
         ValidationCategory.RefinementCompleteness => Color.Warning,
         _ => Color.Error
      };
   }

   private string GetDescendantIssueTooltip(TreeNode node)
   {
       var count = node.InvalidDescendantIds.Count;
       return $"{count} issue{(count != 1 ? "s" : "")} in descendants";
   }

   // Column configuration
   private List<ColumnConfig> _columnConfigs = null!;

   protected override void OnInitialized()
   {
       InitializeColumnConfigs();
   }

   private void InitializeColumnConfigs()
   {
       _columnConfigs = new List<ColumnConfig>
       {
           new() { Id = "title", Title = "Title", IsVisible = true, Order = 0, IsRequired = true },
           new() { Id = "state", Title = "State", IsVisible = true, Order = 1, IsRequired = false }
       };
   }

   private bool IsColumnVisible(string columnId)
   {
       var column = _columnConfigs.FirstOrDefault(c => c.Id == columnId);
       return column?.IsVisible ?? false;
   }

   public class ColumnConfig
   {
       public string Id { get; set; } = string.Empty;
       public string Title { get; set; } = string.Empty;
       public bool IsVisible { get; set; }
       public int Order { get; set; }
       public bool IsRequired { get; set; }
   }
}
