@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Client.Services
@inject MetricsStateService MetricsStateService

@* Effort Distribution Panel - Reusable component for embedding effort distribution data into workspaces *@

<CanonicalDataStateView TData="EffortDistributionDto"
                        State="@_distributionState"
                        Subject="Effort distribution"
                        EmptyTitle="No Effort Distribution Data Available"
                        EmptyMessage="No work items found to analyze. Please sync work items first."
                        FailedTitle="Effort distribution failed to load">
    <ChildContent Context="distributionData">
        <MudGrid Class="mb-4">
            <MetricSummaryCard Label="Total Effort"
                               Value="@distributionData.TotalEffort.ToString()"
                               Icon="@Icons.Material.Filled.Assignment"
                               IconColor="Color.Primary" />
            <MetricSummaryCard Label="Area Paths"
                               Value="@distributionData.EffortByArea.Count.ToString()"
                               Icon="@Icons.Material.Filled.FolderOpen"
                               IconColor="Color.Info" />
            <MetricSummaryCard Label="Iterations"
                               Value="@distributionData.EffortByIteration.Count.ToString()"
                               Icon="@Icons.Material.Filled.CalendarMonth"
                               IconColor="Color.Success" />
            <MetricSummaryCard Label="Avg Utilization"
                               Value="@($"{GetAverageUtilization(distributionData):F0}%")"
                               Icon="@Icons.Material.Filled.Speed"
                               IconColor="@GetUtilizationColor(distributionData)" />
        </MudGrid>

        @if (distributionData.HeatMapData.Any())
        {
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Effort Heat Map</MudText>
                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="overflow-x: auto; max-height: 300px;">
                    <thead>
                        <tr>
                            <th>Area Path</th>
                            @foreach (var iteration in distributionData.EffortByIteration.Take(5))
                            {
                                <th class="text-center">@iteration.SprintName</th>
                            }
                            <th class="text-center">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var areaPath in distributionData.EffortByArea.Take(5))
                        {
                            <tr>
                                <td><strong>@GetShortAreaPath(areaPath.AreaPath)</strong></td>
                                @foreach (var iteration in distributionData.EffortByIteration.Take(5))
                                {
                                    var cell = distributionData.HeatMapData
                                        .FirstOrDefault(c => c.AreaPath == areaPath.AreaPath && c.IterationPath == iteration.IterationPath);
                                    <td class="text-center" style="@GetHeatMapCellStyle(cell)">
                                        @if (cell != null && cell.Effort > 0)
                                        {
                                            <strong>@cell.Effort</strong>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                }
                                <td class="text-center"><strong>@areaPath.TotalEffort</strong></td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }

        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudText Typo="Typo.h6">Effort by Iteration</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               OnClick="LoadDataAsync"
                               Disabled="@(_distributionState.UiState == UiDataState.Loading)" />
            </MudStack>
            <MudChart ChartType="ChartType.Bar"
                      Width="100%"
                      Height="250px"
                      ChartSeries="@GetIterationChartData(distributionData)"
                      XAxisLabels="@GetIterationLabels(distributionData)"
                      ChartOptions="@_chartOptions">
            </MudChart>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Iteration Utilization</MudText>
            <MudTable Items="@distributionData.EffortByIteration.Take(5)" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Sprint</MudTh>
                    <MudTh class="text-right">Effort</MudTh>
                    <MudTh class="text-right">Utilization</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Sprint">@context.SprintName</MudTd>
                    <MudTd DataLabel="Effort" class="text-right">@context.TotalEffort</MudTd>
                    <MudTd DataLabel="Utilization" class="text-right">@context.UtilizationPercentage.ToString("F0")%</MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.UtilizationPercentage > 100)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Over</MudChip>
                        }
                        else if (context.UtilizationPercentage > 90)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">High</MudChip>
                        }
                        else if (context.UtilizationPercentage > 70)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">OK</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Low</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </ChildContent>
</CanonicalDataStateView>

@code {
    [Parameter]
    public string? AreaPath { get; set; }

    [Parameter]
    public int MaxIterations { get; set; } = 10;

    [Parameter]
    public int? DefaultCapacity { get; set; } = 40;

    private DataStateViewModel<EffortDistributionDto> _distributionState = DataStateViewModel<EffortDistributionDto>.NotRequested();

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.NaturalSpline
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _distributionState = DataStateViewModel<EffortDistributionDto>.Loading();
        StateHasChanged();

        var response = await MetricsStateService.GetEffortDistributionStateAsync(
            AreaPath,
            MaxIterations,
            DefaultCapacity,
            CancellationToken.None);
        _distributionState = DataStateViewModel<EffortDistributionDto>.FromResponse(
            response,
            "Effort distribution data could not be loaded right now.");
        StateHasChanged();
    }

    private static string GetShortAreaPath(string areaPath)
    {
        if (string.IsNullOrEmpty(areaPath)) return areaPath;
        var parts = areaPath.Split('\\');
        return parts.Length > 1 ? string.Join("\\", parts.Skip(Math.Max(0, parts.Length - 2))) : areaPath;
    }

    private static string GetHeatMapCellStyle(EffortHeatMapCell? cell)
    {
        if (cell == null || cell.Effort == 0)
            return "background-color: transparent;";

        var intensity = Math.Min(cell.Effort / 50.0, 1.0);
        var r = (int)(255 * intensity);
        var g = (int)(200 * (1 - intensity * 0.5));
        var b = (int)(100 * (1 - intensity));
        return $"background-color: rgba({r},{g},{b},0.7); color: white;";
    }

    private static double GetAverageUtilization(EffortDistributionDto distributionData)
        => !distributionData.EffortByIteration.Any()
            ? 0
            : distributionData.EffortByIteration.Average(i => i.UtilizationPercentage);

    private static Color GetUtilizationColor(EffortDistributionDto distributionData)
    {
        var avg = GetAverageUtilization(distributionData);
        return avg > 100 ? Color.Error :
               avg > 90 ? Color.Warning :
               avg > 70 ? Color.Success :
               Color.Info;
    }

    private static List<ChartSeries> GetIterationChartData(EffortDistributionDto distributionData)
    {
        return
        [
            new ChartSeries
            {
                Name = "Effort",
                Data = distributionData.EffortByIteration.Take(6).Select(i => (double)i.TotalEffort).ToArray()
            }
        ];
    }

    private static string[] GetIterationLabels(EffortDistributionDto distributionData)
        => distributionData.EffortByIteration.Take(6).Select(i => i.SprintName).ToArray();
}
