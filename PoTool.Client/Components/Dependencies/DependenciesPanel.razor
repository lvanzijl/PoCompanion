@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@inject IWorkItemsClient WorkItemsClient
@inject ErrorMessageService ErrorMessageService

@* Dependencies Panel - Reusable component for embedding dependency graph into workspaces *@

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
        Dependency Graph Filters
    </MudText>
    
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudTextField @bind-Value="_areaPathFilter" 
                         Label="Area Path Filter" 
                         Variant="Variant.Outlined"
                         Adornment="Adornment.End"
                         AdornmentIcon="@Icons.Material.Filled.FilterAlt" />
            <MudTextField @bind-Value="_workItemIdsFilter" 
                         Label="Work Item IDs (comma-separated)" 
                         Variant="Variant.Outlined"
                         Style="max-width: 300px;" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudTextField @bind-Value="_workItemTypesFilter" 
                         Label="Work Item Types (e.g., Epic,Feature)" 
                         Variant="Variant.Outlined" />
            <MudButton Variant="Variant.Filled" 
                      Color="Color.Primary" 
                      OnClick="LoadDependencyGraph"
                      Disabled="@_isLoading"
                      StartIcon="@Icons.Material.Filled.Refresh">
                Load Graph
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

<LoadingIndicator IsLoading="@_isLoading" />

@if (!_isLoading && _graphData != null)
{
    <ErrorDisplay ErrorResponse="@_errorResponse" 
                  Class="mb-4"
                  OnDismiss="ClearError" />

    @* Summary Cards *@
    <MudGrid Class="mb-4">
        <MetricSummaryCard Label="Total Nodes"
                          Value="@_graphData.Nodes.Count.ToString()"
                          Icon="@Icons.Material.Filled.Circle"
                          IconColor="Color.Primary" />
        
        <MetricSummaryCard Label="Total Links"
                          Value="@_graphData.Links.Count.ToString()"
                          Icon="@Icons.Material.Filled.Link"
                          IconColor="Color.Info" />
        
        <MetricSummaryCard Label="Blocking Items"
                          Value="@_graphData.Nodes.Count(n => n.IsBlocking).ToString()"
                          Icon="@Icons.Material.Filled.Block"
                          IconColor="Color.Error" />
        
        <MetricSummaryCard Label="Critical Paths"
                          Value="@_graphData.CriticalPaths.Count.ToString()"
                          Icon="@Icons.Material.Filled.Warning"
                          IconColor="Color.Warning" />
    </MudGrid>

    @* Dependency Table *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">Work Items with Dependencies</MudText>
        <MudTable Items="@_graphData.Nodes.Where(n => n.DependencyCount > 0).Take(10)" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>State</MudTh>
                <MudTh>Dependencies</MudTh>
                <MudTh>Blocking?</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.WorkItemId</MudTd>
                <MudTd DataLabel="Title">
                    <MudTooltip Text="@context.Title">
                        @(context.Title?.Length > 35 ? context.Title.Substring(0, 35) + "..." : context.Title)
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Type">@context.Type</MudTd>
                <MudTd DataLabel="State">
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(context.State)">@context.State</MudChip>
                </MudTd>
                <MudTd DataLabel="Dependencies">@context.DependencyCount</MudTd>
                <MudTd DataLabel="Blocking">
                    @if (context.IsBlocking)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
        @if (_graphData.Nodes.Count(n => n.DependencyCount > 0) > 10)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Showing 10 of @_graphData.Nodes.Count(n => n.DependencyCount > 0) items with dependencies
            </MudText>
        }
    </MudPaper>
}
else if (!_isLoading && _graphData == null && _hasAttemptedLoad)
{
    <MudAlert Severity="Severity.Info">No dependency data found for the given filters.</MudAlert>
}
else if (!_isLoading && !_hasAttemptedLoad)
{
    <MudAlert Severity="Severity.Info">Enter filters and click Load Graph to analyze dependencies.</MudAlert>
}

@code {
    [Parameter]
    public string? InitialAreaPath { get; set; }

    private bool _isLoading = false;
    private bool _hasAttemptedLoad = false;
    private string? _areaPathFilter;
    private string? _workItemIdsFilter;
    private string? _workItemTypesFilter;
    private DependencyGraphDto? _graphData;
    private ErrorResponse? _errorResponse;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(InitialAreaPath))
        {
            _areaPathFilter = InitialAreaPath;
            await LoadDependencyGraph();
        }
    }

    private async Task LoadDependencyGraph()
    {
        _isLoading = true;
        _hasAttemptedLoad = true;
        StateHasChanged();

        try
        {
            ClearError();
            var response = GeneratedCacheEnvelopeHelper.ToDataStateResult(
                await WorkItemsClient.GetDependencyGraphAsync(
                areaPathFilter: _areaPathFilter, 
                workItemIds: _workItemIdsFilter,
                workItemTypes: _workItemTypesFilter));
            _graphData = response.CanUseData ? response.Data : null;
            if (!response.CanUseData && !string.IsNullOrWhiteSpace(response.Reason))
            {
                _errorResponse = ErrorMessageService.GetErrorResponse(
                    new InvalidOperationException(response.Reason),
                    "Dependency graph unavailable");
            }
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, "Error loading dependency graph");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void ClearError() => _errorResponse = null;

    private Color GetStateColor(string? state)
    {
        return state?.ToLower() switch
        {
            "new" or "to do" => Color.Default,
            "active" or "in progress" or "doing" => Color.Info,
            "resolved" or "done" or "closed" => Color.Success,
            "removed" => Color.Error,
            _ => Color.Default
        };
    }
}
