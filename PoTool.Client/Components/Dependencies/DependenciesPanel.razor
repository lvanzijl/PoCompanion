@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@using PoTool.Client.Services
@inject IWorkItemsClient WorkItemsClient

@* Dependencies Panel - Reusable component for embedding dependency graph into workspaces *@

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
        Dependency Graph Filters
    </MudText>
    
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudTextField @bind-Value="_areaPathFilter" 
                         Label="Area Path Filter" 
                         Variant="Variant.Outlined"
                         Adornment="Adornment.End"
                         AdornmentIcon="@Icons.Material.Filled.FilterAlt" />
            <MudTextField @bind-Value="_workItemIdsFilter" 
                         Label="Work Item IDs (comma-separated)" 
                         Variant="Variant.Outlined"
                         Style="max-width: 300px;" />
        </MudStack>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudTextField @bind-Value="_workItemTypesFilter" 
                         Label="Work Item Types (e.g., Epic,Feature)" 
                         Variant="Variant.Outlined" />
             <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="LoadDependencyGraph"
                       Disabled="@(_graphState.UiState == UiDataState.Loading)"
                       StartIcon="@Icons.Material.Filled.Refresh">
                 Load Graph
             </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

<CanonicalDataStateView TData="DependencyGraphDto"
                        State="@_graphState"
                        Subject="Dependency graph"
                        EmptyTitle="No dependency data found"
                        EmptyMessage="No dependency data found for the given filters."
                        FailedMessage="Dependency graph could not be loaded right now."
                        OnRecovery="@LoadDependencyGraph">
    <NotRequestedContent>
        <MudAlert Severity="Severity.Info">Enter filters and click Load Graph to analyze dependencies.</MudAlert>
    </NotRequestedContent>
    <ChildContent Context="graphData">
    @* Summary Cards *@
    <MudGrid Class="mb-4">
        <MetricSummaryCard Label="Total Nodes"
                          Value="@graphData.Nodes.Count.ToString()"
                          Icon="@Icons.Material.Filled.Circle"
                          IconColor="Color.Primary" />
        
        <MetricSummaryCard Label="Total Links"
                          Value="@graphData.Links.Count.ToString()"
                          Icon="@Icons.Material.Filled.Link"
                          IconColor="Color.Info" />
        
        <MetricSummaryCard Label="Blocking Items"
                          Value="@graphData.Nodes.Count(n => n.IsBlocking).ToString()"
                          Icon="@Icons.Material.Filled.Block"
                          IconColor="Color.Error" />
        
        <MetricSummaryCard Label="Critical Paths"
                          Value="@graphData.CriticalPaths.Count.ToString()"
                          Icon="@Icons.Material.Filled.Warning"
                          IconColor="Color.Warning" />
    </MudGrid>

    @* Dependency Table *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">Work Items with Dependencies</MudText>
        <MudTable Items="@graphData.Nodes.Where(n => n.DependencyCount > 0).Take(10)" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Title</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>State</MudTh>
                <MudTh>Dependencies</MudTh>
                <MudTh>Blocking?</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.WorkItemId</MudTd>
                <MudTd DataLabel="Title">
                    <MudTooltip Text="@context.Title">
                        @(context.Title?.Length > 35 ? context.Title.Substring(0, 35) + "..." : context.Title)
                    </MudTooltip>
                </MudTd>
                <MudTd DataLabel="Type">@context.Type</MudTd>
                <MudTd DataLabel="State">
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(context.State)">@context.State</MudChip>
                </MudTd>
                <MudTd DataLabel="Dependencies">@context.DependencyCount</MudTd>
                <MudTd DataLabel="Blocking">
                    @if (context.IsBlocking)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Small" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
        @if (graphData.Nodes.Count(n => n.DependencyCount > 0) > 10)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Showing 10 of @graphData.Nodes.Count(n => n.DependencyCount > 0) items with dependencies
            </MudText>
        }
    </MudPaper>
    </ChildContent>
</CanonicalDataStateView>

@code {
    [Parameter]
    public string? InitialAreaPath { get; set; }

    private bool _hasAttemptedLoad = false;
    private string? _areaPathFilter;
    private string? _workItemIdsFilter;
    private string? _workItemTypesFilter;
    private DataStateViewModel<DependencyGraphDto> _graphState = DataStateViewModel<DependencyGraphDto>.NotRequested();

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(InitialAreaPath))
        {
            _areaPathFilter = InitialAreaPath;
            await LoadDependencyGraph();
        }
    }

    private async Task LoadDependencyGraph()
    {
        _hasAttemptedLoad = true;
        _graphState = DataStateViewModel<DependencyGraphDto>.Loading();
        StateHasChanged();

        try
        {
            var response = GeneratedCacheEnvelopeHelper.ToDataStateResult(
                await WorkItemsClient.GetDependencyGraphAsync(
                areaPathFilter: _areaPathFilter, 
                workItemIds: _workItemIdsFilter,
                workItemTypes: _workItemTypesFilter));
            _graphState = _hasAttemptedLoad
                ? DataStateViewModel<DependencyGraphDto>.FromResult(response)
                : DataStateViewModel<DependencyGraphDto>.NotRequested();
        }
        catch (Exception)
        {
            _graphState = DataStateViewModel<DependencyGraphDto>.Failed("Dependency graph could not be loaded right now.");
        }

        StateHasChanged();
    }

    private Color GetStateColor(string? state)
    {
        return state?.ToLower() switch
        {
            "new" or "to do" => Color.Default,
            "active" or "in progress" or "doing" => Color.Info,
            "resolved" or "done" or "closed" => Color.Success,
            "removed" => Color.Error,
            _ => Color.Default
        };
    }
}
