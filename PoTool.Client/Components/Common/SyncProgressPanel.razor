@using PoTool.Shared.WorkItems
@implements IDisposable

@if (_progress != null && !string.IsNullOrEmpty(_progress.Status))
{
    <MudPaper Elevation="2" Class="pa-4 mb-3">
        <MudStack Spacing="3">
            @* Sync Type Badge (if provided) *@
            @if (!string.IsNullOrEmpty(_syncType))
            {
                <MudChip T="string" 
                         Icon="@(_syncType == "Full Sync" ? Icons.Material.Filled.Sync : Icons.Material.Filled.SyncAlt)" 
                         Color="@(_syncType == "Full Sync" ? Color.Primary : Color.Info)"
                         Size="Size.Small">
                    @_syncType
                </MudChip>
            }
            
            @* Status Header with Elapsed Time *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                @if (_progress.Status == "InProgress")
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Syncing...</MudText>
                }
                else if (_progress.Status == "Completed")
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Success">Sync Complete</MudText>
                }
                else if (_progress.Status == "Failed")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Error">Sync Failed</MudText>
                }
                else if (_progress.Status == "Cancelled")
                {
                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Warning" Size="Size.Small" />
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning">Sync Cancelled</MudText>
                }
                
                <MudSpacer />
                
                @* Elapsed Time *@
                @if (_startTime.HasValue && _progress.Status == "InProgress")
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                        @GetElapsedTime()
                    </MudText>
                }
                
                @* Work Items Count *@
                @if (_progress.ProcessedCount > 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_progress.ProcessedCount / @_progress.TotalCount items
                    </MudText>
                }
            </MudStack>

            @* Major Step Progress Bar *@
            @if (_progress.MajorStepTotal > 0)
            {
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="font-weight: 500;">
                            @(_progress.MajorStepLabel ?? $"Step {_progress.MajorStep}")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_progress.MajorStep / @_progress.MajorStepTotal
                        </MudText>
                    </MudStack>
                    <MudProgressLinear 
                        Color="Color.Primary" 
                        Value="@MajorProgressPercentage" 
                        Size="Size.Medium"
                        Rounded="true"
                        Class="mb-1" />
                </MudStack>
            }

            @* Phase-Level Progress (Relations / Fields) *@
            @if (!string.IsNullOrEmpty(_progress.Phase) && _progress.TotalBatches > 0)
            {
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption" Style="font-weight: 500;">
                            @_progress.Phase
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(_progress.HttpStatusCode.HasValue ? $"HTTP {_progress.HttpStatusCode}" : "")
                            @(_progress.ElapsedMs.HasValue ? $" • {_progress.ElapsedMs}ms" : "")
                        </MudText>
                    </MudStack>
                    
                    @* Batch Progress within Phase *@
                    @if (_progress.TotalBatches > 0)
                    {
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">
                                Batch @_progress.BatchIndex / @_progress.TotalBatches
                                @(_progress.IdCount > 0 ? $" ({_progress.IdCount} IDs)" : "")
                            </MudText>
                        </MudStack>
                        <MudProgressLinear 
                            Color="Color.Info" 
                            Value="@BatchProgressPercentage" 
                            Size="Size.Small"
                            Rounded="true" />
                    }
                </MudStack>
            }
            
            @* Phase 1 Summary (if available) *@
            @if (_progress.RelationsCount > 0 || _progress.ReverseLinksCount > 0 || _progress.ParentIdsCount > 0)
            {
                <MudPaper Outlined="true" Class="pa-2">
                    <MudText Typo="Typo.caption" Style="font-weight: 500;" Class="mb-1">Phase 1 Summary</MudText>
                    <MudStack Row="true" Spacing="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="mr-1" />
                            @_progress.RelationsCount relations
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.LinkOff" Size="Size.Small" Class="mr-1" />
                            @_progress.ReverseLinksCount reverse
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mr-1" />
                            @_progress.ParentIdsCount parents
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            @* Minor Step Progress Bar (legacy, when available) *@
            @if (_progress.MinorStepTotal > 0 && string.IsNullOrEmpty(_progress.Phase))
            {
                <MudStack Spacing="1">
                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.caption">
                            @(_progress.MinorStepLabel ?? $"Batch {_progress.MinorStep}")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_progress.MinorStep / @_progress.MinorStepTotal
                        </MudText>
                    </MudStack>
                    <MudProgressLinear 
                        Color="Color.Info" 
                        Value="@MinorProgressPercentage" 
                        Size="Size.Small"
                        Rounded="true" />
                </MudStack>
            }

            @* Message *@
            <MudAlert Severity="@GetMessageSeverity()" Dense="true" Class="mt-1">
                @_progress.Message
            </MudAlert>
        </MudStack>
    </MudPaper>
}

@code {
    [Parameter]
    public string? SyncType { get; set; }
    
    private SyncProgressDto? _progress;
    private DateTime? _startTime;
    private string? _syncType;
    private System.Timers.Timer? _timer;

    private double MajorProgressPercentage => 
        _progress?.MajorStepTotal > 0 
            ? Math.Min(100, (double)_progress.MajorStep / _progress.MajorStepTotal * 100)
            : 0;

    private double MinorProgressPercentage => 
        _progress?.MinorStepTotal > 0 
            ? Math.Min(100, (double)_progress.MinorStep / _progress.MinorStepTotal * 100)
            : 0;

    private double BatchProgressPercentage => 
        _progress?.TotalBatches > 0 
            ? Math.Min(100, (double)_progress.BatchIndex / _progress.TotalBatches * 100)
            : 0;

    protected override void OnInitialized()
    {
        _syncType = SyncType;
        
        // Start timer to update elapsed time every second
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) =>
        {
            if (_progress?.Status == "InProgress" && _startTime.HasValue)
            {
                InvokeAsync(StateHasChanged);
            }
        };
        _timer.Start();
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }

    /// <summary>
    /// Updates the progress display with new data.
    /// </summary>
    public void UpdateProgress(SyncProgressDto progress)
    {
        var wasInProgress = _progress?.Status == "InProgress";
        _progress = progress;
        
        // Start tracking time when sync begins
        if (progress.Status == "InProgress" && !_startTime.HasValue)
        {
            _startTime = DateTime.Now;
        }
        
        // Clear start time when sync completes/fails/cancelled
        if (progress.Status != "InProgress" && wasInProgress)
        {
            _startTime = null;
        }
        
        StateHasChanged();
    }

    /// <summary>
    /// Sets the sync type label (e.g., "Full Sync" or "Incremental Sync").
    /// </summary>
    public void SetSyncType(string syncType)
    {
        _syncType = syncType;
        StateHasChanged();
    }

    /// <summary>
    /// Clears the progress display.
    /// </summary>
    public void Clear()
    {
        _progress = null;
        _startTime = null;
        StateHasChanged();
    }

    /// <summary>
    /// Gets whether a sync is currently in progress.
    /// </summary>
    public bool IsInProgress => _progress?.Status == "InProgress";

    private string GetElapsedTime()
    {
        if (!_startTime.HasValue)
            return "0s";
            
        var elapsed = DateTime.Now - _startTime.Value;
        
        if (elapsed.TotalMinutes >= 1)
            return $"{(int)elapsed.TotalMinutes}m {elapsed.Seconds}s";
        
        return $"{(int)elapsed.TotalSeconds}s";
    }

    private Severity GetMessageSeverity()
    {
        return _progress?.Status switch
        {
            "Completed" => Severity.Success,
            "Failed" => Severity.Error,
            "Cancelled" => Severity.Warning,
            _ => Severity.Info
        };
    }
}
