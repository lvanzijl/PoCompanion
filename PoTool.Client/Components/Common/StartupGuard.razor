@using PoTool.Client.Services
@inject IStartupOrchestratorService StartupOrchestrator
@inject NavigationManager NavigationManager
@inject IPreferencesService PreferencesService
@inject ProfileService ProfileService

@* 
    StartupGuard component that checks startup readiness and routes appropriately.
    This component should be used in layouts to enforce startup gating.
*@

@if (_isChecking)
{
    <MudContainer Class="d-flex justify-center align-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudContainer>
}
else if (!_isReady && _readiness != null)
{
    @* Show blocking message when not ready *@
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <MudText Typo="Typo.h6">Setup Required</MudText>
            <MudText Typo="Typo.body1" Class="mt-2">
                @(_readiness.MissingRequirementMessage ?? "Please complete setup before using this feature.")
            </MudText>
        </MudAlert>
        
        <MudStack Row="true" Spacing="2">
            @if (!_readiness.HasSavedTfsConfig || !_readiness.HasTestedConnectionSuccessfully || !_readiness.HasVerifiedTfsApiSuccessfully)
            {
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           OnClick="@(() => NavigationManager.NavigateTo("/tfsconfig"))">
                    Go to Configuration
                </MudButton>
            }
            else if (!_readiness.HasAnyProfile)
            {
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           OnClick="@(() => NavigationManager.NavigateTo("/profiles"))">
                    Create Profile
                </MudButton>
            }
            else if (_readiness.ActiveProfileId == null)
            {
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           OnClick="@(() => NavigationManager.NavigateTo("/profiles"))">
                    Select Profile
                </MudButton>
            }
        </MudStack>
    </MudContainer>
}
else
{
    @* App is ready - render child content *@
    @ChildContent
}

@implements IDisposable

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    
    /// <summary>
    /// Pages that are exempt from the startup guard (can be accessed without full readiness).
    /// </summary>
    [Parameter]
    public IReadOnlyList<string>? ExemptPages { get; set; }
    
    private bool _isChecking = true;
    private bool _isReady = false;
    private StartupReadinessDto? _readiness;
    private string _lastCheckedLocation = string.Empty;
    
    // Default exempt pages (configuration, profiles, help, profile management, onboarding)
    private static readonly string[] DefaultExemptPages = new[]
    {
        "/tfsconfig",
        "/profiles",
        "/help",
        "/settings/productowner/edit",
        "/onboarding"
    };

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to location changes to detect actual navigation
        NavigationManager.LocationChanged += HandleLocationChanged;
        
        // Perform initial check
        await CheckReadinessAsync();
    }
    
    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Only re-check when the location actually changes
        await CheckReadinessAsync();
        StateHasChanged();
    }
    
    public void Dispose()
    {
        // Unsubscribe from location changes
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private async Task CheckReadinessAsync()
    {
        // Get current location
        var currentLocation = NavigationManager.Uri;
        
        // Skip check if location hasn't changed (prevents unnecessary checks on component re-renders)
        if (_lastCheckedLocation == currentLocation && _readiness != null)
        {
            return;
        }
        
        _lastCheckedLocation = currentLocation;
        _isChecking = true;
        
        try
        {
            _readiness = await StartupOrchestrator.GetStartupReadinessAsync();
            
            if (_readiness == null)
            {
                // Failed to get readiness - assume ready (graceful degradation)
                _isReady = true;
                return;
            }
            
            // If no active profile, try to restore from localStorage
            if (_readiness.ActiveProfileId == null)
            {
                var cachedProfileId = await PreferencesService.GetIntAsync("ActiveProfileId");
                if (cachedProfileId.HasValue)
                {
                    try
                    {
                        // Attempt to restore the profile
                        await ProfileService.SetActiveProfileAsync(cachedProfileId.Value);
                        // Re-check readiness after restoration
                        _readiness = await StartupOrchestrator.GetStartupReadinessAsync();
                        Console.WriteLine($"[StartupGuard] Restored active profile from localStorage: ID {cachedProfileId.Value}");
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[StartupGuard] Failed to restore profile from localStorage: {ex.Message}");
                        // Clear invalid cached profile ID
                        await PreferencesService.RemoveAsync("ActiveProfileId");
                    }
                }
            }
            
            // Check if current page is exempt
            var currentPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
            // Normalize: remove query string and ensure leading slash
            currentPath = "/" + currentPath.Split('?')[0].TrimStart('/');
            
            var exemptPages = ExemptPages?.ToArray() ?? DefaultExemptPages;
            if (exemptPages.Any(p => currentPath.StartsWith(p, StringComparison.OrdinalIgnoreCase)))
            {
                _isReady = true;
                return;
            }
            
            // Check if feature pages are accessible
            _isReady = _readiness != null && StartupOrchestrator.IsFeaturePageAccessible(_readiness);
        }
        catch (Exception)
        {
            // On error, allow access (graceful degradation)
            _isReady = true;
        }
        finally
        {
            _isChecking = false;
        }
    }
}
