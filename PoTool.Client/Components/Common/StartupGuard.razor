@using PoTool.Client.Services
@inject IStartupOrchestratorService StartupOrchestrator
@inject IPreferencesService PreferencesService
@inject NavigationManager NavigationManager
@inject IProfileService ProfileService

@* 
    StartupGuard component that checks startup readiness and routes appropriately.
    This component should be used in layouts to enforce startup gating.
*@

@if (_isChecking)
{
    <MudContainer Class="d-flex justify-center align-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudContainer>
}
else if (!_isReady)
{
    <StartupBlockingPanel Title="@GetBlockingTitle()"
                          Reason="@_startupReadiness.Reason"
                          RecoveryHint="@_startupReadiness.RecoveryHint"
                          Severity="@GetBlockingSeverity()"
                          PrimaryActionText="@GetPrimaryActionText()"
                          PrimaryActionHref="@GetPrimaryActionHref()"
                          SecondaryActionText="@GetSecondaryActionText()"
                          SecondaryActionHref="@GetSecondaryActionHref()" />
}
else
{
    @* App is ready - render child content *@
    @ChildContent
}

@implements IDisposable

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }
    
    /// <summary>
    /// Pages that are exempt from the startup guard (can be accessed without full readiness).
    /// </summary>
    [Parameter]
    public IReadOnlyList<string>? ExemptPages { get; set; }
    
    private bool _isChecking = true;
    private bool _isReady = false;
    private StartupReadinessResult _startupReadiness = new(
        StartupReadinessState.Unavailable,
        Readiness: null,
        Reason: "Startup readiness has not been checked yet.",
        RecoveryHint: "Retry startup once the application is ready.");
    private string _lastCheckedLocation = string.Empty;
    
    // Default exempt pages (settings, profiles, profile management, onboarding, root, sync-gate, blocking page)
    private static readonly string[] DefaultExemptPages = new[]
    {
        "/",
        "/settings",
        "/profiles",
        "/settings/productowner/edit",
        "/onboarding",
        "/sync-gate",
        "/startup-blocked"
    };

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to location changes to detect actual navigation
        NavigationManager.LocationChanged += HandleLocationChanged;
        
        // Perform initial check
        await CheckReadinessAsync();
    }
    
    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Only re-check when the location actually changes
        await CheckReadinessAsync();
        StateHasChanged();
    }
    
    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private async Task CheckReadinessAsync()
    {
        var currentLocation = NavigationManager.Uri;

        if (_lastCheckedLocation == currentLocation && _isChecking is false)
        {
            return;
        }

        _lastCheckedLocation = currentLocation;
        _isChecking = true;

        var currentPath = StartupGuardRouteMatcher.NormalizePath(NavigationManager.ToBaseRelativePath(currentLocation));
        var exemptPages = ExemptPages?.ToArray() ?? DefaultExemptPages;
        if (StartupGuardRouteMatcher.IsExemptPath(currentPath, exemptPages))
        {
            _isReady = true;
            _isChecking = false;
            return;
        }

        try
        {
            _startupReadiness = await StartupOrchestrator.GetStartupReadinessAsync();
            if (_startupReadiness.State == StartupReadinessState.NotReady)
            {
                var cachedProfileId = await PreferencesService.GetIntAsync("ActiveProfileId");
                if (cachedProfileId.HasValue)
                {
                    try
                    {
                        await ProfileService.SetActiveProfileAsync(cachedProfileId.Value);
                        _startupReadiness = await StartupOrchestrator.GetStartupReadinessAsync();
                    }
                    catch
                    {
                        await PreferencesService.RemoveAsync("ActiveProfileId");
                    }
                }
            }

            _isReady = StartupOrchestrator.IsFeaturePageAccessible(_startupReadiness);
        }
        catch
        {
            _startupReadiness = new StartupReadinessResult(
                StartupReadinessState.Error,
                Readiness: null,
                Reason: "Startup enforcement failed unexpectedly.",
                RecoveryHint: "Retry startup. If the problem persists, inspect the client logs.");
            _isReady = false;
        }
        finally
        {
            _isChecking = false;
        }
    }

    private string GetBlockingTitle()
    {
        return _startupReadiness.State switch
        {
            StartupReadinessState.SetupRequired => "Setup required",
            StartupReadinessState.SyncRequired => "Sync required",
            StartupReadinessState.NotReady => "Profile selection required",
            StartupReadinessState.Unavailable => "Startup unavailable",
            StartupReadinessState.Error => "Startup error",
            _ => "Startup blocked"
        };
    }

    private Severity GetBlockingSeverity()
    {
        return _startupReadiness.State is StartupReadinessState.Unavailable or StartupReadinessState.Error
            ? Severity.Error
            : Severity.Warning;
    }

    private string GetPrimaryActionText()
    {
        return _startupReadiness.State switch
        {
            StartupReadinessState.SetupRequired when _startupReadiness.Readiness is { HasSavedTfsConfig: false }
                or { HasTestedConnectionSuccessfully: false }
                or { HasVerifiedTfsApiSuccessfully: false } => "Open settings",
            StartupReadinessState.SetupRequired or StartupReadinessState.NotReady => "Open profiles",
            StartupReadinessState.SyncRequired => "Open sync gate",
            _ => "Retry startup"
        };
    }

    private string GetPrimaryActionHref()
    {
        return _startupReadiness.State switch
        {
            StartupReadinessState.SetupRequired when _startupReadiness.Readiness is { HasSavedTfsConfig: false }
                or { HasTestedConnectionSuccessfully: false }
                or { HasVerifiedTfsApiSuccessfully: false } => "/settings/tfs",
            StartupReadinessState.SetupRequired or StartupReadinessState.NotReady => "/profiles",
            StartupReadinessState.SyncRequired => "/sync-gate?returnUrl=%2Fhome",
            _ => "/"
        };
    }

    private string? GetSecondaryActionText()
    {
        return _startupReadiness.State is StartupReadinessState.Unavailable or StartupReadinessState.Error
            ? "Open settings"
            : null;
    }

    private string? GetSecondaryActionHref()
    {
        return _startupReadiness.State is StartupReadinessState.Unavailable or StartupReadinessState.Error
            ? "/settings/tfs"
            : null;
    }
}
