@typeparam T
@using MudBlazor

<MudTable Items="@Items"
          Dense="true"
          Hover="@Hover"
          Striped="@Striped"
          Bordered="@Bordered"
          FixedHeader="@FixedHeader"
          FixedFooter="@FixedFooter"
          Height="@Height"
          Loading="@Loading"
          LoadingProgressColor="@LoadingProgressColor"
          Filter="@Filter"
          Elevation="@Elevation"
          Square="@Square"
          Outlined="@Outlined"
          Class="@Class"
          Style="@Style"
          SortLabel="@SortLabel"
          AllowUnsorted="@AllowUnsorted"
          RowsPerPage="@RowsPerPage"
          CurrentPage="@CurrentPage"
          MultiSelection="@MultiSelection"
          @bind-SelectedItem="SelectedItem"
          @bind-SelectedItems="SelectedItems"
          OnRowClick="@OnRowClick"
          RowClass="@RowClass"
          RowStyle="@RowStyle"
          CustomHeader="@CustomHeader"
          CustomFooter="@CustomFooter"
          Virtualize="@Virtualize"
          CanCancelEdit="@CanCancelEdit"
          CommitEditTooltip="@CommitEditTooltip"
          CancelEditTooltip="@CancelEditTooltip"
          RowEditPreview="@RowEditPreview"
          RowEditCommit="@RowEditCommit"
          RowEditCancel="@RowEditCancel">
    @if (HeaderContent != null)
    {
        <HeaderContent>@HeaderContent</HeaderContent>
    }
    @if (ColGroup != null)
    {
        <ColGroup>@ColGroup</ColGroup>
    }
    @if (RowTemplate != null)
    {
        <RowTemplate>@RowTemplate(context)</RowTemplate>
    }
    @if (ChildRowContent != null)
    {
        <ChildRowContent>@ChildRowContent(context)</ChildRowContent>
    }
    @if (NoRecordsContent != null)
    {
        <NoRecordsContent>@NoRecordsContent</NoRecordsContent>
    }
    @if (LoadingContent != null)
    {
        <LoadingContent>@LoadingContent</LoadingContent>
    }
    @if (PagerContent != null)
    {
        <PagerContent>@PagerContent</PagerContent>
    }
    @if (FooterContent != null)
    {
        <FooterContent>@FooterContent</FooterContent>
    }
</MudTable>

@code {
    [Parameter] public IEnumerable<T>? Items { get; set; }
    [Parameter] public bool Hover { get; set; } = true;
    [Parameter] public bool Striped { get; set; }
    [Parameter] public bool Bordered { get; set; }
    [Parameter] public bool FixedHeader { get; set; }
    [Parameter] public bool FixedFooter { get; set; }
    [Parameter] public string? Height { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public Color LoadingProgressColor { get; set; } = Color.Info;
    [Parameter] public Func<T, bool>? Filter { get; set; }
    [Parameter] public int Elevation { get; set; } = 1;
    [Parameter] public bool Square { get; set; }
    [Parameter] public bool Outlined { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public string? SortLabel { get; set; }
    [Parameter] public bool AllowUnsorted { get; set; } = true;
    [Parameter] public int RowsPerPage { get; set; } = 10;
    [Parameter] public int CurrentPage { get; set; }
    [Parameter] public bool MultiSelection { get; set; }
    [Parameter] public T? SelectedItem { get; set; }
    [Parameter] public EventCallback<T> SelectedItemChanged { get; set; }
    [Parameter] public HashSet<T>? SelectedItems { get; set; }
    [Parameter] public EventCallback<HashSet<T>> SelectedItemsChanged { get; set; }
    [Parameter] public EventCallback<TableRowClickEventArgs<T>> OnRowClick { get; set; }
    [Parameter] public Func<T, int, string>? RowClass { get; set; }
    [Parameter] public Func<T, int, string>? RowStyle { get; set; }
    [Parameter] public bool CustomHeader { get; set; }
    [Parameter] public bool CustomFooter { get; set; }
    [Parameter] public bool Virtualize { get; set; }
    [Parameter] public bool CanCancelEdit { get; set; }
    [Parameter] public string? CommitEditTooltip { get; set; }
    [Parameter] public string? CancelEditTooltip { get; set; }
    [Parameter] public Action<object>? RowEditPreview { get; set; }
    [Parameter] public EventCallback<object> RowEditCommit { get; set; }
    [Parameter] public EventCallback<object> RowEditCancel { get; set; }
    
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment? ColGroup { get; set; }
    [Parameter] public RenderFragment<T>? RowTemplate { get; set; }
    [Parameter] public RenderFragment<T>? ChildRowContent { get; set; }
    [Parameter] public RenderFragment? NoRecordsContent { get; set; }
    [Parameter] public RenderFragment? LoadingContent { get; set; }
    [Parameter] public RenderFragment? PagerContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
}
