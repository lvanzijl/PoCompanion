@using MudBlazor

@* This component is the standard button entry point. Raw MudButton should not be used for normal UI actions.
   TODO: keep button semantics aligned with docs/rules/ui-rules.md and density aligned with docs/rules/fluent-ui-compat-rules.md. *@
<MudButton Variant="@ResolvedVariant"
           Color="@ResolvedColor"
           Size="Size.Small"
           Disabled="@Disabled"
           FullWidth="@FullWidth"
           StartIcon="@ResolvedIcon"
           IconColor="Color.Inherit"
           Class="@ResolvedClass"
           Style="@Style"
           OnClick="@OnClick"
           ButtonType="@ButtonType"
           Href="@Href"
           Target="@Target">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        @Label
    }
    else
    {
        @ChildContent
    }
</MudButton>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public global::PoTool.Client.Components.Common.Compact.ButtonRole? ButtonRole { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Variant Variant { get; set; } = Variant.Filled;
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; }
    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
    [Parameter] public ButtonType ButtonType { get; set; } = ButtonType.Button;
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }

    private CompactButtonAppearance? Appearance => ButtonRole.HasValue
        ? CompactButtonStyleResolver.Resolve(ButtonRole.Value)
        : null;

    private Variant ResolvedVariant => Appearance?.Variant ?? Variant;

    private Color ResolvedColor => Appearance?.Color ?? Color;

    private string? ResolvedIcon => string.IsNullOrWhiteSpace(Icon) ? StartIcon : Icon;

    private string ResolvedClass => string.Join(
        " ",
        new[]
        {
            "compact-button",
            Appearance?.CssClass,
            Class
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
}
