@typeparam T
@using MudBlazor

<MudList @bind-SelectedValue="SelectedValue"
         @bind-SelectedItem="SelectedItem"
         Dense="true"
         Disabled="@Disabled"
         DisablePadding="@DisablePadding"
         DisableGutters="@DisableGutters"
         Clickable="@Clickable"
         Color="@Color"
         Class="@Class"
         Style="@Style"
         SelectedItemChanged="@SelectedItemChanged"
         SelectedValueChanged="@SelectedValueChanged">
    @ChildContent
</MudList>

@code {
    [Parameter] public T? SelectedValue { get; set; }
    [Parameter] public EventCallback<T> SelectedValueChanged { get; set; }
    [Parameter] public MudListItem<T>? SelectedItem { get; set; }
    [Parameter] public EventCallback<MudListItem<T>> SelectedItemChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool DisablePadding { get; set; }
    [Parameter] public bool DisableGutters { get; set; }
    [Parameter] public bool Clickable { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Default;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string? Style { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
