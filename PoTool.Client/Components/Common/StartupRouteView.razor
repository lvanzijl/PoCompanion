@using PoTool.Client.Services
@inject NavigationManager NavigationManager
@inject IOnboardingService OnboardingService
@inject IStartupOrchestratorService StartupOrchestrator

@if (_canRender)
{
    <RouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout" />
    <FocusOnNavigate RouteData="@RouteData" Selector="h1" />
}
else
{
    <MudContainer Class="d-flex justify-center align-center" Style="height: 100vh;">
        <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
    </MudContainer>
}

@code {
    private static readonly string[] UnguardedPaths =
    {
        "/profiles",
        "/settings",
        "/onboarding",
        "/sync-gate",
        "/startup-blocked"
    };

    private bool _canRender;
    private string? _evaluatedUri;

    [Parameter, EditorRequired]
    public RouteData RouteData { get; set; } = default!;

    [Parameter, EditorRequired]
    public Type DefaultLayout { get; set; } = default!;

    protected override async Task OnParametersSetAsync()
    {
        var currentUri = NavigationManager.Uri;
        if (string.Equals(_evaluatedUri, currentUri, StringComparison.Ordinal))
        {
            return;
        }

        _evaluatedUri = currentUri;
        _canRender = false;

        var currentRelativeUri = NavigationManager.ToBaseRelativePath(currentUri);
        var currentPath = StartupGuardRouteMatcher.NormalizePath(currentRelativeUri);
        if (StartupGuardRouteMatcher.IsExemptPath(currentPath, UnguardedPaths))
        {
            _canRender = true;
            return;
        }

        var readiness = await StartupOrchestrator.GetStartupReadinessAsync();
        if (currentPath == "/")
        {
            await RouteRootAsync(readiness);
            return;
        }

        if (StartupOrchestrator.IsFeaturePageAccessible(readiness))
        {
            _canRender = true;
            return;
        }

        NavigateToDecision(StartupOrchestrator.DetermineRoute(readiness), currentRelativeUri);
    }

    private async Task RouteRootAsync(StartupReadinessResult readiness)
    {
        if (readiness.Readiness?.HasSavedTfsConfig == false)
        {
            await OnboardingService.ResetOnboardingAsync();
        }

        if (!await OnboardingService.HasCompletedOnboardingAsync()
            && readiness.State == StartupReadinessState.SetupRequired)
        {
            NavigationManager.NavigateTo("/onboarding", replace: true);
            return;
        }

        NavigateToDecision(StartupOrchestrator.DetermineRoute(readiness), null);
    }

    private void NavigateToDecision(StartupRoutingResult routingResult, string? returnUrl)
    {
        var targetUri = StartupNavigationTargetResolver.GetTargetUri(routingResult, returnUrl);
        NavigationManager.NavigateTo(targetUri, replace: true);
    }
}
