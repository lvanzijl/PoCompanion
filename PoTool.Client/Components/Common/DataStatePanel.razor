@using PoTool.Client.Helpers
@using PoTool.Shared.DataState

<MudPaper Elevation="1" Class="pa-6">
    <MudStack Spacing="3">
        <MudAlert Severity="@GetSeverity()" Variant="Variant.Filled" Dense="true">
            @DisplayContent.Title
        </MudAlert>

        <MudText Typo="Typo.body1">
            @DisplayContent.Message
        </MudText>

        @if (HasRecoveryAction)
        {
            <MudStack Row="true">
                <MudButton Variant="Variant.Outlined"
                           Color="@(State == DataStateDto.Failed ? Color.Error : Color.Primary)"
                           OnClick="HandleRecoveryAsync">
                    @RecoveryActionText
                </MudButton>
            </MudStack>
        }

        @if (State == DataStateDto.NotReady && ProductOwnerId.HasValue)
        {
            <CacheStatusSection ProductOwnerId="@ProductOwnerId.Value" />
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DataStateDto State { get; set; }

    [Parameter]
    public UiDataState? UiState { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string Subject { get; set; } = "Data";

    [Parameter]
    public string? Reason { get; set; }

    [Parameter]
    public int? ProductOwnerId { get; set; }

    [Parameter]
    public string RecoveryActionText { get; set; } = "Retry";

    [Parameter]
    public EventCallback OnRecovery { get; set; }

    private bool HasRecoveryAction => OnRecovery.HasDelegate;

    private CacheStateDisplayContent DisplayContent
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(Title) || !string.IsNullOrWhiteSpace(Message))
            {
                var fallback = CacheStatePresentation.Create(Subject, State, Reason);
                return new CacheStateDisplayContent(
                    string.IsNullOrWhiteSpace(Title) ? fallback.Title : Title,
                    string.IsNullOrWhiteSpace(Message) ? fallback.Message : Message);
            }

            return CacheStatePresentation.Create(Subject, UiState ?? CacheStatePresentation.ToUiDataState(State), Reason);
        }
    }

    private Task HandleRecoveryAsync()
        => OnRecovery.InvokeAsync();

    private Severity GetSeverity() => (UiState ?? CacheStatePresentation.ToUiDataState(State)) switch
    {
        UiDataState.Loading => Severity.Info,
        UiDataState.EmptyButValid => Severity.Info,
        UiDataState.Invalid => Severity.Warning,
        UiDataState.Failed => Severity.Error,
        _ => Severity.Normal
    };
}
