@using PoTool.Shared.DataState

<MudPaper Elevation="1" Class="pa-6">
    <MudStack Spacing="3">
        <MudAlert Severity="@GetSeverity()" Variant="Variant.Filled" Dense="true">
            @Title
        </MudAlert>

        <MudText Typo="Typo.body1">
            @Message
        </MudText>

        @if (State == DataStateDto.NotReady && ProductOwnerId.HasValue)
        {
            <CacheStatusSection ProductOwnerId="@ProductOwnerId.Value" />
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public DataStateDto State { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public int? ProductOwnerId { get; set; }

    private Severity GetSeverity() => State switch
    {
        DataStateDto.NotReady => Severity.Info,
        DataStateDto.Empty => Severity.Info,
        DataStateDto.Failed => Severity.Error,
        _ => Severity.Normal
    };
}
