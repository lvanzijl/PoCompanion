<MudButton Variant="Variant.Outlined"
           Color="Color.Default"
           Size="Size.Small"
           FullWidth="true"
           Class="dashboard-workspace-card"
           OnClick="OnClick">
    <MudStack Spacing="2" Class="dashboard-workspace-card__content">
        <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="dashboard-workspace-card__title">@Title</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary">@SignalText</MudText>
    </MudStack>
</MudButton>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SignalText { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.Dashboard;

    [Parameter]
    public Color IconColor { get; set; } = Color.Primary;

    [Parameter]
    public EventCallback OnClick { get; set; }
}
