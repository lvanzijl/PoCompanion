<MudCard Elevation="2"
         Class="dashboard-workspace-card"
         @onclick="OnClick"
         @onkeydown="HandleKeyDown"
         tabindex="0"
         role="button"
         aria-label="@($"{Title} workspace")">
    <MudCardContent Class="dashboard-workspace-card__content">
        <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="dashboard-workspace-card__title">@Title</MudText>
        <MudText Typo="Typo.body2" Class="dashboard-workspace-card__signal">@SignalText</MudText>
    </MudCardContent>
</MudCard>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string SignalText { get; set; } = string.Empty;

    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.Dashboard;

    [Parameter]
    public Color IconColor { get; set; } = Color.Primary;

    [Parameter]
    public EventCallback OnClick { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" || e.Code == "Space")
        {
            await OnClick.InvokeAsync();
        }
    }
}
