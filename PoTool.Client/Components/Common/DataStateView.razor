@typeparam TData
@using PoTool.Client.Models
@using PoTool.Client.Helpers
@using PoTool.Shared.DataState

@if (IsLoading || State.UiState == UiDataState.Loading)
{
    <LoadingIndicator IsLoading="true" />
}
else if (State.UiState == UiDataState.Invalid)
{
    <DataStatePanel State="@State.State"
                    UiState="UiDataState.Invalid"
                    Subject="@Subject"
                    Reason="@State.Reason"
                    Title="@InvalidTitle"
                    Message="@(State.Reason ?? InvalidMessage)"
                    ProductOwnerId="@ProductOwnerId"
                    RecoveryActionText="@RecoveryActionText"
                    OnRecovery="@OnRecovery" />
}
else if (State.UiState == UiDataState.Failed)
{
    <DataStatePanel State="DataStateDto.Failed"
                    UiState="UiDataState.Failed"
                    Subject="@Subject"
                    Reason="@State.Reason"
                    Title="@FailedTitle"
                    Message="@(State.Reason ?? FailedMessage)"
                    ProductOwnerId="@ProductOwnerId"
                    RecoveryActionText="@RecoveryActionText"
                    OnRecovery="@OnRecovery" />
}
else if (State.UiState == UiDataState.EmptyButValid)
{
    <EmptyStateDisplay Title="@EmptyTitle"
                      Message="@(State.Reason ?? EmptyMessage)" />
}
else if (State.UiState == UiDataState.Ready && State.Data is not null)
{
    @ChildContent(State.Data)
}
else
{
    @NotRequestedContent
}

@code {
    [Parameter, EditorRequired]
    public DataStateViewModel<TData> State { get; set; } = DataStateViewModel<TData>.NotRequested();

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<TData> ChildContent { get; set; } = default!;

    [Parameter]
    public RenderFragment? NotRequestedContent { get; set; }

    [Parameter]
    public int? ProductOwnerId { get; set; }

    [Parameter]
    public string Subject { get; set; } = "Data";

    [Parameter]
    public string NotReadyTitle { get; set; } = string.Empty;

    [Parameter]
    public string NotReadyMessage { get; set; } = string.Empty;

    [Parameter]
    public string FailedTitle { get; set; } = string.Empty;

    [Parameter]
    public string FailedMessage { get; set; } = string.Empty;

    [Parameter]
    public string InvalidTitle { get; set; } = string.Empty;

    [Parameter]
    public string InvalidMessage { get; set; } = string.Empty;

    [Parameter]
    public string RecoveryActionText { get; set; } = "Retry";

    [Parameter]
    public EventCallback OnRecovery { get; set; }

    [Parameter]
    public string EmptyTitle { get; set; } = "No data available";

    [Parameter]
    public string EmptyMessage { get; set; } = "No data is available for the current selection.";
}
