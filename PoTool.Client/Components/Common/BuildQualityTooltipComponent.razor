@using PoTool.Client.ApiClient

<MudStack Spacing="1" Class="build-quality-tooltip">
    <MudText Typo="Typo.subtitle2">@GetSectionTitle()</MudText>

    @foreach (var line in GetEvidenceLines())
    {
        <MudText Typo="Typo.caption">@line</MudText>
    }

    @if (!string.IsNullOrWhiteSpace(GetUnknownReason()))
    {
        <MudText Typo="Typo.caption" Color="Color.Default">@GetUnknownReason()</MudText>
    }

    <MudDivider Class="my-1" />

    <MudText Typo="Typo.subtitle2">Confidence</MudText>
    <MudText Typo="Typo.caption">@BuildQualityPresentation.GetConfidenceSummary(Result)</MudText>
    <MudText Typo="Typo.caption">Build threshold: @(Result.Evidence.BuildThresholdMet ? "met" : "not met")</MudText>
    <MudText Typo="Typo.caption">Test threshold: @(Result.Evidence.TestThresholdMet ? "met" : "not met")</MudText>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public BuildQualityResultDto Result { get; set; } = default!;

    [Parameter]
    public BuildQualityDimension Dimension { get; set; } = BuildQualityDimension.Builds;

    private string GetSectionTitle() =>
        Dimension switch
        {
            BuildQualityDimension.Builds => "Build evidence",
            BuildQualityDimension.Tests => "Test evidence",
            BuildQualityDimension.Coverage => "Coverage evidence",
            _ => "Evidence"
        };

    private IEnumerable<string> GetEvidenceLines()
    {
        yield return Dimension switch
        {
            BuildQualityDimension.Builds => $"Eligible: {Result.Evidence.EligibleBuilds}",
            BuildQualityDimension.Tests => $"Total tests: {Result.Evidence.TotalTests}",
            BuildQualityDimension.Coverage => $"Covered lines: {Result.Evidence.CoveredLines}",
            _ => string.Empty
        };

        switch (Dimension)
        {
            case BuildQualityDimension.Builds:
                yield return $"Succeeded: {Result.Evidence.SucceededBuilds}";
                yield return $"Failed: {Result.Evidence.FailedBuilds + Result.Evidence.PartiallySucceededBuilds}";
                yield return $"Canceled: {Result.Evidence.CanceledBuilds}";
                break;

            case BuildQualityDimension.Tests:
                yield return $"Passed: {Result.Evidence.PassedTests}";
                yield return $"Not applicable: {Result.Evidence.NotApplicableTests}";
                yield return $"Volume: {Result.Metrics.TestVolume}";
                break;

            case BuildQualityDimension.Coverage:
                yield return $"Total lines: {Result.Evidence.TotalLines}";
                yield return $"Coverage: {BuildQualityPresentation.FormatPercent(Result.Metrics.Coverage, Result.Evidence.CoverageUnknown)}";
                break;
        }
    }

    private string? GetUnknownReason()
    {
        var reason = Dimension switch
        {
            BuildQualityDimension.Builds => Result.Evidence.SuccessRateUnknownReason,
            BuildQualityDimension.Tests => Result.Evidence.TestPassRateUnknownReason,
            BuildQualityDimension.Coverage => Result.Evidence.CoverageUnknownReason,
            _ => null
        };

        return string.IsNullOrWhiteSpace(reason)
            ? null
            : BuildQualityPresentation.GetUnknownReasonText(reason);
    }
}
