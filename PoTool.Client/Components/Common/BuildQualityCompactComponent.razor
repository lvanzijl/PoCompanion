@using PoTool.Client.ApiClient

@if (Result is not null)
{
    <MudPaper Elevation="@Elevation" Class="pa-3">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Title</MudText>
        }

        <MudGrid Spacing="2">
            <MudItem xs="12" md="3">
                <div class="build-quality-compact__tile">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">Builds</MudText>
                            <MudTooltip Placement="Placement.Bottom" Arrow="true">
                                <ChildContent>
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </ChildContent>
                                <TooltipContent>
                                    <BuildQualityTooltipComponent Result="Result" Dimension="BuildQualityDimension.Builds" />
                                </TooltipContent>
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.subtitle1">
                            @BuildQualityPresentation.FormatPercent(Result.Metrics.SuccessRate, Result.Evidence.SuccessRateUnknown)
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Eligible: @Result.Evidence.EligibleBuilds</MudText>
                    </MudStack>
                </div>
            </MudItem>

            <MudItem xs="12" md="3">
                <div class="build-quality-compact__tile">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">Tests</MudText>
                            <MudTooltip Placement="Placement.Bottom" Arrow="true">
                                <ChildContent>
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </ChildContent>
                                <TooltipContent>
                                    <BuildQualityTooltipComponent Result="Result" Dimension="BuildQualityDimension.Tests" />
                                </TooltipContent>
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.subtitle1">
                            @BuildQualityPresentation.FormatPercent(Result.Metrics.TestPassRate, Result.Evidence.TestPassRateUnknown)
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Volume: @Result.Metrics.TestVolume</MudText>
                    </MudStack>
                </div>
            </MudItem>

            <MudItem xs="12" md="3">
                <div class="build-quality-compact__tile">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">Coverage</MudText>
                            <MudTooltip Placement="Placement.Bottom" Arrow="true">
                                <ChildContent>
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </ChildContent>
                                <TooltipContent>
                                    <BuildQualityTooltipComponent Result="Result" Dimension="BuildQualityDimension.Coverage" />
                                </TooltipContent>
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.subtitle1">
                            @BuildQualityPresentation.FormatPercent(Result.Metrics.Coverage, Result.Evidence.CoverageUnknown)
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total lines: @Result.Evidence.TotalLines</MudText>
                    </MudStack>
                </div>
            </MudItem>

            <MudItem xs="12" md="3">
                <div class="build-quality-compact__tile">
                    <MudStack Spacing="0">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption">Confidence</MudText>
                            <MudTooltip Placement="Placement.Bottom" Arrow="true">
                                <ChildContent>
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" />
                                </ChildContent>
                                <TooltipContent>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.caption">Build threshold: @(Result.Evidence.BuildThresholdMet ? "met" : "not met")</MudText>
                                        <MudText Typo="Typo.caption">Test threshold: @(Result.Evidence.TestThresholdMet ? "met" : "not met")</MudText>
                                    </MudStack>
                                </TooltipContent>
                            </MudTooltip>
                        </MudStack>
                        <MudText Typo="Typo.subtitle1">@Result.Metrics.Confidence</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Build: @(Result.Evidence.BuildThresholdMet ? "met" : "not met") · Test: @(Result.Evidence.TestThresholdMet ? "met" : "not met")</MudText>
                    </MudStack>
                </div>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    [Parameter, EditorRequired]
    public BuildQualityResultDto Result { get; set; } = default!;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public int Elevation { get; set; } = 1;
}

<style>
    .build-quality-compact__tile {
        height: 100%;
        border-radius: 8px;
        padding: 8px;
        border: 1px solid var(--mud-palette-divider);
        background: rgba(96, 125, 139, 0.08);
    }
</style>
