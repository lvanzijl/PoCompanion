@* VelocityPanel — legacy wrapper. Velocity signals are now embedded in Sprint Trend
   (Calibration panel, advanced mode) and Planning (Capacity Confidence block). *@

<MudAlert Severity="Severity.Info" Class="mb-2">
    <MudText Typo="Typo.body2">
        Velocity and predictability signals are now available in
        <MudLink Href="/home/sprint-trend">Sprint Trend</MudLink>
        (Calibration panel — enable advanced mode) and
        <MudLink Href="/home/planning">Planning</MudLink>
        (Capacity Confidence block).
    </MudText>
</MudAlert>

@code {
    /// <summary>Team area path (retained for parameter compatibility — no longer used).</summary>
    [Parameter] public string? TeamAreaPath { get; set; }

    /// <summary>Product IDs (retained for parameter compatibility — no longer used).</summary>
    [Parameter] public int[]? ProductIds { get; set; }

    /// <summary>Maximum sprints (retained for parameter compatibility — no longer used).</summary>
    [Parameter] public int MaxSprints { get; set; } = 10;
}
