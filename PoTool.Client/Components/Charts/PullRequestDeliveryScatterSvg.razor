@*
    PullRequestDeliveryScatterSvg — Reusable SVG scatter chart for PR Delivery Insights.

    X axis: PR creation time over the selected date range
    Y axis: PR lifetime in hours (auto-scaled from data)

    Color mapping (by PR state):
      completed            → green  (--mud-palette-success)
      abandoned            → red    (--mud-palette-error)
      active               → neutral (--mud-palette-text-secondary)

    Shape mapping (by Epic):
      Each unique Epic gets a distinct shape: circle, square, triangle (cycling).
      No-epic PRs are shown as small circles (neutral).

    Overlay lines:
      Median: dashed info color
      P90:    dashed warning color

    Interactions:
      Hover a point   → SVG tooltip shown
      Click a point   → OnPointClick callback fired
*@

@namespace PoTool.Client.Components.Charts
@using PoTool.Client.Helpers
@using PoTool.Shared.PullRequests

<div class="pr-scatter-container" style="position: relative; width: 100%;">
    <div class="pr-scatter-layout">
        <div class="pr-scatter-chart">
            <svg viewBox="0 0 820 300"
                 style="width: 100%; height: auto; max-height: @(Height)px; display: block; overflow: visible;"
                 @onmouseleave="() => _hoveredPoint = null">

        @* ── Y axis grid lines + labels ────────────────────────────── *@
        @foreach (var tick in GetYTicks())
        {
            <line x1="@L" y1="@F(tick.Px)"
                  x2="@F(PlotRight)" y2="@F(tick.Px)"
                  stroke="var(--mud-palette-divider)" stroke-width="0.5" />
            @Txt(LeftPad - 6, tick.Px + 3.5, "end", 9, "var(--mud-palette-text-secondary)", FormatYLabel(tick.Val))
        }

        @* ── X axis ticks + labels ─────────────────────────────────── *@
        @foreach (var tick in GetXTicks())
        {
            <line x1="@F(tick.Px)" y1="@F(PlotBottom)"
                  x2="@F(tick.Px)" y2="@F(PlotBottom + 4)"
                  stroke="var(--mud-palette-divider)" stroke-width="1" />
            @Txt(tick.Px, PlotBottom + 14, "middle", 9, "var(--mud-palette-text-secondary)", FormatXLabel(tick.Time))
        }

        @* ── Axis lines ─────────────────────────────────────────────── *@
        <line x1="@L" y1="@T" x2="@L" y2="@F(PlotBottom)"
              stroke="var(--mud-palette-divider)" stroke-width="1" />
        <line x1="@L" y1="@F(PlotBottom)" x2="@F(PlotRight)" y2="@F(PlotBottom)"
              stroke="var(--mud-palette-divider)" stroke-width="1" />

        @* ── Y axis label ──────────────────────────────────────────── *@
        @((MarkupString)$"""<text x="11" y="{F(TopPad + PlotHeight / 2)}" text-anchor="middle" font-size="9" fill="var(--mud-palette-text-secondary)" transform="rotate(-90 11 {F(TopPad + PlotHeight / 2)})">Lifetime (h)</text>""")

        @* ── Median overlay line ───────────────────────────────────── *@
        @if (ShowMedianLine && MedianLifetimeHours.HasValue && MedianLifetimeHours.Value > 0)
        {
            var medY = ToSvgY(MedianLifetimeHours.Value);
            <line x1="@L" y1="@F(medY)" x2="@F(PlotRight)" y2="@F(medY)"
                  stroke="var(--mud-palette-info)" stroke-width="1"
                  stroke-dasharray="4,3" opacity="0.80" />
            @Txt(PlotRight + 3, medY + 3, "start", 8, "var(--mud-palette-info)", "med")
        }

        @* ── P90 overlay line ──────────────────────────────────────── *@
        @if (ShowP90Line && P90LifetimeHours.HasValue && P90LifetimeHours.Value > 0)
        {
            var p90Y = ToSvgY(P90LifetimeHours.Value);
            <line x1="@L" y1="@F(p90Y)" x2="@F(PlotRight)" y2="@F(p90Y)"
                  stroke="var(--mud-palette-warning)" stroke-width="1"
                  stroke-dasharray="2,3" opacity="0.80" />
            @Txt(PlotRight + 3, p90Y + 3, "start", 8, "var(--mud-palette-warning)", "P90")
        }

        @* ── Data points ───────────────────────────────────────────── *@
        @foreach (var pt in Data)
        {
            double cx      = ToSvgX(pt.CreatedDate);
            double cy      = ToSvgY(pt.LifetimeHours);
            bool isHovered = _hoveredPoint?.Id == pt.Id;

            double opacity = isHovered ? 1.0 : 0.80;
            double r       = isHovered ? 8.0 : 5.5;
            var stroke     = isHovered ? "var(--mud-palette-primary)" : "transparent";
            var color      = GetStatusColor(pt.Status);
            var shape      = GetEpicShape(pt.EpicId);

            @if (shape == "circle")
            {
                <circle cx="@F(cx)" cy="@F(cy)" r="@F(r)"
                        fill="@color"
                        opacity="@F(opacity)"
                        stroke="@stroke"
                        stroke-width="@(isHovered ? "1.5" : "0")"
                        style="cursor: pointer;"
                        @onmouseenter="() => _hoveredPoint = pt"
                        @onmouseleave="() => _hoveredPoint = null"
                        @onclick="() => HandlePointClick(pt)" />
            }
            else if (shape == "square")
            {
                double side = r * 1.6;
                <rect x="@F(cx - side/2)" y="@F(cy - side/2)"
                      width="@F(side)" height="@F(side)"
                      fill="@color"
                      opacity="@F(opacity)"
                      stroke="@stroke"
                      stroke-width="@(isHovered ? "1.5" : "0")"
                      style="cursor: pointer;"
                      @onmouseenter="() => _hoveredPoint = pt"
                      @onmouseleave="() => _hoveredPoint = null"
                      @onclick="() => HandlePointClick(pt)" />
            }
            else
            {
                @* triangle *@
                double th = r * 1.8;
                string pts = $"{F(cx)},{F(cy - th)} {F(cx - th * 0.87)},{F(cy + th * 0.5)} {F(cx + th * 0.87)},{F(cy + th * 0.5)}";
                <polygon points="@pts"
                         fill="@color"
                         opacity="@F(opacity)"
                         stroke="@stroke"
                         stroke-width="@(isHovered ? "1.5" : "0")"
                         style="cursor: pointer;"
                         @onmouseenter="() => _hoveredPoint = pt"
                         @onmouseleave="() => _hoveredPoint = null"
                         @onclick="() => HandlePointClick(pt)" />
            }
        }

        @* ── SVG tooltip (shown on hover) ──────────────────────────── *@
        @if (_hoveredPoint != null)
        {
            const double ttW = 220;
            const double ttH = 120;
            double htX = ToSvgX(_hoveredPoint.CreatedDate);
            double htY = ToSvgY(_hoveredPoint.LifetimeHours);
            double ttX = Math.Min(htX + 10, 820 - ttW - 5);
            double ttY = Math.Max(htY - ttH - 8, TopPad + 2);
            var statusColor = GetStatusColor(_hoveredPoint.Status);

            <g pointer-events="none">
                @* shadow *@
                <rect x="@F(ttX + 2)" y="@F(ttY + 2)" width="@ttW" height="@ttH"
                      rx="4" fill="rgba(0,0,0,0.14)" />
                @* background *@
                <rect x="@F(ttX)" y="@F(ttY)" width="@ttW" height="@ttH"
                      rx="4"
                      fill="var(--mud-palette-surface)"
                      stroke="var(--mud-palette-divider)"
                      stroke-width="0.8" />
                @* PR title *@
                @((MarkupString)$"""<text x="{F(ttX+8)}" y="{F(ttY+16)}" font-size="10.5" font-weight="600" fill="var(--mud-palette-text-primary)">{He(Trunc(_hoveredPoint.Title, 28))}</text>""")
                @* Epic / Feature *@
                @((MarkupString)$"""<text x="{F(ttX+8)}" y="{F(ttY+30)}" font-size="9" fill="var(--mud-palette-text-secondary)">{He(_hoveredPoint.EpicName ?? "No Epic")} · {He(_hoveredPoint.FeatureName ?? "No Feature")}</text>""")
                @* Lifetime *@
                @((MarkupString)$"""<text x="{F(ttX+8)}" y="{F(ttY+46)}" font-size="9" fill="var(--mud-palette-text-secondary)">⏱ {He(PrFormatHelpers.FormatLifetime(_hoveredPoint.LifetimeHours))} lifetime</text>""")
                @* Category *@
                @((MarkupString)$"""<text x="{F(ttX+8)}" y="{F(ttY+61)}" font-size="9" fill="var(--mud-palette-text-secondary)">Category: {He(_hoveredPoint.Category)}</text>""")
                @* Status chip *@
                <rect x="@F(ttX+8)" y="@F(ttY+72)"
                      width="@GetStatusChipW(_hoveredPoint.Status)" height="16" rx="8"
                      fill="@statusColor" opacity="0.18" />
                @((MarkupString)$"""<text x="{F(ttX+16)}" y="{F(ttY+84)}" font-size="9" font-weight="600" fill="{statusColor}">{He(PrFormatHelpers.FormatStatus(_hoveredPoint.Status))}</text>""")
            </g>
        }

        @* ── Empty state ───────────────────────────────────────────── *@
        @if (!Data.Any())
        {
            @((MarkupString)$"""<text x="{F(LeftPad + PlotWidth / 2)}" y="{F(TopPad + PlotHeight / 2)}" text-anchor="middle" font-size="12" fill="var(--mud-palette-text-disabled)">No PR data for the selected period</text>""")
        }
            </svg>
        </div>

        @* ── Legend ─────────────────────────────────────────────────── *@
        <aside class="pr-scatter-legend-panel" aria-label="PR lifetime scatter legend">
            <div class="pr-legend-section">
                <span class="pr-legend-title">Color → PR state</span>
                <span class="pr-legend-item pr-legend-completed">● @PrFormatHelpers.FormatStatus("completed")</span>
                <span class="pr-legend-item pr-legend-abandoned">● @PrFormatHelpers.FormatStatus("abandoned")</span>
                @if (Data.Any(p => string.Equals(p.Status, "active", StringComparison.OrdinalIgnoreCase)))
                {
                    <span class="pr-legend-item pr-legend-active">● @PrFormatHelpers.FormatStatus("active")</span>
                }
            </div>

            @if (_epicLegendItems.Count > 0)
            {
                <div class="pr-legend-section">
                    <span class="pr-legend-title">Shape → Epic</span>
                    @foreach (var item in _epicLegendItems)
                    {
                        var sym = item.Shape switch { "circle" => "●", "square" => "■", _ => "▲" };
                        <span class="pr-legend-item pr-legend-shape">@sym @item.Label</span>
                    }
                </div>
            }

            @if (ShowMedianLine && MedianLifetimeHours.HasValue || ShowP90Line && P90LifetimeHours.HasValue)
            {
                <div class="pr-legend-section">
                    <span class="pr-legend-title">Reference lines</span>
                    @if (ShowMedianLine && MedianLifetimeHours.HasValue)
                    {
                        <span class="pr-legend-item pr-legend-median">— Median lifetime</span>
                    }
                    @if (ShowP90Line && P90LifetimeHours.HasValue)
                    {
                        <span class="pr-legend-item pr-legend-p90">- - P90 lifetime</span>
                    }
                </div>
            }
        </aside>
    </div>
</div>

@code {
    // ── Chart geometry constants ────────────────────────────────────────
    private const double LeftPad   = 56;
    private const double RightPad  = 40;
    private const double TopPad    = 14;
    private const double BottomPad = 42;
    private const double PlotRight  = 820 - RightPad;
    private const double PlotBottom = 300 - BottomPad;
    private const double PlotWidth  = PlotRight - LeftPad;
    private const double PlotHeight = PlotBottom - TopPad;

    private static string L => F(LeftPad);
    private static string T => F(TopPad);

    // ── Parameters ───────────────────────────────────────────────────────

    /// <summary>PR delivery scatter data points.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<PrDeliveryScatterPointDto> Data { get; set; } = Array.Empty<PrDeliveryScatterPointDto>();

    /// <summary>Component display height in pixels (CSS max-height).</summary>
    [Parameter]
    public int Height { get; set; } = 340;

    /// <summary>Show the median lifetime overlay line.</summary>
    [Parameter]
    public bool ShowMedianLine { get; set; } = true;

    /// <summary>Show the P90 lifetime overlay line.</summary>
    [Parameter]
    public bool ShowP90Line { get; set; } = true;

    /// <summary>Median lifetime hours for overlay.</summary>
    [Parameter]
    public double? MedianLifetimeHours { get; set; }

    /// <summary>P90 lifetime hours for overlay.</summary>
    [Parameter]
    public double? P90LifetimeHours { get; set; }

    /// <summary>Fired when a data point is clicked.</summary>
    [Parameter]
    public EventCallback<PrDeliveryScatterPointDto> OnPointClick { get; set; }

    // ── Internal state ────────────────────────────────────────────────────
    private PrDeliveryScatterPointDto? _hoveredPoint;

    /// <summary>Maps (epicId?.ToString() ?? "none") → shape name.</summary>
    private Dictionary<string, string> _epicShapeMap = new();
    private List<(string Shape, string Label)> _epicLegendItems = new();

    private static readonly string[] Shapes = { "circle", "square", "triangle" };

    protected override void OnParametersSet()
    {
        // Build a stable epic → shape mapping based on first-seen order.
        _epicShapeMap = new Dictionary<string, string>();
        _epicLegendItems = new List<(string Shape, string Label)>();
        var legendKeys = new HashSet<string>(StringComparer.Ordinal);
        int idx = 0;
        foreach (var pt in Data)
        {
            var key = GetEpicKey(pt.EpicId);
            if (!_epicShapeMap.ContainsKey(key))
            {
                _epicShapeMap[key] = Shapes[idx % Shapes.Length];
                idx++;
            }

            if (pt.EpicId.HasValue &&
                !string.IsNullOrWhiteSpace(pt.EpicName) &&
                legendKeys.Add(key))
            {
                _epicLegendItems.Add((_epicShapeMap[key], pt.EpicName));
            }
        }
    }

    // ── Coordinate mapping ────────────────────────────────────────────────

    private double ToSvgX(DateTimeOffset t)
    {
        if (!Data.Any()) return LeftPad;
        var xMin = Data.Min(p => p.CreatedDate);
        var xMax = Data.Max(p => p.CreatedDate);
        var total = (xMax - xMin).TotalSeconds;
        if (total <= 0) return LeftPad + PlotWidth / 2;
        var ratio = Math.Clamp((t - xMin).TotalSeconds / total, 0.0, 1.0);
        return LeftPad + ratio * PlotWidth;
    }

    private double ToSvgY(double hours)
    {
        var yMax = GetYMax();
        if (yMax <= 0) return PlotBottom;
        var ratio = Math.Clamp(hours / yMax, 0.0, 1.0);
        return PlotBottom - ratio * PlotHeight;
    }

    // ── Axis helpers ──────────────────────────────────────────────────────

    private double GetYMax()
    {
        double dataMax = Data.Any(p => p.LifetimeHours > 0) ? Data.Max(p => p.LifetimeHours) : 24.0;
        double overlayMax = Math.Max(MedianLifetimeHours ?? 0, P90LifetimeHours ?? 0);
        return RoundUpNice(Math.Max(dataMax, overlayMax) * 1.15);
    }

    private static double RoundUpNice(double v)
    {
        if (v <= 0)    return 24;
        if (v <= 12)   return 12;
        if (v <= 24)   return 24;
        if (v <= 48)   return 48;
        if (v <= 72)   return 72;
        if (v <= 120)  return 120;
        if (v <= 168)  return 168;
        if (v <= 336)  return 336;
        if (v <= 720)  return 720;
        return Math.Ceiling(v / 168.0) * 168;
    }

    private record YTick(double Val, double Px);
    private record XTick(DateTimeOffset Time, double Px);

    private IEnumerable<YTick> GetYTicks()
    {
        var yMax = GetYMax();
        var step = GetYStep(yMax);
        for (double y = 0; y <= yMax; y += step)
            yield return new YTick(y, ToSvgY(y));
    }

    private static double GetYStep(double yMax) =>
        yMax <= 24  ? 6   :
        yMax <= 48  ? 12  :
        yMax <= 120 ? 24  :
        yMax <= 168 ? 24  :
        yMax <= 336 ? 48  :
        yMax <= 720 ? 120 : 168;

    private IEnumerable<XTick> GetXTicks()
    {
        if (!Data.Any()) yield break;
        var xMin = Data.Min(p => p.CreatedDate);
        var xMax = Data.Max(p => p.CreatedDate);
        var span = xMax - xMin;

        int everyDays = span.TotalDays <= 14  ? 2  :
                        span.TotalDays <= 31  ? 7  :
                        span.TotalDays <= 90  ? 14 :
                        span.TotalDays <= 182 ? 30 : 60;

        var day = xMin.Date.AddDays(1);
        while (day <= xMax.Date)
        {
            var dto = new DateTimeOffset(day, xMin.Offset);
            if ((dto - xMin).TotalDays % everyDays < 1.0 || everyDays == 1)
            {
                yield return new XTick(dto, ToSvgX(dto));
            }
            day = day.AddDays(1);
        }
    }

    private static string FormatYLabel(double h) =>
        h >= 168 ? $"{(int)(h / 168)}w" :
        h >= 24  ? $"{(int)(h / 24)}d"  :
                   $"{(int)h}h";

    private static string FormatXLabel(DateTimeOffset t) => t.ToString("MMM d");

    // ── Color + shape helpers ─────────────────────────────────────────────

    /// <summary>
    /// Color based on PR status:
    ///   completed → green (merged)
    ///   abandoned → red
    ///   active    → grey
    /// </summary>
    private static string GetStatusColor(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "completed" => "var(--mud-palette-success)",
            "abandoned" => "var(--mud-palette-error)",
            _           => "var(--mud-palette-text-secondary)"
        };
    }

    private string GetEpicShape(int? epicId)
    {
        var key = GetEpicKey(epicId);
        return _epicShapeMap.TryGetValue(key, out var shape) ? shape : "circle";
    }

    private static string GetEpicKey(int? epicId) => epicId?.ToString() ?? "none";

    // ── Tooltip helpers ───────────────────────────────────────────────────

    private static double GetStatusChipW(string status) =>
        status.ToLowerInvariant() switch
        {
            "completed" => 60,
            "abandoned" => 72,
            "active"    => 52,
            _           => 60
        };

    private static string Trunc(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";

    // ── SVG rendering utilities ───────────────────────────────────────────

    private static string F(double v) => v.ToString("F1", System.Globalization.CultureInfo.InvariantCulture);

    private static MarkupString Txt(double x, double y, string anchor, int size, string fill, string content)
        => (MarkupString)$"<text x=\"{F(x)}\" y=\"{F(y)}\" text-anchor=\"{anchor}\" font-size=\"{size}\" fill=\"{fill}\">{He(content)}</text>";

    private static string He(string s)
        => System.Net.WebUtility.HtmlEncode(s);

    // ── Event handlers ────────────────────────────────────────────────────

    private async Task HandlePointClick(PrDeliveryScatterPointDto pt)
    {
        if (OnPointClick.HasDelegate)
            await OnPointClick.InvokeAsync(pt);
    }
}
