@page "/workitems"
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Client.Configuration
@using PoTool.Client.Components.WorkItems.SubComponents
@using PoTool.Client.Components.Settings
@using PoTool.Client.Models
@inject WorkItemService WorkItemService
@inject IWorkItemSyncHubService SyncHubService
@inject ITreeBuilderService TreeBuilderService
@inject SettingsService SettingsService
@inject ModeIsolatedStateService StateService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject HttpClient Http
@inject IDialogService DialogService
@implements IAsyncDisposable

<PageTitle>Work Item Explorer</PageTitle>

<div class="workitem-explorer">
    <WorkItemToolbar ApiBase="@_apiBase"
                     HubUrl="@_hubUrl"
                     IsSyncing="@_isSyncing"
                     SyncMessage="@_syncMessage"
                     SyncStatusClass="@_syncStatusClass"
                     FilterText="@_filterText"
                     OnSyncRequested="@RequestSync"
                     OnClearState="@ClearExpandedState"
                     OnFilterChanged="@HandleFilterChanged"
                     OnSettingsRequested="@OpenSettings" />

    <div class="type-legend">
        <span class="legend-item"><span class="type-indicator" style="background-color: #4CAF50"></span> Goal</span>
        <span class="legend-item"><span class="type-indicator" style="background-color: #8BC34A"></span> Objective</span>
        <span class="legend-item"><span class="type-indicator" style="background-color: #FF9800"></span> Epic</span>
        <span class="legend-item"><span class="type-indicator" style="background-color: #9C27B0"></span> Feature</span>
        <span class="legend-item"><span class="type-indicator" style="background-color: #2196F3"></span> PBI</span>
        <span class="legend-item"><span class="type-indicator" style="background-color: #FFEB3B"></span> Task</span>
    </div>

    <div class="content">
        <WorkItemTreeView IsLoading="@_isLoading"
                          TreeRoots="@_treeRoots"
                          SelectedId="@_selectedWorkItem?.TfsId"
                          SelectedIds="@_selectedIds"
                          OnNodeToggled="@HandleNodeToggled"
                          OnNodeSelected="@HandleNodeSelected" />

        <WorkItemDetailPanel SelectedWorkItem="@_selectedWorkItem" 
                            SelectedWorkItems="@_selectedWorkItems" />
    </div>
</div>

@code {

    private List<WorkItemDto> _workItems = new();
    private List<WorkItemDto> _filteredWorkItems = new();
    private WorkItemDto? _selectedWorkItem;
    private List<WorkItemDto> _selectedWorkItems = new();
    private HashSet<int> _selectedIds = new();
    private string _filterText = string.Empty;
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string _syncMessage = string.Empty;
    private string _syncStatusClass = string.Empty;

    // Resolved endpoints for debugging
    private string _apiBase = string.Empty;
    private string _hubUrl = string.Empty;

    // Tree structure
    private List<TreeNode> _treeRoots = new();

    // Preserve expanded state across reloads and filters
    private readonly Dictionary<int, bool> _expandedState = new();

    protected override async Task OnInitializedAsync()
    {
        await InitializeSignalRAsync();
        await LoadExpandedStateAsync();
        await LoadWorkItems();
    }

    private async Task InitializeSignalRAsync()
    {
        _apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? NavigationManager.BaseUri.TrimEnd('/');
        _hubUrl = _apiBase + "/hubs/workitems";

        SyncHubService.OnSyncStatusChanged += HandleSyncStatus;

        try
        {
            await SyncHubService.StartAsync(_hubUrl);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error connecting to SignalR hub: {ex.Message}");
        }
    }

    private void HandleSyncStatus(string status, string message)
    {
        _syncMessage = message;
        _syncStatusClass = status switch
        {
            "InProgress" => "status-progress",
            "Completed" => "status-success",
            "Failed" => "status-error",
            _ => ""
        };

        _isSyncing = status == "InProgress";

        if (status == "Completed")
        {
            _ = LoadWorkItems();
        }

        StateHasChanged();
    }

    private async Task LoadWorkItems()
    {
        _isLoading = true;
        try
        {
            // Get current settings to determine which Goals to load
            var settings = await SettingsService.GetOrCreateDefaultSettingsAsync();
            StateService.SetMode(settings.DataMode);

            if (settings.ConfiguredGoalIds.Count > 0)
            {
                // Load hierarchy for configured Goals
                _workItems = (await WorkItemService.GetGoalHierarchyAsync(settings.ConfiguredGoalIds)).ToList();
            }
            else
            {
                // Fallback to loading all items if no Goals configured
                _workItems = (await WorkItemService.GetAllAsync()).ToList();
            }

            ApplyFilter();
            await SaveExpandedStateAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading work items: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RequestSync()
    {
        _syncMessage = string.Empty;

        if (SyncHubService.IsConnected)
        {
            _isSyncing = true;
            _syncMessage = "Requesting sync via SignalR...";
            _syncStatusClass = "status-progress";

            try
            {
                await SyncHubService.RequestSyncAsync(AppSettings.DefaultAreaPath);
                await Task.Delay(AppSettings.SyncDelayMilliseconds);
                await LoadWorkItems();
            }
            catch (Exception ex)
            {
                _syncMessage = $"Error requesting sync via SignalR: {ex.Message}";
                _syncStatusClass = "status-error";
            }
            finally
            {
                _isSyncing = false;
            }
            return;
        }

        // Fallback: call API endpoint to trigger sync
        try
        {
            _isSyncing = true;
            _syncMessage = "Requesting sync via HTTP...";
            _syncStatusClass = "status-progress";

            var resp = await Http.PostAsync(_apiBase + "/api/workitems/sync", null);
            if (resp.IsSuccessStatusCode)
            {
                await LoadWorkItems();
                _syncMessage = "Sync completed (HTTP)";
                _syncStatusClass = "status-success";
            }
            else
            {
                _syncMessage = $"Sync request failed (HTTP): {resp.StatusCode}";
                _syncStatusClass = "status-error";
            }
        }
        catch (Exception ex)
        {
            _syncMessage = $"Error requesting sync (HTTP): {ex.Message}";
            _syncStatusClass = "status-error";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void HandleFilterChanged(string filterText)
    {
        _filterText = filterText;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        _filteredWorkItems = TreeBuilderService.FilterWithAncestors(_workItems, _filterText);
        _treeRoots = TreeBuilderService.BuildTree(_filteredWorkItems, _expandedState);
        StateHasChanged();
    }

    private async Task HandleNodeToggled(TreeNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        _expandedState[node.Id] = node.IsExpanded;
        await SaveExpandedStateAsync();
        StateHasChanged();
    }

    private void HandleNodeSelected(TreeNode node)
    {
        // Deserialize the work item from JSON payload
        if (!string.IsNullOrEmpty(node.JsonPayload))
        {
            var workItem = System.Text.Json.JsonSerializer.Deserialize<WorkItemDto>(node.JsonPayload);
            if (workItem != null)
            {
                // Toggle selection: if already selected, add/remove from multi-selection
                if (_selectedIds.Contains(node.Id))
                {
                    _selectedIds.Remove(node.Id);
                    _selectedWorkItems.RemoveAll(w => w.TfsId == node.Id);
                }
                else
                {
                    _selectedIds.Add(node.Id);
                    _selectedWorkItems.Add(workItem);
                }

                // Update single selection to last clicked item
                _selectedWorkItem = workItem;
                
                // If only one item selected, use single-item view
                if (_selectedIds.Count == 1)
                {
                    _selectedWorkItems.Clear();
                    _selectedWorkItems.Add(workItem);
                }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        SyncHubService.OnSyncStatusChanged -= HandleSyncStatus;
        await SyncHubService.DisposeAsync();
    }



    private async Task LoadExpandedStateAsync()
    {
        _expandedState.Clear();
        var loadedState = await StateService.LoadExpandedStateAsync();
        foreach (var kv in loadedState)
        {
            _expandedState[kv.Key] = kv.Value;
        }
    }

    private async Task SaveExpandedStateAsync()
    {
        await StateService.SaveExpandedStateAsync(_expandedState);
    }

    private async Task ClearExpandedState()
    {
        _expandedState.Clear();
        await SaveExpandedStateAsync();
        ApplyFilter();
    }

    private async Task OpenSettings()
    {
        var parameters = new DialogParameters
        {
            { "OnSettingsSaved", EventCallback.Factory.Create(this, HandleSettingsSaved) }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<AppSettingsDialog>("Settings", parameters, options);
    }

    private async Task HandleSettingsSaved()
    {
        // Reload work items after settings change
        await LoadWorkItems();
    }
}
