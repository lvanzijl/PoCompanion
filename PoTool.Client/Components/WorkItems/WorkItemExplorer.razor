@page "/workitems"
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Client.Configuration
@using PoTool.Client.Components.WorkItems.SubComponents
@using PoTool.Client.Components.Common
@using MudBlazor
@inject WorkItemService WorkItemService
@inject IWorkItemSyncHubService SyncHubService
@inject ITreeBuilderService TreeBuilderService
@inject WorkItemFilteringService FilteringService
@inject WorkItemSelectionService SelectionService
@inject ProfileService ProfileService
@inject TfsConfigService TfsConfigService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ErrorMessageService ErrorMessageService
@implements IAsyncDisposable

<PageTitle>Work Item Explorer</PageTitle>

<div class="workitem-explorer">
    <WorkItemToolbar ApiBase="@_apiBase"
                     HubUrl="@_hubUrl"
                     IsSyncing="@_isSyncing"
                     SyncMessage="@_syncMessage"
                     SyncStatusClass="@_syncStatusClass"
                     FilterText="@_filterText"
                     ValidationFilters="@_validationFilters"
                     LastSyncTime="@_lastSyncTime"
                     SelectedCount="@_selectedIds.Count"
                     SelectedWorkItems="@_selectedWorkItems"
                     OnSyncRequested="@RequestSync"
                     OnIncrementalSyncRequested="@RequestIncrementalSync"
                     OnClearState="@ClearExpandedState"
                     OnFilterChanged="@HandleFilterChanged"
                     OnValidationFiltersChanged="@HandleValidationFiltersChanged"
                     OnSelectAll="@SelectAllItems"
                     OnClearSelection="@ClearSelection" />

    <ErrorDisplay ErrorResponse="@_errorResponse" 
                  Class="mx-4 mt-2"
                  OnDismiss="ClearError" />

    <ValidationSummaryPanel WorkItemsWithValidation="@_workItemsWithValidation" 
                           InitiallyExpanded="false"
                           OnFixesApplied="HandleFixesApplied" />

    <ValidationHistoryPanel InitiallyExpanded="false" />

    @if (_profileGoals.Count > 1)
    {
        <div class="goal-filter-panel mx-4 mt-2">
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Class="mr-1" />
                    Goal Filter (within profile)
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                    Select specific goals from your profile to focus on
                </MudText>
                <MudSelect T="int" 
                           Label="Select Goals" 
                           MultiSelection="true" 
                           SelectedValues="_selectedGoalIdsTyped"
                           SelectedValuesChanged="HandleGoalSelectionChanged"
                           Dense="true">
                    @foreach (var goal in _profileGoals)
                    {
                        <MudSelectItem T="int" Value="@goal.TfsId">@goal.Title</MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </div>
    }

    <div class="type-legend">
        @foreach (var type in WorkItemTypeHelper.AllTypes)
        {
            <span class="legend-item">
                <span class="type-indicator" style="background-color: @WorkItemTypeHelper.GetColor(type)"></span>
                @type
            </span>
        }
    </div>

    <div class="content" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="true" tabindex="0" role="tree" aria-label="Work item hierarchy tree">
        <WorkItemTreeGrid IsLoading="@_isLoading"
                          TreeRoots="@_treeRoots"
                          SelectedId="@_selectedWorkItem?.TfsId"
                          SelectedIds="@_selectedIds"
                          OnNodeToggled="@HandleNodeToggled"
                          OnNodeSelectedWithModifiers="@HandleNodeSelectedWithModifiers"
                          OnRevealInvalidItem="@HandleRevealInvalidItem" />

        <WorkItemDetailPanel SelectedWorkItem="@_selectedWorkItem" 
                            SelectedWorkItems="@_selectedWorkItems"
                            ValidationIssues="@_selectedValidationIssues" />
    </div>
</div>

@code {

    private List<WorkItemDto> _workItems = new();
    private List<WorkItemWithValidationDto> _workItemsWithValidation = new();
    private List<WorkItemDto> _filteredWorkItems = new();
    private WorkItemDto? _selectedWorkItem;
    private readonly List<WorkItemDto> _selectedWorkItems = new();
    private readonly HashSet<int> _selectedIds = new();
    private List<string> _selectedValidationIssues = new();
    private string _filterText = string.Empty;
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string _syncMessage = string.Empty;
    private string _syncStatusClass = string.Empty;
    private DateTimeOffset? _lastSyncTime;

    // Error display
    private ErrorResponse? _errorResponse;

    // Validation filters
    private readonly List<ValidationFilter> _validationFilters = new()
    {
        new ValidationFilter { Id = "parentProgress", Label = "Parent Progress Issues", IsEnabled = false, Count = 0 },
        new ValidationFilter { Id = "missingEffort", Label = "Missing Effort Issues", IsEnabled = false, Count = 0 }
    };

    // Profile goal filtering
    private List<WorkItemDto> _profileGoals = new();
    private IEnumerable<int> _selectedGoalIdsTyped = new HashSet<int>();
    private List<int> _profileGoalIds = new();

    // Resolved endpoints for debugging
    private string _apiBase = string.Empty;
    private string _hubUrl = string.Empty;

    // Tree structure
    private List<TreeNode> _treeRoots = new();
    private List<TreeNode> _flatNodeList = new(); // Flat list for keyboard navigation

    // Preserve expanded state across reloads and filters
    private readonly Dictionary<int, bool> _expandedState = new();
    
    // Selection service state
    private WorkItemSelectionService.SelectionState _selectionState = new();

    protected override async Task OnInitializedAsync()
    {
        await InitializeSignalRAsync();
        await LoadExpandedStateAsync();
        await LoadLastSyncTimeAsync();
        await LoadWorkItems();
    }

    private async Task LoadLastSyncTimeAsync()
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            _lastSyncTime = config?.LastValidated;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading last sync time: {ex.Message}");
        }
    }

    private async Task InitializeSignalRAsync()
    {
        _apiBase = NavigationManager.BaseUri.TrimEnd('/');
        _hubUrl = _apiBase + "/hubs/workitems";

        SyncHubService.OnSyncStatusChanged += HandleSyncStatus;

        try
        {
            await SyncHubService.StartAsync(_hubUrl);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error connecting to SignalR hub: {ex.Message}");
        }
    }

    private void HandleSyncStatus(string status, string message)
    {
        _syncMessage = message;
        _syncStatusClass = status switch
        {
            "InProgress" => "status-progress",
            "Completed" => "status-success",
            "Failed" => "status-error",
            _ => ""
        };

        _isSyncing = status == "InProgress";

        if (status == "Completed")
        {
            _ = LoadWorkItems();
        }

        StateHasChanged();
    }

    private async Task LoadWorkItems()
    {
        _isLoading = true;
        try
        {
            // Get active profile to determine which goals to load
            var activeProfile = await ProfileService.GetActiveProfileAsync();

            // Load hierarchy with validation - get all first
            var allWorkItems = (await WorkItemService.GetAllWithValidationAsync()).ToList();
            Console.WriteLine($"[WorkItemExplorer] Loaded {allWorkItems.Count} total work items");
            
            // Then filter by profile goals if configured
            if (activeProfile != null && activeProfile.GoalIds.Any())
            {
                _profileGoalIds = activeProfile.GoalIds.ToList();
                Console.WriteLine($"[WorkItemExplorer] Active profile goal IDs: {string.Join(", ", _profileGoalIds)}");
                
                // Load goal details for the filter UI
                _profileGoals = allWorkItems
                    .Where(wi => _profileGoalIds.Contains(wi.TfsId) && wi.Type == "Goal")
                    .Select(wi => new WorkItemDto 
                    { 
                        TfsId = wi.TfsId, 
                        Title = wi.Title, 
                        Type = wi.Type,
                        State = wi.State,
                        ParentTfsId = wi.ParentTfsId,
                        AreaPath = wi.AreaPath,
                        IterationPath = wi.IterationPath,
                        JsonPayload = wi.JsonPayload,
                        RetrievedAt = wi.RetrievedAt,
                        Effort = wi.Effort
                    })
                    .ToList();
                
                // Initialize selected goals to all profile goals if not set
                if (!_selectedGoalIdsTyped.Any())
                {
                    _selectedGoalIdsTyped = _profileGoalIds.ToHashSet();
                }
                
                // Get the actual goal IDs to filter by (intersection of profile goals and selected goals)
                var activeGoalIds = _profileGoalIds
                    .Where(id => _selectedGoalIdsTyped.Contains(id))
                    .ToList();
                
                if (!activeGoalIds.Any())
                {
                    activeGoalIds = _profileGoalIds; // Fallback to all profile goals if none selected
                }
                
                // Use batch filtering - makes a single API call instead of N calls
                var filteredIds = await FilteringService.FilterByGoalsAsync(activeGoalIds);
                Console.WriteLine($"[WorkItemExplorer] Filtered to {filteredIds.Count} work items by goals");
                _workItemsWithValidation = allWorkItems.Where(wi => filteredIds.Contains(wi.TfsId)).ToList();
            }
            else
            {
                Console.WriteLine($"[WorkItemExplorer] No active profile or goals configured, showing all work items");
                _workItemsWithValidation = allWorkItems;
                _profileGoals.Clear();
                _selectedGoalIdsTyped = new HashSet<int>();
            }

            Console.WriteLine($"[WorkItemExplorer] Final work item count: {_workItemsWithValidation.Count}");
            await ApplyFilterAsync();
            await UpdateValidationFilterCountsAsync();
            await SaveExpandedStateAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading work items: {ex.Message}");
            Console.WriteLine($"[WorkItemExplorer] Stack trace: {ex.StackTrace}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RequestSync()
    {
        _syncMessage = string.Empty;

        if (SyncHubService.IsConnected)
        {
            _isSyncing = true;
            _syncMessage = "Requesting full sync via SignalR...";
            _syncStatusClass = "status-progress";

            try
            {
                await SyncHubService.RequestSyncAsync(AppSettings.DefaultAreaPath);
                await Task.Delay(AppSettings.SyncDelayMilliseconds);
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
            }
            catch (Exception ex)
            {
                _syncMessage = FormatTfsError("Error requesting sync via SignalR", ex);
                _syncStatusClass = "status-error";
                ShowTfsErrorSnackbar(ex);
            }
            finally
            {
                _isSyncing = false;
            }
            return;
        }

        // Fallback: call API endpoint to trigger sync
        try
        {
            _isSyncing = true;
            _syncMessage = "Requesting full sync via HTTP...";
            _syncStatusClass = "status-progress";

            var success = await TfsConfigService.RequestSyncAsync();
            if (success)
            {
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
                _syncMessage = "Full sync completed (HTTP)";
                _syncStatusClass = "status-success";
            }
            else
            {
                _syncMessage = "Sync request failed (HTTP)";
                _syncStatusClass = "status-error";
            }
        }
        catch (Exception ex)
        {
            _syncMessage = FormatTfsError("Error requesting sync", ex);
            _syncStatusClass = "status-error";
            ShowTfsErrorSnackbar(ex);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task RequestIncrementalSync()
    {
        _syncMessage = string.Empty;

        try
        {
            _isSyncing = true;
            _syncMessage = "Requesting incremental sync...";
            _syncStatusClass = "status-progress";

            // For incremental sync, we pass the last sync time to the API
            var success = await TfsConfigService.RequestIncrementalSyncAsync();
            if (success)
            {
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
                _syncMessage = "Incremental sync completed";
                _syncStatusClass = "status-success";
            }
            else
            {
                _syncMessage = "Incremental sync request failed";
                _syncStatusClass = "status-error";
            }
        }
        catch (Exception ex)
        {
            _syncMessage = FormatTfsError("Error requesting incremental sync", ex);
            _syncStatusClass = "status-error";
            ShowTfsErrorSnackbar(ex);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task HandleFilterChanged(string filterText)
    {
        _filterText = filterText;
        await ApplyFilterAsync();
    }

    private async Task HandleValidationFiltersChanged(List<ValidationFilter> filters)
    {
        await ApplyFilterAsync();
    }

    private async Task HandleGoalSelectionChanged(IEnumerable<int> selectedGoals)
    {
        _selectedGoalIdsTyped = selectedGoals;
        await LoadWorkItems();
    }

    private async Task ApplyFilterAsync()
    {
        // Get enabled filter IDs
        var enabledFilterIds = _validationFilters
            .Where(f => f.IsEnabled)
            .Select(f => f.Id);

        // Apply combined filtering using service
        var filteredItems = await FilteringService.ApplyCombinedFilterAsync(
            _workItemsWithValidation,
            _filterText,
            enabledFilterIds);

        _treeRoots = TreeBuilderService.BuildTreeWithValidation(filteredItems, _expandedState);
        _flatNodeList = SelectionService.BuildFlatNodeList(_treeRoots);
        StateHasChanged();
    }

    private async Task UpdateValidationFilterCountsAsync()
    {
        foreach (var filter in _validationFilters)
        {
            filter.Count = await FilteringService.CountWorkItemsByValidationFilterAsync(_workItemsWithValidation, filter.Id);
        }
    }

    private async Task HandleNodeToggled(TreeNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        _expandedState[node.Id] = node.IsExpanded;
        _flatNodeList = SelectionService.BuildFlatNodeList(_treeRoots);
        await SaveExpandedStateAsync();
        StateHasChanged();
    }

    private void HandleNodeSelected(TreeNode node, bool ctrlKey = false, bool shiftKey = false)
    {
        // Use selection service with modifier keys
        _selectionState = SelectionService.ToggleNodeSelection(node, _selectionState, ctrlKey, shiftKey);
        
        // Sync local state with service state
        SyncSelectionStateToLocal();
        _selectedValidationIssues = node.ValidationIssues;
    }
    
    private void HandleNodeSelectedWithModifiers((TreeNode Node, bool CtrlKey, bool ShiftKey) args)
    {
        HandleNodeSelected(args.Node, args.CtrlKey, args.ShiftKey);
    }

    private List<string> GetValidationIssuesForNode(int? tfsId)
    {
        if (!tfsId.HasValue) return new List<string>();
        
        var itemWithValidation = _workItemsWithValidation.FirstOrDefault(wi => wi.TfsId == tfsId.Value);
        if (itemWithValidation == null) return new List<string>();
        
        return itemWithValidation.ValidationIssues
            .Select(vi => $"{vi.Severity}: {vi.Message}")
            .ToList();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Handle Ctrl+A for Select All
        if (e.Key == "a" && e.CtrlKey)
        {
            SelectAllItems();
            return;
        }

        // Handle Escape for Clear Selection
        if (e.Key == "Escape")
        {
            ClearSelection();
            return;
        }

        // Use selection service for keyboard navigation
        var result = SelectionService.HandleKeyboardNavigation(e.Key, _selectionState, _flatNodeList);
        
        if (result.nodeToToggle != null && result.shouldToggle)
        {
            await HandleNodeToggled(result.nodeToToggle);
        }
        else if (result.newState != _selectionState)
        {
            _selectionState = result.newState;
            SyncSelectionStateToLocal();
        }

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        SyncHubService.OnSyncStatusChanged -= HandleSyncStatus;
        await SyncHubService.DisposeAsync();
    }



    private async Task LoadExpandedStateAsync()
    {
        try
        {
            _expandedState.Clear();
            var stateJson = await JS.InvokeAsync<string?>("localStorage.getItem", "workitem-expanded-state");
            if (!string.IsNullOrEmpty(stateJson))
            {
                var loadedState = System.Text.Json.JsonSerializer.Deserialize<Dictionary<int, bool>>(stateJson);
                if (loadedState != null)
                {
                    foreach (var kv in loadedState)
                    {
                        _expandedState[kv.Key] = kv.Value;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading expanded state: {ex.Message}");
        }
    }

    private async Task SaveExpandedStateAsync()
    {
        try
        {
            var stateJson = System.Text.Json.JsonSerializer.Serialize(_expandedState);
            await JS.InvokeVoidAsync("localStorage.setItem", "workitem-expanded-state", stateJson);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error saving expanded state: {ex.Message}");
        }
    }

    private async Task ClearExpandedState()
    {
        _expandedState.Clear();
        await SaveExpandedStateAsync();
        await ApplyFilterAsync();
    }

    private async Task HandleFixesApplied()
    {
        // Reload work items after fixes are applied
        Snackbar.Add("Reloading work items to reflect changes...", Severity.Info);
        await LoadWorkItems();
    }

    private string FormatTfsError(string context, Exception ex)
    {
        var errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        return errorResponse.UserMessage;
    }

    private void ShowTfsErrorSnackbar(Exception ex)
    {
        var severity = ex.Message.Contains("429") || ex.Message.ToLower().Contains("rate limit") ? Severity.Warning : Severity.Error;
        var errorResponse = ErrorMessageService.GetErrorResponse(ex, "TFS operation failed");
        Snackbar.Add(errorResponse.UserMessage, severity);
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private void SelectAllItems()
    {
        _selectionState = SelectionService.SelectAllNodes(_flatNodeList);
        SyncSelectionStateToLocal();
        _selectedValidationIssues = GetValidationIssuesForNode(_selectedWorkItem?.TfsId);
        StateHasChanged();
    }

    private void ClearSelection()
    {
        _selectionState = SelectionService.ClearSelection();
        SyncSelectionStateToLocal();
        _selectedValidationIssues = new List<string>();
        StateHasChanged();
    }
    
    private void SyncSelectionStateToLocal()
    {
        _selectedIds.Clear();
        foreach (var id in _selectionState.SelectedIds)
        {
            _selectedIds.Add(id);
        }
        
        _selectedWorkItems.Clear();
        _selectedWorkItems.AddRange(_selectionState.SelectedWorkItems);
        _selectedWorkItem = _selectionState.PrimarySelectedWorkItem;
    }

    private async Task HandleRevealInvalidItem(TreeNode node)
    {
        if (!node.HasDescendantIssues || node.InvalidDescendantIds.Count == 0)
        {
            return;
        }

        // Get the first invalid descendant ID
        var targetId = node.InvalidDescendantIds[0];

        // Build a map of all nodes for quick lookup (local to this operation)
        var nodeMap = new Dictionary<int, TreeNode>();
        foreach (var root in _treeRoots)
        {
            AddNodeToMap(root, nodeMap);
        }

        if (!nodeMap.TryGetValue(targetId, out var targetNode))
        {
            Snackbar.Add("Target node not found", Severity.Warning);
            return;
        }

        // Resolve the path to the target node
        var pathToTarget = new List<TreeNode>();
        var current = targetNode;
        while (current != null)
        {
            pathToTarget.Insert(0, current);
            if (current.ParentId.HasValue && nodeMap.TryGetValue(current.ParentId.Value, out var parent))
            {
                current = parent;
            }
            else
            {
                break;
            }
        }

        // Expand all nodes along the path
        foreach (var nodeOnPath in pathToTarget)
        {
            if (!nodeOnPath.IsExpanded)
            {
                nodeOnPath.IsExpanded = true;
                _expandedState[nodeOnPath.Id] = true;
            }
        }

        // Rebuild the flat list
        _flatNodeList = SelectionService.BuildFlatNodeList(_treeRoots);
        await SaveExpandedStateAsync();

        // Trigger state update
        StateHasChanged();

        // TODO: Scroll to target and highlight (requires JS interop)
        Snackbar.Add($"Revealed item: {targetNode.Title}", Severity.Info);
    }

    private void AddNodeToMap(TreeNode node, Dictionary<int, TreeNode> map)
    {
        map[node.Id] = node;
        foreach (var child in node.Children)
        {
            AddNodeToMap(child, map);
        }
    }
}
