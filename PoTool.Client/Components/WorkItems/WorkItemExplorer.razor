@page "/workitems"
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Client.Configuration
@using PoTool.Client.Components.WorkItems.SubComponents
@using PoTool.Client.Components.Settings
@using PoTool.Client.Components.Common
@using PoTool.Core.Exceptions
@inject WorkItemService WorkItemService
@inject IWorkItemSyncHubService SyncHubService
@inject ITreeBuilderService TreeBuilderService
@inject SettingsService SettingsService
@inject TfsConfigService TfsConfigService
@inject ModeIsolatedStateService StateService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ErrorMessageService ErrorMessageService
@implements IAsyncDisposable

<PageTitle>Work Item Explorer</PageTitle>

<div class="workitem-explorer">
    <WorkItemToolbar ApiBase="@_apiBase"
                     HubUrl="@_hubUrl"
                     IsSyncing="@_isSyncing"
                     SyncMessage="@_syncMessage"
                     SyncStatusClass="@_syncStatusClass"
                     FilterText="@_filterText"
                     ValidationFilters="@_validationFilters"
                     LastSyncTime="@_lastSyncTime"
                     OnSyncRequested="@RequestSync"
                     OnIncrementalSyncRequested="@RequestIncrementalSync"
                     OnClearState="@ClearExpandedState"
                     OnFilterChanged="@HandleFilterChanged"
                     OnValidationFiltersChanged="@HandleValidationFiltersChanged"
                     OnSettingsRequested="@OpenSettings" />

    <ErrorDisplay ErrorResponse="@_errorResponse" 
                  Class="mx-4 mt-2"
                  OnDismiss="ClearError" />

    <div class="type-legend">
        @foreach (var type in WorkItemTypeHelper.AllTypes)
        {
            <span class="legend-item">
                <span class="type-indicator" style="background-color: @WorkItemTypeHelper.GetColor(type)"></span>
                @type
            </span>
        }
    </div>

    <div class="content" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="true" tabindex="0" role="tree" aria-label="Work item hierarchy tree">
        <WorkItemTreeView IsLoading="@_isLoading"
                          TreeRoots="@_treeRoots"
                          SelectedId="@_selectedWorkItem?.TfsId"
                          SelectedIds="@_selectedIds"
                          OnNodeToggled="@HandleNodeToggled"
                          OnNodeSelected="@HandleNodeSelected" />

        <WorkItemDetailPanel SelectedWorkItem="@_selectedWorkItem" 
                            SelectedWorkItems="@_selectedWorkItems"
                            ValidationIssues="@_selectedValidationIssues" />
    </div>
</div>

@code {

    private List<WorkItemDto> _workItems = new();
    private List<WorkItemWithValidationDto> _workItemsWithValidation = new();
    private List<WorkItemDto> _filteredWorkItems = new();
    private WorkItemDto? _selectedWorkItem;
    private readonly List<WorkItemDto> _selectedWorkItems = new();
    private readonly HashSet<int> _selectedIds = new();
    private List<string> _selectedValidationIssues = new();
    private string _filterText = string.Empty;
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private string _syncMessage = string.Empty;
    private string _syncStatusClass = string.Empty;
    private DateTimeOffset? _lastSyncTime;

    // Error display
    private ErrorResponse? _errorResponse;

    // Validation filters
    private readonly List<ValidationFilter> _validationFilters = new()
    {
        new ValidationFilter { Id = "parentProgress", Label = "Parent Progress Issues", IsEnabled = false },
        new ValidationFilter { Id = "missingEffort", Label = "Missing Effort Issues", IsEnabled = false }
    };

    // Resolved endpoints for debugging
    private string _apiBase = string.Empty;
    private string _hubUrl = string.Empty;

    // Tree structure
    private List<TreeNode> _treeRoots = new();
    private readonly List<TreeNode> _flatNodeList = new(); // Flat list for keyboard navigation

    // Preserve expanded state across reloads and filters
    private readonly Dictionary<int, bool> _expandedState = new();

    protected override async Task OnInitializedAsync()
    {
        await InitializeSignalRAsync();
        await LoadExpandedStateAsync();
        await LoadLastSyncTimeAsync();
        await LoadWorkItems();
    }

    private async Task LoadLastSyncTimeAsync()
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            _lastSyncTime = config?.LastValidated;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading last sync time: {ex.Message}");
        }
    }

    private async Task InitializeSignalRAsync()
    {
        _apiBase = NavigationManager.BaseUri.TrimEnd('/');
        _hubUrl = _apiBase + "/hubs/workitems";

        SyncHubService.OnSyncStatusChanged += HandleSyncStatus;

        try
        {
            await SyncHubService.StartAsync(_hubUrl);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error connecting to SignalR hub: {ex.Message}");
        }
    }

    private void HandleSyncStatus(string status, string message)
    {
        _syncMessage = message;
        _syncStatusClass = status switch
        {
            "InProgress" => "status-progress",
            "Completed" => "status-success",
            "Failed" => "status-error",
            _ => ""
        };

        _isSyncing = status == "InProgress";

        if (status == "Completed")
        {
            _ = LoadWorkItems();
        }

        StateHasChanged();
    }

    private async Task LoadWorkItems()
    {
        _isLoading = true;
        try
        {
            // Get current settings to determine which Goals to load
            var settings = await SettingsService.GetOrCreateDefaultSettingsAsync();
            StateService.SetMode(settings.DataMode);

            // Load hierarchy with validation
            var goalIds = settings.ConfiguredGoalIds.ToList();
            _workItemsWithValidation = goalIds.Count > 0
                ? (await WorkItemService.GetAllWithValidationAsync()).Where(wi => 
                    goalIds.Contains(wi.TfsId) || 
                    IsDescendantOfGoals(wi, goalIds)).ToList()
                : (await WorkItemService.GetAllWithValidationAsync()).ToList();

            ApplyFilter();
            await SaveExpandedStateAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[WorkItemExplorer] Error loading work items: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private bool IsDescendantOfGoals(WorkItemWithValidationDto item, List<int> goalIds)
    {
        if (goalIds == null || goalIds.Count == 0)
            return true;

        // Check if this item is itself a goal
        if (goalIds.Contains(item.TfsId))
            return true;

        // Create lookup dictionary for efficient parent traversal
        var itemLookup = _workItemsWithValidation.ToDictionary(wi => wi.TfsId);

        // Traverse up the parent chain to see if any ancestor is a configured goal
        var current = item;
        while (current.ParentTfsId.HasValue)
        {
            if (goalIds.Contains(current.ParentTfsId.Value))
                return true;

            // Find parent in lookup dictionary
            if (!itemLookup.TryGetValue(current.ParentTfsId.Value, out current))
                break;
        }

        return false;
    }

    private async Task RequestSync()
    {
        _syncMessage = string.Empty;

        if (SyncHubService.IsConnected)
        {
            _isSyncing = true;
            _syncMessage = "Requesting full sync via SignalR...";
            _syncStatusClass = "status-progress";

            try
            {
                await SyncHubService.RequestSyncAsync(AppSettings.DefaultAreaPath);
                await Task.Delay(AppSettings.SyncDelayMilliseconds);
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
            }
            catch (Exception ex)
            {
                _syncMessage = FormatTfsError("Error requesting sync via SignalR", ex);
                _syncStatusClass = "status-error";
                ShowTfsErrorSnackbar(ex);
            }
            finally
            {
                _isSyncing = false;
            }
            return;
        }

        // Fallback: call API endpoint to trigger sync
        try
        {
            _isSyncing = true;
            _syncMessage = "Requesting full sync via HTTP...";
            _syncStatusClass = "status-progress";

            var success = await TfsConfigService.RequestSyncAsync();
            if (success)
            {
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
                _syncMessage = "Full sync completed (HTTP)";
                _syncStatusClass = "status-success";
            }
            else
            {
                _syncMessage = "Sync request failed (HTTP)";
                _syncStatusClass = "status-error";
            }
        }
        catch (Exception ex)
        {
            _syncMessage = FormatTfsError("Error requesting sync", ex);
            _syncStatusClass = "status-error";
            ShowTfsErrorSnackbar(ex);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task RequestIncrementalSync()
    {
        _syncMessage = string.Empty;

        try
        {
            _isSyncing = true;
            _syncMessage = "Requesting incremental sync...";
            _syncStatusClass = "status-progress";

            // For incremental sync, we pass the last sync time to the API
            var success = await TfsConfigService.RequestIncrementalSyncAsync();
            if (success)
            {
                await LoadWorkItems();
                await LoadLastSyncTimeAsync();
                _syncMessage = "Incremental sync completed";
                _syncStatusClass = "status-success";
            }
            else
            {
                _syncMessage = "Incremental sync request failed";
                _syncStatusClass = "status-error";
            }
        }
        catch (Exception ex)
        {
            _syncMessage = FormatTfsError("Error requesting incremental sync", ex);
            _syncStatusClass = "status-error";
            ShowTfsErrorSnackbar(ex);
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void HandleFilterChanged(string filterText)
    {
        _filterText = filterText;
        ApplyFilter();
    }

    private void HandleValidationFiltersChanged(List<ValidationFilter> filters)
    {
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        // Apply text filter and validation filters together
        var filteredItems = _workItemsWithValidation.AsEnumerable();

        // Filter by validation issues if any filters are enabled (OR logic)
        var enabledFilters = _validationFilters.Where(f => f.IsEnabled).ToList();
        if (enabledFilters.Any())
        {
            var invalidIds = new HashSet<int>();
            
            foreach (var filter in enabledFilters)
            {
                IEnumerable<int> filterInvalidIds = filter.Id switch
                {
                    "parentProgress" => _workItemsWithValidation
                        .Where(wi => wi.ValidationIssues.Any(issue => 
                            issue.Message.Contains("Parent") || issue.Message.Contains("Ancestor")))
                        .Select(wi => wi.TfsId),
                    "missingEffort" => _workItemsWithValidation
                        .Where(wi => wi.ValidationIssues.Any(issue => 
                            issue.Message.Contains("effort")))
                        .Select(wi => wi.TfsId),
                    _ => Enumerable.Empty<int>()
                };
                
                foreach (var id in filterInvalidIds)
                {
                    invalidIds.Add(id);
                }
            }

            // Include invalid items and their ancestors
            filteredItems = FilterWithAncestorsValidation(filteredItems, invalidIds);
        }

        // Then apply text filter if present
        if (!string.IsNullOrWhiteSpace(_filterText))
        {
            filteredItems = TreeBuilderService.FilterWithAncestors(
                filteredItems.Select(ConvertToWorkItemDto).ToList(), 
                _filterText
            ).Select(dto => _workItemsWithValidation.First(wi => wi.TfsId == dto.TfsId));
        }

        _treeRoots = TreeBuilderService.BuildTreeWithValidation(filteredItems, _expandedState);
        RebuildFlatNodeListFromTree();
        StateHasChanged();
    }

    private IEnumerable<WorkItemWithValidationDto> FilterWithAncestorsValidation(
        IEnumerable<WorkItemWithValidationDto> items, 
        HashSet<int> targetIds)
    {
        var itemsList = items.ToList();
        var itemLookup = itemsList.ToDictionary(w => w.TfsId);
        var toInclude = new Dictionary<int, WorkItemWithValidationDto>();

        foreach (var targetId in targetIds)
        {
            if (!itemLookup.TryGetValue(targetId, out var item))
                continue;

            // Include the target item
            if (!toInclude.ContainsKey(item.TfsId))
            {
                toInclude[item.TfsId] = item;
            }

            // Include all ancestors
            var current = item;
            while (current.ParentTfsId.HasValue)
            {
                var parentId = current.ParentTfsId.Value;
                if (itemLookup.TryGetValue(parentId, out var parent))
                {
                    if (!toInclude.ContainsKey(parent.TfsId))
                    {
                        toInclude[parent.TfsId] = parent;
                    }
                    current = parent;
                }
                else
                {
                    break;
                }
            }
        }

        return toInclude.Values.ToList();
    }

    private WorkItemDto ConvertToWorkItemDto(WorkItemWithValidationDto item)
    {
        return new WorkItemDto
        {
            TfsId = item.TfsId,
            Type = item.Type,
            Title = item.Title,
            ParentTfsId = item.ParentTfsId,
            AreaPath = item.AreaPath,
            IterationPath = item.IterationPath,
            State = item.State,
            JsonPayload = item.JsonPayload,
            RetrievedAt = item.RetrievedAt,
            Effort = item.Effort
        };
    }

    private void RebuildFlatNodeListFromTree()
    {
        _flatNodeList.Clear();
        foreach (var root in _treeRoots)
        {
            AddNodeToFlatList(root);
        }
    }

    private void AddNodeToFlatList(TreeNode node)
    {
        _flatNodeList.Add(node);
        if (node.IsExpanded)
        {
            foreach (var child in node.Children)
            {
                AddNodeToFlatList(child);
            }
        }
    }

    private async Task HandleNodeToggled(TreeNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        _expandedState[node.Id] = node.IsExpanded;
        await SaveExpandedStateAsync();
        StateHasChanged();
    }

    private void HandleNodeSelected(TreeNode node)
    {
        // Deserialize the work item from JSON payload
        if (!string.IsNullOrEmpty(node.JsonPayload))
        {
            var workItem = System.Text.Json.JsonSerializer.Deserialize<WorkItemDto>(node.JsonPayload);
            if (workItem != null)
            {
                // Toggle selection: if already selected, remove from multi-selection
                if (_selectedIds.Contains(node.Id))
                {
                    _selectedIds.Remove(node.Id);
                    _selectedWorkItems.RemoveAll(w => w.TfsId == node.Id);
                    
                    // Update single selection to first remaining item or null
                    _selectedWorkItem = _selectedWorkItems.FirstOrDefault();
                    _selectedValidationIssues = GetValidationIssuesForNode(_selectedWorkItem?.TfsId);
                }
                else
                {
                    _selectedIds.Add(node.Id);
                    if (!_selectedWorkItems.Any(w => w.TfsId == node.Id))
                    {
                        _selectedWorkItems.Add(workItem);
                    }
                    
                    // Update single selection to last clicked item
                    _selectedWorkItem = workItem;
                    _selectedValidationIssues = node.ValidationIssues;
                }
            }
        }
    }

    private List<string> GetValidationIssuesForNode(int? tfsId)
    {
        if (!tfsId.HasValue) return new List<string>();
        
        var itemWithValidation = _workItemsWithValidation.FirstOrDefault(wi => wi.TfsId == tfsId.Value);
        if (itemWithValidation == null) return new List<string>();
        
        return itemWithValidation.ValidationIssues
            .Select(vi => $"{vi.Severity}: {vi.Message}")
            .ToList();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (_flatNodeList.Count == 0) return;

        var currentIndex = -1;
        if (_selectedWorkItem != null)
        {
            currentIndex = _flatNodeList.FindIndex(n => n.Id == _selectedWorkItem.TfsId);
        }

        switch (e.Key)
        {
            case "ArrowDown":
                if (currentIndex < _flatNodeList.Count - 1)
                {
                    var nextNode = _flatNodeList[currentIndex + 1];
                    HandleNodeSelected(nextNode);
                }
                break;

            case "ArrowUp":
                if (currentIndex > 0)
                {
                    var prevNode = _flatNodeList[currentIndex - 1];
                    HandleNodeSelected(prevNode);
                }
                else if (currentIndex == -1 && _flatNodeList.Count > 0)
                {
                    HandleNodeSelected(_flatNodeList[0]);
                }
                break;

            case "ArrowRight":
                if (currentIndex >= 0)
                {
                    var node = _flatNodeList[currentIndex];
                    if (node.Children.Any() && !node.IsExpanded)
                    {
                        await HandleNodeToggled(node);
                    }
                }
                break;

            case "ArrowLeft":
                if (currentIndex >= 0)
                {
                    var node = _flatNodeList[currentIndex];
                    if (node.Children.Any() && node.IsExpanded)
                    {
                        await HandleNodeToggled(node);
                    }
                }
                break;

            case "Enter":
            case " ":
                if (currentIndex >= 0)
                {
                    var node = _flatNodeList[currentIndex];
                    if (node.Children.Any())
                    {
                        await HandleNodeToggled(node);
                    }
                }
                break;
        }

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        SyncHubService.OnSyncStatusChanged -= HandleSyncStatus;
        await SyncHubService.DisposeAsync();
    }



    private async Task LoadExpandedStateAsync()
    {
        _expandedState.Clear();
        var loadedState = await StateService.LoadExpandedStateAsync();
        foreach (var kv in loadedState)
        {
            _expandedState[kv.Key] = kv.Value;
        }
    }

    private async Task SaveExpandedStateAsync()
    {
        await StateService.SaveExpandedStateAsync(_expandedState);
    }

    private async Task ClearExpandedState()
    {
        _expandedState.Clear();
        await SaveExpandedStateAsync();
        ApplyFilter();
    }

    private async Task OpenSettings()
    {
        var parameters = new DialogParameters
        {
            { "OnSettingsSaved", EventCallback.Factory.Create(this, HandleSettingsSaved) }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<AppSettingsDialog>("Settings", parameters, options);
    }

    private async Task HandleSettingsSaved()
    {
        // Reload work items after settings change
        await LoadWorkItems();
    }

    private string FormatTfsError(string context, Exception ex)
    {
        var errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        return errorResponse.UserMessage;
    }

    private void ShowTfsErrorSnackbar(Exception ex)
    {
        var severity = ex is TfsRateLimitException ? Severity.Warning : Severity.Error;
        var errorResponse = ErrorMessageService.GetErrorResponse(ex, "TFS operation failed");
        Snackbar.Add(errorResponse.UserMessage, severity);
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }
}
