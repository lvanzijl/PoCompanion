@using PoTool.Client.ApiClient
@inject IWorkItemsClient WorkItemsClient
@inject ISnackbar Snackbar

@* Validation Summary Panel - shows overall data quality *@

@if (WorkItemsWithValidation != null && WorkItemsWithValidation.Any())
{
    var totalItems = WorkItemsWithValidation.Count();
    var itemsWithIssues = WorkItemsWithValidation.Count(wi => wi.ValidationIssues.Any());
    var totalIssues = WorkItemsWithValidation.Sum(wi => wi.ValidationIssues.Count);
    var errorCount = WorkItemsWithValidation.Sum(wi => wi.ValidationIssues.Count(issue => issue.Severity.Equals("Error", StringComparison.OrdinalIgnoreCase)));
    var warningCount = WorkItemsWithValidation.Sum(wi => wi.ValidationIssues.Count(issue => issue.Severity.Equals("Warning", StringComparison.OrdinalIgnoreCase)));

    <MudPaper Elevation="2" Class="pa-4 mb-4 mx-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Rule" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Data Quality Summary</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                @if (errorCount > 0 && !_isProcessingFixes)
                {
                    <MudTooltip Text="Analyze and fix validation issues automatically">
                        <CompactButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                   OnClick="ShowImpactAnalysisAsync">
                            Fix Issues
                        </CompactButton>
                    </MudTooltip>
                }
                @if (_isProcessingFixes)
                {
                    <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                }
                @if (IsExpanded)
                {
                    <CompactIconButton Icon="@Icons.Material.Filled.ExpandLess" 
                                   OnClick="@(() => IsExpanded = false)" />
                }
                else
                {
                    <CompactIconButton Icon="@Icons.Material.Filled.ExpandMore" 
                                   OnClick="@(() => IsExpanded = true)" />
                }
            </MudStack>
        </MudStack>

        @if (IsExpanded)
        {
            <MudDivider Class="my-3" />
            
            <MudGrid>
                <!-- Overall Health -->
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@GetHealthIcon(itemsWithIssues, totalItems)" 
                                        Color="@GetHealthColor(itemsWithIssues, totalItems)" 
                                        Size="Size.Large" />
                                <MudText Typo="Typo.h4">@GetHealthPercentage(itemsWithIssues, totalItems)%</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Data Quality Score
                                </MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    @(totalItems - itemsWithIssues) of @totalItems items are valid
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Error Count -->
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Error" 
                                        Color="Color.Error" 
                                        Size="Size.Large" />
                                <MudText Typo="Typo.h4">@errorCount</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Errors
                                </MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    Critical issues
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Warning Count -->
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" 
                                        Color="Color.Warning" 
                                        Size="Size.Large" />
                                <MudText Typo="Typo.h4">@warningCount</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Warnings
                                </MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    Recommended fixes
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Items with Issues -->
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" 
                                        Color="Color.Info" 
                                        Size="Size.Large" />
                                <MudText Typo="Typo.h4">@itemsWithIssues</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Items Need Attention
                                </MudText>
                                <MudText Typo="Typo.body2" Align="Align.Center">
                                    Out of @totalItems items
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <!-- Common Issues -->
            @if (totalIssues > 0)
            {
                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">Common Issues:</MudText>
                <MudStack Spacing="1">
                    @if (errorCount > 0)
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Icon="@Icons.Material.Filled.Error">
                            <strong>@errorCount error(s):</strong> Critical data quality issues that should be fixed immediately
                        </MudAlert>
                    }
                    @if (warningCount > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Icon="@Icons.Material.Filled.Warning">
                            <strong>@warningCount warning(s):</strong> Recommended improvements for better data quality
                        </MudAlert>
                    }
                </MudStack>

                @if (_impactAnalysis != null)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Impact Analysis:</MudText>
                    <MudCard Outlined="true" Class="mb-3">
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" Spacing="3">
                                    <MudChip T="string" Icon="@Icons.Material.Filled.Block" Color="Color.Error" Size="Size.Small">
                                        @_impactAnalysis.TotalBlockedItems Blocked Items
                                    </MudChip>
                                    <MudChip T="string" Icon="@Icons.Material.Filled.AccountTree" Color="Color.Warning" Size="Size.Small">
                                        @_impactAnalysis.TotalAffectedHierarchies Affected Hierarchies
                                    </MudChip>
                                </MudStack>

                                @if (_impactAnalysis.Recommendations.Any())
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-2">Recommendations:</MudText>
                                    @foreach (var recommendation in _impactAnalysis.Recommendations.OrderBy(r => r.Priority))
                                    {
                                        <MudAlert Severity="Severity.Info" Dense="true" Icon="@Icons.Material.Filled.Lightbulb">
                                            <strong>@recommendation.RecommendationType:</strong> @recommendation.Description
                                        </MudAlert>

                                        @if (recommendation.RecommendationType == "SetParentsToInProgress" && recommendation.AffectedWorkItemIds.Any())
                                        {
                                            <CompactButton Variant="Variant.Filled" 
                                                       Color="Color.Success" 
                                                       StartIcon="@Icons.Material.Filled.PlayArrow"
                                                       OnClick="@(() => ApplyFixesAsync(recommendation.AffectedWorkItemIds.ToList()))"
                                                       Disabled="@_isProcessingFixes"
                                                       Class="ml-4">
                                                Apply Fix (@recommendation.AffectedWorkItemIds.Count items)
                                            </CompactButton>
                                        }
                                    }
                                }
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }

                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-3">
                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" />
                    Tip: Click on individual work items to see specific validation issues and recommendations
                </MudText>
            }
            else
            {
                <MudDivider Class="my-3" />
                <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle">
                    Excellent! All work items have valid data. Your metrics and reports will be accurate.
                </MudAlert>
            }
        }
        else
        {
            <!-- Compact View -->
            <MudStack Row="true" Spacing="3" Class="mt-2" Justify="Justify.SpaceAround">
                <MudChip T="string" Icon="@GetHealthIcon(itemsWithIssues, totalItems)" 
                        Color="@GetHealthColor(itemsWithIssues, totalItems)" 
                        Size="Size.Small">
                    @GetHealthPercentage(itemsWithIssues, totalItems)% Valid
                </MudChip>
                @if (errorCount > 0)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small">
                        @errorCount Errors
                    </MudChip>
                }
                @if (warningCount > 0)
                {
                    <MudChip T="string" Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small">
                        @warningCount Warnings
                    </MudChip>
                }
            </MudStack>
        }
    </MudPaper>
}

@code {
    [Parameter]
    public List<WorkItemWithValidationDto>? WorkItemsWithValidation { get; set; }

    [Parameter]
    public bool InitiallyExpanded { get; set; } = false;

    [Parameter]
    public EventCallback OnFixesApplied { get; set; }

    private bool IsExpanded { get; set; }
    private ValidationImpactAnalysisDto? _impactAnalysis;
    private bool _isProcessingFixes;

    protected override void OnInitialized()
    {
        IsExpanded = InitiallyExpanded;
    }

    private async Task ShowImpactAnalysisAsync()
    {
        try
        {
            _isProcessingFixes = true;
            StateHasChanged();

            _impactAnalysis = await WorkItemsClient.GetValidationImpactAnalysisAsync(null, null);
            IsExpanded = true;

            if (_impactAnalysis.Violations.Count == 0)
            {
                Snackbar.Add("No validation violations found that can be auto-fixed", Severity.Info);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error analyzing validation issues: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessingFixes = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFixesAsync(IReadOnlyList<int> workItemIds)
    {
        try
        {
            _isProcessingFixes = true;
            StateHasChanged();

            // Convert to list for processing
            var workItemIdsList = workItemIds.ToList();

            // Create fix suggestions for each work item
            var fixes = new List<FixValidationViolationDto>();
            foreach (var workItemId in workItemIdsList)
            {
                var workItem = WorkItemsWithValidation?.FirstOrDefault(w => w.TfsId == workItemId);
                if (workItem != null)
                {
                    fixes.Add(new FixValidationViolationDto
                    {
                        WorkItemId = workItemId,
                        FixType = "SetToInProgress",
                        Description = $"Set {workItem.Type} '{workItem.Title}' to In Progress",
                        NewState = "In Progress",
                        Justification = "Required to unblock child work items"
                    });
                }
            }

            if (fixes.Count == 0)
            {
                Snackbar.Add("No fixes to apply", Severity.Warning);
                return;
            }

            // Apply the fixes
            var command = new FixValidationViolationBatchCommand
            {
                Fixes = fixes
            };

            var result = await WorkItemsClient.FixValidationViolationsAsync(command);

            // Show results
            if (result.SuccessfulFixes > 0)
            {
                Snackbar.Add($"Successfully fixed {result.SuccessfulFixes} work item(s)", Severity.Success);
                
                // Clear the impact analysis to refresh
                _impactAnalysis = null;
                
                // Notify parent to refresh data
                await OnFixesApplied.InvokeAsync();
            }

            if (result.FailedFixes > 0)
            {
                var failedItems = result.Results.Where(r => !r.Success).Select(r => r.WorkItemId);
                Snackbar.Add($"Failed to fix {result.FailedFixes} work item(s): {string.Join(", ", failedItems)}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error applying fixes: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessingFixes = false;
            StateHasChanged();
        }
    }

    private int GetHealthPercentage(int itemsWithIssues, int totalItems)
    {
        if (totalItems == 0) return 100;
        return (int)Math.Round((totalItems - itemsWithIssues) * 100.0 / totalItems);
    }

    private string GetHealthIcon(int itemsWithIssues, int totalItems)
    {
        var percentage = GetHealthPercentage(itemsWithIssues, totalItems);
        return percentage >= 90 ? Icons.Material.Filled.CheckCircle :
               percentage >= 70 ? Icons.Material.Filled.Warning :
               Icons.Material.Filled.Error;
    }

    private Color GetHealthColor(int itemsWithIssues, int totalItems)
    {
        var percentage = GetHealthPercentage(itemsWithIssues, totalItems);
        return percentage >= 90 ? Color.Success :
               percentage >= 70 ? Color.Warning :
               Color.Error;
    }
}
