@using PoTool.Client.ApiClient
@inject ISnackbar Snackbar

@* Work Item History Timeline Component *@

<div class="history-timeline">
    @if (IsLoading)
    {
        <div class="loading-container">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading revision history...</MudText>
        </div>
    }
    else if (HasError)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled">
            Failed to load revision history. @ErrorMessage
        </MudAlert>
    }
    else if (Revisions == null || !Revisions.Any())
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            No revision history available for this work item.
        </MudText>
    }
    else
    {
        <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
            @foreach (var revision in Revisions.OrderByDescending(r => r.RevisionNumber))
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @revision.ChangedDate.LocalDateTime.ToString("g")
                        </MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudCard Class="revision-card">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.body1">
                                        <strong>Revision @revision.RevisionNumber</strong> by @revision.ChangedBy
                                    </MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                @if (!string.IsNullOrWhiteSpace(revision.Comment))
                                {
                                    <div class="revision-comment">
                                        <MudText Typo="Typo.body2" Class="mb-2">
                                            <em>@revision.Comment</em>
                                        </MudText>
                                    </div>
                                }
                                
                                @if (revision.FieldChanges != null && revision.FieldChanges.Count > 0)
                                {
                                    <div class="field-changes">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                            Changed Fields:
                                        </MudText>
                                        @foreach (var changeKvp in revision.FieldChanges)
                                        {
                                            var change = changeKvp.Value;
                                            <div class="field-change-item">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">
                                                    @GetFriendlyFieldName(change.FieldName)
                                                </MudChip>
                                                <div class="field-change-values">
                                                    @if (!string.IsNullOrEmpty(change.OldValue))
                                                    {
                                                        <MudText Typo="Typo.caption" Class="old-value">
                                                            <del>@TruncateValue(change.OldValue)</del>
                                                        </MudText>
                                                        <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" />
                                                    }
                                                    <MudText Typo="Typo.caption" Class="new-value">
                                                        @TruncateValue(change.NewValue)
                                                    </MudText>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else if (revision.RevisionNumber == 1)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Work item created
                                    </MudText>
                                }
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</div>

@code {
    [Parameter]
    public IEnumerable<WorkItemRevisionDto>? Revisions { get; set; }

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool HasError { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    private string GetFriendlyFieldName(string fieldName)
    {
        // Convert TFS field names to user-friendly names
        return fieldName switch
        {
            "System.Title" => "Title",
            "System.State" => "State",
            "System.AssignedTo" => "Assigned To",
            "System.AreaPath" => "Area Path",
            "System.IterationPath" => "Iteration Path",
            "System.Description" => "Description",
            "Microsoft.VSTS.Scheduling.Effort" => "Effort",
            "System.Tags" => "Tags",
            "System.WorkItemType" => "Work Item Type",
            _ => fieldName.Replace("System.", "").Replace("Microsoft.VSTS.", "").Replace(".", " ")
        };
    }

    private string TruncateValue(string? value, int maxLength = 100)
    {
        if (string.IsNullOrEmpty(value))
            return "(empty)";
        
        if (value.Length <= maxLength)
            return value;
        
        return value.Substring(0, maxLength) + "...";
    }
}
