@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@inject IWorkItemsClient WorkItemsClient
@inject WorkItemService WorkItemService
@inject ISnackbar Snackbar

@* Validation History Panel - shows historical violations trend *@

<MudPaper Elevation="2" Class="pa-4 mb-4 mx-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Validation History</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.FilterList"
                       Size="Size.Small"
                       OnClick="LoadHistoryAsync"
                       Disabled="@_isLoading">
                Apply Filters
            </MudButton>
            @if (_selectedAreaPaths.Any() || _startDate.HasValue || _endDate.HasValue)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Clear"
                           Size="Size.Small"
                           OnClick="ClearFilters"
                           Disabled="@_isLoading">
                    Clear
                </MudButton>
            }
            @if (IsExpanded)
            {
                <MudIconButton Icon="@Icons.Material.Filled.ExpandLess" 
                               OnClick="@(() => IsExpanded = false)" 
                               Size="Size.Small" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.ExpandMore" 
                               OnClick="@(() => IsExpanded = true)" 
                               Size="Size.Small" />
            }
        </MudStack>
    </MudStack>

    @if (IsExpanded)
    {
        <!-- Filters -->
        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="6" md="4">
                <CompactSelect T="string"
                               Label="Area Path Filter"
                               @bind-SelectedValues="_selectedAreaPaths"
                               MultiSelection="true"
                               Clearable="true"
                               HelperText="Select one or more area paths to filter"
                               Class="mt-2">
                    @if (_availableAreaPaths != null)
                    {
                        @foreach (var areaPath in _availableAreaPaths)
                        {
                            <MudSelectItem T="string" Value="@areaPath">@areaPath</MudSelectItem>
                        }
                    }
                </CompactSelect>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudDatePicker @bind-Date="_startDate" 
                               Label="Start Date" 
                               Variant="Variant.Outlined"
                               Clearable="true"
                               Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudDatePicker @bind-Date="_endDate" 
                               Label="End Date" 
                               Variant="Variant.Outlined"
                               Clearable="true"
                               Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />

        @if (_isLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
        }

        @if (_historyRecords != null && _historyRecords.Any())
        {
            <!-- Summary Cards -->
            <MudGrid Class="mb-3">
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                                <MudText Typo="Typo.h4">@_historyRecords.Count()</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Total Violations
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Size="Size.Large" />
                                <MudText Typo="Typo.h4">@_historyRecords.Select(h => h.WorkItemId).Distinct().Count()</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Affected Work Items
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Color="Color.Warning" Size="Size.Large" />
                                <MudText Typo="Typo.h4">@_historyRecords.Select(h => h.AreaPath).Distinct().Count()</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Affected Areas
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Outlined="true">
                        <MudCardContent>
                            <MudStack Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" />
                                <MudText Typo="Typo.h4">@_historyRecords.Count(h => h.Severity == "Error")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                    Errors
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <!-- History Table -->
            <CompactTable Items="@_historyRecords" Hover="true" Striped="true" FixedHeader="true" Height="400px">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Work Item</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Severity</MudTh>
                    <MudTh>Violation</MudTh>
                    <MudTh>Area Path</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.DetectedAt.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="Work Item">
                        <MudText Typo="Typo.body2">@context.WorkItemId</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.WorkItemTitle</MudText>
                    </MudTd>
                    <MudTd DataLabel="Type">@context.WorkItemType</MudTd>
                    <MudTd DataLabel="Severity">
                        @if (context.Severity == "Error")
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Error">Error</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Warning">Warning</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Violation">@context.ViolationMessage</MudTd>
                    <MudTd DataLabel="Area Path">@context.AreaPath</MudTd>
                </RowTemplate>
            </CompactTable>
        }
        else if (!_isLoading)
        {
            <MudAlert Severity="Severity.Info">
                No validation history found for the selected filters.
            </MudAlert>
        }
    }
</MudPaper>

@code {
    [Parameter]
    public bool InitiallyExpanded { get; set; } = false;

    private bool IsExpanded { get; set; }
    private bool _isLoading;
    private ICollection<ValidationViolationHistoryDto>? _historyRecords;
    private IEnumerable<string> _selectedAreaPaths = new List<string>();
    private List<string>? _availableAreaPaths;
    private DateTime? _startDate;
    private DateTime? _endDate;

    protected override async Task OnInitializedAsync()
    {
        IsExpanded = InitiallyExpanded;
        await LoadAvailableAreaPathsAsync();
        if (IsExpanded)
        {
            await LoadHistoryAsync();
        }
    }

    private async Task LoadAvailableAreaPathsAsync()
    {
        try
        {
            var areaPaths = await WorkItemService.GetDistinctAreaPathsAsync();
            _availableAreaPaths = areaPaths.CanUseData
                ? areaPaths.Data!.ToList()
                : new List<string>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading area paths: {ex.Message}");
            _availableAreaPaths = new List<string>();
        }
    }

    private async Task LoadHistoryAsync()
    {
        try
        {
            _isLoading = true;
            StateHasChanged();

            DateTimeOffset? startDateOffset = _startDate.HasValue 
                ? new DateTimeOffset(_startDate.Value, TimeSpan.Zero) 
                : null;
            DateTimeOffset? endDateOffset = _endDate.HasValue 
                ? new DateTimeOffset(_endDate.Value, TimeSpan.Zero) 
                : null;

            // Convert selected area paths to comma-separated string for API
            string? areaPathFilter = _selectedAreaPaths.Any() 
                ? string.Join(",", _selectedAreaPaths) 
                : null;

            var response = GeneratedCacheEnvelopeHelper.ToDataStateResult(
                await WorkItemsClient.GetValidationHistoryAsync(
                areaPathFilter, 
                startDateOffset, 
                endDateOffset, 
                null),
                static data => (IReadOnlyList<ValidationViolationHistoryDto>)data.ToReadOnlyList());
            _historyRecords = response.CanUseData
                ? response.Data!.ToList()
                : new List<ValidationViolationHistoryDto>();

            if (_historyRecords?.Count == 0)
            {
                Snackbar.Add("No validation history found", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading validation history: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ClearFilters()
    {
        _selectedAreaPaths = new List<string>();
        _startDate = null;
        _endDate = null;
        StateHasChanged();
        await LoadHistoryAsync();
    }
}
