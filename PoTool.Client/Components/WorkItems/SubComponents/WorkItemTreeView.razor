@using PoTool.Client.Models
@using MudBlazor

@* Tree view container component with virtual scrolling *@

<div class="tree-view">
    @if (IsLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        <MudText Typo="Typo.body2" Class="mt-2">Loading work items...</MudText>
    }
    else if (!TreeRoots.Any())
    {
        <div class="empty-state pa-4">
            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
            <MudText Typo="Typo.h6" Class="mb-2">No work items found</MudText>
            <MudText Typo="Typo.body2">Click "Full Sync" to retrieve work items from Azure DevOps, or check your filter settings.</MudText>
        </div>
    }
    else
    {
        <ul class="workitem-tree-root">
            @* Use MudVirtualize for performance with large datasets *@
            <MudVirtualize Items="@GetFlatNodeList()" Context="node" OverscanCount="10">
                <div class="virtualized-node" style="padding-left:@(node.Level * 1.25)rem">
                    <MudPaper Class="node-row" Elevation="0">
                        @if (node.Node.Children.Any())
                        {
                            <MudIconButton 
                                Icon="@(node.Node.IsExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                                Size="Size.Small" 
                                Color="Color.Default"
                                OnClick="() => OnNodeToggled.InvokeAsync(node.Node)"
                                Class="caret-button" />
                        }
                        else
                        {
                            <span class="leaf-placeholder"></span>
                        }

                        <MudIcon Icon="@GetIconForType(node.Node.Type)" 
                                 Size="Size.Small" 
                                 Style="@($"color: {node.Node.TypeColor}")" 
                                 title="@node.Node.Type" />

                        <MudChip T="string" 
                                 Size="Size.Small" 
                                 Color="@GetChipColor(node.Node.Type)"
                                 Variant="Variant.Filled"
                                 Class="type-chip">
                            @GetTypeText(node.Node)
                        </MudChip>

                        <div class="title-block" 
                             @onclick="() => OnNodeSelected.InvokeAsync(node.Node)" 
                             @onclick:stopPropagation="true">
                            <MudText Typo="Typo.body2" 
                                     Class="@GetTitleClass(node.Node)">
                                @node.Node.Title
                            </MudText>
                        </div>
                        
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Class="status-chip">
                            @node.Node.State
                        </MudChip>
                        
                        @if (node.Node.HasValidationIssues)
                        {
                            <MudTooltip Text="@GetValidationTooltip(node.Node)">
                                <MudIcon Icon="@GetValidationIcon(node.Node)" 
                                         Size="Size.Small" 
                                         Color="@GetValidationColor(node.Node)" 
                                         Class="validation-icon" />
                            </MudTooltip>
                        }
                    </MudPaper>
                </div>
            </MudVirtualize>
        </ul>
    }
</div>

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public List<TreeNode> TreeRoots { get; set; } = new();

    [Parameter]
    public int? SelectedId { get; set; }

    [Parameter]
    public HashSet<int>? SelectedIds { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeToggled { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeSelected { get; set; }
    
    private record FlatNode(TreeNode Node, int Level);
    
    // Memoization fields for flat list
    private List<FlatNode>? _cachedFlatList;
    private int _cachedTreeRootsHashCode;
    
    private List<FlatNode> GetFlatNodeList()
    {
        // Calculate hash based on tree structure
        var currentHash = CalculateTreeHash();
        
        // Return cached list if tree hasn't changed
        if (_cachedFlatList != null && _cachedTreeRootsHashCode == currentHash)
        {
            return _cachedFlatList;
        }
        
        // Rebuild flat list
        var flatList = new List<FlatNode>();
        foreach (var root in TreeRoots)
        {
            AddNodeToFlatList(root, 0, flatList);
        }
        
        // Cache the result
        _cachedFlatList = flatList;
        _cachedTreeRootsHashCode = currentHash;
        
        return flatList;
    }
    
    private int CalculateTreeHash()
    {
        // Create hash based on tree structure and expansion state
        var hash = new HashCode();
        hash.Add(TreeRoots.Count);
        foreach (var root in TreeRoots)
        {
            AddNodeToHash(root, ref hash);
        }
        return hash.ToHashCode();
    }
    
    private void AddNodeToHash(TreeNode node, ref HashCode hash)
    {
        hash.Add(node.Id);
        hash.Add(node.IsExpanded);
        hash.Add(node.Children.Count);
        
        if (node.IsExpanded)
        {
            foreach (var child in node.Children)
            {
                AddNodeToHash(child, ref hash);
            }
        }
    }
    
    private void AddNodeToFlatList(TreeNode node, int level, List<FlatNode> flatList)
    {
        flatList.Add(new FlatNode(node, level));
        
        if (node.IsExpanded && node.Children.Any())
        {
            foreach (var child in node.Children)
            {
                AddNodeToFlatList(child, level + 1, flatList);
            }
        }
    }
    
    private bool IsPlaceholder(TreeNode node) => string.IsNullOrEmpty(node.JsonPayload);
    
    private string GetIconForType(string type)
    {
        return type switch
        {
            "Goal" => Icons.Material.Filled.Flag,
            "Objective" => Icons.Material.Filled.TrackChanges,
            "Epic" => Icons.Material.Filled.Layers,
            "Feature" => Icons.Material.Filled.Dashboard,
            "Product Backlog Item" => Icons.Material.Filled.Assignment,
            "Bug" => Icons.Material.Filled.BugReport,
            "Task" => Icons.Material.Filled.CheckCircle,
            _ => Icons.Material.Filled.Circle
        };
    }
    
    private Color GetChipColor(string type)
    {
        return type switch
        {
            "Goal" => Color.Success,
            "Objective" => Color.Info,
            "Epic" => Color.Warning,
            "Feature" => Color.Secondary,
            "Product Backlog Item" => Color.Primary,
            "Bug" => Color.Error,
            "Task" => Color.Default,
            _ => Color.Default
        };
    }
    
    private string GetTypeText(TreeNode node)
    {
        if (IsPlaceholder(node))
        {
            return "(missing)";
        }
        
        // Abbreviate for better display
        return node.Type switch
        {
            "Product Backlog Item" => "PBI",
            "Bug" => "BUG",
            "Objective" => "OBJ",
            _ => node.Type.ToUpper()
        };
    }
    
    private string GetTitleClass(TreeNode node)
    {
        var className = IsPlaceholder(node) ? "workitem-title placeholder-title" : "workitem-title";
        if ((SelectedId.HasValue && SelectedId.Value == node.Id) || 
            (SelectedIds != null && SelectedIds.Contains(node.Id)))
        {
            className += " selected";
        }
        return className;
    }
    
    private string GetValidationTooltip(TreeNode node)
    {
        return string.Join("\n", node.ValidationIssues);
    }
    
    private string GetValidationIcon(TreeNode node)
    {
        return node.HighestSeverity switch
        {
            "Error" => Icons.Material.Filled.Error,
            "Warning" => Icons.Material.Filled.Warning,
            _ => Icons.Material.Filled.Info
        };
    }
    
    private Color GetValidationColor(TreeNode node)
    {
        return node.HighestSeverity switch
        {
            "Error" => Color.Error,
            "Warning" => Color.Warning,
            _ => Color.Info
        };
    }
    
    private string GetValidationAriaLabel(TreeNode node)
    {
        var issueCount = node.ValidationIssues.Count;
        return $"{node.HighestSeverity}: {issueCount} validation issue{(issueCount != 1 ? "s" : "")}";
    }
}
