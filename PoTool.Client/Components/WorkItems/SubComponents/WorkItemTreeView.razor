@using PoTool.Client.Models

@* Tree view container component *@

<div class="tree-view">
    @if (IsLoading)
    {
        <p>Loading work items...</p>
    }
    else if (!TreeRoots.Any())
    {
        <div class="empty-state pa-4">
            <p class="mb-2"><strong>No work items found</strong></p>
            <p>Click "Full Sync" to retrieve work items from Azure DevOps, or check your filter settings.</p>
        </div>
    }
    else
    {
        <ul class="workitem-tree-root">
            @foreach (var node in TreeRoots)
            {
                <WorkItemTreeNode Node="@node"
                                 Level="0"
                                 SelectedId="@SelectedId"
                                 SelectedIds="@SelectedIds"
                                 OnNodeToggled="@OnNodeToggled"
                                 OnNodeSelected="@OnNodeSelected" />
            }
        </ul>
    }
</div>

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public List<TreeNode> TreeRoots { get; set; } = new();

    [Parameter]
    public int? SelectedId { get; set; }

    [Parameter]
    public HashSet<int>? SelectedIds { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeToggled { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeSelected { get; set; }
}
