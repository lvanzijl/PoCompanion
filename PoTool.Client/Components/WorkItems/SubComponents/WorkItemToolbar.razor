@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Core.Contracts
@inject ExportService ExportService
@inject ReportService ReportService
@inject IClipboardService ClipboardService
@inject TfsConfigService TfsConfigService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@implements IDisposable

@* Toolbar for work item explorer actions *@

<div class="workitem-toolbar">
    <div class="header">
        <h1>Work Item Explorer</h1>
        <div class="header-actions">
            <button class="btn-settings" @onclick="OnSettingsClicked">
                <span>⚙️ Settings</span>
            </button>
            <MudTooltip Text="Downloads all work items from Azure DevOps. Use when syncing for the first time or after major changes." 
                        Placement="Placement.Bottom">
                <button class="btn-sync" @onclick="OnSyncClicked" disabled="@IsSyncing">
                    @if (IsSyncing)
                    {
                        <span>Syncing...</span>
                    }
                    else
                    {
                        <span>Full Sync</span>
                    }
                </button>
            </MudTooltip>
            <MudTooltip Text="Downloads only changes since last sync (faster). Use for regular updates." 
                        Placement="Placement.Bottom">
                <button class="btn-sync" @onclick="OnIncrementalSyncClicked" disabled="@IsSyncing">
                    @if (IsSyncing)
                    {
                        <span>Syncing...</span>
                    }
                    else
                    {
                        <span>Incremental Sync</span>
                    }
                </button>
            </MudTooltip>
            <button class="btn-clear" @onclick="OnClearStateClicked">Clear tree state</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(SyncMessage))
    {
        <div class="sync-status @SyncStatusClass">
            @SyncMessage
        </div>
    }

    @if (LastSyncTime.HasValue)
    {
        <div class="last-sync-time">
            <small>Last sync: @LastSyncTime.Value.ToLocalTime().ToString("g")</small>
        </div>
    }

    <div class="endpoint-info">
        <small>API base: @ApiBase</small><br />
        <small>Hub URL: @HubUrl</small>
    </div>

    <div class="search-filter">
        <input type="text" 
               placeholder="Filter by title..." 
               @bind="FilterText" 
               @bind:event="oninput"
               @onkeyup="OnFilterKeyUp" />
        
        @if (SelectedCount > 0)
        {
            <div class="selection-info">
                <span class="selection-count">@SelectedCount item@(SelectedCount == 1 ? "" : "s") selected</span>
                <button class="btn-clear-selection" @onclick="OnClearSelection">Clear Selection</button>
            </div>
            
            @* Bulk operation buttons *@
            <div class="bulk-actions">
                <MudTooltip Text="Export selected items to CSV format">
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Primary" 
                              StartIcon="@Icons.Material.Filled.FileDownload" 
                              Size="Size.Small"
                              OnClick="ExportToCsv">
                        Export CSV
                    </MudButton>
                </MudTooltip>
                
                <MudTooltip Text="Export selected items to JSON format">
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Primary" 
                              StartIcon="@Icons.Material.Filled.FileDownload" 
                              Size="Size.Small"
                              OnClick="ExportToJson">
                        Export JSON
                    </MudButton>
                </MudTooltip>
                
                <MudTooltip Text="Copy work item IDs to clipboard (comma-separated)">
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Secondary" 
                              StartIcon="@Icons.Material.Filled.ContentCopy" 
                              Size="Size.Small"
                              OnClick="CopyIdsToClipboard">
                        Copy IDs
                    </MudButton>
                </MudTooltip>
                
                <MudTooltip Text="Copy work item URLs to clipboard">
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Secondary" 
                              StartIcon="@Icons.Material.Filled.Link" 
                              Size="Size.Small"
                              OnClick="CopyUrlsToClipboard">
                        Copy URLs
                    </MudButton>
                </MudTooltip>
                
                <MudTooltip Text="Generate summary report for selected items">
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Info" 
                              StartIcon="@Icons.Material.Filled.Assessment" 
                              Size="Size.Small"
                              OnClick="GenerateReport">
                        Generate Report
                    </MudButton>
                </MudTooltip>
            </div>
        }
        
        <div class="selection-actions">
            <MudTooltip Text="Select all visible items (Ctrl+A)">
                <button class="btn-select-all" @onclick="OnSelectAll">Select All</button>
            </MudTooltip>
        </div>
        
        <div class="validation-filters">
            <label class="filter-label">Validation Filters:</label>
            
            @foreach (var filter in ValidationFilters)
            {
                <MudTooltip Text="@GetFilterTooltip(filter.Id)" Placement="Placement.Bottom">
                    <label class="validation-filter-item">
                        <input type="checkbox" 
                               checked="@filter.IsEnabled"
                               @onchange="@(e => OnValidationFilterChanged(filter, (bool)(e.Value ?? false)))" />
                        <span>@filter.Label (@filter.Count)</span>
                    </label>
                </MudTooltip>
            }
            
            <button class="btn-toggle-filters" @onclick="OnToggleAllFilters">
                @(AreAllFiltersEnabled ? "Clear All" : "Select All")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string ApiBase { get; set; } = string.Empty;

    [Parameter]
    public string HubUrl { get; set; } = string.Empty;

    [Parameter]
    public bool IsSyncing { get; set; }

    [Parameter]
    public string SyncMessage { get; set; } = string.Empty;

    [Parameter]
    public string SyncStatusClass { get; set; } = string.Empty;

    [Parameter]
    public string FilterText { get; set; } = string.Empty;

    [Parameter]
    public List<ValidationFilter> ValidationFilters { get; set; } = new();

    [Parameter]
    public DateTimeOffset? LastSyncTime { get; set; }

    [Parameter]
    public EventCallback OnSyncRequested { get; set; }

    [Parameter]
    public EventCallback OnIncrementalSyncRequested { get; set; }

    [Parameter]
    public EventCallback OnClearState { get; set; }

    [Parameter]
    public EventCallback<string> OnFilterChanged { get; set; }

    [Parameter]
    public EventCallback<List<ValidationFilter>> OnValidationFiltersChanged { get; set; }

    [Parameter]
    public EventCallback OnSettingsRequested { get; set; }

    [Parameter]
    public int SelectedCount { get; set; }

    [Parameter]
    public EventCallback OnSelectAll { get; set; }

    [Parameter]
    public EventCallback OnClearSelection { get; set; }

    [Parameter]
    public List<WorkItemDto> SelectedWorkItems { get; set; } = new();

    private bool AreAllFiltersEnabled => ValidationFilters.All(f => f.IsEnabled);
    
    // Debouncing fields
    private System.Threading.Timer? _debounceTimer;
    private const int DebounceDelayMilliseconds = 300;

    private string GetFilterTooltip(string filterId)
    {
        return filterId switch
        {
            "parentProgress" => "Highlights work items that are in progress but their parent or ancestor is not in progress",
            "missingEffort" => "Highlights work items in 'In Progress' state without effort or story points assigned",
            _ => ""
        };
    }

    private async Task OnSyncClicked()
    {
        await OnSyncRequested.InvokeAsync();
    }

    private async Task OnIncrementalSyncClicked()
    {
        await OnIncrementalSyncRequested.InvokeAsync();
    }

    private async Task OnSettingsClicked()
    {
        await OnSettingsRequested.InvokeAsync();
    }

    private async Task OnClearStateClicked()
    {
        await OnClearState.InvokeAsync();
    }

    private void OnFilterKeyUp()
    {
        // Cancel previous timer if it exists
        _debounceTimer?.Dispose();
        
        // Create new timer that will fire after debounce delay
        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await OnFilterChanged.InvokeAsync(FilterText);
            });
        }, null, DebounceDelayMilliseconds, System.Threading.Timeout.Infinite);
    }
    
    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }

    private async Task OnValidationFilterChanged(ValidationFilter filter, bool isEnabled)
    {
        filter.IsEnabled = isEnabled;
        await OnValidationFiltersChanged.InvokeAsync(ValidationFilters);
    }

    private async Task OnToggleAllFilters()
    {
        var newState = !AreAllFiltersEnabled;
        foreach (var filter in ValidationFilters)
        {
            filter.IsEnabled = newState;
        }
        await OnValidationFiltersChanged.InvokeAsync(ValidationFilters);
    }

    // Bulk operation handlers
    private async Task ExportToCsv()
    {
        try
        {
            var csv = ExportService.ExportToCsv(SelectedWorkItems);
            await DownloadFile(csv, $"workitems_{DateTime.Now:yyyyMMdd_HHmmss}.csv", "text/csv");
            Snackbar.Add($"Exported {SelectedWorkItems.Count} items to CSV", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export CSV: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportToJson()
    {
        try
        {
            var json = ExportService.ExportToJson(SelectedWorkItems);
            await DownloadFile(json, $"workitems_{DateTime.Now:yyyyMMdd_HHmmss}.json", "application/json");
            Snackbar.Add($"Exported {SelectedWorkItems.Count} items to JSON", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export JSON: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyIdsToClipboard()
    {
        try
        {
            var ids = string.Join(", ", SelectedWorkItems.Select(w => w.TfsId));
            await ClipboardService.CopyToClipboardAsync(ids);
            Snackbar.Add($"Copied {SelectedWorkItems.Count} work item IDs to clipboard", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to copy IDs: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyUrlsToClipboard()
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            if (config == null || string.IsNullOrEmpty(config.Url) || string.IsNullOrEmpty(config.Project))
            {
                Snackbar.Add("TFS configuration not found. Please configure Azure DevOps connection first.", Severity.Warning);
                return;
            }

            var urls = SelectedWorkItems
                .Select(w => Core.WorkItems.TfsUrlBuilder.BuildWorkItemUrl(config.Url, config.Project, w.TfsId))
                .ToList();
            
            var urlsText = string.Join(Environment.NewLine, urls);
            await ClipboardService.CopyToClipboardAsync(urlsText);
            Snackbar.Add($"Copied {SelectedWorkItems.Count} work item URLs to clipboard", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to copy URLs: {ex.Message}", Severity.Error);
        }
    }

    private async Task GenerateReport()
    {
        try
        {
            var report = ReportService.GenerateSummaryReport(SelectedWorkItems);
            await DownloadFile(report, $"workitems_report_{DateTime.Now:yyyyMMdd_HHmmss}.md", "text/markdown");
            Snackbar.Add($"Generated report for {SelectedWorkItems.Count} items", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to generate report: {ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadFile(string content, string filename, string mimeType)
    {
        try
        {
            var bytes = System.Text.Encoding.UTF8.GetBytes(content);
            var base64 = Convert.ToBase64String(bytes);
            await JSRuntime.InvokeVoidAsync("downloadFile", filename, base64, mimeType);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to download file: {ex.Message}", Severity.Error);
            throw;
        }
    }
}
