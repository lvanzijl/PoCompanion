@using PoTool.Client.Models

@* Toolbar for work item explorer actions *@

<div class="workitem-toolbar">
    <div class="header">
        <h1>Work Item Explorer</h1>
        <div class="header-actions">
            <button class="btn-settings" @onclick="OnSettingsClicked">
                <span>⚙️ Settings</span>
            </button>
            <button class="btn-sync" @onclick="OnSyncClicked" disabled="@IsSyncing">
                @if (IsSyncing)
                {
                    <span>Syncing...</span>
                }
                else
                {
                    <span>Full Sync</span>
                }
            </button>
            <button class="btn-sync" @onclick="OnIncrementalSyncClicked" disabled="@IsSyncing">
                @if (IsSyncing)
                {
                    <span>Syncing...</span>
                }
                else
                {
                    <span>Incremental Sync</span>
                }
            </button>
            <button class="btn-clear" @onclick="OnClearStateClicked">Clear tree state</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(SyncMessage))
    {
        <div class="sync-status @SyncStatusClass">
            @SyncMessage
        </div>
    }

    @if (LastSyncTime.HasValue)
    {
        <div class="last-sync-time">
            <small>Last sync: @LastSyncTime.Value.ToLocalTime().ToString("g")</small>
        </div>
    }

    <div class="endpoint-info">
        <small>API base: @ApiBase</small><br />
        <small>Hub URL: @HubUrl</small>
    </div>

    <div class="search-filter">
        <input type="text" 
               placeholder="Filter by title..." 
               @bind="FilterText" 
               @bind:event="oninput"
               @onkeyup="OnFilterKeyUp" />
        
        <div class="validation-filters">
            <label class="filter-label">Validation Filters:</label>
            
            @foreach (var filter in ValidationFilters)
            {
                <label class="validation-filter-item">
                    <input type="checkbox" 
                           checked="@filter.IsEnabled"
                           @onchange="@(e => OnValidationFilterChanged(filter, (bool)(e.Value ?? false)))" />
                    <span>@filter.Label</span>
                </label>
            }
            
            <button class="btn-toggle-filters" @onclick="OnToggleAllFilters">
                @(AreAllFiltersEnabled ? "Clear All" : "Select All")
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string ApiBase { get; set; } = string.Empty;

    [Parameter]
    public string HubUrl { get; set; } = string.Empty;

    [Parameter]
    public bool IsSyncing { get; set; }

    [Parameter]
    public string SyncMessage { get; set; } = string.Empty;

    [Parameter]
    public string SyncStatusClass { get; set; } = string.Empty;

    [Parameter]
    public string FilterText { get; set; } = string.Empty;

    [Parameter]
    public List<ValidationFilter> ValidationFilters { get; set; } = new();

    [Parameter]
    public DateTimeOffset? LastSyncTime { get; set; }

    [Parameter]
    public EventCallback OnSyncRequested { get; set; }

    [Parameter]
    public EventCallback OnIncrementalSyncRequested { get; set; }

    [Parameter]
    public EventCallback OnClearState { get; set; }

    [Parameter]
    public EventCallback<string> OnFilterChanged { get; set; }

    [Parameter]
    public EventCallback<List<ValidationFilter>> OnValidationFiltersChanged { get; set; }

    [Parameter]
    public EventCallback OnSettingsRequested { get; set; }

    private bool AreAllFiltersEnabled => ValidationFilters.All(f => f.IsEnabled);

    private async Task OnSyncClicked()
    {
        await OnSyncRequested.InvokeAsync();
    }

    private async Task OnIncrementalSyncClicked()
    {
        await OnIncrementalSyncRequested.InvokeAsync();
    }

    private async Task OnSettingsClicked()
    {
        await OnSettingsRequested.InvokeAsync();
    }

    private async Task OnClearStateClicked()
    {
        await OnClearState.InvokeAsync();
    }

    private async Task OnFilterKeyUp()
    {
        await OnFilterChanged.InvokeAsync(FilterText);
    }

    private async Task OnValidationFilterChanged(ValidationFilter filter, bool isEnabled)
    {
        filter.IsEnabled = isEnabled;
        await OnValidationFiltersChanged.InvokeAsync(ValidationFilters);
    }

    private async Task OnToggleAllFilters()
    {
        var newState = !AreAllFiltersEnabled;
        foreach (var filter in ValidationFilters)
        {
            filter.IsEnabled = newState;
        }
        await OnValidationFiltersChanged.InvokeAsync(ValidationFilters);
    }
}
