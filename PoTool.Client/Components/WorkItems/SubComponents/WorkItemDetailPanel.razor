@using PoTool.Client.ApiClient
@using PoTool.Shared.Contracts
@using PoTool.Client.Services
@using System.Text.Json
@using PoTool.Shared.Helpers
@inject IClipboardService ClipboardService
@inject TfsConfigService TfsConfigService
@inject BrowserNavigationService BrowserNavigationService
@inject WorkItemService WorkItemService
@inject StateClassificationService StateClassificationService
@inject ISnackbar Snackbar

@* Detail panel for displaying selected work item(s) *@

@if (SelectedWorkItems != null && SelectedWorkItems.Count > 1)
{
    <div class="detail-panel">
        <h2>Multiple Items Selected (@SelectedWorkItems.Count)</h2>
        
        @* Show common fields *@
        @if (GetCommonType() != null)
        {
            <div class="detail-field">
                <label>Type:</label>
                <span>@GetCommonType()</span>
            </div>
        }
        else
        {
            <div class="detail-field disabled">
                <label>Type:</label>
                <span class="multi-select-info">(Multiple types selected)</span>
            </div>
        }

        @if (GetCommonState() != null)
        {
            <div class="detail-field">
                <label>State:</label>
                <span>@GetCommonState()</span>
            </div>
        }
        else
        {
            <div class="detail-field disabled">
                <label>State:</label>
                <span class="multi-select-info">(Multiple states selected)</span>
            </div>
        }

        @if (GetCommonAreaPath() != null)
        {
            <div class="detail-field">
                <label>Area Path:</label>
                <span>@GetCommonAreaPath()</span>
            </div>
        }
        else
        {
            <div class="detail-field disabled">
                <label>Area Path:</label>
                <span class="multi-select-info">(Multiple area paths selected)</span>
            </div>
        }

        @if (GetCommonDescription() != null)
        {
            <div class="detail-field">
                <label>Description:</label>
                @if (string.IsNullOrWhiteSpace(GetCommonDescription()))
                {
                    <span class="no-value">(No description)</span>
                }
                else
                {
                    <div class="description-content">@((MarkupString)HtmlSanitizationHelper.Sanitize(GetCommonDescription()))</div>
                }
            </div>
        }
        else
        {
            <div class="detail-field disabled">
                <label>Description:</label>
                <span class="multi-select-info">(Multiple descriptions selected)</span>
            </div>
        }

        <div class="detail-section">
            <h3>Selected Items:</h3>
            <ul class="selected-items-list">
                @foreach (var item in SelectedWorkItems)
                {
                    <li>[@item.TfsId] @item.Title</li>
                }
            </ul>
        </div>
    </div>
}
else if (SelectedWorkItem != null)
{
    <div class="detail-panel">
        <h2>@SelectedWorkItem.Title</h2>
        
        @* Quick Actions *@
        <div class="quick-actions">
            <MudTooltip Text="Open this work item in Azure DevOps">
                <CompactButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          StartIcon="@Icons.Material.Filled.OpenInNew" 
                          OnClick="@(() => OpenInAzureDevOps(SelectedWorkItem.TfsId))">
                    Open in Azure DevOps
                </CompactButton>
            </MudTooltip>
            
            <MudTooltip Text="Copy work item ID to clipboard">
                <CompactButton Variant="Variant.Outlined" 
                          Color="Color.Secondary" 
                          StartIcon="@Icons.Material.Filled.ContentCopy" 
                          OnClick="@(() => CopyIdToClipboard(SelectedWorkItem.TfsId))">
                    Copy ID
                </CompactButton>
            </MudTooltip>
            
            <MudTooltip Text="Copy work item URL to clipboard">
                <CompactButton Variant="Variant.Outlined" 
                          Color="Color.Secondary" 
                          StartIcon="@Icons.Material.Filled.Link" 
                          OnClick="@(() => CopyUrlToClipboard(SelectedWorkItem.TfsId))">
                    Copy URL
                </CompactButton>
            </MudTooltip>
        </div>
        
        @* Tabs for Details and History *@
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
                <div class="detail-field">
                    <label>TFS ID:</label>
                    <span>@SelectedWorkItem.TfsId</span>
                </div>
                <div class="detail-field">
                    <label>Type:</label>
                    <span>@SelectedWorkItem.Type</span>
                </div>
                <div class="detail-field">
                    <label>State:</label>
                    <span>@SelectedWorkItem.State</span>
                </div>
                <div class="detail-field">
                    <label>Area Path:</label>
                    <span>@SelectedWorkItem.AreaPath</span>
                </div>
                <div class="detail-field">
                    <label>Iteration Path:</label>
                    <span>@SelectedWorkItem.IterationPath</span>
                </div>
                @if (SelectedWorkItem.ParentTfsId.HasValue)
                {
                    <div class="detail-field">
                        <label>Parent ID:</label>
                        <span>@SelectedWorkItem.ParentTfsId.Value</span>
                    </div>
                }
                <div class="detail-field">
                    <label>Retrieved At:</label>
                    <span>@SelectedWorkItem.RetrievedAt.ToString("g")</span>
                </div>
                @if (SelectedWorkItem.Effort.HasValue)
                {
                    <div class="detail-field">
                        <label>Effort:</label>
                        <span>@SelectedWorkItem.Effort.Value hours</span>
                    </div>
                }
                else
                {
                    <div class="detail-field">
                        <label>Effort:</label>
                        <span class="no-value">(not set)</span>
                    </div>
                }

                @if (SelectedWorkItem.BusinessValue.HasValue)
                {
                    <div class="detail-field">
                        <label>Business Value:</label>
                        <span>@SelectedWorkItem.BusinessValue.Value</span>
                    </div>
                }
                else
                {
                    <div class="detail-field">
                        <label>Business Value:</label>
                        <span class="no-value">(not set)</span>
                    </div>
                }

                <div class="detail-field">
                    <label>Description:</label>
                    @if (!string.IsNullOrWhiteSpace(SelectedWorkItem.Description))
                    {
                        <div class="description-content">@((MarkupString)HtmlSanitizationHelper.Sanitize(SelectedWorkItem.Description))</div>
                    }
                    else
                    {
                        <span class="no-value">(No description)</span>
                    }
                </div>

                @* Display validation issues section *@
                @if (ValidationIssues != null && ValidationIssues.Any())
                {
                    <div class="detail-section validation-section">
                        <h3>Validation Issues</h3>
                        @if (Errors.Any())
                        {
                            <div class="validation-group errors">
                                <h4>❌ Errors</h4>
                                <ul class="validation-list">
                                    @foreach (var error in Errors)
                                    {
                                        <li>
                                            @error
                                            @if (error.Contains("Parent") && error.Contains("not in progress") && SelectedWorkItem != null)
                                            {
                                                <div class="fix-suggestion">
                                                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Size="Size.Small" Color="Color.Info" />
                                                    @GetParentProgressSuggestion()
                                                </div>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                        @if (Warnings.Any())
                        {
                            <div class="validation-group warnings">
                                <h4>⚠️ Warnings</h4>
                                <ul class="validation-list">
                                    @foreach (var warning in Warnings)
                                    {
                                        <li>
                                            @warning
                                            @if (warning.Contains("Ancestor") && warning.Contains("not in progress"))
                                            {
                                                <div class="fix-suggestion">
                                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Info" />
                                                    <strong>Suggestion:</strong> Review parent hierarchy and ensure all ancestors are in progress
                                                </div>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }
            </MudTabPanel>
            
            <MudTabPanel Text="Activity" Icon="@Icons.Material.Filled.History" OnClick="@LoadHistoryAsync">
                @if (_isLoadingHistory)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
                }
                else if (_historyError != null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true">@_historyError</MudAlert>
                }
                else if (_revisions != null && _revisions.Count > 0)
                {
                    <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-2">
                        @foreach (var rev in _revisions.OrderByDescending(r => r.ChangedDate))
                        {
                            <MudTimelineItem Color="@GetRevisionColor(rev)" Size="Size.Small">
                                <ItemContent>
                                    <MudText Typo="Typo.body2" Class="mb-1">
                                        <strong>Rev @rev.RevisionNumber</strong> — @rev.ChangedDate.LocalDateTime.ToString("g")
                                    </MudText>
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary mb-1">
                                        @rev.ChangedBy
                                    </MudText>
                                    @if (rev.FieldChanges != null && rev.FieldChanges.Count > 0)
                                    {
                                        @foreach (var field in rev.FieldChanges)
                                        {
                                            <MudText Typo="Typo.caption">
                                                <strong>@FormatFieldName(field.Key)</strong>:
                                                @if (!string.IsNullOrEmpty(field.Value.OldValue))
                                                {
                                                    <span class="mud-text-secondary">@field.Value.OldValue</span>
                                                    <span> → </span>
                                                }
                                                <span>@(field.Value.NewValue ?? "(cleared)")</span>
                                            </MudText>
                                        }
                                    }
                                    @if (!string.IsNullOrWhiteSpace(rev.Comment))
                                    {
                                        <MudText Typo="Typo.caption" Class="mt-1" Style="font-style: italic;">
                                            @rev.Comment
                                        </MudText>
                                    }
                                </ItemContent>
                            </MudTimelineItem>
                        }
                    </MudTimeline>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        No activity data available.
                    </MudAlert>
                }
            </MudTabPanel>
        </MudTabs>
    </div>
}

@code {
    [Parameter]
    public WorkItemDto? SelectedWorkItem { get; set; }

    [Parameter]
    public List<WorkItemDto>? SelectedWorkItems { get; set; }

    [Parameter]
    public List<string>? ValidationIssues { get; set; }

    private List<string> Errors => ValidationIssues?
        .Where(issue => issue.StartsWith("Error:", StringComparison.OrdinalIgnoreCase))
        .Select(issue => issue.Substring(issue.IndexOf(':') + 1).Trim())
        .ToList() ?? new List<string>();

    private List<string> Warnings => ValidationIssues?
        .Where(issue => issue.StartsWith("Warning:", StringComparison.OrdinalIgnoreCase))
        .Select(issue => issue.Substring(issue.IndexOf(':') + 1).Trim())
        .ToList() ?? new List<string>();

    private int? _lastLoadedWorkItemId;
    private bool _isLoadingHistory;
    private string? _historyError;
    private ICollection<WorkItemRevisionDto>? _revisions;

    private string? GetCommonType()
    {
        if (SelectedWorkItems == null || !SelectedWorkItems.Any()) return null;
        var firstType = SelectedWorkItems[0].Type;
        if (firstType == null) return null;
        return SelectedWorkItems.All(w => w.Type != null && w.Type == firstType) ? firstType : null;
    }

    private string? GetCommonState()
    {
        if (SelectedWorkItems == null || !SelectedWorkItems.Any()) return null;
        var firstState = SelectedWorkItems[0].State;
        if (firstState == null) return null;
        return SelectedWorkItems.All(w => w.State != null && w.State == firstState) ? firstState : null;
    }

    private string? GetCommonAreaPath()
    {
        if (SelectedWorkItems == null || !SelectedWorkItems.Any()) return null;
        var firstAreaPath = SelectedWorkItems[0].AreaPath;
        if (firstAreaPath == null) return null;
        return SelectedWorkItems.All(w => w.AreaPath != null && w.AreaPath == firstAreaPath) ? firstAreaPath : null;
    }

    private string? GetCommonDescription()
    {
        if (SelectedWorkItems == null || !SelectedWorkItems.Any()) return null;
        var firstDescription = SelectedWorkItems[0].Description;
        // For description, we consider null and empty string as equivalent
        var normalizedFirst = string.IsNullOrWhiteSpace(firstDescription) ? string.Empty : firstDescription;
        var allMatch = SelectedWorkItems.All(w =>
        {
            var normalizedDesc = string.IsNullOrWhiteSpace(w.Description) ? string.Empty : w.Description;
            return normalizedDesc == normalizedFirst;
        });
        
        // Return empty string if all are null/empty (so we show placeholder), or the first value if all match
        return allMatch ? (string.IsNullOrWhiteSpace(firstDescription) ? string.Empty : firstDescription) : null;
    }

    private async Task LoadHistoryAsync()
    {
        if (SelectedWorkItem == null || _lastLoadedWorkItemId == SelectedWorkItem.TfsId)
            return;

        _lastLoadedWorkItemId = SelectedWorkItem.TfsId;
        _isLoadingHistory = true;
        _historyError = null;
        _revisions = null;
        StateHasChanged();

        try
        {
            var revisions = await WorkItemService.GetRevisionsAsync(SelectedWorkItem.TfsId);
            _revisions = revisions.ToList();
        }
        catch (Exception ex)
        {
            _historyError = $"Failed to load activity history: {ex.Message}";
        }
        finally
        {
            _isLoadingHistory = false;
            StateHasChanged();
        }
    }

    private static Color GetRevisionColor(WorkItemRevisionDto rev)
    {
        if (rev.FieldChanges != null && rev.FieldChanges.ContainsKey("System.State"))
            return Color.Primary;
        return Color.Default;
    }

    private static string FormatFieldName(string fieldRef)
    {
        // Strip the "System." or "Microsoft.VSTS." prefix for cleaner display
        var name = fieldRef;
        if (name.StartsWith("System.", StringComparison.Ordinal))
            name = name["System.".Length..];
        else if (name.StartsWith("Microsoft.VSTS.Common.", StringComparison.Ordinal))
            name = name["Microsoft.VSTS.Common.".Length..];
        else if (name.StartsWith("Microsoft.VSTS.Scheduling.", StringComparison.Ordinal))
            name = name["Microsoft.VSTS.Scheduling.".Length..];
        return name;
    }

    // Quick action handlers
    private async Task OpenInAzureDevOps(int workItemId)
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            if (config == null || string.IsNullOrEmpty(config.Url) || string.IsNullOrEmpty(config.Project))
            {
                Snackbar.Add("TFS configuration not found. Please configure Azure DevOps connection first.", Severity.Warning);
                return;
            }

            var url = PoTool.Shared.WorkItems.TfsUrlBuilder.BuildWorkItemUrl(config.Url, config.Project, workItemId);
            await OpenUrl(url);
            Snackbar.Add($"Opening work item {workItemId} in Azure DevOps", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to open work item: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyIdToClipboard(int workItemId)
    {
        try
        {
            await ClipboardService.CopyToClipboardAsync(workItemId.ToString());
            Snackbar.Add($"Work item ID {workItemId} copied to clipboard", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to copy ID: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyUrlToClipboard(int workItemId)
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            if (config == null || string.IsNullOrEmpty(config.Url) || string.IsNullOrEmpty(config.Project))
            {
                Snackbar.Add("TFS configuration not found. Please configure Azure DevOps connection first.", Severity.Warning);
                return;
            }

            var url = PoTool.Shared.WorkItems.TfsUrlBuilder.BuildWorkItemUrl(config.Url, config.Project, workItemId);
            await ClipboardService.CopyToClipboardAsync(url);
            Snackbar.Add($"Work item URL copied to clipboard", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to copy URL: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenUrl(string url)
    {
        // Open URL in new browser tab
        await BrowserNavigationService.OpenInNewTabAsync(url);
    }

    private MarkupString GetParentProgressSuggestion()
    {
        if (SelectedWorkItem?.ParentTfsId == null)
            return (MarkupString)"<strong>Suggested Fix:</strong> Set parent work item to an In Progress state";

        // Try to get parent work item type from validation error message
        var parentType = ExtractParentTypeFromError();
        if (string.IsNullOrEmpty(parentType))
            return (MarkupString)"<strong>Suggested Fix:</strong> Set parent work item to an In Progress state";

        try
        {
            // Get available In Progress states for the parent type
            var inProgressStates = StateClassificationService.GetInProgressStatesAsync(parentType).Result;

            if (inProgressStates.Count == 0)
            {
                return (MarkupString)$"<strong>Suggested Fix:</strong> Set parent {parentType} to an In Progress state (configure state classifications in settings)";
            }
            else if (inProgressStates.Count == 1)
            {
                return (MarkupString)$"<strong>Suggested Fix:</strong> Set parent {parentType} to \"{inProgressStates[0]}\" state";
            }
            else
            {
                var statesList = string.Join(", ", inProgressStates.Select(s => $"\"{s}\""));
                return (MarkupString)$"<strong>Suggested Fix:</strong> Set parent {parentType} to one of these In Progress states: {statesList}";
            }
        }
        catch
        {
            return (MarkupString)"<strong>Suggested Fix:</strong> Set parent work item to an In Progress state";
        }
    }

    private string ExtractParentTypeFromError()
    {
        // Look for "Parent 'TypeName' is not in progress" pattern in errors
        foreach (var error in Errors)
        {
            if (error.Contains("Parent") && error.Contains("not in progress"))
            {
                var match = System.Text.RegularExpressions.Regex.Match(error, @"Parent '([^']+)'");
                if (match.Success && match.Groups.Count > 1)
                {
                    return match.Groups[1].Value;
                }
            }
        }
        return string.Empty;
    }
}
