@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Client.Pages.Metrics.SubComponents
@inject MetricsStateService MetricsStateService
@inject BacklogHealthCalculationService HealthCalculationService

@* Backlog Health Panel - Reusable component for embedding backlog health data into workspaces *@

<DataStateView TData="MultiIterationBacklogHealthDto"
               State="@_healthState"
               IsLoading="@_isLoading"
               EmptyTitle="No Backlog Health Data Available"
               EmptyMessage="No work items found to analyze. Please sync work items first."
               NotReadyTitle="Backlog health is syncing"
               NotReadyMessage="Backlog health data will load once the cache is ready."
               FailedTitle="Backlog health failed to load">
    <ChildContent Context="healthData">
        <BacklogHealthTrendCard TrendSummary="@healthData.Trend.Summary"
                               IterationCount="@healthData.IterationHealth.Count"
                               TotalWorkItems="@healthData.TotalWorkItems"
                               TotalIssues="@healthData.TotalIssues"
                               EffortTrend="@healthData.Trend.EffortTrend"
                               ValidationTrend="@healthData.Trend.ValidationTrend"
                               BlockerTrend="@healthData.Trend.BlockerTrend" />

        <IterationHealthTable Iterations="@healthData.IterationHealth.Take(3).ToList()" />

        <MudPaper Elevation="1" Class="pa-4 mt-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Issue Comparison Across Iterations</MudText>
            <MudChart ChartType="ChartType.Bar"
                      Width="100%"
                      Height="300px"
                      ChartSeries="@GetComparisonData(healthData)"
                      XAxisLabels="@GetIterationLabels(healthData)"
                      ChartOptions="@_chartOptions">
            </MudChart>
        </MudPaper>
    </ChildContent>
</DataStateView>

@code {
    /// <summary>
    /// Optional product IDs to filter health data. If null, shows data for all products.
    /// </summary>
    [Parameter]
    public IEnumerable<int>? ProductIds { get; set; }
    
    /// <summary>
    /// Optional area path to filter health data.
    /// </summary>
    [Parameter]
    public string? AreaPath { get; set; }
    
    /// <summary>
    /// Maximum number of iterations to display. Default is 5.
    /// </summary>
    [Parameter]
    public int MaxIterations { get; set; } = 5;

    private bool _isLoading = true;
    private DataStateViewModel<MultiIterationBacklogHealthDto> _healthState = DataStateViewModel<MultiIterationBacklogHealthDto>.NotRequested();

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.NaturalSpline
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Reload data when parameters change
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _healthState = DataStateViewModel<MultiIterationBacklogHealthDto>.Loading();
        StateHasChanged();

        var response = await MetricsStateService.GetMultiIterationBacklogHealthStateAsync(
            productOwnerId: null,
            ProductIds?.ToArray(),
            AreaPath,
            MaxIterations,
            CancellationToken.None);

        var envelopeState = DataStateViewModel<SprintQueryResponseDto<MultiIterationBacklogHealthDto>>.FromResponse(
            response,
            "Backlog health data could not be loaded right now.");

        _healthState = envelopeState.State switch
        {
            PoTool.Shared.DataState.DataStateDto.Available when envelopeState.Data?.Data is not null
                => new DataStateViewModel<MultiIterationBacklogHealthDto>(
                    envelopeState.State,
                    envelopeState.Data.Data,
                    envelopeState.Reason,
                    envelopeState.RetryAfterSeconds),
            _ => new DataStateViewModel<MultiIterationBacklogHealthDto>(
                envelopeState.State,
                Reason: envelopeState.Reason,
                RetryAfterSeconds: envelopeState.RetryAfterSeconds)
        };

        _isLoading = false;
        StateHasChanged();
    }

    private List<ChartSeries> GetComparisonData(MultiIterationBacklogHealthDto healthData)
    {
        return HealthCalculationService.GenerateComparisonChartData(healthData);
    }

    private string[] GetIterationLabels(MultiIterationBacklogHealthDto healthData)
    {
        return HealthCalculationService.GetIterationLabels(healthData);
    }
}
