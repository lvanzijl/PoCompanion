@using PoTool.Shared.WorkItems

@* Triage card for a single validation category, showing total item count, top rule groups, and an "Open queue" action. *@
<MudCard Elevation="2" Style="height: 100%;">
    <MudCardHeader>
        <CardHeaderContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@Category.CategoryLabel</MudText>
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@(Category.TotalItemCount > 0 ? IconColor : Color.Default)">
                        @Category.TotalItemCount items
                    </MudChip>
                </MudStack>
            </MudStack>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        @if (Category.TopRuleGroups.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">No issues detected.</MudText>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">Top rule groups:</MudText>
            <MudList T="string" Dense="true">
                @foreach (var group in Category.TopRuleGroups)
                {
                    <MudListItem T="string" Dense="true">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.body2">@ValidationRuleDescriptions.GetTitle(group.RuleId)</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@group.ItemCount</MudChip>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        }
    </MudCardContent>

    <MudCardActions>
        <MudButton Variant="Variant.Filled"
                   Color="@(Category.TotalItemCount > 0 ? Color.Primary : Color.Default)"
                   Disabled="@(Category.TotalItemCount == 0)"
                   StartIcon="@Icons.Material.Filled.Queue"
                   OnClick="HandleOpenQueue"
                   FullWidth="true">
            Open queue
        </MudButton>
    </MudCardActions>
</MudCard>

@code {
    /// <summary>Category data to display.</summary>
    [Parameter, EditorRequired]
    public ValidationCategoryTriageDto Category { get; set; } = null!;

    /// <summary>Icon to display for the category.</summary>
    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.Info;

    /// <summary>Color of the category icon.</summary>
    [Parameter]
    public Color IconColor { get; set; } = Color.Default;

    /// <summary>Callback invoked when the "Open queue" button is clicked.</summary>
    [Parameter]
    public EventCallback OnOpenQueue { get; set; }

    private async Task HandleOpenQueue()
    {
        await OnOpenQueue.InvokeAsync();
    }
}
