@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Client.Pages.PullRequests.SubComponents
@using PoTool.Client.Pages.Pipelines.SubComponents
@using SharedPullRequestMetricsDto = PoTool.Shared.PullRequests.PullRequestMetricsDto
@inject PullRequestService PullRequestService
@inject PipelineService PipelineService

@* Flow Panel - Combined PR and Pipeline metrics for embedding into workspaces *@

<CanonicalDataStateView TData="FlowPanelData"
                        State="@_flowState"
                        Subject="Flow"
                        EmptyTitle="No flow data available"
                        EmptyMessage="No PR or pipeline data is available for the current selection."
                        FailedMessage="Flow data could not be loaded right now."
                        OnRecovery="@LoadDataAsync">
    <ChildContent Context="flowData">
        @if (flowData.PrMetrics.Any())
        {
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.MergeType" Class="mr-2" />
                        Pull Request Metrics
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Primary"
                                   OnClick="LoadDataAsync"
                                   Disabled="@(_flowState.UiState == UiDataState.Loading)" />
                </MudStack>

                <PRMetricsSummaryPanel TotalPRs="@GetTotalPRs(flowData.PrMetrics)"
                                       AvgTimeOpen="@GetAvgTimeOpen(flowData.PrMetrics)"
                                       AvgIterations="@GetAvgIterations(flowData.PrMetrics)"
                                       AvgFiles="@GetAvgFiles(flowData.PrMetrics)" />
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.MergeType" Class="mr-2" />
                    Pull Request Metrics
                </MudText>
                <MudAlert Severity="Severity.Info">No PR data available. Configure repositories in product settings.</MudAlert>
            </MudPaper>
        }

        @if (flowData.PipelineMetrics.Any())
        {
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Engineering" Class="mr-2" />
                    Pipeline Metrics
                </MudText>

                <PipelineMetricsSummaryPanel Metrics="@flowData.PipelineMetrics" />
            </MudPaper>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Engineering" Class="mr-2" />
                    Pipeline Metrics
                </MudText>
                <MudAlert Severity="Severity.Info">No pipeline data available. Check that pipelines exist in your Azure DevOps project.</MudAlert>
            </MudPaper>
        }
    </ChildContent>
</CanonicalDataStateView>

@code {
    [Parameter]
    public IEnumerable<int>? ProductIds { get; set; }

    private DataStateViewModel<FlowPanelData> _flowState = DataStateViewModel<FlowPanelData>.NotRequested();

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _flowState = DataStateViewModel<FlowPanelData>.Loading();
        StateHasChanged();

        try
        {
            string? productIdsParam = ProductIds != null && ProductIds.Any()
                ? string.Join(",", ProductIds)
                : null;

            var prTask = PullRequestService.GetMetricsAsync(productIdsParam);
            var pipelineTask = PipelineService.GetMetricsAsync(productIdsParam);

            await Task.WhenAll(prTask, pipelineTask);

            var prResponse = await prTask;
            var pipelineResponse = await pipelineTask;

            var prMetrics = prResponse.CanUseData
                ? prResponse.Data!.ToList()
                : new List<PullRequestMetricsDto>();
            var pipelineMetrics = pipelineResponse.CanUseData
                ? pipelineResponse.Data!.ToList()
                : new List<PipelineMetricsDto>();

            var failedResponse = prResponse.Status is DataStateResultStatus.Failed or DataStateResultStatus.Invalid
                ? prResponse.Reason
                : pipelineResponse.Status is DataStateResultStatus.Failed or DataStateResultStatus.Invalid
                    ? pipelineResponse.Reason
                    : null;
            if (!string.IsNullOrWhiteSpace(failedResponse))
            {
                _flowState = DataStateViewModel<FlowPanelData>.Failed(failedResponse);
                return;
            }

            _flowState = !prMetrics.Any() && !pipelineMetrics.Any()
                ? DataStateViewModel<FlowPanelData>.Empty("No PR or pipeline data is available for the current selection.")
                : DataStateViewModel<FlowPanelData>.Ready(new FlowPanelData(prMetrics, pipelineMetrics));
        }
        catch (Exception)
        {
            _flowState = DataStateViewModel<FlowPanelData>.Failed("Flow data could not be loaded right now.");
        }

        StateHasChanged();
    }

    private static string GetTotalPRs(IReadOnlyList<SharedPullRequestMetricsDto> prMetrics)
        => prMetrics.Count.ToString();

    private static string GetAvgTimeOpen(IReadOnlyList<SharedPullRequestMetricsDto> prMetrics)
    {
        if (prMetrics.Count == 0)
        {
            return "0.0d";
        }

        var avgDays = prMetrics.Average(metric => metric.TotalTimeOpen.TotalDays);
        return $"{avgDays:F1}d";
    }

    private static string GetAvgIterations(IReadOnlyList<SharedPullRequestMetricsDto> prMetrics)
    {
        if (prMetrics.Count == 0)
        {
            return "0.0";
        }

        var avgIterations = prMetrics.Average(metric => metric.IterationCount);
        return avgIterations.ToString("F1");
    }

    private static string GetAvgFiles(IReadOnlyList<SharedPullRequestMetricsDto> prMetrics)
    {
        if (prMetrics.Count == 0)
        {
            return "0.0";
        }

        var avgFiles = prMetrics.Average(metric => metric.TotalFileCount);
        return avgFiles.ToString("F1");
    }

    private sealed record FlowPanelData(
        IReadOnlyList<SharedPullRequestMetricsDto> PrMetrics,
        IReadOnlyList<PipelineMetricsDto> PipelineMetrics);
}
