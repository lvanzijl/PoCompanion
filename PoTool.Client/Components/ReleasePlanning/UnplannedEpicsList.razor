@using PoTool.Shared.ReleasePlanning
@inject IDialogService DialogService

<MudPaper Class="unplanned-epics-list pa-4 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle1" Class="mb-2 font-weight-bold">
        <MudIcon Icon="@Icons.Material.Filled.ViewList" Size="Size.Small" Class="mr-1" />
        Unplanned Epics
    </MudText>

    @if ((Epics == null || Epics.Count == 0) && (StagedEpics == null || StagedEpics.Count == 0))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            All Epics are placed on the board.
        </MudText>
    }
    else
    {
        <!-- Primary row: Top 5 priority-ordered unplanned epics -->
        @if (Epics != null && Epics.Count > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                Priority Order (Top 5)
            </MudText>
            <div class="epic-chips-container d-flex flex-row flex-wrap gap-2 mb-3" style="overflow-x: hidden;">
                @foreach (var epic in Epics.Take(5))
                {
                    <MudChip T="string"
                             Size="Size.Medium"
                             Color="@GetValidationColor(epic.ValidationIndicator)"
                             Variant="Variant.Outlined"
                             Class="unplanned-epic-chip"
                             draggable="true"
                             @ondragstart="@(() => HandleDragStart(epic))">
                        <div class="d-flex align-center gap-1">
                            @if (epic.ValidationIndicator != ValidationIndicator.None)
                            {
                                <MudIcon Icon="@GetValidationIcon(epic.ValidationIndicator)" 
                                         Size="Size.Small" />
                            }
                            <span class="text-truncate" style="max-width: 200px;">
                                @epic.Title
                            </span>
                            @if (epic.Effort.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                    @epic.Effort
                                </MudChip>
                            }
                        </div>
                    </MudChip>
                }
                
                @if (Epics.Count > 5)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="@ShowAllEpics">
                        +@(Epics.Count - 5) more
                    </MudButton>
                }
            </div>
        }

        <!-- Secondary row: Staged epics from "+X more" dialog -->
        @if (StagedEpics != null && StagedEpics.Count > 0)
        {
            <MudDivider Class="mb-2" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                Selected for Planning
            </MudText>
            <div class="epic-chips-container d-flex flex-row flex-wrap gap-2" style="overflow-x: hidden;">
                @foreach (var epic in StagedEpics)
                {
                    <MudChip T="string"
                             Size="Size.Medium"
                             Color="Color.Primary"
                             Variant="Variant.Filled"
                             Class="unplanned-epic-chip"
                             draggable="true"
                             OnClose="@(() => HandleRemoveStaged(epic))"
                             @ondragstart="@(() => HandleDragStart(epic))">
                        <div class="d-flex align-center gap-1">
                            @if (epic.ValidationIndicator != ValidationIndicator.None)
                            {
                                <MudIcon Icon="@GetValidationIcon(epic.ValidationIndicator)" 
                                         Size="Size.Small" />
                            }
                            <span class="text-truncate" style="max-width: 200px;">
                                @epic.Title
                            </span>
                            @if (epic.Effort.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                    @epic.Effort
                                </MudChip>
                            }
                        </div>
                    </MudChip>
                }
            </div>
        }
    }
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<UnplannedEpicDto>? Epics { get; set; }

    [Parameter]
    public List<UnplannedEpicDto>? StagedEpics { get; set; }

    [Parameter]
    public EventCallback<EpicDropEventArgs> OnEpicDrop { get; set; }

    [Parameter]
    public EventCallback<(int EpicId, int ObjectiveId)> OnEpicDragStart { get; set; }

    [Parameter]
    public EventCallback<UnplannedEpicDto> OnEpicStaged { get; set; }

    private UnplannedEpicDto? _draggingEpic;

    private async Task HandleDragStart(UnplannedEpicDto epic)
    {
        _draggingEpic = epic;
        await OnEpicDragStart.InvokeAsync((epic.EpicId, epic.ObjectiveId));
    }

    private void HandleRemoveStaged(UnplannedEpicDto epic)
    {
        StagedEpics?.Remove(epic);
        StateHasChanged();
    }

    private static Color GetValidationColor(ValidationIndicator indicator)
    {
        return indicator switch
        {
            ValidationIndicator.Error => Color.Error,
            ValidationIndicator.Warning => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetValidationIcon(ValidationIndicator indicator)
    {
        return indicator switch
        {
            ValidationIndicator.Error => Icons.Material.Filled.Error,
            ValidationIndicator.Warning => Icons.Material.Filled.Warning,
            _ => Icons.Material.Filled.CheckCircle
        };
    }

    private async Task ShowAllEpics()
    {
        if (Epics == null || Epics.Count == 0)
        {
            return;
        }

        var parameters = new DialogParameters<UnplannedEpicsDialog>
        {
            { x => x.Epics, Epics },
            { x => x.OnEpicSelected, EventCallback.Factory.Create<UnplannedEpicDto>(this, HandleEpicSelectedFromDialog) }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<UnplannedEpicsDialog>("All Unplanned Epics", parameters, options);
    }

    private async Task HandleEpicSelectedFromDialog(UnplannedEpicDto epic)
    {
        await OnEpicStaged.InvokeAsync(epic);
    }
}

<style>
    .unplanned-epics-list {
        background-color: var(--mud-palette-background-grey);
    }

    .unplanned-epic-chip {
        cursor: grab;
    }

    .unplanned-epic-chip:active {
        cursor: grabbing;
    }
</style>
