@using PoTool.Shared.ReleasePlanning

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-2" />
            Add Iteration Line
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2">
                Iteration lines mark sprint boundaries on the planning board.
            </MudText>

            <!-- Label -->
            <MudTextField @bind-Value="_label" 
                          Label="Iteration Label"
                          Variant="Variant.Outlined"
                          Required="true"
                          Placeholder="e.g., Sprint 1, Iteration 2" />

            <!-- Position -->
            <MudNumericField @bind-Value="_verticalPosition" 
                             Label="Vertical Position"
                             Variant="Variant.Outlined"
                             Required="true"
                             Step="0.5"
                             Min="0"
                             HideSpinButtons="false"
                             HelperText="Position between rows (e.g., 0.5 places line between row 0 and 1)" />

            @if (_verticalPosition >= 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.body2">
                        The iteration line will appear @GetPositionDescription()
                    </MudText>
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Add" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_label) || _verticalPosition < 0 || _isAdding)"
                   StartIcon="@(_isAdding ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.Add)">
            @(_isAdding ? "Adding..." : "Add Iteration")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public int MaxRowIndex { get; set; } = 0;

    private string _label = string.Empty;
    private double _verticalPosition = 0.5;
    private bool _isAdding;

    protected override void OnInitialized()
    {
        // Default to position after the first row
        _verticalPosition = MaxRowIndex > 0 ? 0.5 : 0.5;
    }

    private string GetPositionDescription()
    {
        var wholePart = Math.Floor(_verticalPosition);
        var fractionalPart = _verticalPosition - wholePart;

        if (Math.Abs(fractionalPart - 0.5) < 0.01)
        {
            return $"between row {(int)wholePart} and row {(int)wholePart + 1}";
        }
        else if (fractionalPart < 0.01)
        {
            return $"at the top of row {(int)wholePart}";
        }
        else
        {
            return $"near row {(int)Math.Round(_verticalPosition)}";
        }
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(_label) || _verticalPosition < 0)
            return;

        _isAdding = true;
        StateHasChanged();

        try
        {
            var result = new IterationLineData(_label, _verticalPosition);
            MudDialog?.Close(DialogResult.Ok(result));
        }
        finally
        {
            _isAdding = false;
        }
    }

    public record IterationLineData(string Label, double VerticalPosition);
}
