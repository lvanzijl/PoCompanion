@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@inject WorkItemService WorkItemService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
            Add Lane
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading Objectives...</MudText>
        }
        else
        {
            <DataStateView TData="IReadOnlyList<WorkItemDto>"
                           State="@_objectiveState"
                           EmptyTitle="No Objectives available"
                           EmptyMessage="All Objectives may already be added or no Objectives exist in the current Program Increment."
                           NotReadyTitle="Objectives are syncing"
                           NotReadyMessage="Objective data will load once the cache is ready."
                           FailedTitle="Objectives failed to load">
                <ChildContent Context="objectives">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.body2">
                            Select an Objective to add as a lane on the Release Planning Board.
                        </MudText>

                        <MudSelect T="int?"
                                   @bind-Value="_selectedObjectiveId"
                                   Label="Objective"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Placeholder="Select an Objective">
                            @foreach (var objective in objectives)
                            {
                                <MudSelectItem Value="@((int?)objective.TfsId)">
                                    @objective.Title
                                </MudSelectItem>
                            }
                        </MudSelect>

                        @if (_selectedObjectiveId.HasValue)
                        {
                            var selectedObj = objectives.FirstOrDefault(o => o.TfsId == _selectedObjectiveId.Value);
                            if (selectedObj != null)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true">
                                    <MudText Typo="Typo.body2">
                                        This will add a lane for <strong>@selectedObj.Title</strong> to the planning board.
                                    </MudText>
                                </MudAlert>
                            }
                        }
                    </MudStack>
                </ChildContent>
            </DataStateView>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Add" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@(!_selectedObjectiveId.HasValue || _isAdding)"
                   StartIcon="@(_isAdding ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.Add)">
            @(_isAdding ? "Adding..." : "Add Lane")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public IReadOnlyList<int> ExistingObjectiveIds { get; set; } = [];

    private List<WorkItemDto> _availableObjectives = new();
    private DataStateViewModel<IReadOnlyList<WorkItemDto>> _objectiveState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.NotRequested();
    private int? _selectedObjectiveId;
    private bool _isLoading = true;
    private bool _isAdding;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableObjectivesAsync();
    }

    private async Task LoadAvailableObjectivesAsync()
    {
        _isLoading = true;
        _objectiveState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.Loading();
        StateHasChanged();

        var response = await WorkItemService.GetAllStateAsync();
        var state = DataStateViewModel<IReadOnlyList<WorkItemDto>>.FromResponse(
            response,
            "Objective data could not be loaded right now.");

        _objectiveState = state.State == PoTool.Shared.DataState.DataStateDto.Available
            ? state with
            {
                Data = state.Data?
                    .Where(w => w.Type.Equals("Objective", StringComparison.OrdinalIgnoreCase))
                    .Where(w => !ExistingObjectiveIds.Contains(w.TfsId))
                    .OrderBy(w => w.Title)
                    .ToList() ?? new List<WorkItemDto>()
            }
            : state;

        _availableObjectives = _objectiveState.Data?.ToList() ?? [];

        _isLoading = false;
        StateHasChanged();
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private async Task Add()
    {
        if (!_selectedObjectiveId.HasValue)
            return;

        _isAdding = true;
        StateHasChanged();

        try
        {
            // Return the selected objective ID to the caller
            MudDialog?.Close(DialogResult.Ok(_selectedObjectiveId.Value));
        }
        finally
        {
            _isAdding = false;
        }
    }
}
