@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@inject WorkItemService WorkItemService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
            Add Lane
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading Objectives...</MudText>
        }
        else if (_availableObjectives.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No Objectives available to add as lanes. All Objectives may already be added or no Objectives exist in the current Program Increment.
            </MudAlert>
        }
        else
        {
            <MudStack Spacing="3">
                <MudText Typo="Typo.body2">
                    Select an Objective to add as a lane on the Release Planning Board.
                </MudText>

                <MudSelect T="int?" 
                           @bind-Value="_selectedObjectiveId" 
                           Label="Objective"
                           Variant="Variant.Outlined"
                           Required="true"
                           Placeholder="Select an Objective">
                    @foreach (var objective in _availableObjectives)
                    {
                        <MudSelectItem Value="@((int?)objective.TfsId)">
                            @objective.Title
                        </MudSelectItem>
                    }
                </MudSelect>

                @if (_selectedObjectiveId.HasValue)
                {
                    var selectedObj = _availableObjectives.FirstOrDefault(o => o.TfsId == _selectedObjectiveId.Value);
                    if (selectedObj != null)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            <MudText Typo="Typo.body2">
                                This will add a lane for <strong>@selectedObj.Title</strong> to the planning board.
                            </MudText>
                        </MudAlert>
                    }
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Add" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   Disabled="@(!_selectedObjectiveId.HasValue || _isAdding)"
                   StartIcon="@(_isAdding ? Icons.Material.Filled.HourglassTop : Icons.Material.Filled.Add)">
            @(_isAdding ? "Adding..." : "Add Lane")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public IReadOnlyList<int> ExistingObjectiveIds { get; set; } = [];

    private List<WorkItemDto> _availableObjectives = new();
    private int? _selectedObjectiveId;
    private bool _isLoading = true;
    private bool _isAdding;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableObjectivesAsync();
    }

    private async Task LoadAvailableObjectivesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            var allWorkItems = await WorkItemService.GetAllAsync();
            
            // Filter for Objectives that are not already on the board
            _availableObjectives = allWorkItems
                .Where(w => w.Type.Equals("Objective", StringComparison.OrdinalIgnoreCase))
                .Where(w => !ExistingObjectiveIds.Contains(w.TfsId))
                .OrderBy(w => w.Title)
                .ToList();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private async Task Add()
    {
        if (!_selectedObjectiveId.HasValue)
            return;

        _isAdding = true;
        StateHasChanged();

        try
        {
            // Return the selected objective ID to the caller
            MudDialog?.Close(DialogResult.Ok(_selectedObjectiveId.Value));
        }
        finally
        {
            _isAdding = false;
        }
    }
}
