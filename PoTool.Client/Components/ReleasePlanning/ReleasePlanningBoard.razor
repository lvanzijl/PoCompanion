@using PoTool.Shared.ReleasePlanning
@using PoTool.Client.Services
@inject ReleasePlanningService ReleasePlanningService
@inject ILogger<ReleasePlanningBoard> Logger
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudPaper Class="release-planning-board pa-4" Elevation="0" @onkeydown="@HandleKeyDown" tabindex="0">
    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Class="mt-2">Loading Release Planning Board...</MudText>
    }
    else if (_board == null)
    {
        <MudAlert Severity="Severity.Warning">
            Unable to load the Release Planning Board. Please try again.
        </MudAlert>
    }
    else
    {
        <!-- Unplanned Epics Source List -->
        <UnplannedEpicsList 
            Epics="_unplannedEpics"
            StagedEpics="_stagedEpics"
            OnEpicDrop="@HandleEpicDrop"
            OnEpicDragStart="@(args => HandleUnplannedEpicDragStart(args.Item1, args.Item2))"
            OnEpicStaged="@HandleEpicStaged" />

        <!-- Board Container -->
        <MudPaper Class="board-container mt-4" Elevation="1">
            @if (_board.Lanes.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-4">
                    No Lanes configured. Add Objectives to the board to get started.
                </MudAlert>
            }
            else
            {
                <!-- Lane Headers -->
                <div class="lane-headers d-flex">
                    @foreach (var lane in _board.Lanes)
                    {
                        <div class="lane-header flex-grow-1 pa-2">
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                @lane.ObjectiveTitle
                            </MudText>
                        </div>
                    }
                </div>

                <!-- Row Grid with Lanes and Connectors -->
                <div class="board-grid" style="position: relative;">
                    <!-- SVG Connector Layer -->
                    <ConnectorRenderer 
                        Connectors="_board.Connectors"
                        Placements="_board.Placements"
                        Lanes="_board.Lanes"
                        RowHeight="80"
                        CardWidth="180"
                        CardHeight="60"
                        LaneWidth="200" />
                    
                    @if (_board.Lanes.Count > 0)
                    {
                        <!-- Drop zone before first row -->
                        <div class="drop-zone-between-rows" 
                             style="height: 20px; position: relative; z-index: 1;"
                             @ondragover:preventDefault
                             @ondragover="@(() => HandleDropZoneDragOver(0))"
                             @ondrop="@(async () => await HandleInsertBeforeRow(0))">
                            @if (_dropTargetRowIndex == 0 && _isDraggingEpic)
                            {
                                <div class="drop-placeholder">Drop here to place at top</div>
                            }
                        </div>
                    }

                    @for (int row = 0; row <= _board.MaxRowIndex; row++)
                    {
                        var currentRow = row;
                        var linesAtPosition = GetLinesAtPosition(currentRow + 0.5);
                        <div class="row-container d-flex" style="min-height: 80px; position: relative;">
                            @foreach (var lane in _board.Lanes)
                            {
                                var lanePlacements = _board.Placements
                                    .Where(p => p.LaneId == lane.Id && p.RowIndex == currentRow)
                                    .OrderBy(p => p.OrderInRow)
                                    .ToList();

                                var isDropTarget = _dropTargetLaneId == lane.Id && _dropTargetRowIndex == currentRow;
                                var laneRowClass = isDropTarget ? "lane-row flex-grow-1 pa-2 drop-target" : "lane-row flex-grow-1 pa-2";

                                <div class="@laneRowClass"
                                     style="border-right: 2px solid var(--mud-palette-divider); position: relative; z-index: 2;"
                                     @ondragover:preventDefault
                                     @ondragover="@(() => HandleRowDragOver(lane.ObjectiveId, currentRow))"
                                     @ondrop="@(async () => await HandleRowDrop(lane.ObjectiveId, currentRow))">
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var placement in lanePlacements)
                                        {
                                            var epicClass = GetEpicPreviewClass(placement, currentRow);
                                            
                                            // Add "being dragged" class if this is the epic being dragged
                                            if (_draggingPlacementId.HasValue && placement.Id == _draggingPlacementId.Value)
                                            {
                                                epicClass = string.IsNullOrEmpty(epicClass) 
                                                    ? "epic-being-dragged" 
                                                    : $"{epicClass} epic-being-dragged";
                                            }
                                            
                                            <div class="@epicClass">
                                                <EpicCard 
                                                    Placement="@placement"
                                                    ObjectiveId="@lane.ObjectiveId"
                                                    IsSelected="@(_selectedPlacementId == placement.Id)"
                                                    OnDragStart="@HandlePlannedEpicDragStart"
                                                    OnSelected="@HandleEpicSelected"
                                                    OnMove="@HandleEpicMove"
                                                    OnContextMenu="@HandleEpicContextMenu"
                                                    OnSplitRequested="@HandleEpicSplit"
                                                    OnViewDetailsRequested="@HandleViewDetails" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Horizontal Lines between rows - full width across all lanes -->
                        <div class="lines-container" style="position: relative; pointer-events: none;">
                            @foreach (var line in linesAtPosition.MilestoneLines)
                            {
                                var isBeingDragged = _draggingLineId == line.Id;
                                var lineClass = isBeingDragged ? "milestone-line draggable-line line-being-dragged" : "milestone-line draggable-line";
                                <div class="@lineClass"
                                     style="pointer-events: auto; width: 100%;"
                                     draggable="true"
                                     @ondragstart="@(e => HandleLineStartDrag(line.Id, true, line.Label, line.Type, line.VerticalPosition))"
                                     @ondragover:preventDefault
                                     @ondragover="@(e => HandleLineDragOver(e, currentRow + 0.5))"
                                     @ondrop="@(async e => await HandleLineDrop(line.Id, true))">
                                    <MudDivider DividerType="DividerType.FullWidth" 
                                                Class="milestone-line-divider" 
                                                Style="pointer-events: none;" />
                                    <MudChip T="string" 
                                             Size="Size.Small" 
                                             Color="Color.Primary"
                                             Icon="@Icons.Material.Filled.DragHandle"
                                             Class="line-label"
                                             Style="pointer-events: auto;">
                                        @line.Label
                                    </MudChip>
                                </div>
                            }
                            @foreach (var line in linesAtPosition.IterationLines)
                            {
                                var isBeingDragged = _draggingLineId == line.Id;
                                var lineClass = isBeingDragged ? "iteration-line draggable-line line-being-dragged" : "iteration-line draggable-line";
                                <div class="@lineClass"
                                     style="pointer-events: auto; width: 100%;"
                                     draggable="true"
                                     @ondragstart="@(e => HandleLineStartDrag(line.Id, false, line.Label, default, line.VerticalPosition))"
                                     @ondragover:preventDefault
                                     @ondragover="@(e => HandleLineDragOver(e, currentRow + 0.5))"
                                     @ondrop="@(async e => await HandleLineDrop(line.Id, false))">
                                    <MudDivider DividerType="DividerType.FullWidth" 
                                                Class="iteration-line-divider" 
                                                Style="border-style: dashed; pointer-events: none;" />
                                    <MudChip T="string" 
                                             Size="Size.Small" 
                                             Color="Color.Secondary"
                                             Variant="Variant.Outlined"
                                             Icon="@Icons.Material.Filled.DragHandle"
                                             Class="line-label"
                                             Style="pointer-events: auto;">
                                        @line.Label
                                    </MudChip>
                                </div>
                            }

                            <!-- Preview Line during drag -->
                            @if (IsPreviewLineAtPosition(currentRow + 0.5))
                            {
                                <div class="@(_draggingIsMilestone ? "milestone-line-preview" : "iteration-line-preview")">
                                    <MudDivider DividerType="DividerType.FullWidth" 
                                                Class="@(_draggingIsMilestone ? "milestone-line-divider" : "iteration-line-divider")"
                                                Style="@(_draggingIsMilestone ? "pointer-events: none;" : "border-style: dashed; pointer-events: none;")" />
                                    <MudChip T="string" 
                                             Size="Size.Small" 
                                             Color="@(_draggingIsMilestone ? Color.Primary : Color.Secondary)"
                                             Variant="@(_draggingIsMilestone ? Variant.Filled : Variant.Outlined)"
                                             Class="line-label">
                                        @_draggingLineLabel (Preview)
                                    </MudChip>
                                </div>
                            }
                        </div>

                        <!-- Drop zone between rows -->
                        <div class="drop-zone-between-rows" 
                             style="height: 20px; position: relative; z-index: 1;"
                             @ondragover:preventDefault
                             @ondragover="@(() => HandleDropZoneDragOver(currentRow + 1))"
                             @ondrop="@(async () => await HandleInsertBeforeRow(currentRow + 1))">
                            @if (_dropTargetRowIndex == currentRow + 1 && _isDraggingEpic)
                            {
                                <div class="drop-placeholder">Drop here</div>
                            }
                        </div>
                    }
                </div>
            }
        </MudPaper>
    }
</MudPaper>

@code {
    private ReleasePlanningBoardDto? _board;
    private IReadOnlyList<UnplannedEpicDto>? _unplannedEpics;
    private List<UnplannedEpicDto> _stagedEpics = new(); // Epics selected from "+X more" dialog
    private bool _isLoading = true;

    // Epic selection state (Issue #5)
    private int? _selectedPlacementId;

    // Epic dragging state
    private int? _draggingEpicId;
    private int? _draggingObjectiveId;
    private int? _draggingPlacementId; // For planned epics
    private bool _isDraggingFromUnplanned;
    private bool _isDraggingEpic => _draggingEpicId.HasValue;

    // Drop target preview state
    private int? _dropTargetLaneId;
    private int? _dropTargetRowIndex;

    // Line dragging state
    private int? _draggingLineId;
    private bool _draggingIsMilestone;
    private string _draggingLineLabel = string.Empty;
    private MilestoneType _draggingMilestoneType;
    private double _draggingOriginalPosition;
    private double? _draggingTargetPosition;

    // Constants for drag behavior
    private const double POSITION_TOLERANCE = 0.1;

    protected override async Task OnInitializedAsync()
    {
        await LoadBoardAsync();
    }

    private async Task LoadBoardAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _board = await ReleasePlanningService.GetBoardAsync();
            _unplannedEpics = await ReleasePlanningService.GetUnplannedEpicsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading Release Planning Board");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    #region Epic Drag and Drop

    /// <summary>
    /// Called when an epic starts being dragged from the unplanned list.
    /// </summary>
    private void HandleUnplannedEpicDragStart(int epicId, int objectiveId)
    {
        _draggingEpicId = epicId;
        _draggingObjectiveId = objectiveId;
        _draggingPlacementId = null;
        _isDraggingFromUnplanned = true;
        Logger.LogDebug("Started dragging unplanned Epic {EpicId} from Objective {ObjectiveId}", epicId, objectiveId);
    }

    /// <summary>
    /// Called when a planned epic starts being dragged from the board.
    /// </summary>
    private void HandlePlannedEpicDragStart((int PlacementId, int EpicId, int ObjectiveId) args)
    {
        _draggingEpicId = args.EpicId;
        _draggingObjectiveId = args.ObjectiveId;
        _draggingPlacementId = args.PlacementId;
        _isDraggingFromUnplanned = false;
        Logger.LogDebug("Started dragging planned Epic {EpicId} (Placement {PlacementId}) from Objective {ObjectiveId}", 
            args.EpicId, args.PlacementId, args.ObjectiveId);
    }

    /// <summary>
    /// Called when dragging over a lane row.
    /// </summary>
    private void HandleRowDragOver(int objectiveId, int rowIndex)
    {
        // Validate that the epic can be dropped here
        // Per spec: Epics can only be placed in their parent Objective's lane
        if (_draggingEpicId.HasValue && _draggingObjectiveId.HasValue)
        {
            if (_draggingObjectiveId.Value != objectiveId)
            {
                Logger.LogDebug("Cannot drop Epic {EpicId} into lane for different Objective {ObjectiveId}", 
                    _draggingEpicId.Value, objectiveId);
                return;
            }

            // Find the lane
            var lane = _board?.Lanes.FirstOrDefault(l => l.ObjectiveId == objectiveId);
            if (lane != null)
            {
                // Update drop target preview state
                _dropTargetLaneId = lane.Id;
                _dropTargetRowIndex = rowIndex;
                StateHasChanged();
            }
        }
    }

    /// <summary>
    /// Called when dragging over a drop zone between rows.
    /// </summary>
    private void HandleDropZoneDragOver(int targetRowIndex)
    {
        if (_draggingEpicId.HasValue && _draggingObjectiveId.HasValue)
        {
            // For drop zones, we set the row index but clear the lane ID
            _dropTargetLaneId = null;
            _dropTargetRowIndex = targetRowIndex;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Called when an epic is dropped onto a lane row.
    /// </summary>
    private async Task HandleRowDrop(int objectiveId, int rowIndex)
    {
        if (!_draggingEpicId.HasValue || !_draggingObjectiveId.HasValue)
        {
            ResetEpicDragState();
            ResetDropTargetState();
            return;
        }

        // Validate that epic belongs to this objective
        if (_draggingObjectiveId.Value != objectiveId)
        {
            Snackbar.Add("Epics can only be placed in their parent Objective's lane", Severity.Warning);
            ResetEpicDragState();
            ResetDropTargetState();
            return;
        }

        // Find the lane
        var lane = _board?.Lanes.FirstOrDefault(l => l.ObjectiveId == objectiveId);
        if (lane == null)
        {
            ResetEpicDragState();
            ResetDropTargetState();
            return;
        }

        // Calculate OrderInRow: place at the end of the row
        var existingPlacementsInRow = _board?.Placements
            .Where(p => p.LaneId == lane.Id && p.RowIndex == rowIndex && p.Id != _draggingPlacementId)
            .OrderBy(p => p.OrderInRow)
            .ToList() ?? new List<EpicPlacementDto>();
        
        int orderInRow = existingPlacementsInRow.Count > 0 
            ? existingPlacementsInRow.Max(p => p.OrderInRow) + 1 
            : 0;

        if (_isDraggingFromUnplanned)
        {
            // Create a new placement
            await HandleEpicDrop(new EpicDropEventArgs
            {
                EpicId = _draggingEpicId.Value,
                ObjectiveId = objectiveId,
                RowIndex = rowIndex
            });
        }
        else if (_draggingPlacementId.HasValue)
        {
            // Move existing placement
            await HandleEpicMove(new EpicMoveEventArgs
            {
                PlacementId = _draggingPlacementId.Value,
                NewRowIndex = rowIndex,
                NewOrderInRow = orderInRow
            });
        }

        ResetEpicDragState();
        ResetDropTargetState();
    }

    /// <summary>
    /// Resets drop target preview state.
    /// </summary>
    private void ResetDropTargetState()
    {
        _dropTargetLaneId = null;
        _dropTargetRowIndex = null;
    }

    /// <summary>
    /// Resets epic drag state.
    /// </summary>
    private void ResetEpicDragState()
    {
        _draggingEpicId = null;
        _draggingObjectiveId = null;
        _draggingPlacementId = null;
        _isDraggingFromUnplanned = false;
    }

    #endregion

    #region Epic Selection and Deletion (Issue #5)

    /// <summary>
    /// Handles keyboard input for the board (e.g., Delete key).
    /// </summary>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Delete" && _selectedPlacementId.HasValue)
        {
            await DeleteSelectedEpic();
        }
        else if (e.Key == "Escape")
        {
            // Clear selection on Escape
            _selectedPlacementId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Handles epic selection (clicking on a card).
    /// </summary>
    private void HandleEpicSelected(int placementId)
    {
        // Toggle selection: if already selected, deselect; otherwise select
        if (_selectedPlacementId == placementId)
        {
            _selectedPlacementId = null;
        }
        else
        {
            _selectedPlacementId = placementId;
        }
        StateHasChanged();
        Logger.LogDebug("Epic placement {PlacementId} selected: {IsSelected}", placementId, _selectedPlacementId.HasValue);
    }

    /// <summary>
    /// Deletes the currently selected epic from the board.
    /// Returns it to the unplanned list.
    /// </summary>
    private async Task DeleteSelectedEpic()
    {
        if (!_selectedPlacementId.HasValue)
        {
            return;
        }

        var placementId = _selectedPlacementId.Value;
        var placement = _board?.Placements.FirstOrDefault(p => p.Id == placementId);
        
        if (placement == null)
        {
            Logger.LogWarning("Attempted to delete non-existent placement {PlacementId}", placementId);
            _selectedPlacementId = null;
            return;
        }

        try
        {
            var result = await ReleasePlanningService.DeletePlacementAsync(placementId);
            
            if (result?.Success == true)
            {
                Snackbar.Add($"Epic '{placement.EpicTitle}' removed from board", Severity.Success);
                _selectedPlacementId = null; // Clear selection
                await LoadBoardAsync(); // Reload to reflect changes
            }
            else
            {
                Snackbar.Add($"Failed to remove Epic: {result?.ErrorMessage}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error deleting epic placement {PlacementId}", placementId);
            Snackbar.Add("Error removing Epic from board", Severity.Error);
        }
    }

    #endregion

    /// <summary>
    /// Handles dropping an epic into a space between rows (creates a new row).
    /// </summary>
    private async Task HandleInsertBeforeRow(int targetRow)
    {
        if (!_draggingEpicId.HasValue || !_draggingObjectiveId.HasValue)
        {
            ResetEpicDragState();
            ResetDropTargetState();
            return;
        }

        // Find the lane for this objective
        var lane = _board?.Lanes.FirstOrDefault(l => l.ObjectiveId == _draggingObjectiveId.Value);
        if (lane == null)
        {
            Snackbar.Add("Cannot place epic: lane not found", Severity.Warning);
            ResetEpicDragState();
            ResetDropTargetState();
            return;
        }

        // For inserting before a row, we place at that row index
        // The existing epics will be shifted down by the service
        if (_isDraggingFromUnplanned)
        {
            await HandleEpicDrop(new EpicDropEventArgs
            {
                EpicId = _draggingEpicId.Value,
                ObjectiveId = _draggingObjectiveId.Value,
                RowIndex = targetRow
            });
        }
        else if (_draggingPlacementId.HasValue)
        {
            await HandleEpicMove(new EpicMoveEventArgs
            {
                PlacementId = _draggingPlacementId.Value,
                NewRowIndex = targetRow,
                NewOrderInRow = 0
            });
        }

        ResetEpicDragState();
        ResetDropTargetState();
    }

    private async Task HandleEpicDrop(EpicDropEventArgs args)
    {
        if (_board == null) return;

        // Find the lane for this Objective
        var lane = _board.Lanes.FirstOrDefault(l => l.ObjectiveId == args.ObjectiveId);
        if (lane == null)
        {
            // Create the lane if it doesn't exist
            var result = await ReleasePlanningService.CreateLaneAsync(args.ObjectiveId, _board.Lanes.Count);
            if (result?.Success != true)
            {
                Logger.LogError("Failed to create lane for Objective {ObjectiveId}", args.ObjectiveId);
                Snackbar.Add("Failed to create lane for Objective", Severity.Error);
                return;
            }
            await LoadBoardAsync();
            lane = _board?.Lanes.FirstOrDefault(l => l.ObjectiveId == args.ObjectiveId);
            if (lane == null) return;
        }

        // Create the placement
        var placementResult = await ReleasePlanningService.CreatePlacementAsync(
            args.EpicId, 
            lane.Id, 
            args.RowIndex, 
            0);

        if (placementResult?.Success == true)
        {
            Snackbar.Add("Epic placed on board", Severity.Success);
            
            // Remove from staged epics if it was there
            _stagedEpics.RemoveAll(e => e.EpicId == args.EpicId);
            
            await LoadBoardAsync();
        }
        else
        {
            Logger.LogError("Failed to create placement for Epic {EpicId}", args.EpicId);
            Snackbar.Add("Failed to place Epic on board", Severity.Error);
        }
    }

    private async Task HandleEpicMove(EpicMoveEventArgs args)
    {
        var result = await ReleasePlanningService.MoveEpicAsync(
            args.PlacementId, 
            args.NewRowIndex, 
            args.NewOrderInRow);

        if (result?.Success == true)
        {
            Snackbar.Add("Epic moved successfully", Severity.Success);
            await LoadBoardAsync();
        }
        else
        {
            Snackbar.Add("Failed to move Epic", Severity.Error);
        }
    }

    private void HandleEpicContextMenu(EpicContextMenuEventArgs args)
    {
        // Context menu actions are now handled by dedicated event handlers
        Logger.LogDebug("Context menu requested for Epic {EpicId}", args.EpicId);
    }

    private async Task HandleEpicSplit(EpicSplitEventArgs args)
    {
        var parameters = new DialogParameters<SplitEpicDialog>
        {
            { x => x.EpicId, args.EpicId },
            { x => x.EpicTitle, args.EpicTitle }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SplitEpicDialog>("Split Epic", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EpicSplitResultDto splitResult })
        {
            if (splitResult.Success)
            {
                Snackbar.Add($"Epic split successfully! New Epic ID: {splitResult.ExtractedEpicId}", Severity.Success);
                await LoadBoardAsync();
            }
            else
            {
                Snackbar.Add($"Failed to split Epic: {splitResult.ErrorMessage}", Severity.Error);
            }
        }
    }

    private void HandleViewDetails(EpicViewDetailsEventArgs args)
    {
        // Navigate to Work Item Explorer with the Epic selected
        Navigation.NavigateTo($"/workitems?selected={args.EpicId}");
    }

    /// <summary>
    /// Called when an epic is staged from the "+X more" dialog.
    /// </summary>
    private void HandleEpicStaged(UnplannedEpicDto epic)
    {
        // Add to staged list if not already there
        if (!_stagedEpics.Any(e => e.EpicId == epic.EpicId))
        {
            _stagedEpics.Add(epic);
            StateHasChanged();
            Logger.LogDebug("Staged Epic {EpicId} for planning", epic.EpicId);
        }
    }

    private (IEnumerable<MilestoneLineDto> MilestoneLines, IEnumerable<IterationLineDto> IterationLines) GetLinesAtPosition(double position)
    {
        if (_board == null)
        {
            return (Enumerable.Empty<MilestoneLineDto>(), Enumerable.Empty<IterationLineDto>());
        }

        var milestoneLines = _board.MilestoneLines
            .Where(l => Math.Abs(l.VerticalPosition - position) < 0.5);
        var iterationLines = _board.IterationLines
            .Where(l => Math.Abs(l.VerticalPosition - position) < 0.5);

        return (milestoneLines, iterationLines);
    }

    #region Line Dragging

    private void HandleLineStartDrag(int lineId, bool isMilestone, string label, MilestoneType type, double verticalPosition)
    {
        _draggingLineId = lineId;
        _draggingIsMilestone = isMilestone;
        _draggingLineLabel = label;
        _draggingMilestoneType = type;
        _draggingOriginalPosition = verticalPosition;
        _draggingTargetPosition = null;
        Logger.LogDebug("Started dragging {LineType} line {LineId} from position {Position}", 
            isMilestone ? "milestone" : "iteration", lineId, verticalPosition);
    }

    private void HandleLineDragOver(DragEventArgs e, double rowPosition)
    {
        if (_draggingLineId == null) return;
        
        // Update target position for visual feedback
        if (_draggingTargetPosition != rowPosition)
        {
            _draggingTargetPosition = rowPosition;
            StateHasChanged(); // Trigger re-render to show preview
        }
    }

    private async Task HandleLineDrop(int lineId, bool isMilestone)
    {
        if (_draggingLineId == null || _draggingTargetPosition == null)
        {
            ResetLineDragState();
            return;
        }

        // Don't update if dropped at original position
        if (Math.Abs(_draggingTargetPosition.Value - _draggingOriginalPosition) < POSITION_TOLERANCE)
        {
            ResetLineDragState();
            return;
        }

        try
        {
            LineOperationResultDto? result = null;

            if (_draggingIsMilestone)
            {
                result = await ReleasePlanningService.UpdateMilestoneLineAsync(
                    _draggingLineId.Value,
                    _draggingLineLabel,
                    _draggingTargetPosition.Value,
                    _draggingMilestoneType);
            }
            else
            {
                result = await ReleasePlanningService.UpdateIterationLineAsync(
                    _draggingLineId.Value,
                    _draggingLineLabel,
                    _draggingTargetPosition.Value);
            }

            if (result?.Success == true)
            {
                Snackbar.Add($"{(_draggingIsMilestone ? "Milestone" : "Iteration")} line repositioned successfully", Severity.Success);
                await LoadBoardAsync();
            }
            else
            {
                Snackbar.Add($"Failed to reposition {(_draggingIsMilestone ? "milestone" : "iteration")} line", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error repositioning line {LineId}", _draggingLineId);
            Snackbar.Add("Error repositioning line", Severity.Error);
        }
        finally
        {
            ResetLineDragState();
        }
    }

    private void ResetLineDragState()
    {
        _draggingLineId = null;
        _draggingIsMilestone = false;
        _draggingLineLabel = string.Empty;
        _draggingMilestoneType = default;
        _draggingOriginalPosition = 0;
        _draggingTargetPosition = null;
        StateHasChanged(); // Clear preview
    }

    /// <summary>
    /// Determines if the preview line should be shown at the given position.
    /// </summary>
    private bool IsPreviewLineAtPosition(double position)
    {
        return _draggingLineId != null 
            && _draggingTargetPosition != null 
            && Math.Abs(_draggingTargetPosition.Value - position) < POSITION_TOLERANCE;
    }

    /// <summary>
    /// Determines the CSS class for an Epic card based on the line drag preview.
    /// Epics that would be affected by the line movement get a visual indicator.
    /// </summary>
    private string GetEpicPreviewClass(EpicPlacementDto placement, int rowIndex)
    {
        // Early return if not dragging
        if (_draggingLineId == null || _draggingTargetPosition == null)
        {
            return string.Empty;
        }

        var epicPosition = rowIndex + 0.5; // Middle of the row
        
        // Early return if line movement is negligible
        if (Math.Abs(_draggingTargetPosition.Value - _draggingOriginalPosition) < POSITION_TOLERANCE)
        {
            return string.Empty;
        }

        // Determine if the epic's inclusion/exclusion state would change
        // Epic is "before" the line if its position is less than the line position
        bool wasBeforeLine = epicPosition < _draggingOriginalPosition;
        bool wouldBeBeforeLine = epicPosition < _draggingTargetPosition.Value;

        // If the epic's relationship to the line changes, apply preview styling
        return (wasBeforeLine != wouldBeBeforeLine) ? "epic-preview-affected" : string.Empty;
    }

    #endregion
}
