@using PoTool.Shared.ReleasePlanning
@using PoTool.Client.Services
@inject ReleasePlanningService ReleasePlanningService
@inject ILogger<ReleasePlanningBoard> Logger
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudPaper Class="release-planning-board pa-4" Elevation="0">
    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        <MudText Typo="Typo.body2" Class="mt-2">Loading Release Planning Board...</MudText>
    }
    else if (_board == null)
    {
        <MudAlert Severity="Severity.Warning">
            Unable to load the Release Planning Board. Please try again.
        </MudAlert>
    }
    else
    {
        <!-- Unplanned Epics Source List -->
        <UnplannedEpicsList 
            Epics="_unplannedEpics"
            OnEpicDrop="@HandleEpicDrop" />

        <!-- Board Container -->
        <MudPaper Class="board-container mt-4" Elevation="1">
            @if (_board.Lanes.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Class="ma-4">
                    No Lanes configured. Add Objectives to the board to get started.
                </MudAlert>
            }
            else
            {
                <!-- Lane Headers -->
                <div class="lane-headers d-flex">
                    @foreach (var lane in _board.Lanes)
                    {
                        <div class="lane-header flex-grow-1 pa-2">
                            <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                @lane.ObjectiveTitle
                            </MudText>
                        </div>
                    }
                </div>

                <!-- Row Grid with Lanes and Connectors -->
                <div class="board-grid" style="position: relative;">
                    <!-- SVG Connector Layer -->
                    <ConnectorRenderer 
                        Connectors="_board.Connectors"
                        Placements="_board.Placements"
                        Lanes="_board.Lanes"
                        RowHeight="80"
                        CardWidth="180"
                        CardHeight="60"
                        LaneWidth="200" />
                    
                    @for (int row = 0; row <= _board.MaxRowIndex; row++)
                    {
                        var currentRow = row;
                        var linesAtPosition = GetLinesAtPosition(currentRow + 0.5);
                        <div class="row-container d-flex" style="min-height: 80px;">
                            @foreach (var lane in _board.Lanes)
                            {
                                var lanePlacements = _board.Placements
                                    .Where(p => p.LaneId == lane.Id && p.RowIndex == currentRow)
                                    .OrderBy(p => p.OrderInRow)
                                    .ToList();

                                <div class="lane-row flex-grow-1 pa-1"
                                     style="border-right: 1px solid var(--mud-palette-lines-default);">
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var placement in lanePlacements)
                                        {
                                            var epicClass = GetEpicPreviewClass(placement, currentRow);
                                            <div class="@epicClass">
                                                <EpicCard 
                                                    Placement="@placement"
                                                    OnMove="@HandleEpicMove"
                                                    OnContextMenu="@HandleEpicContextMenu"
                                                    OnSplitRequested="@HandleEpicSplit"
                                                    OnViewDetailsRequested="@HandleViewDetails" />
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Horizontal Lines between rows -->
                        @foreach (var line in linesAtPosition.MilestoneLines)
                        {
                            var isBeingDragged = _draggingLineId == line.Id;
                            var lineClass = isBeingDragged ? "milestone-line draggable-line line-being-dragged" : "milestone-line draggable-line";
                            <div class="@lineClass"
                                 draggable="true"
                                 @ondragstart="@(e => HandleLineStartDrag(line.Id, true, line.Label, line.Type, line.VerticalPosition))"
                                 @ondragover:preventDefault
                                 @ondragover="@(e => HandleLineDragOver(e, currentRow + 0.5))"
                                 @ondrop="@(async e => await HandleLineDrop(line.Id, true))">
                                <MudDivider DividerType="DividerType.FullWidth" 
                                            Class="milestone-line-divider" />
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="Color.Primary"
                                         Icon="@Icons.Material.Filled.DragHandle"
                                         Class="line-label">
                                    @line.Label
                                </MudChip>
                            </div>
                        }
                        @foreach (var line in linesAtPosition.IterationLines)
                        {
                            var isBeingDragged = _draggingLineId == line.Id;
                            var lineClass = isBeingDragged ? "iteration-line draggable-line line-being-dragged" : "iteration-line draggable-line";
                            <div class="@lineClass"
                                 draggable="true"
                                 @ondragstart="@(e => HandleLineStartDrag(line.Id, false, line.Label, default, line.VerticalPosition))"
                                 @ondragover:preventDefault
                                 @ondragover="@(e => HandleLineDragOver(e, currentRow + 0.5))"
                                 @ondrop="@(async e => await HandleLineDrop(line.Id, false))">
                                <MudDivider DividerType="DividerType.FullWidth" 
                                            Class="iteration-line-divider" 
                                            Style="border-style: dashed;" />
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="Color.Secondary"
                                         Variant="Variant.Outlined"
                                         Icon="@Icons.Material.Filled.DragHandle"
                                         Class="line-label">
                                    @line.Label
                                </MudChip>
                            </div>
                        }

                        <!-- Preview Line during drag -->
                        @if (_draggingLineId != null && _draggingTargetPosition != null && Math.Abs(_draggingTargetPosition.Value - (currentRow + 0.5)) < POSITION_TOLERANCE)
                        {
                            <div class="@(_draggingIsMilestone ? "milestone-line-preview" : "iteration-line-preview")">
                                <MudDivider DividerType="DividerType.FullWidth" 
                                            Class="@(_draggingIsMilestone ? "milestone-line-divider" : "iteration-line-divider")"
                                            Style="@(_draggingIsMilestone ? "" : "border-style: dashed;")" />
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="@(_draggingIsMilestone ? Color.Primary : Color.Secondary)"
                                         Variant="@(_draggingIsMilestone ? Variant.Filled : Variant.Outlined)"
                                         Class="line-label">
                                    @_draggingLineLabel (Preview)
                                </MudChip>
                            </div>
                        }
                    }
                </div>
            }
        </MudPaper>

        <!-- Add Row Button -->
        <div class="mt-2">
            <MudTooltip Text="Rows are automatically created when you place Epics on the board">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           Variant="Variant.Text"
                           Disabled="true">
                    Add Row
                </MudButton>
            </MudTooltip>
        </div>
    }
</MudPaper>

@code {
    private ReleasePlanningBoardDto? _board;
    private IReadOnlyList<UnplannedEpicDto>? _unplannedEpics;
    private bool _isLoading = true;

    // Line dragging state
    private int? _draggingLineId;
    private bool _draggingIsMilestone;
    private string _draggingLineLabel = string.Empty;
    private MilestoneType _draggingMilestoneType;
    private double _draggingOriginalPosition;
    private double? _draggingTargetPosition;

    // Constants for drag behavior
    private const double POSITION_TOLERANCE = 0.1;

    protected override async Task OnInitializedAsync()
    {
        await LoadBoardAsync();
    }

    private async Task LoadBoardAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _board = await ReleasePlanningService.GetBoardAsync();
            _unplannedEpics = await ReleasePlanningService.GetUnplannedEpicsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading Release Planning Board");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleEpicDrop(EpicDropEventArgs args)
    {
        if (_board == null) return;

        // Find the lane for this Objective
        var lane = _board.Lanes.FirstOrDefault(l => l.ObjectiveId == args.ObjectiveId);
        if (lane == null)
        {
            // Create the lane if it doesn't exist
            var result = await ReleasePlanningService.CreateLaneAsync(args.ObjectiveId, _board.Lanes.Count);
            if (result?.Success != true)
            {
                Logger.LogError("Failed to create lane for Objective {ObjectiveId}", args.ObjectiveId);
                Snackbar.Add("Failed to create lane for Objective", Severity.Error);
                return;
            }
            await LoadBoardAsync();
            lane = _board?.Lanes.FirstOrDefault(l => l.ObjectiveId == args.ObjectiveId);
            if (lane == null) return;
        }

        // Create the placement
        var placementResult = await ReleasePlanningService.CreatePlacementAsync(
            args.EpicId, 
            lane.Id, 
            args.RowIndex, 
            0);

        if (placementResult?.Success == true)
        {
            Snackbar.Add("Epic placed on board", Severity.Success);
            await LoadBoardAsync();
        }
        else
        {
            Logger.LogError("Failed to create placement for Epic {EpicId}", args.EpicId);
            Snackbar.Add("Failed to place Epic on board", Severity.Error);
        }
    }

    private async Task HandleEpicMove(EpicMoveEventArgs args)
    {
        var result = await ReleasePlanningService.MoveEpicAsync(
            args.PlacementId, 
            args.NewRowIndex, 
            args.NewOrderInRow);

        if (result?.Success == true)
        {
            Snackbar.Add("Epic moved successfully", Severity.Success);
            await LoadBoardAsync();
        }
        else
        {
            Snackbar.Add("Failed to move Epic", Severity.Error);
        }
    }

    private void HandleEpicContextMenu(EpicContextMenuEventArgs args)
    {
        // Context menu actions are now handled by dedicated event handlers
        Logger.LogDebug("Context menu requested for Epic {EpicId}", args.EpicId);
    }

    private async Task HandleEpicSplit(EpicSplitEventArgs args)
    {
        var parameters = new DialogParameters<SplitEpicDialog>
        {
            { x => x.EpicId, args.EpicId },
            { x => x.EpicTitle, args.EpicTitle }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<SplitEpicDialog>("Split Epic", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: EpicSplitResultDto splitResult })
        {
            if (splitResult.Success)
            {
                Snackbar.Add($"Epic split successfully! New Epic ID: {splitResult.ExtractedEpicId}", Severity.Success);
                await LoadBoardAsync();
            }
            else
            {
                Snackbar.Add($"Failed to split Epic: {splitResult.ErrorMessage}", Severity.Error);
            }
        }
    }

    private void HandleViewDetails(EpicViewDetailsEventArgs args)
    {
        // Navigate to Work Item Explorer with the Epic selected
        Navigation.NavigateTo($"/workitems?selected={args.EpicId}");
    }

    private (IEnumerable<MilestoneLineDto> MilestoneLines, IEnumerable<IterationLineDto> IterationLines) GetLinesAtPosition(double position)
    {
        if (_board == null)
        {
            return (Enumerable.Empty<MilestoneLineDto>(), Enumerable.Empty<IterationLineDto>());
        }

        var milestoneLines = _board.MilestoneLines
            .Where(l => Math.Abs(l.VerticalPosition - position) < 0.5);
        var iterationLines = _board.IterationLines
            .Where(l => Math.Abs(l.VerticalPosition - position) < 0.5);

        return (milestoneLines, iterationLines);
    }

    #region Line Dragging

    private void HandleLineStartDrag(int lineId, bool isMilestone, string label, MilestoneType type, double verticalPosition)
    {
        _draggingLineId = lineId;
        _draggingIsMilestone = isMilestone;
        _draggingLineLabel = label;
        _draggingMilestoneType = type;
        _draggingOriginalPosition = verticalPosition;
        _draggingTargetPosition = null;
        Logger.LogDebug("Started dragging {LineType} line {LineId} from position {Position}", 
            isMilestone ? "milestone" : "iteration", lineId, verticalPosition);
    }

    private void HandleLineDragOver(DragEventArgs e, double rowPosition)
    {
        if (_draggingLineId == null) return;
        
        // Update target position for visual feedback
        if (_draggingTargetPosition != rowPosition)
        {
            _draggingTargetPosition = rowPosition;
            StateHasChanged(); // Trigger re-render to show preview
        }
    }

    private async Task HandleLineDrop(int lineId, bool isMilestone)
    {
        if (_draggingLineId == null || _draggingTargetPosition == null)
        {
            ResetLineDragState();
            return;
        }

        // Don't update if dropped at original position
        if (Math.Abs(_draggingTargetPosition.Value - _draggingOriginalPosition) < POSITION_TOLERANCE)
        {
            ResetLineDragState();
            return;
        }

        try
        {
            LineOperationResultDto? result = null;

            if (_draggingIsMilestone)
            {
                result = await ReleasePlanningService.UpdateMilestoneLineAsync(
                    _draggingLineId.Value,
                    _draggingLineLabel,
                    _draggingTargetPosition.Value,
                    _draggingMilestoneType);
            }
            else
            {
                result = await ReleasePlanningService.UpdateIterationLineAsync(
                    _draggingLineId.Value,
                    _draggingLineLabel,
                    _draggingTargetPosition.Value);
            }

            if (result?.Success == true)
            {
                Snackbar.Add($"{(_draggingIsMilestone ? "Milestone" : "Iteration")} line repositioned successfully", Severity.Success);
                await LoadBoardAsync();
            }
            else
            {
                Snackbar.Add($"Failed to reposition {(_draggingIsMilestone ? "milestone" : "iteration")} line", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error repositioning line {LineId}", _draggingLineId);
            Snackbar.Add("Error repositioning line", Severity.Error);
        }
        finally
        {
            ResetLineDragState();
        }
    }

    private void ResetLineDragState()
    {
        _draggingLineId = null;
        _draggingIsMilestone = false;
        _draggingLineLabel = string.Empty;
        _draggingMilestoneType = default;
        _draggingOriginalPosition = 0;
        _draggingTargetPosition = null;
        StateHasChanged(); // Clear preview
    }

    /// <summary>
    /// Determines the CSS class for an Epic card based on the line drag preview.
    /// Epics that would be affected by the line movement get a visual indicator.
    /// </summary>
    private string GetEpicPreviewClass(EpicPlacementDto placement, int rowIndex)
    {
        // Early return if not dragging
        if (_draggingLineId == null || _draggingTargetPosition == null)
        {
            return string.Empty;
        }

        var epicPosition = rowIndex + 0.5; // Middle of the row
        
        // Early return if line movement is negligible
        if (Math.Abs(_draggingTargetPosition.Value - _draggingOriginalPosition) < POSITION_TOLERANCE)
        {
            return string.Empty;
        }

        // Determine if the epic's inclusion/exclusion state would change
        // Epic is "before" the line if its position is less than the line position
        bool wasBeforeLine = epicPosition < _draggingOriginalPosition;
        bool wouldBeBeforeLine = epicPosition < _draggingTargetPosition.Value;

        // If the epic's relationship to the line changes, apply preview styling
        return (wasBeforeLine != wouldBeBeforeLine) ? "epic-preview-affected" : string.Empty;
    }

    #endregion
}
