@using PoTool.Shared.ReleasePlanning

<div class="epic-card-container" style="position: relative;">
    <MudPaper Class="@GetCardClass()" 
              Elevation="2" 
              Style="@GetCardStyle()"
              draggable="true"
              @ondragstart="@HandleDragStart"
              @onclick="@HandleClick">
        <div class="d-flex flex-column">
            <div class="d-flex justify-space-between align-center">
                <MudText Typo="Typo.body2" Class="font-weight-bold text-truncate" Style="max-width: 120px;">
                    @Placement.EpicTitle
                </MudText>
                
                <div class="d-flex align-center gap-1">
                    <!-- Validation Indicator - always visible per spec -->
                    @if (Placement.ValidationIndicator != ValidationIndicator.None)
                    {
                        <MudIcon Icon="@GetValidationIcon()" 
                                 Color="@GetValidationColor()"
                                 Size="Size.Small" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" 
                                 Color="Color.Success"
                                 Size="Size.Small" />
                    }

                    <!-- Context Menu -->
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" 
                             Size="Size.Small" 
                             Dense="true"
                             AnchorOrigin="Origin.BottomRight"
                             TransformOrigin="Origin.TopRight">
                        <MudMenuItem OnClick="@HandleSplitEpic">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" />
                                <span>Split Epic</span>
                            </div>
                        </MudMenuItem>
                        <MudMenuItem OnClick="@HandleViewDetails">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" />
                                <span>View Details</span>
                            </div>
                        </MudMenuItem>
                    </MudMenu>
                </div>
            </div>
            
            <div class="d-flex gap-2 mt-1">
                @if (Placement.Effort.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                        @Placement.Effort pts
                    </MudChip>
                }
                
                <MudChip T="string" 
                         Size="Size.Small" 
                         Color="@GetStateColor()" 
                         Variant="Variant.Text">
                    @Placement.State
                </MudChip>
            </div>
        </div>
    </MudPaper>
</div>

@code {
    [Parameter]
    public required EpicPlacementDto Placement { get; set; }

    [Parameter]
    public EventCallback<EpicMoveEventArgs> OnMove { get; set; }

    [Parameter]
    public EventCallback<EpicContextMenuEventArgs> OnContextMenu { get; set; }

    [Parameter]
    public EventCallback<EpicSplitEventArgs> OnSplitRequested { get; set; }

    [Parameter]
    public EventCallback<EpicViewDetailsEventArgs> OnViewDetailsRequested { get; set; }

    [Parameter]
    public int ObjectiveId { get; set; } // Passed from parent to track lane ownership

    [Parameter]
    public EventCallback<(int PlacementId, int EpicId, int ObjectiveId)> OnDragStart { get; set; }

    [Parameter]
    public EventCallback<int> OnSelected { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    private string GetCardClass()
    {
        return IsSelected ? "epic-card pa-2 epic-card-selected" : "epic-card pa-2";
    }

    private string GetCardStyle()
    {
        var borderColor = Placement.ValidationIndicator switch
        {
            ValidationIndicator.Error => "var(--mud-palette-error)",
            ValidationIndicator.Warning => "var(--mud-palette-warning)",
            _ => "var(--mud-palette-primary)"
        };

        return $"border-left: 4px solid {borderColor}; min-width: 180px; cursor: grab;";
    }

    private string GetValidationIcon()
    {
        return Placement.ValidationIndicator switch
        {
            ValidationIndicator.Error => Icons.Material.Filled.Error,
            ValidationIndicator.Warning => Icons.Material.Filled.Warning,
            _ => Icons.Material.Filled.CheckCircle
        };
    }

    private Color GetValidationColor()
    {
        return Placement.ValidationIndicator switch
        {
            ValidationIndicator.Error => Color.Error,
            ValidationIndicator.Warning => Color.Warning,
            _ => Color.Success
        };
    }

    private Color GetStateColor()
    {
        return Placement.State.ToLowerInvariant() switch
        {
            "active" => Color.Primary,
            "new" => Color.Default,
            "resolved" or "closed" or "done" => Color.Success,
            "removed" => Color.Secondary,
            _ => Color.Default
        };
    }

    private async Task HandleDragStart()
    {
        // Notify parent about which epic is being dragged
        await OnDragStart.InvokeAsync((Placement.Id, Placement.EpicId, ObjectiveId));
    }

    private async Task HandleClick()
    {
        // Notify parent about selection
        await OnSelected.InvokeAsync(Placement.Id);
    }

    private async Task HandleSplitEpic()
    {
        await OnSplitRequested.InvokeAsync(new EpicSplitEventArgs
        {
            PlacementId = Placement.Id,
            EpicId = Placement.EpicId,
            EpicTitle = Placement.EpicTitle
        });
    }

    private async Task HandleViewDetails()
    {
        await OnViewDetailsRequested.InvokeAsync(new EpicViewDetailsEventArgs
        {
            PlacementId = Placement.Id,
            EpicId = Placement.EpicId
        });
    }
}
