@using PoTool.Shared.ReleasePlanning
@using PoTool.Client.Services
@inject ReleasePlanningService ReleasePlanningService
@inject ILogger<ObjectiveEpicsDialog> Logger

<MudDialog>
    <DialogContent>
        @if (_isLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading Epics...</MudText>
        }
        else if (_epics == null || _epics.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                No Epics found for this Objective.
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <strong>All Epics for Objective: @ObjectiveTitle</strong>
            </MudText>

            <MudList T="ObjectiveEpicDto" Dense="true">
                @foreach (var epic in _epics.OrderBy(e => e.IsPlanned ? 0 : 1).ThenBy(e => e.Title))
                {
                    <MudListItem T="ObjectiveEpicDto">
                        <div class="d-flex justify-space-between align-center">
                            <div class="d-flex align-center gap-2 flex-grow-1">
                                @if (epic.ValidationIndicator != ValidationIndicator.None)
                                {
                                    <MudIcon Icon="@GetValidationIcon(epic.ValidationIndicator)" 
                                             Color="@GetValidationColor(epic.ValidationIndicator)"
                                             Size="Size.Small" />
                                }
                                <MudText Typo="Typo.body2" Class="flex-grow-1">
                                    @epic.Title
                                </MudText>
                                @if (epic.Effort.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                        @epic.Effort pts
                                    </MudChip>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                @if (epic.IsPlanned)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                        Planned (Row @epic.RowIndex)
                                    </MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                        Not Planned
                                    </MudChip>
                                }
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="@GetStateColor(epic.State)" 
                                         Variant="Variant.Text">
                                    @epic.State
                                </MudChip>
                            </div>
                        </div>
                    </MudListItem>
                    <MudDivider />
                }
            </MudList>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public int ObjectiveId { get; set; }

    [Parameter]
    public string ObjectiveTitle { get; set; } = string.Empty;

    private IReadOnlyList<ObjectiveEpicDto>? _epics;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadEpicsAsync();
    }

    private async Task LoadEpicsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            _epics = await ReleasePlanningService.GetObjectiveEpicsAsync(ObjectiveId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading Epics for Objective {ObjectiveId}", ObjectiveId);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        MudDialog?.Cancel();
    }

    private static string GetValidationIcon(ValidationIndicator indicator)
    {
        return indicator switch
        {
            ValidationIndicator.Error => Icons.Material.Filled.Error,
            ValidationIndicator.Warning => Icons.Material.Filled.Warning,
            _ => Icons.Material.Filled.CheckCircle
        };
    }

    private static Color GetValidationColor(ValidationIndicator indicator)
    {
        return indicator switch
        {
            ValidationIndicator.Error => Color.Error,
            ValidationIndicator.Warning => Color.Warning,
            _ => Color.Success
        };
    }

    private static Color GetStateColor(string state)
    {
        return state.ToLowerInvariant() switch
        {
            "active" => Color.Primary,
            "new" => Color.Default,
            "resolved" or "closed" or "done" => Color.Success,
            "removed" => Color.Secondary,
            _ => Color.Default
        };
    }
}
