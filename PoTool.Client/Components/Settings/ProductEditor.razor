@using MudBlazor
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using ProductPictureType = PoTool.Shared.Settings.ProductPictureType
@inject ProductService ProductService
@inject TeamService TeamService
@inject WorkItemService WorkItemService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ErrorMessageService ErrorMessageService

<MudPaper Elevation="1" Class="pa-4">
    <MudForm @ref="_form">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">@(IsEditing ? "Edit Product" : "Add Product")</MudText>

            <CompactTextField @bind-Value="_name" 
                          Label="Product Name" 
                          Required="true"
                          HelperText="e.g., 'Customer Portal', 'Mobile App'" />

            <MudStack Spacing="1">
                <CompactTextField @bind-Value="_backlogRootWorkItemIdText" 
                              Label="Backlog Root Work Item ID" 
                              Required="true"
                              HelperText="Enter the work item ID that defines the product backlog"
                              InputType="InputType.Number"
                              OnBlur="ValidateWorkItemId"
                              Error="@_workItemValidationFailed"
                              ErrorText="@_workItemValidationError" />
                
                @if (_isValidatingWorkItem)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Validating work item...</MudText>
                    </MudStack>
                }
                else if (_workItemValidationSuccess)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-1">
                        Work item validated successfully
                    </MudAlert>
                }
            </MudStack>

            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Style="flex: 0 0 auto;">Linked Teams</MudText>
                    <CompactButton OnClick="OpenCreateTeamDialog" 
                               Color="Color.Primary" 
                               Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add">
                        Create New Team
                    </CompactButton>
                </MudStack>
                <CompactSelect T="int"
                               @bind-SelectedValues="_selectedTeamIds"
                               MultiSelection="true"
                               HelperText="Select teams that work on this product">
                    @foreach (var team in _availableTeams)
                    {
                        <MudSelectItem T="int" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </CompactSelect>
            </MudStack>

            @if (!_availableTeams.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        No teams available. Use the "Create New Team" button above to create one.
                    </MudText>
                </MudAlert>
            }

            @* Picture Selector *@
            <div class="mt-2">
                <PicturePicker Title="Product Picture" 
                               Category="Product" 
                               @bind-SelectedImageId="_selectedImageId" />
            </div>

            @if (_errorResponse != null)
            {
                <ErrorDisplay ErrorResponse="@_errorResponse" 
                              OnDismiss="ClearError" />
            }

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <CompactButton OnClick="SaveProduct" 
                           Color="Color.Primary" 
                           Variant="Variant.Filled" 
                           Disabled="@(_isSaving || _workItemValidationFailed || _isValidatingWorkItem)"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>@(IsEditing ? "Update" : "Create") Product</span>
                    }
                </CompactButton>
                <CompactButton OnClick="Cancel" 
                           Color="Color.Default" 
                           Variant="Variant.Outlined">
                    Cancel
                </CompactButton>
            </MudStack>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter]
    public int ProductOwnerId { get; set; }

    [Parameter]
    public ProductDto? Product { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private MudForm _form = null!;
    
    private bool IsEditing => Product != null;
    private bool _isSaving = false;
    private ErrorResponse? _errorResponse;

    // TFS Work Item validation state
    private bool _isValidatingWorkItem = false;
    private bool _workItemValidationFailed = false;
    private bool _workItemValidationSuccess = false;
    private string _workItemValidationError = string.Empty;

    private string _name = string.Empty;
    private string _backlogRootWorkItemIdText = string.Empty;
    private int _backlogRootWorkItemId = 0;
    private int _selectedImageId = 0;
    private IEnumerable<int> _selectedTeamIds = new List<int>();

    private List<TeamDto> _availableTeams = new();

    protected override async Task OnInitializedAsync()
    {
        _selectedImageId = Random.Shared.Next(0, 64);
        
        await LoadDataAsync();

        if (Product != null)
        {
            _name = Product.Name;
            _backlogRootWorkItemId = Product.BacklogRootWorkItemId;
            _backlogRootWorkItemIdText = Product.BacklogRootWorkItemId.ToString();
            _selectedImageId = Product.DefaultPictureId;
            _selectedTeamIds = Product.TeamIds.ToList();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var teamsTask = TeamService.GetAllTeamsAsync();
            await teamsTask;
            _availableTeams = (await teamsTask).ToList();
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, "Error loading data");
        }
    }

    private async Task SaveProduct()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_backlogRootWorkItemIdText) || !int.TryParse(_backlogRootWorkItemIdText, out _backlogRootWorkItemId) || _backlogRootWorkItemId <= 0)
        {
            Snackbar.Add("Please enter a valid work item ID", Severity.Warning);
            return;
        }

        // Check if validation passed
        if (_workItemValidationFailed)
        {
            Snackbar.Add("Please fix the work item validation error before saving", Severity.Error);
            return;
        }

        // Validate if not already validated
        if (!_workItemValidationSuccess && !IsEditing)
        {
            await ValidateWorkItemId();
            if (_workItemValidationFailed)
            {
                return;
            }
        }

        try
        {
            _isSaving = true;
            ClearError();

            if (IsEditing && Product != null)
            {
                var updated = await ProductService.UpdateProductAsync(
                    Product.Id,
                    _name,
                    _backlogRootWorkItemId,
                    ProductPictureType.Default,
                    _selectedImageId,
                    null);

                // Update team links
                await UpdateTeamLinksAsync(Product.Id, Product.TeamIds.ToList(), _selectedTeamIds.ToList());

                Snackbar.Add("Product updated successfully", Severity.Success);
            }
            else
            {
                var ownerIdToUse = ProductOwnerId == 0 ? (int?)null : ProductOwnerId;
                var created = await ProductService.CreateProductAsync(
                    ownerIdToUse,
                    _name,
                    _backlogRootWorkItemId,
                    ProductPictureType.Default,
                    _selectedImageId,
                    null);

                // Add team links for new product
                foreach (var teamId in _selectedTeamIds)
                {
                    await ProductService.LinkTeamAsync(created.Id, teamId);
                }

                Snackbar.Add("Product created successfully", Severity.Success);
            }

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, IsEditing ? "Error updating product" : "Error creating product");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UpdateTeamLinksAsync(int productId, List<int> currentTeamIds, List<int> newTeamIds)
    {
        // Find teams to unlink (in current but not in new)
        var teamsToUnlink = currentTeamIds.Except(newTeamIds);
        foreach (var teamId in teamsToUnlink)
        {
            await ProductService.UnlinkTeamAsync(productId, teamId);
        }

        // Find teams to link (in new but not in current)
        var teamsToLink = newTeamIds.Except(currentTeamIds);
        foreach (var teamId in teamsToLink)
        {
            await ProductService.LinkTeamAsync(productId, teamId);
        }
    }

    private async Task Cancel()
    {
        await OnCancelled.InvokeAsync();
    }

    private async Task ValidateWorkItemId()
    {
        // Reset validation state
        _workItemValidationFailed = false;
        _workItemValidationSuccess = false;
        _workItemValidationError = string.Empty;

        // Parse the work item ID
        if (!int.TryParse(_backlogRootWorkItemIdText, out var workItemId) || workItemId <= 0)
        {
            _workItemValidationFailed = true;
            _workItemValidationError = "Please enter a valid work item ID";
            return;
        }

        try
        {
            _isValidatingWorkItem = true;
            StateHasChanged();

            // Call TFS to validate the work item exists
            var workItem = await WorkItemService.GetByTfsIdAsync(workItemId);
            
            if (workItem == null)
            {
                _workItemValidationFailed = true;
                _workItemValidationError = $"Work item {workItemId} not found in TFS";
            }
            else
            {
                _workItemValidationSuccess = true;
                _backlogRootWorkItemId = workItemId;
            }
        }
        catch (Exception ex)
        {
            _workItemValidationFailed = true;
            _workItemValidationError = $"Error validating work item: {ex.Message}";
        }
        finally
        {
            _isValidatingWorkItem = false;
            StateHasChanged();
        }
    }

    private async Task OpenCreateTeamDialog()
    {
        var parameters = new DialogParameters
        {
            { "Team", null }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<InlineTeamCreationDialog>("Create New Team", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is TeamDto newTeam)
        {
            // Reload teams to include the newly created one
            await LoadDataAsync();
            
            // Auto-select the newly created team
            var selectedList = _selectedTeamIds.ToList();
            selectedList.Add(newTeam.Id);
            _selectedTeamIds = selectedList;
            
            Snackbar.Add($"Team '{newTeam.Name}' created and linked", Severity.Success);
        }
    }

    private void ClearError()
    {
        _errorResponse = null;
    }
}
