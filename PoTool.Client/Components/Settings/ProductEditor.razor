@using MudBlazor
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Storage
@using PoTool.Client.Models
@using ProductPictureType = PoTool.Shared.Settings.ProductPictureType
@inject ProductService ProductService
@inject TeamService TeamService
@inject WorkItemService WorkItemService
@inject DraftStorageService DraftStorageService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ErrorMessageService ErrorMessageService

<MudPaper Elevation="1" Class="pa-4">
    <MudForm @ref="_form">
        <MudStack Spacing="3">
            <MudText Typo="Typo.h6">@(IsEditing ? "Edit Product" : "Add Product")</MudText>

            <CompactTextField @bind-Value="_name" 
                          Label="Product Name" 
                          Required="true"
                          HelperText="e.g., 'Customer Portal', 'Mobile App'"
                          @bind-Value:after="@(() => SaveDraftAsync())" />

            <MudStack Spacing="1">
                <CompactTextField @bind-Value="_backlogRootWorkItemIdText" 
                              Label="Backlog Root Work Item ID" 
                              Required="true"
                              HelperText="Enter the work item ID that defines the product backlog"
                              InputType="InputType.Number"
                              OnBlur="ValidateWorkItemId"
                              Error="@_workItemValidationFailed"
                              ErrorText="@_workItemValidationError"
                              @bind-Value:after="@(() => SaveDraftAsync())" />
                
                @if (_isValidatingWorkItem)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Validating work item...</MudText>
                    </MudStack>
                }
                else if (_workItemValidationSuccess)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mt-1">
                        @if (!string.IsNullOrEmpty(_validatedWorkItemTitle))
                        {
                            <text>@_backlogRootWorkItemIdText – @_validatedWorkItemTitle</text>
                        }
                        else
                        {
                            <text>Work item validated successfully</text>
                        }
                    </MudAlert>
                }
            </MudStack>

            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Style="flex: 0 0 auto;">Linked Teams</MudText>
                    <CompactButton OnClick="OpenCreateTeamDialog" 
                               Color="Color.Primary" 
                               Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add">
                        Add Team from TFS
                    </CompactButton>
                </MudStack>
                <CompactSelect T="int"
                               @bind-SelectedValues="_selectedTeamIds"
                               MultiSelection="true"
                               HelperText="Select teams that work on this product"
                               @bind-SelectedValues:after="@(() => SaveDraftAsync())">
                    @foreach (var team in _availableTeams)
                    {
                        <MudSelectItem T="int" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </CompactSelect>
            </MudStack>

            @if (!_availableTeams.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    <MudText Typo="Typo.caption">
                        No teams available. Use the "Add Team from TFS" button above to select a team from Azure DevOps.
                    </MudText>
                </MudAlert>
            }

            @* Repository Configuration *@
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Style="flex: 0 0 auto;">Repositories</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="flex: 1 1 auto;">Git repositories in Azure DevOps/TFS</MudText>
                </MudStack>
                
                @* List of existing repositories *@
                @if (_repositories.Any())
                {
                    <MudPaper Elevation="0" Class="pa-2" Style="border: 1px solid var(--mud-palette-divider);">
                        <MudStack Spacing="1">
                            @foreach (var repo in _repositories)
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Style="flex: 1 1 auto;">@repo.Name</MudText>
                                    <CompactButton OnClick="@(() => RemoveRepository(repo.Name))"
                                                   Color="Color.Error"
                                                   Variant="Variant.Text"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Delete">
                                        Remove
                                    </CompactButton>
                                </MudStack>
                            }
                        </MudStack>
                    </MudPaper>
                }
                else if (IsEditing)
                {
                    <MudAlert Severity="Severity.Info" Dense="true">
                        <MudText Typo="Typo.caption">
                            No repositories configured. Add at least one repository below.
                        </MudText>
                    </MudAlert>
                }
                
                @* Add new repository *@
                <MudStack Row="true" Spacing="1">
                    <CompactTextField @bind-Value="_newRepositoryName"
                                      Label="Repository Name"
                                      Placeholder="e.g., MyRepo"
                                      HelperText="Enter the repository name from Azure DevOps"
                                      Style="flex: 1 1 auto;"
                                      Error="@_repositoryError"
                                      ErrorText="@_repositoryErrorMessage" />
                    <CompactButton OnClick="AddRepository"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Disabled="@(string.IsNullOrWhiteSpace(_newRepositoryName))"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Style="margin-top: 16px;">
                        Add
                    </CompactButton>
                </MudStack>
            </MudStack>

            @* Picture Selector *@
            <div class="mt-2">
                <PicturePicker Title="Product Picture" 
                               Category="Product" 
                               @bind-SelectedImageId="_selectedImageId"
                               @bind-SelectedImageId:after="@(() => SaveDraftAsync())" />
            </div>

            @if (_errorResponse != null)
            {
                <ErrorDisplay ErrorResponse="@_errorResponse" 
                              OnDismiss="ClearError" />
            }

            <MudStack Row="true" Spacing="2" Class="mt-2">
                <CompactButton OnClick="SaveProduct" 
                           Color="Color.Primary" 
                           Variant="Variant.Filled" 
                           Disabled="@(_isSaving || _workItemValidationFailed || _isValidatingWorkItem)"
                           StartIcon="@Icons.Material.Filled.Save">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>@(IsEditing ? "Update" : "Create") Product</span>
                    }
                </CompactButton>
                <CompactButton OnClick="Cancel" 
                           Color="Color.Default" 
                           Variant="Variant.Outlined">
                    Cancel
                </CompactButton>
            </MudStack>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter]
    public int ProductOwnerId { get; set; }

    [Parameter]
    public ProductDto? Product { get; set; }

    [Parameter]
    public EventCallback<bool> OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancelled { get; set; }

    private MudForm _form = null!;
    
    private bool IsEditing => Product != null;
    private bool _isSaving = false;
    private ErrorResponse? _errorResponse;

    // TFS Work Item validation state
    private bool _isValidatingWorkItem = false;
    private bool _workItemValidationFailed = false;
    private bool _workItemValidationSuccess = false;
    private string _workItemValidationError = string.Empty;
    private string? _validatedWorkItemTitle = null;

    private string _name = string.Empty;
    private string _backlogRootWorkItemIdText = string.Empty;
    private int _backlogRootWorkItemId = 0;
    private int _selectedImageId = 0;
    private IEnumerable<int> _selectedTeamIds = new List<int>();

    private List<TeamDto> _availableTeams = new();

    // Repository management state
    private List<RepositoryDto> _repositories = new();
    private string _newRepositoryName = string.Empty;
    private bool _repositoryError = false;
    private string _repositoryErrorMessage = string.Empty;

    private string DraftKey => $"product_edit_{ProductOwnerId}_{(Product?.Id ?? 0)}";

    protected override async Task OnInitializedAsync()
    {
        _selectedImageId = Random.Shared.Next(0, 64);
        
        await LoadDataAsync();

        if (Product != null)
        {
            // Editing existing product - use product data
            _name = Product.Name;
            _backlogRootWorkItemId = Product.BacklogRootWorkItemId;
            _backlogRootWorkItemIdText = Product.BacklogRootWorkItemId.ToString();
            _selectedImageId = Product.DefaultPictureId;
            _selectedTeamIds = Product.TeamIds.ToList();
            _repositories = Product.Repositories.ToList();
        }
        else
        {
            // Creating new product - try to restore draft
            await RestoreDraftAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var teamsTask = TeamService.GetAllTeamsAsync();
            await teamsTask;
            _availableTeams = (await teamsTask).ToList();
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, "Error loading data");
        }
    }

    private async Task SaveProduct()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_backlogRootWorkItemIdText) || !int.TryParse(_backlogRootWorkItemIdText, out _backlogRootWorkItemId) || _backlogRootWorkItemId <= 0)
        {
            Snackbar.Add("Please enter a valid work item ID", Severity.Warning);
            return;
        }

        // Check if validation passed
        if (_workItemValidationFailed)
        {
            Snackbar.Add("Please fix the work item validation error before saving", Severity.Error);
            return;
        }

        // Validate if not already validated
        if (!_workItemValidationSuccess && !IsEditing)
        {
            await ValidateWorkItemId();
            if (_workItemValidationFailed)
            {
                return;
            }
        }

        try
        {
            _isSaving = true;
            ClearError();
            
            bool repositoriesChanged = false;

            if (IsEditing && Product != null)
            {
                var updated = await ProductService.UpdateProductAsync(
                    Product.Id,
                    _name,
                    _backlogRootWorkItemId,
                    ProductPictureType.Default,
                    _selectedImageId,
                    null);

                // Update team links
                await UpdateTeamLinksAsync(Product.Id, Product.TeamIds.ToList(), _selectedTeamIds.ToList());

                // Check if repositories changed
                var oldRepoNames = Product.Repositories.Select(r => r.Name).OrderBy(n => n).ToList();
                var newRepoNames = _repositories.Select(r => r.Name).OrderBy(n => n).ToList();
                repositoriesChanged = !oldRepoNames.SequenceEqual(newRepoNames, StringComparer.OrdinalIgnoreCase);

                // Update repositories
                await UpdateRepositoriesAsync(Product.Id, Product.Repositories.Select(r => r.Name).ToList(), _repositories.Select(r => r.Name).ToList());

                Snackbar.Add("Product updated successfully", Severity.Success);
            }
            else
            {
                var ownerIdToUse = ProductOwnerId == 0 ? (int?)null : ProductOwnerId;
                var created = await ProductService.CreateProductAsync(
                    ownerIdToUse,
                    _name,
                    _backlogRootWorkItemId,
                    ProductPictureType.Default,
                    _selectedImageId,
                    null);

                // Add team links for new product
                foreach (var teamId in _selectedTeamIds)
                {
                    await ProductService.LinkTeamAsync(created.Id, teamId);
                }

                // Add repositories for new product
                foreach (var repo in _repositories)
                {
                    await ProductService.CreateRepositoryAsync(created.Id, repo.Name);
                }

                // New product with repositories should trigger sync
                repositoriesChanged = _repositories.Any();

                Snackbar.Add("Product created successfully", Severity.Success);
                
                // Clear draft after successful creation
                await ClearDraftAsync();
            }

            // Notify parent with sync request if repositories changed
            await OnSaved.InvokeAsync(repositoriesChanged);
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, IsEditing ? "Error updating product" : "Error creating product");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task UpdateTeamLinksAsync(int productId, List<int> currentTeamIds, List<int> newTeamIds)
    {
        // Find teams to unlink (in current but not in new)
        var teamsToUnlink = currentTeamIds.Except(newTeamIds);
        foreach (var teamId in teamsToUnlink)
        {
            await ProductService.UnlinkTeamAsync(productId, teamId);
        }

        // Find teams to link (in new but not in current)
        var teamsToLink = newTeamIds.Except(currentTeamIds);
        foreach (var teamId in teamsToLink)
        {
            await ProductService.LinkTeamAsync(productId, teamId);
        }
    }

    private async Task UpdateRepositoriesAsync(int productId, List<string> currentRepoNames, List<string> newRepoNames)
    {
        // Find repositories to delete (in current but not in new)
        var reposToDelete = currentRepoNames.Except(newRepoNames, StringComparer.OrdinalIgnoreCase);
        foreach (var repoName in reposToDelete)
        {
            // Find the repository ID by name
            var repo = _repositories.FirstOrDefault(r => r.Name.Equals(repoName, StringComparison.OrdinalIgnoreCase));
            if (repo != null)
            {
                await ProductService.DeleteRepositoryAsync(productId, repo.Id);
            }
        }

        // Find repositories to add (in new but not in current)
        var reposToAdd = newRepoNames.Except(currentRepoNames, StringComparer.OrdinalIgnoreCase);
        foreach (var repoName in reposToAdd)
        {
            await ProductService.CreateRepositoryAsync(productId, repoName);
        }
    }

    private void AddRepository()
    {
        _repositoryError = false;
        _repositoryErrorMessage = string.Empty;

        var trimmedName = _newRepositoryName.Trim();

        // Validation
        if (string.IsNullOrWhiteSpace(trimmedName))
        {
            _repositoryError = true;
            _repositoryErrorMessage = "Repository name cannot be empty";
            return;
        }

        // Check for duplicates (case-insensitive)
        if (_repositories.Any(r => r.Name.Equals(trimmedName, StringComparison.OrdinalIgnoreCase)))
        {
            _repositoryError = true;
            _repositoryErrorMessage = "This repository already exists";
            return;
        }

        // Add to list (for new products, we'll create a temporary DTO with Id=0)
        var newRepo = new RepositoryDto
        {
            Id = 0,  // Temporary ID for unsaved repositories
            ProductId = Product?.Id ?? 0,
            Name = trimmedName,
            CreatedAt = DateTimeOffset.UtcNow
        };

        _repositories.Add(newRepo);
        _newRepositoryName = string.Empty;

        // Save draft
        Task.Run(async () => await SaveDraftAsync());
    }

    private void RemoveRepository(string repoName)
    {
        var repo = _repositories.FirstOrDefault(r => r.Name.Equals(repoName, StringComparison.OrdinalIgnoreCase));
        if (repo != null)
        {
            _repositories.Remove(repo);
            // Save draft
            Task.Run(async () => await SaveDraftAsync());
        }
    }

    private async Task Cancel()
    {
        // Clear draft on cancel (user is abandoning changes)
        if (!IsEditing)
        {
            await ClearDraftAsync();
        }
        await OnCancelled.InvokeAsync();
    }

    private async Task ValidateWorkItemId()
    {
        // Reset validation state
        _workItemValidationFailed = false;
        _workItemValidationSuccess = false;
        _workItemValidationError = string.Empty;
        _validatedWorkItemTitle = null;

        // Parse the work item ID
        if (!int.TryParse(_backlogRootWorkItemIdText, out var workItemId) || workItemId <= 0)
        {
            _workItemValidationFailed = true;
            _workItemValidationError = "Please enter a valid work item ID";
            return;
        }

        try
        {
            _isValidatingWorkItem = true;
            StateHasChanged();

            // Call TFS to validate the work item exists (direct validation, not cache)
            var response = await WorkItemService.ValidateWorkItemAsync(workItemId);
            
            if (response.Exists)
            {
                _workItemValidationSuccess = true;
                _backlogRootWorkItemId = workItemId;
                _validatedWorkItemTitle = response.Title;
                _workItemValidationError = string.Empty;
            }
            else
            {
                _workItemValidationFailed = true;
                if (!string.IsNullOrEmpty(response.ErrorMessage))
                {
                    _workItemValidationError = response.ErrorMessage;
                }
                else
                {
                    _workItemValidationError = "Work item not found on TFS";
                }
            }
        }
        catch (Exception ex)
        {
            _workItemValidationFailed = true;
            _workItemValidationError = $"Error validating work item: {ex.Message}";
        }
        finally
        {
            _isValidatingWorkItem = false;
            StateHasChanged();
        }
    }

    private async Task OpenCreateTeamDialog()
    {
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<TfsTeamPickerDialog>("Select Team from TFS", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is TeamDto newTeam)
        {
            // Reload teams to include the newly created one
            await LoadDataAsync();
            
            // Auto-select the newly created team
            var selectedList = _selectedTeamIds.ToList();
            selectedList.Add(newTeam.Id);
            _selectedTeamIds = selectedList;
            
            Snackbar.Add($"Team '{newTeam.Name}' created and linked", Severity.Success);
        }
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    /// <summary>
    /// Saves the current form state as a draft.
    /// </summary>
    private async Task SaveDraftAsync()
    {
        // Only save drafts for new products (not when editing existing ones)
        if (IsEditing) return;

        var draft = new ProductEditorDraft
        {
            Name = _name,
            BacklogRootWorkItemIdText = _backlogRootWorkItemIdText,
            SelectedImageId = _selectedImageId,
            SelectedTeamIds = _selectedTeamIds.ToList()
        };

        await DraftStorageService.SaveDraftAsync(DraftKey, draft);
    }

    /// <summary>
    /// Restores form state from a draft.
    /// </summary>
    private async Task RestoreDraftAsync()
    {
        var draft = await DraftStorageService.LoadDraftAsync<ProductEditorDraft>(DraftKey);
        
        if (draft != null)
        {
            _name = draft.Name;
            _backlogRootWorkItemIdText = draft.BacklogRootWorkItemIdText;
            _selectedImageId = draft.SelectedImageId;
            _selectedTeamIds = draft.SelectedTeamIds;
            
            // Parse work item ID if present
            if (int.TryParse(_backlogRootWorkItemIdText, out var workItemId))
            {
                _backlogRootWorkItemId = workItemId;
            }
        }
    }

    /// <summary>
    /// Clears the draft after successful save.
    /// </summary>
    private async Task ClearDraftAsync()
    {
        await DraftStorageService.ClearDraftAsync(DraftKey);
    }
}
