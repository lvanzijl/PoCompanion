@using PoTool.Client.Services
@using PoTool.Shared.Settings
@inject CacheSyncService CacheSyncService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div class="settings-section">
    <MudText Typo="Typo.h4" Class="mb-3">Cache Management</MudText>

    @* ── Cache Insights ── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Color="Color.Info" />
                <MudText Typo="Typo.h6">Cache Insights</MudText>
            </MudStack>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="LoadInsightsAsync" Disabled="@_loading">
                Refresh
            </MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_insights != null)
        {
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6" sm="4">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Status</MudText>
                    <MudChip T="string" Color="@GetStatusColor(_insights.SyncStatus)" Size="Size.Small">
                        @_insights.SyncStatus
                    </MudChip>
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Last Successful Sync</MudText>
                    <MudText Typo="Typo.body2">
                        @(_insights.LastSuccessfulSync?.LocalDateTime.ToString("g") ?? "Never")
                    </MudText>
                </MudItem>
                <MudItem xs="6" sm="4">
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Last Attempt</MudText>
                    <MudText Typo="Typo.body2">
                        @(_insights.LastAttemptSync?.LocalDateTime.ToString("g") ?? "Never")
                    </MudText>
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(_insights.LastErrorMessage))
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    @_insights.LastErrorMessage
                </MudAlert>
            }

            <MudSimpleTable Dense="true" Hover="true" Bordered="true" Striped="true">
                <thead>
                    <tr>
                        <th>Entity Type</th>
                        <th style="text-align:right">Count</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _insights.EntityCounts)
                    {
                        <tr>
                            <td>@item.EntityType</td>
                            <td style="text-align:right">@item.TotalCount.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </MudPaper>

    @* ── Granular Cache Reset ── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" Color="Color.Error" />
            <MudText Typo="Typo.h6">Cache Reset</MudText>
        </MudStack>

        <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
            Select entity types to reset, or reset everything at once.
        </MudText>

        <MudGrid Spacing="1" Class="mb-3">
            @foreach (var type in CacheEntityTypes.All)
            {
                <MudItem xs="6" sm="4" md="3">
                    <MudCheckBox T="bool" Value="@IsTypeSelected(type)"
                                 ValueChanged="@(v => ToggleTypeSelection(type, v))"
                                 Label="@type" Dense="true" Color="Color.Error" />
                </MudItem>
            }
        </MudGrid>

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Delete"
                       Disabled="@(_resetting || _selectedTypes.Count == 0)"
                       OnClick="ResetSelectedAsync">
                Reset Selected (@_selectedTypes.Count)
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.DeleteForever"
                       Disabled="@_resetting"
                       OnClick="ResetAllAsync">
                Reset All
            </MudButton>
        </MudStack>

        @if (_resetResult != null)
        {
            <MudAlert Severity="Severity.Success" Dense="true" Class="mt-3">
                @_resetResult.Message
            </MudAlert>
        }
    </MudPaper>

    @* ── Activity Ledger Validation ── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Info" />
            <MudText Typo="Typo.h6">Activity Ledger Validation</MudText>
        </MudStack>

        <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
            Cache inspection only. Reads persisted activity events and cached work items. No TFS calls.
        </MudText>

        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudNumericField T="int?" Label="Work Item ID"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Required="true"
                                 Min="1"
                                 @bind-Value="_validationWorkItemId" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="From Changed Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               @bind-Date="_validationFromDate" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudDatePicker Label="To Changed Date"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               @bind-Date="_validationToDate" />
            </MudItem>
        </MudGrid>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Search"
                   Disabled="@(_validationLoading || !_validationWorkItemId.HasValue || _validationWorkItemId.Value <= 0)"
                   OnClick="LoadActivityLedgerValidationAsync">
            Load Activity Ledger
        </MudButton>

        @if (_validationLoading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mt-3" />
        }

        @if (!string.IsNullOrWhiteSpace(_validationError))
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                @_validationError
            </MudAlert>
        }

        @if (_validationResult != null)
        {
            <MudDivider Class="my-3" />

            <MudText Typo="Typo.subtitle1" Class="mb-2">Current Cached Snapshot</MudText>
            @if (_validationResult.Snapshot == null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                    Work item not found in cache.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Bordered="true" Striped="true" Class="mb-3">
                    <tbody>
                        <tr><td>Title</td><td>@_validationResult.Snapshot.Title</td></tr>
                        <tr><td>Type</td><td>@_validationResult.Snapshot.Type</td></tr>
                        <tr><td>State</td><td>@_validationResult.Snapshot.State</td></tr>
                        <tr><td>Assigned To</td><td>@(_validationResult.Snapshot.AssignedTo ?? "Unknown")</td></tr>
                        <tr><td>Current Iteration</td><td>@(_validationResult.Snapshot.CurrentIterationPath ?? "Unknown")</td></tr>
                        <tr><td>Parent / Feature / Epic</td><td>@FormatHierarchyChain(_validationResult.Snapshot)</td></tr>
                        <tr><td>Last ChangedDate</td><td>@(_validationResult.Snapshot.LastChangedDate?.LocalDateTime.ToString("g") ?? "Unknown")</td></tr>
                    </tbody>
                </MudSimpleTable>
            }

            var totalEvents = _validationResult.SprintGroups.Sum(g => g.TotalEventCount) + _validationResult.UnknownSprintEvents.Count;
            <MudText Typo="Typo.subtitle1" Class="mb-2">Sprint Grouped Activity</MudText>
            @if (totalEvents == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No activity recorded in cache.
                </MudAlert>
            }
            else
            {
                @foreach (var sprintGroup in _validationResult.SprintGroups)
                {
                    <MudPaper Outlined="true" Class="pa-3 mb-3">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.subtitle2">@sprintGroup.SprintName</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">@($"{sprintGroup.TotalEventCount} events")</MudChip>
                        </MudStack>
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="color: var(--mud-palette-text-secondary);">
                            @($"{sprintGroup.SprintStart?.LocalDateTime.ToString("d") ?? "Unknown"} - {sprintGroup.SprintEnd?.LocalDateTime.ToString("d") ?? "Unknown"}")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="d-block mb-2" Style="color: var(--mud-palette-text-secondary);">
                            @($"Distinct fields touched: {sprintGroup.DistinctFieldsTouchedCount} | Distinct users: {sprintGroup.DistinctUsersCount}")
                        </MudText>
                        <MudTable Items="@sprintGroup.Events" Dense="true" Hover="true" Striped="true" Virtualize="true" Height="300px">
                            <HeaderContent>
                                <MudTh>Timestamp</MudTh>
                                <MudTh>Changed By</MudTh>
                                <MudTh>Field</MudTh>
                                <MudTh>Old → New</MudTh>
                                <MudTh>Iteration Path At Time</MudTh>
                                <MudTh>Parent / Feature / Epic</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Timestamp">@context.Timestamp.LocalDateTime.ToString("g")</MudTd>
                                <MudTd DataLabel="Changed By">@(context.ChangedBy ?? "Unknown")</MudTd>
                                <MudTd DataLabel="Field">@context.FieldRefName</MudTd>
                                <MudTd DataLabel="Old/New">@FormatValueTransition(context.OldValue, context.NewValue)</MudTd>
                                <MudTd DataLabel="Iteration">@context.IterationPathAtTime</MudTd>
                                <MudTd DataLabel="Hierarchy">@FormatHierarchyAtTime(context)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }

                @if (_validationResult.UnknownSprintEvents.Count > 0)
                {
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                            <MudText Typo="Typo.subtitle2">Unknown / Not Configured Sprint</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">@($"{_validationResult.UnknownSprintEvents.Count} events")</MudChip>
                        </MudStack>
                        <MudTable Items="@_validationResult.UnknownSprintEvents" Dense="true" Hover="true" Striped="true" Virtualize="true" Height="300px">
                            <HeaderContent>
                                <MudTh>Timestamp</MudTh>
                                <MudTh>Changed By</MudTh>
                                <MudTh>Field</MudTh>
                                <MudTh>Old → New</MudTh>
                                <MudTh>Iteration Path At Time</MudTh>
                                <MudTh>Parent / Feature / Epic</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Timestamp">@context.Timestamp.LocalDateTime.ToString("g")</MudTd>
                                <MudTd DataLabel="Changed By">@(context.ChangedBy ?? "Unknown")</MudTd>
                                <MudTd DataLabel="Field">@context.FieldRefName</MudTd>
                                <MudTd DataLabel="Old/New">@FormatValueTransition(context.OldValue, context.NewValue)</MudTd>
                                <MudTd DataLabel="Iteration">
                                    <MudText Typo="Typo.body2" Color="Color.Warning">@context.IterationPathAtTime</MudText>
                                </MudTd>
                                <MudTd DataLabel="Hierarchy">@FormatHierarchyAtTime(context)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudPaper>
                }
            }
        }
    </MudPaper>

</div>

@code {
    [Parameter, EditorRequired]
    public int ProductOwnerId { get; set; }

    // Insights state
    private CacheInsightsDto? _insights;
    private bool _loading = true;

    // Reset state
    private readonly HashSet<string> _selectedTypes = new();
    private bool _resetting;
    private CacheResetResponse? _resetResult;

    // Activity ledger validation
    private int? _validationWorkItemId;
    private DateTime? _validationFromDate;
    private DateTime? _validationToDate;
    private bool _validationLoading;
    private string? _validationError;
    private ActivityLedgerValidationDto? _validationResult;


    protected override async Task OnInitializedAsync()
    {
        await LoadInsightsAsync();
    }

    private async Task LoadInsightsAsync()
    {
        _loading = true;
        try
        {
            _insights = await CacheSyncService.GetCacheInsightsAsync(ProductOwnerId);
        }
        finally
        {
            _loading = false;
        }
    }

    // Reset helpers
    private bool IsTypeSelected(string type) => _selectedTypes.Contains(type);

    private void ToggleTypeSelection(string type, bool selected)
    {
        if (selected) _selectedTypes.Add(type);
        else _selectedTypes.Remove(type);
    }

    private async Task ResetSelectedAsync()
    {
        var confirmed = await ShowConfirmationAsync(
            $"Reset {_selectedTypes.Count} entity type(s)?",
            $"This will delete all cached data for: {string.Join(", ", _selectedTypes)}");
        if (!confirmed) return;

        _resetting = true;
        _resetResult = null;
        try
        {
            var request = new CacheResetRequest { EntityTypes = _selectedTypes.ToList() };
            _resetResult = await CacheSyncService.ResetCacheSelectiveAsync(ProductOwnerId, request);
            if (_resetResult?.Success == true)
            {
                Snackbar.Add("Cache reset completed", Severity.Success);
                await LoadInsightsAsync();
            }
            else
            {
                Snackbar.Add("Cache reset failed", Severity.Error);
            }
        }
        finally
        {
            _resetting = false;
        }
    }

    private async Task ResetAllAsync()
    {
        var confirmed = await ShowConfirmationAsync(
            "Reset all cached data?",
            "This will delete ALL cached data and reset the sync state.");
        if (!confirmed) return;

        _resetting = true;
        _resetResult = null;
        try
        {
            var request = new CacheResetRequest(); // Empty = reset all
            _resetResult = await CacheSyncService.ResetCacheSelectiveAsync(ProductOwnerId, request);
            if (_resetResult?.Success == true)
            {
                Snackbar.Add("Full cache reset completed", Severity.Success);
                await LoadInsightsAsync();
            }
            else
            {
                Snackbar.Add("Cache reset failed", Severity.Error);
            }
        }
        finally
        {
            _resetting = false;
        }
    }

    private async Task<bool> ShowConfirmationAsync(string title, string message)
    {
        var parameters = new DialogParameters<MudMessageBox>();
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        var result = await DialogService.ShowMessageBox(title, message, yesText: "Reset", cancelText: "Cancel");
        return result == true;
    }

    private async Task LoadActivityLedgerValidationAsync()
    {
        if (!_validationWorkItemId.HasValue || _validationWorkItemId.Value <= 0)
        {
            return;
        }

        _validationLoading = true;
        _validationError = null;
        _validationResult = null;

        var fromChangedDate = _validationFromDate.HasValue
            ? new DateTimeOffset(DateTime.SpecifyKind(_validationFromDate.Value.Date, DateTimeKind.Utc))
            : (DateTimeOffset?)null;
        var toChangedDate = _validationToDate.HasValue
            ? new DateTimeOffset(DateTime.SpecifyKind(_validationToDate.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Utc))
            : (DateTimeOffset?)null;

        try
        {
            _validationResult = await CacheSyncService.GetActivityLedgerValidationAsync(
                ProductOwnerId,
                _validationWorkItemId.Value,
                fromChangedDate,
                toChangedDate);

            if (_validationResult == null)
            {
                _validationError = "Unable to load activity ledger validation data.";
            }
        }
        finally
        {
            _validationLoading = false;
        }
    }

    private static string FormatHierarchyChain(CachedWorkItemSnapshotDto snapshot)
    {
        return $"Parent: {FormatNode(snapshot.ParentId, snapshot.ParentTitle)} | Feature: {FormatNode(snapshot.FeatureId, snapshot.FeatureTitle)} | Epic: {FormatNode(snapshot.EpicId, snapshot.EpicTitle)}";
    }

    private static string FormatHierarchyAtTime(ActivityLedgerEventDto evt)
    {
        return $"Parent: {evt.ParentIdAtTime?.ToString() ?? "-"} | Feature: {evt.FeatureIdAtTime?.ToString() ?? "-"} | Epic: {evt.EpicIdAtTime?.ToString() ?? "-"}";
    }

    private static string FormatValueTransition(string? oldValue, string? newValue)
    {
        return $"{(string.IsNullOrWhiteSpace(oldValue) ? "∅" : oldValue)} → {(string.IsNullOrWhiteSpace(newValue) ? "∅" : newValue)}";
    }

    private static string FormatNode(int? id, string? title)
    {
        if (!id.HasValue)
        {
            return "-";
        }

        return string.IsNullOrWhiteSpace(title) ? id.Value.ToString() : $"{id.Value} ({title})";
    }

    private static Color GetStatusColor(CacheSyncStatusDto status)
    {
        return status switch
        {
            CacheSyncStatusDto.Success => Color.Success,
            CacheSyncStatusDto.SuccessWithWarnings => Color.Warning,
            CacheSyncStatusDto.InProgress => Color.Info,
            CacheSyncStatusDto.Failed => Color.Error,
            _ => Color.Default
        };
    }
}
