@using MudBlazor
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@inject SettingsService SettingsService
@inject ModeIsolatedStateService StateService
@inject WorkItemService WorkItemService
@inject ErrorMessageService ErrorMessageService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Application Settings</MudText>

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudForm @ref="_form">
                <MudSelect T="DataMode" 
                           @bind-Value="_dataMode" 
                           Label="Data Mode" 
                           Variant="Variant.Outlined"
                           Class="mb-4">
                    <MudSelectItem Value="DataMode.Mock">Mock (Test Data)</MudSelectItem>
                    <MudSelectItem Value="DataMode.Tfs">TFS (Live Data)</MudSelectItem>
                </MudSelect>

                <MudText Typo="Typo.subtitle1" Class="mb-2">Configured Goals</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Select the goals you want to track
                </MudText>

                @if (_loadingGoals)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                }
                else
                {
                    <MudSelect T="WorkItemDto" 
                               Label="Select Goals" 
                               MultiSelection="true"
                               @bind-SelectedValues="_selectedGoals"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter"
                               Class="mb-4"
                               Dense="false"
                               MaxHeight="400">
                        @foreach (var goal in _availableGoals)
                        {
                            <MudSelectItem Value="@goal">
                                @goal.Title (ID: @goal.TfsId)
                            </MudSelectItem>
                        }
                    </MudSelect>

                    @if (_selectedGoals != null && _selectedGoals.Any())
                    {
                        <MudText Typo="Typo.caption" Color="Color.Info" Class="mb-2">
                            @_selectedGoals.Count() goal(s) selected
                        </MudText>
                    }
                }

                @if (_errorResponse != null)
                {
                    <ErrorDisplay ErrorResponse="@_errorResponse" 
                                  Class="mb-4"
                                  OnDismiss="ClearError" />
                }

                <MudText Typo="Typo.caption" Color="Color.Info" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" />
                    Switching modes will clear the current data and UI state.
                </MudText>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="SaveSettings" Color="Color.Primary" Variant="Variant.Filled" Disabled="_isLoading || _isSaving">
            @if (_isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {
                <text>Save</text>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public EventCallback OnSettingsSaved { get; set; }

    private MudForm _form = null!;
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _loadingGoals = false;
    private DataMode _dataMode = DataMode.Mock;
    private ErrorResponse? _errorResponse;
    private List<WorkItemDto> _availableGoals = new();
    private IEnumerable<WorkItemDto> _selectedGoals = new List<WorkItemDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
        await LoadAvailableGoals();
    }

    private async Task LoadSettings()
    {
        _isLoading = true;
        try
        {
            var settings = await SettingsService.GetOrCreateDefaultSettingsAsync();
            _dataMode = settings.DataMode;
            StateService.SetMode(_dataMode);
            
            // After loading available goals, pre-select the configured ones
            if (settings.ConfiguredGoalIds.Any() && _availableGoals.Any())
            {
                _selectedGoals = _availableGoals
                    .Where(g => settings.ConfiguredGoalIds.Contains(g.TfsId))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading settings");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAvailableGoals()
    {
        _loadingGoals = true;
        try
        {
            ClearError();
            var goals = await WorkItemService.GetAllGoalsAsync();
            _availableGoals = goals.OrderBy(g => g.Title).ToList();
            
            // Pre-select goals after loading if settings are already loaded
            if (!_isLoading)
            {
                var settings = await SettingsService.GetOrCreateDefaultSettingsAsync();
                _selectedGoals = _availableGoals
                    .Where(g => settings.ConfiguredGoalIds.Contains(g.TfsId))
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading available goals");
        }
        finally
        {
            _loadingGoals = false;
        }
    }

    private async Task SaveSettings()
    {
        ClearError();
        
        try
        {
            _isSaving = true;
            
            // Get selected goal IDs
            var goalIds = _selectedGoals.Select(g => g.TfsId).ToList();
            
            if (goalIds.Count == 0)
            {
                _errorResponse = new ErrorResponse
                {
                    UserMessage = "Please select at least one Goal",
                    Suggestion = "Choose at least one goal to track from the dropdown above."
                };
                return;
            }

            // Save settings
            var savedSettings = await SettingsService.UpdateSettingsAsync(_dataMode, goalIds);

            // Update state service mode
            StateService.SetMode(_dataMode);

            // Clear mode-isolated state
            await StateService.ClearStateAsync();

            // Notify parent
            await OnSettingsSaved.InvokeAsync();

            // Close dialog
            MudDialog.Close(DialogResult.Ok(savedSettings));
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error saving settings");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
