@using PoTool.Shared.Settings

<MudStack Spacing="3">
    <MudText Typo="Typo.subtitle1">Profile Picture</MudText>
    
    @* Current Selection Display *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudCard Elevation="2" Style="width: 80px; height: 80px; padding: 4px;">
            <img src="@GetCurrentImagePath()" 
                 alt="Selected profile" 
                 style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px;" />
        </MudCard>
        <MudStack Spacing="1">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Current Selection
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Image @SelectedImageId
            </MudText>
        </MudStack>
    </MudStack>
    
    @* Image Grid *@
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Choose from @TotalImages marine-themed images:
    </MudText>
    
    <MudPaper Elevation="1" Class="pa-3" Style="max-height: 400px; overflow-y: auto;">
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(60px, 1fr)); gap: 8px;">
            @for (int i = 0; i < TotalImages; i++)
            {
                var imageId = i; // Capture for lambda
                var isSelected = imageId == SelectedImageId;
                var imagePath = $"images/profiles/profile-{imageId}.png";
                
                <div @onclick="() => SelectImage(imageId)" 
                     style="@GetImageStyle(isSelected)"
                     title="Image @imageId">
                    <img src="@imagePath" 
                         alt="Profile @imageId" 
                         style="width: 100%; height: 100%; object-fit: cover; border-radius: 4px;" />
                </div>
            }
        </div>
    </MudPaper>
    
    @* Future: Custom Image Upload *@
    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
        <MudText Typo="Typo.caption">
            Custom image upload coming soon!
        </MudText>
    </MudAlert>
</MudStack>

@code {
    private const int TotalImages = 64;
    
    [Parameter]
    public int SelectedImageId { get; set; } = 0;
    
    [Parameter]
    public EventCallback<int> SelectedImageIdChanged { get; set; }
    
    private async Task SelectImage(int imageId)
    {
        SelectedImageId = imageId;
        await SelectedImageIdChanged.InvokeAsync(imageId);
    }
    
    private string GetCurrentImagePath()
    {
        return $"images/profiles/profile-{SelectedImageId}.png";
    }
    
    private string GetImageStyle(bool isSelected)
    {
        var baseStyle = "cursor: pointer; width: 60px; height: 60px; border-radius: 8px; transition: all 0.2s ease;";
        
        if (isSelected)
        {
            return baseStyle + " border: 3px solid var(--mud-palette-primary); box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);";
        }
        
        return baseStyle + " border: 2px solid transparent; opacity: 0.7;";
    }
}

<style>
    .profile-image-selector img:hover {
        opacity: 1 !important;
        transform: scale(1.05);
    }
</style>
