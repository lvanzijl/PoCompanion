@using MudBlazor
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Validators
@using PoTool.Client.Helpers
@inject ProfileService ProfileService
@inject WorkItemService WorkItemService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ErrorMessageService ErrorMessageService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Manage Profiles</MudText>

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <!-- List of existing profiles -->
            @if (_profiles != null && _profiles.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">Your Profiles</MudText>
                <CompactList T="string" Class="mb-4">
                    @foreach (var profile in _profiles)
                    {
                        <MudListItem T="string">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1"><strong>@profile.Name</strong></MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        Team: @profile.TeamName | @profile.AreaPaths.Count area path(s) | @profile.GoalIds.Count goal(s)
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1">
                                    <CompactIconButton Icon="@Icons.Material.Filled.Edit" 
                                                   Color="Color.Primary" 
                                                   OnClick="@(() => EditProfile(profile))" />
                                    <CompactIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Color="Color.Error" 
                                                   OnClick="@(() => DeleteProfile(profile))" />
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                        <MudDivider />
                    }
                </CompactList>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    No profiles yet. Create your first profile to get started.
                </MudAlert>
            }

            <!-- Create/Edit Profile Form -->
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                @(_isEditing ? "Edit Profile" : "Create New Profile")
            </MudText>

            <MudForm @ref="_form">
                <CompactTextField @bind-Value="_profileName" 
                              Label="Profile Name" 
                              Required="true"
                              HelperText="e.g., 'Product A - Team Alpha'" />

                <CompactTextField @bind-Value="_teamName" 
                              Label="Team Name" 
                              Required="true"
                              HelperText="The team responsible for these area paths" />

                <MudAutocomplete T="string"
                                 @bind-Value="_currentAreaPath"
                                 Label="Area Paths"
                                 SearchFunc="@SearchAreaPaths"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Clearable="true"
                                 ResetValueOnEmptyText="false"
                                 AdornmentIcon="@Icons.Material.Filled.FolderOpen"
                                 AdornmentColor="Color.Primary"
                                 HelperText="Type to search and select area paths"
                                 OnAdornmentClick="@AddAreaPath"
                                 Class="mt-2" />
                
                @if (_selectedAreaPaths.Any())
                {
                    <MudChipSet T="string" Class="mt-2">
                        @foreach (var path in _selectedAreaPaths)
                        {
                            <MudChip T="string" Text="@path" OnClose="@(() => RemoveAreaPath(path))" />
                        }
                    </MudChipSet>
                }

                <MudSelect T="int"
                           @bind-Value="_currentGoalId"
                           Label="Goals (Optional)"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomCenter"
                           AdornmentIcon="@Icons.Material.Filled.Flag"
                           AdornmentColor="Color.Primary"
                           HelperText="Select goal IDs to filter work items"
                           Class="mt-2">
                    @foreach (var goal in _availableGoals)
                    {
                        <MudSelectItem T="int" Value="@goal.TfsId">@goal.Title (ID: @goal.TfsId)</MudSelectItem>
                    }
                </MudSelect>
                
                <MudButton Size="Size.Small" 
                          Variant="Variant.Text" 
                          Color="Color.Primary" 
                          StartIcon="@Icons.Material.Filled.Add"
                          OnClick="AddGoalId"
                          Disabled="@(_currentGoalId == 0)"
                          Class="mt-1">
                    Add Goal
                </MudButton>
                
                @if (_selectedGoalIds.Any())
                {
                    <MudChipSet T="string" Class="mt-2">
                        @foreach (var goalId in _selectedGoalIds)
                        {
                            var goalTitle = _availableGoals.FirstOrDefault(g => g.TfsId == goalId)?.Title ?? $"Goal {goalId}";
                            <MudChip T="string" Text="@($"{goalTitle} (ID: {goalId})")" OnClose="@(() => RemoveGoalId(goalId))" />
                        }
                    </MudChipSet>
                }

                @if (_errorResponse != null)
                {
                    <ErrorDisplay ErrorResponse="@_errorResponse" 
                                  Class="mt-4"
                                  OnDismiss="ClearError" />
                }

                <MudStack Row="true" Class="mt-4" Spacing="2">
                    <CompactButton OnClick="SaveProfile" 
                               Color="Color.Primary" 
                               Variant="Variant.Filled" 
                               Disabled="_isSaving"
                               StartIcon="@Icons.Material.Filled.Save">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>@(_isEditing ? "Update" : "Create") Profile</span>
                        }
                    </CompactButton>
                    @if (_isEditing)
                    {
                        <CompactButton OnClick="CancelEdit" 
                                   Color="Color.Default" 
                                   Variant="Variant.Outlined">
                            Cancel
                        </CompactButton>
                    }
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <CompactButton OnClick="Close" Color="Color.Default">Close</CompactButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;

    private IEnumerable<ProfileDto> _profiles = Enumerable.Empty<ProfileDto>();
    private List<string> _allAreaPaths = new();
    private List<WorkItemDto> _availableGoals = new();
    
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isEditing = false;
    private int? _editingProfileId;

    private string _profileName = string.Empty;
    private string _teamName = string.Empty;
    private string _currentAreaPath = string.Empty;
    private int _currentGoalId = 0;
    
    private HashSet<string> _selectedAreaPaths = new();
    private HashSet<int> _selectedGoalIds = new();

    private ErrorResponse? _errorResponse;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
        await LoadAreaPaths();
        await LoadGoals();
    }

    private async Task LoadProfiles()
    {
        try
        {
            _isLoading = true;
            ClearError();
            _profiles = await ProfileService.GetAllProfilesAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading profiles");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAreaPaths()
    {
        try
        {
            var areaPaths = await WorkItemService.GetDistinctAreaPathsAsync();
            _allAreaPaths = areaPaths.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading area paths: {ex.Message}");
        }
    }

    private async Task LoadGoals()
    {
        try
        {
            var goals = await WorkItemService.GetAllGoalsAsync();
            _availableGoals = goals.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading goals: {ex.Message}");
        }
    }

    private async Task<IEnumerable<string>> SearchAreaPaths(string value, CancellationToken token)
    {
        if (string.IsNullOrWhiteSpace(value))
            return _allAreaPaths;

        return _allAreaPaths
            .Where(ap => ap.Contains(value, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void AddAreaPath()
    {
        if (!string.IsNullOrWhiteSpace(_currentAreaPath) && !_selectedAreaPaths.Contains(_currentAreaPath))
        {
            _selectedAreaPaths.Add(_currentAreaPath);
            _currentAreaPath = string.Empty;
            StateHasChanged();
        }
    }

    private void RemoveAreaPath(string path)
    {
        _selectedAreaPaths.Remove(path);
        StateHasChanged();
    }

    private void AddGoalId()
    {
        if (_currentGoalId > 0 && !_selectedGoalIds.Contains(_currentGoalId))
        {
            _selectedGoalIds.Add(_currentGoalId);
            _currentGoalId = 0;
            StateHasChanged();
        }
    }

    private void RemoveGoalId(int goalId)
    {
        _selectedGoalIds.Remove(goalId);
        StateHasChanged();
    }

    private void EditProfile(ProfileDto profile)
    {
        _isEditing = true;
        _editingProfileId = profile.Id;
        _profileName = profile.Name;
        _teamName = profile.TeamName;
        _selectedAreaPaths = new HashSet<string>(profile.AreaPaths);
        _selectedGoalIds = new HashSet<int>(profile.GoalIds);
    }

    private async Task DeleteProfile(ProfileDto profile)
    {
        var result = await DialogService.ShowMessageBox(
            "Confirm Delete",
            $"Are you sure you want to delete the profile '{profile.Name}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var deleted = await ProfileService.DeleteProfileAsync(profile.Id);
                if (deleted)
                {
                    Snackbar.Add($"Profile '{profile.Name}' deleted successfully", Severity.Success);
                    await LoadProfiles();
                    ClearForm();
                }
            }
            catch (Exception ex)
            {
                ShowError(ex, "Error deleting profile");
            }
        }
    }

    private async Task SaveProfile()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        if (!_selectedAreaPaths.Any())
        {
            Snackbar.Add("Please add at least one area path", Severity.Warning);
            return;
        }

        try
        {
            _isSaving = true;
            ClearError();

            var areaPaths = _selectedAreaPaths.ToList();
            var goalIds = _selectedGoalIds.ToList();

            if (_isEditing && _editingProfileId.HasValue)
            {
                await ProfileService.UpdateProfileAsync(
                    _editingProfileId.Value,
                    _profileName,
                    areaPaths,
                    _teamName,
                    goalIds);
                Snackbar.Add("Profile updated successfully", Severity.Success);
            }
            else
            {
                await ProfileService.CreateProfileAsync(
                    _profileName,
                    areaPaths,
                    _teamName,
                    goalIds);
                Snackbar.Add("Profile created successfully", Severity.Success);
            }

            await LoadProfiles();
            ClearForm();
        }
        catch (Exception ex)
        {
            ShowError(ex, _isEditing ? "Error updating profile" : "Error creating profile");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void CancelEdit()
    {
        ClearForm();
    }

    private void ClearForm()
    {
        _isEditing = false;
        _editingProfileId = null;
        _profileName = string.Empty;
        _teamName = string.Empty;
        _currentAreaPath = string.Empty;
        _currentGoalId = 0;
        _selectedAreaPaths.Clear();
        _selectedGoalIds.Clear();
        _form?.ResetValidation();
    }



    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}
