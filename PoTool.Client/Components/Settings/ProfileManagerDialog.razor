@using MudBlazor
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Settings
@using PoTool.Client.Validators
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using CoreSettings = PoTool.Core.Settings
@inject ProfileService ProfileService
@inject WorkItemService WorkItemService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ErrorMessageService ErrorMessageService

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Manage Profiles</MudText>

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <!-- List of existing profiles -->
            @if (_profiles != null && _profiles.Any())
            {
                <MudText Typo="Typo.subtitle1" Class="mb-2">Your Profiles</MudText>
                <CompactList T="string" Class="mb-4">
                    @foreach (var profile in _profiles)
                    {
                        <MudListItem T="string">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body1"><strong>@profile.Name</strong></MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        Team: @profile.TeamName | @profile.AreaPaths.Count area path(s) | @profile.GoalIds.Count goal(s)
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Spacing="1">
                                    <CompactIconButton Icon="@Icons.Material.Filled.Edit" 
                                                   Color="Color.Primary" 
                                                   OnClick="@(() => EditProfile(profile))" />
                                    <CompactIconButton Icon="@Icons.Material.Filled.Delete" 
                                                   Color="Color.Error" 
                                                   OnClick="@(() => DeleteProfile(profile))" />
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                        <MudDivider />
                    }
                </CompactList>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    No profiles yet. Create your first profile to get started.
                </MudAlert>
            }

            <!-- Create/Edit Profile Form -->
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                @(_isEditing ? "Edit Profile" : "Create New Profile")
            </MudText>

            <MudForm @ref="_form">
                <CompactTextField @bind-Value="_profileName" 
                              Label="Profile Name" 
                              Required="true"
                              HelperText="e.g., 'Product A - Team Alpha'" />

                <CompactTextField @bind-Value="_teamName" 
                              Label="Team Name" 
                              Required="true"
                              HelperText="The team responsible for these area paths" />

                <MultiSelectCombobox TItem="string"
                                     Label="Area Paths"
                                     Placeholder="Type to filter area paths..."
                                     Items="@_allAreaPaths"
                                     SelectedItems="@_selectedAreaPathsList"
                                     SelectedItemsChanged="@((items) => _selectedAreaPathsList = items.ToList())"
                                     GetItemText="@(item => item)"
                                     HelperText="Select one or more area paths"
                                     Required="true" />

                <MultiSelectCombobox TItem="WorkItemDto"
                                     Label="Goals"
                                     Placeholder="Type to filter goals..."
                                     Items="@_availableGoals"
                                     SelectedItems="@_selectedGoalsList"
                                     SelectedItemsChanged="@((items) => _selectedGoalsList = items.ToList())"
                                     GetItemText="@GetGoalText"
                                     HelperText="Select one or more goals"
                                     Required="true" />

                <MudDivider Class="my-4" />

                <ProfilePictureSelector @bind-PictureType="_pictureType"
                                       @bind-DefaultPictureId="_defaultPictureId"
                                       @bind-CustomPicturePath="_customPicturePath" />

                @if (_errorResponse != null)
                {
                    <ErrorDisplay ErrorResponse="@_errorResponse" 
                                  Class="mt-4"
                                  OnDismiss="ClearError" />
                }

                <MudStack Row="true" Class="mt-4" Spacing="2">
                    <CompactButton OnClick="SaveProfile" 
                               Color="Color.Primary" 
                               Variant="Variant.Filled" 
                               Disabled="@(_isSaving || !CanSaveProfile())"
                               StartIcon="@Icons.Material.Filled.Save">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>@(_isEditing ? "Update" : "Create") Profile</span>
                        }
                    </CompactButton>
                    @if (_isEditing)
                    {
                        <CompactButton OnClick="CancelEdit" 
                                   Color="Color.Default" 
                                   Variant="Variant.Outlined">
                            Cancel
                        </CompactButton>
                    }
                </MudStack>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <CompactButton OnClick="Close" Color="Color.Default">Close</CompactButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private MudForm _form = null!;

    private IEnumerable<ProfileDto> _profiles = Enumerable.Empty<ProfileDto>();
    private List<string> _allAreaPaths = new();
    private List<WorkItemDto> _availableGoals = new();
    
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _isEditing = false;
    private int? _editingProfileId;

    private string _profileName = string.Empty;
    private string _teamName = string.Empty;
    
    // Changed from IEnumerable to List for multi-select combobox
    private List<string> _selectedAreaPathsList = new();
    private List<WorkItemDto> _selectedGoalsList = new();

    // Profile picture state
    private CoreSettings.ProfilePictureType _pictureType = CoreSettings.ProfilePictureType.Default;
    private int _defaultPictureId = 0;
    private string? _customPicturePath = null;

    private ErrorResponse? _errorResponse;

    private string GetGoalText(WorkItemDto item) => $"{item.Title} (ID: {item.TfsId})";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfiles();
        await LoadAreaPaths();
        await LoadGoals();
    }

    private async Task LoadProfiles()
    {
        try
        {
            _isLoading = true;
            ClearError();
            _profiles = await ProfileService.GetAllProfilesAsync();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading profiles");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadAreaPaths()
    {
        try
        {
            var areaPaths = await WorkItemService.GetDistinctAreaPathsAsync();
            _allAreaPaths = areaPaths.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading area paths: {ex.Message}");
        }
    }

    private async Task LoadGoals()
    {
        try
        {
            var goals = await WorkItemService.GetAllGoalsAsync();
            _availableGoals = goals.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading goals: {ex.Message}");
        }
    }

    private void EditProfile(ProfileDto profile)
    {
        _isEditing = true;
        _editingProfileId = profile.Id;
        _profileName = profile.Name;
        _teamName = profile.TeamName;
        _selectedAreaPathsList = profile.AreaPaths.ToList();
        
        // Map goal IDs to WorkItemDto objects
        _selectedGoalsList = _availableGoals
            .Where(g => profile.GoalIds.Contains(g.TfsId))
            .ToList();
        
        // Load profile picture settings
        _pictureType = (CoreSettings.ProfilePictureType)profile.PictureType;
        _defaultPictureId = profile.DefaultPictureId;
        _customPicturePath = profile.CustomPicturePath;
    }

    private async Task DeleteProfile(ProfileDto profile)
    {
        var result = await DialogService.ShowMessageBox(
            "Confirm Delete",
            $"Are you sure you want to delete the profile '{profile.Name}'?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var deleted = await ProfileService.DeleteProfileAsync(profile.Id);
                if (deleted)
                {
                    Snackbar.Add($"Profile '{profile.Name}' deleted successfully", Severity.Success);
                    await LoadProfiles();
                    ClearForm();
                }
            }
            catch (Exception ex)
            {
                ShowError(ex, "Error deleting profile");
            }
        }
    }

    private bool CanSaveProfile()
    {
        return !string.IsNullOrWhiteSpace(_profileName) 
            && !string.IsNullOrWhiteSpace(_teamName)
            && _selectedAreaPathsList.Any()
            && _selectedGoalsList.Any();
    }

    private async Task SaveProfile()
    {
        await _form.Validate();
        if (!_form.IsValid)
        {
            return;
        }

        if (!_selectedAreaPathsList.Any())
        {
            Snackbar.Add("Please select at least one area path", Severity.Warning);
            return;
        }

        if (!_selectedGoalsList.Any())
        {
            Snackbar.Add("Please select at least one goal", Severity.Warning);
            return;
        }

        try
        {
            _isSaving = true;
            ClearError();

            var areaPaths = _selectedAreaPathsList.ToList();
            var goalIds = _selectedGoalsList.Select(g => g.TfsId).ToList();

            if (_isEditing && _editingProfileId.HasValue)
            {
                await ProfileService.UpdateProfileAsync(
                    _editingProfileId.Value,
                    _profileName,
                    areaPaths,
                    _teamName,
                    goalIds,
                    _pictureType,
                    _defaultPictureId,
                    _customPicturePath);
                Snackbar.Add("Profile updated successfully", Severity.Success);
            }
            else
            {
                await ProfileService.CreateProfileAsync(
                    _profileName,
                    areaPaths,
                    _teamName,
                    goalIds,
                    _pictureType,
                    _defaultPictureId,
                    _customPicturePath);
                Snackbar.Add("Profile created successfully", Severity.Success);
            }

            await LoadProfiles();
            ClearForm();
        }
        catch (Exception ex)
        {
            ShowError(ex, _isEditing ? "Error updating profile" : "Error creating profile");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void CancelEdit()
    {
        ClearForm();
    }

    private void ClearForm()
    {
        _isEditing = false;
        _editingProfileId = null;
        _profileName = string.Empty;
        _teamName = string.Empty;
        _selectedAreaPathsList = new List<string>();
        _selectedGoalsList = new List<WorkItemDto>();
        _pictureType = CoreSettings.ProfilePictureType.Default;
        _defaultPictureId = 0;
        _customPicturePath = null;
        _form?.ResetValidation();
    }



    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private void Close()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
}
