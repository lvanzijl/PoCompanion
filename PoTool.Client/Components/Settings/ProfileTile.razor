@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using ProfilePictureType = PoTool.Shared.Settings.ProfilePictureType
@inject NavigationManager NavigationManager

<MudCard Class="@GetCardClass()" 
         Elevation="@(IsActive ? 6 : 2)"
         Style="cursor: pointer; transition: all 0.3s ease;">
    <MudCardContent Class="d-flex flex-column align-center pa-4" @onclick="HandleClick">
        @* Profile Picture *@
        <div style="width: 80px; height: 80px; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
            <img src="@GetProfileImagePath()" 
                 alt="@(Profile?.Name ?? "Profile")" 
                 style="width: 100%; height: 100%; object-fit: cover;"
                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
            <div style="display: none; width: 100%; height: 100%; align-items: center; justify-content: center; background-color: @GetAvatarColorHex(); color: white; font-size: 2rem; font-weight: bold;">
                @GetProfileInitials()
            </div>
        </div>
        
        @* Profile Name *@
        <MudText Typo="Typo.h6" Class="mt-3 text-center" Style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            @(Profile?.Name ?? "Unknown")
        </MudText>
        
        @* Active indicator *@
        @if (IsActive)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" 
                     Color="Color.Success" 
                     Size="Size.Small" 
                     Class="mt-2" />
        }
    </MudCardContent>
    <MudCardActions Class="justify-center">
        <CompactIconButton Icon="@Icons.Material.Filled.Inventory2" 
                       Color="Color.Primary" 
                       OnClick="@OpenProductOwnerDetails"
                       Title="Show Details" />
    </MudCardActions>
</MudCard>

@code {
    [Parameter]
    public ProfileDto? Profile { get; set; }
    
    [Parameter]
    public bool IsActive { get; set; }
    
    [Parameter]
    public EventCallback<ProfileDto> OnClick { get; set; }
    
    private string GetCardClass()
    {
        return IsActive ? "profile-tile profile-tile-active" : "profile-tile";
    }
    
    private string GetProfileImagePath()
    {
        if (Profile == null)
        {
            return "images/profiles/profile-0.png";
        }
        
        // Use custom picture if available, otherwise use default
        if ((int)Profile.PictureType == 1 && !string.IsNullOrEmpty(Profile.CustomPicturePath))
        {
            return Profile.CustomPicturePath;
        }
        
        // Use default picture ID (0-63)
        var imageId = Math.Max(0, Math.Min(63, Profile.DefaultPictureId));
        return $"images/profiles/profile-{imageId}.png";
    }
    
    private string GetProfileInitials()
    {
        if (Profile == null || string.IsNullOrWhiteSpace(Profile.Name))
        {
            return "?";
        }
        
        var parts = Profile.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }
        
        return Profile.Name.Length >= 2 
            ? Profile.Name.Substring(0, 2).ToUpperInvariant() 
            : Profile.Name.ToUpperInvariant();
    }
    
    private Color GetAvatarColor()
    {
        if (Profile == null) return Color.Default;
        
        // Use profile ID to deterministically select a color
        var colors = new[] { Color.Primary, Color.Secondary, Color.Tertiary, Color.Info, Color.Success, Color.Warning };
        return colors[Math.Abs(Profile.Id) % colors.Length];
    }
    
    private string GetAvatarColorHex()
    {
        if (Profile == null) return "#757575";
        
        // Use profile ID to deterministically select a color
        var colors = new[] { "#1976d2", "#9c27b0", "#d32f2f", "#0288d1", "#388e3c", "#f57c00" };
        return colors[Math.Abs(Profile.Id) % colors.Length];
    }
    
    private async Task HandleClick()
    {
        if (Profile != null)
        {
            await OnClick.InvokeAsync(Profile);
        }
    }

    private void OpenProductOwnerDetails()
    {
        if (Profile != null)
        {
            NavigationManager.NavigateTo($"/settings/productowner/{Profile.Id}");
        }
    }
}

<style>
    .profile-tile {
        min-width: 160px;
        max-width: 180px;
        border-radius: 12px;
    }
    
    .profile-tile:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3) !important;
    }
    
    .profile-tile-active {
        border: 2px solid var(--mud-palette-success);
    }
</style>
