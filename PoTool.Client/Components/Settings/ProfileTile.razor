@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Models

<MudCard Class="@GetCardClass()" 
         Elevation="@(IsActive ? 6 : 2)"
         Style="cursor: pointer; transition: all 0.3s ease;"
         @onclick="HandleClick">
    <MudCardContent Class="d-flex flex-column align-center pa-4">
        @* Profile Picture *@
        <MudAvatar Size="Size.Large" 
                   Style="width: 80px; height: 80px; font-size: 2rem;">
            @if (Profile != null)
            {
                <MudImage Src="@GetProfileImageUrl()" 
                          Alt="@Profile.Name" 
                          ObjectFit="ObjectFit.Cover" />
            }
        </MudAvatar>
        
        @* Profile Name *@
        <MudText Typo="Typo.h6" Class="mt-3 text-center" Style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            @(Profile?.Name ?? "Unknown")
        </MudText>
        
        @* Team Name *@
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="text-center" Style="max-width: 140px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            @(Profile?.TeamName ?? "No Team")
        </MudText>
        
        @* Active indicator *@
        @if (IsActive)
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" 
                     Color="Color.Success" 
                     Size="Size.Small" 
                     Class="mt-2" />
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    public ProfileDto? Profile { get; set; }
    
    [Parameter]
    public bool IsActive { get; set; }
    
    [Parameter]
    public EventCallback<ProfileDto> OnClick { get; set; }
    
    private const string DefaultProfilePicturesPath = "/assets/profile-defaults/";
    private const string DefaultProfilePictureFallback = "profile-0.svg";
    
    private string GetCardClass()
    {
        return IsActive ? "profile-tile profile-tile-active" : "profile-tile";
    }
    
    private string GetProfileImageUrl()
    {
        if (Profile == null)
        {
            return $"{DefaultProfilePicturesPath}{DefaultProfilePictureFallback}";
        }
        
        // Use custom picture if set
        if ((ProfilePictureType)Profile.PictureType == ProfilePictureType.Custom 
            && !string.IsNullOrEmpty(Profile.CustomPicturePath))
        {
            return Profile.CustomPicturePath;
        }
        
        // Use default picture (constrain to 0-63 range)
        var pictureId = Math.Clamp(Profile.DefaultPictureId, 0, 63);
        return $"{DefaultProfilePicturesPath}profile-{pictureId}.svg";
    }
    
    private async Task HandleClick()
    {
        if (Profile != null)
        {
            await OnClick.InvokeAsync(Profile);
        }
    }
}

<style>
    .profile-tile {
        min-width: 160px;
        max-width: 180px;
        border-radius: 12px;
    }
    
    .profile-tile:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.3) !important;
    }
    
    .profile-tile-active {
        border: 2px solid var(--mud-palette-success);
    }
</style>
