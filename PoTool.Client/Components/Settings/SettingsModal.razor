@using System.Net.Http.Json
@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@inject TfsConfigService TfsConfigService
@inject NavigationManager NavigationManager
@inject IOnboardingService OnboardingService
@inject IProfileService ProfileService
@inject ISnackbar Snackbar
@implements IDisposable

@if (Visible)
{
    <div class="settings-modal-backdrop" @onclick="Close"></div>
    <div class="settings-modal">
        <div class="settings-header">
            <h3>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2" />
                Settings
            </h3>
            <button class="close-btn" @onclick="Close">×</button>
        </div>

        <div class="settings-content">
            <MudStack Spacing="4">
                @* Cache Status Section *@
                @if (_profileId.HasValue)
                {
                    <div>
                        <MudText Typo="Typo.h6" Class="mb-3">
                            <MudIcon Icon="@Icons.Material.Filled.Cached" Class="mr-2" />
                            Cache Status
                        </MudText>
                        <CacheStatusSection ProductOwnerId="@_profileId.Value" AutoSync="false" />
                    </div>
                    
                    <MudDivider />
                }

                @* TFS Configuration Section *@
                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Cloud" Class="mr-2" />
                        TFS / Azure DevOps Configuration
                    </MudText>

                    @* Current Configuration Summary *@
                    @if (!string.IsNullOrEmpty(_model.Url))
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2"><strong>URL:</strong> @_model.Url</MudText>
                                <MudText Typo="Typo.body2"><strong>Project:</strong> @_model.Project</MudText>
                                <MudText Typo="Typo.body2"><strong>Default Area Path:</strong> @_model.DefaultAreaPath</MudText>
                            </MudStack>
                        </MudAlert>
                    }

                    <EditForm Model="_model" OnValidSubmit="SaveConfig">
                        <MudStack Spacing="3">
                            <MudTextField @bind-Value="_model.Url"
                                          Label="TFS / Azure DevOps URL"
                                          Placeholder="https://dev.azure.com/yourorg"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />

                            <MudTextField @bind-Value="_model.Project"
                                          Label="Project"
                                          Placeholder="Project name"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />

                            <MudTextField @bind-Value="_model.DefaultAreaPath"
                                          Label="Default Area Path"
                                          Placeholder="e.g., ProjectName\Team A"
                                          HelperText="The area path used for work item queries"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />

                            <MudAlert Severity="Severity.Info" Dense="true">
                                <strong>Authentication:</strong> Uses Windows credentials (NTLM) of the current user.
                            </MudAlert>

                            <MudStack Row="true" Spacing="2">
                                <MudButton ButtonType="ButtonType.Submit"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save">
                                    Save
                                </MudButton>
                                <MudButton OnClick="TestConnection"
                                           Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           StartIcon="@Icons.Material.Filled.CheckCircle">
                                    Test Connection
                                </MudButton>
                            </MudStack>
                        </MudStack>
                    </EditForm>

                    @if (!string.IsNullOrEmpty(_statusMessage))
                    {
                        <MudAlert Severity="@GetStatusSeverity()" Class="mt-3" Dense="true">
                            @_statusMessage
                        </MudAlert>
                    }
                </div>

                <MudDivider />

                @* Work Item State Mapping Section *@
                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" />
                        Work Item State Mapping
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mb-3">
                        Configure how TFS work item states map to the system's canonical lifecycle states (New, In Progress, Done, Removed).
                    </MudText>
                    <MudButton OnClick="OpenWorkItemStates"
                               Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Settings">
                        Configure State Mapping
                    </MudButton>
                </div>

                <MudDivider />

                @* Getting Started Section *@
                <div>
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" />
                        Getting Started
                    </MudText>
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        Need help setting up? Run the getting started wizard to configure your connection and team.
                    </MudAlert>
                    <MudButton OnClick="OpenOnboardingWizard"
                               Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.Rocket">
                        Run Getting Started Wizard
                    </MudButton>
                </div>
            </MudStack>
        </div>

        <div class="settings-actions">
            <MudButton OnClick="Close"
                       Variant="Variant.Text"
                       Color="Color.Default">
                Close
            </MudButton>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    private TfsModel _model = new();
    private string _statusMessage = string.Empty;
    private string _statusClass = string.Empty;
    private int? _profileId;

    protected override async Task OnParametersSetAsync()
    {
        if (Visible)
        {
            await LoadExisting();
            await LoadActiveProfile();
        }
    }

    private async Task LoadActiveProfile()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading active profile: {ex.Message}");
            _profileId = null;
        }
    }

    private async Task LoadExisting()
    {
        _statusMessage = string.Empty;
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            if (config != null)
            {
                _model.Url = config.Url ?? string.Empty;
                _model.Project = config.Project ?? string.Empty;
                _model.DefaultAreaPath = config.DefaultAreaPath ?? string.Empty;
            }
        }
        catch (Exception ex)
        {
            _statusMessage = "Could not load existing configuration: " + ex.Message;
            _statusClass = "status-error";
        }
    }

    private async Task SaveConfig()
    {
        _statusMessage = "Saving...";
        _statusClass = "status-info";
        try
        {
            await TfsConfigService.SaveConfigAsync(_model.Url, _model.Project, _model.DefaultAreaPath);
            _statusMessage = "Saved successfully";
            _statusClass = "status-success";
            Snackbar.Add("Configuration saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            _statusMessage = "Save failed: " + ex.Message;
            _statusClass = "status-error";
            Snackbar.Add($"Failed to save configuration: {ex.Message}", Severity.Error);
        }
    }

    private async Task TestConnection()
    {
        _statusMessage = "Testing...";
        _statusClass = "status-info";
        try
        {
            var isValid = await TfsConfigService.ValidateConnectionAsync();
            if (isValid)
            {
                _statusMessage = "Connection OK";
                _statusClass = "status-success";
                Snackbar.Add("Connection test successful", Severity.Success);
            }
            else
            {
                _statusMessage = "Connection failed";
                _statusClass = "status-error";
                Snackbar.Add("Connection test failed", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _statusMessage = "Test failed: " + ex.Message;
            _statusClass = "status-error";
            Snackbar.Add($"Connection test failed: {ex.Message}", Severity.Error);
        }
    }

    private Severity GetStatusSeverity()
    {
        return _statusClass switch
        {
            "status-success" => Severity.Success,
            "status-error" => Severity.Error,
            "status-info" => Severity.Info,
            _ => Severity.Normal
        };
    }

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(Visible);
    }

    private async Task OpenWorkItemStates()
    {
        // Close the settings modal first
        await Close();
        
        // Small delay to ensure modal is fully closed before navigation
        await Task.Delay(100);
        
        // Navigate to the work item states configuration page
        NavigationManager.NavigateTo("/settings/workitem-states");
    }

    private async Task OpenOnboardingWizard()
    {
        // Reset onboarding state so the wizard can be shown again
        await OnboardingService.ResetOnboardingAsync();
        
        // Close the settings modal first
        await Close();
        
        // Small delay to ensure modal is fully closed before navigation
        await Task.Delay(100);
        
        // Navigate to onboarding page (force reload to ensure clean state after reset)
        NavigationManager.NavigateTo("/onboarding", forceLoad: true);
    }

    public void Dispose()
    {
        // no-op for now
    }

    private class TfsModel
    {
        public string Url { get; set; } = string.Empty;
        public string Project { get; set; } = string.Empty;
        public string DefaultAreaPath { get; set; } = string.Empty;
    }
}
