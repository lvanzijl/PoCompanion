    private async Task SaveRepositories()
    {
        if (!_createdProductId.HasValue)
        {
            _repositorySaveResult = new ConnectionTestResult(false, "No product created yet. Please complete the product creation step first.");
            return;
        }

        if (!_selectedRepositoryNames.Any())
        {
            _repositorySaveResult = new ConnectionTestResult(false, "No repositories selected.");
            return;
        }

        ClearRepositoryError();
        _isSavingRepositories = true;
        
        try
        {
            var successCount = 0;
            var failedRepos = new List<(string Name, string Error)>();

            // Save repositories in parallel for better performance
            var saveTasks = _selectedRepositoryNames.Select(async repoName =>
            {
                try
                {
                    var requestBody = new { Name = repoName };
                    var response = await HttpClient.PostAsJsonAsync(
                        $"/api/products/{_createdProductId.Value}/repositories", 
                        requestBody);
                    
                    if (response.IsSuccessStatusCode)
                    {
                        return (Success: true, Name: repoName, Error: (string?)null);
                    }
                    else
                    {
                        var errorContent = await response.Content.ReadAsStringAsync();
                        return (Success: false, Name: repoName, Error: $"HTTP {(int)response.StatusCode}: {errorContent}");
                    }
                }
                catch (Exception ex)
                {
                    return (Success: false, Name: repoName, Error: ex.Message);
                }
            });

            var results = await Task.WhenAll(saveTasks);
            
            successCount = results.Count(r => r.Success);
            failedRepos = results
                .Where(r => !r.Success)
                .Select(r => (r.Name, r.Error ?? "Unknown error"))
                .ToList();

            if (failedRepos.Any())
            {
                var failedDetails = string.Join(", ", failedRepos.Select(f => $"{f.Name} ({f.Error})"));
                _repositorySaveResult = new ConnectionTestResult(
                    successCount > 0, 
                    $"Saved {successCount} repository(ies). Failed: {failedDetails}");
                Snackbar.Add($"Partially saved repositories", Severity.Warning);
            }
            else
            {
                _repositorySaveResult = new ConnectionTestResult(true, $"Successfully saved {successCount} repository(ies)!");
                Snackbar.Add("Repositories saved successfully", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            _repositorySaveResult = new ConnectionTestResult(false, "Repository save failed.");
            ShowRepositoryError(ex, "Error saving repositories");
        }
        finally
        {
            _isSavingRepositories = false;
        }
    }

