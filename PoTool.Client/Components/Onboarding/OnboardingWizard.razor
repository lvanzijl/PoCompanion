    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_tfsConfigHub is not null)
            {
                if (_tfsConfigHub.State == HubConnectionState.Connected)
                {
                    await _tfsConfigHub.InvokeAsync("LeaveConfigProgressGroup");
                }
                await _tfsConfigHub.DisposeAsync();
            }
        }
        catch
        {
            // Ignore disposal errors
        }
    }

