    private List<TfsConfigProgressUpdate> GetFilteredProgressUpdates()
    {
        var filtered = new List<TfsConfigProgressUpdate>();
        var phaseGroups = _progressUpdates.GroupBy(u => u.Phase);
        
        foreach (var group in phaseGroups)
        {
            var phase = group.Key;
            var updates = group.ToList();
            
            // For "Verifying API - {capabilityId}" sub-phases (individual API checks)
            if (phase.StartsWith("Verifying API - "))
            {
                // Check if all API checks passed by looking for the summary message
                var allChecksPassed = _progressUpdates.Any(u => 
                    u.Phase == "Verifying API" && 
                    u.State == ProgressState.Succeeded && 
                    u.Message.Contains("All"));
                
                // Hide individual successful checks when all checks passed
                // Only show individual checks (including successes) when some failed
                if (allChecksPassed)
                {
                    // Skip this individual check (don't show it since all passed)
                    continue;
                }
                else
                {
                    // Show all individual checks when some failed
                    filtered.AddRange(updates);
                }
            }
            else
            {
                // For main phases, if there's a succeeded/failed state, remove the running state
                var hasCompletedState = updates.Any(u => u.State == ProgressState.Succeeded || u.State == ProgressState.Failed);
                
                if (hasCompletedState)
                {
                    // Only keep succeeded/failed states, skip running states
                    filtered.AddRange(updates.Where(u => u.State != ProgressState.Running));
                }
                else
                {
                    // No completed state yet, keep all (including running)
                    filtered.AddRange(updates);
                }
            }
        }
        
        return filtered;
    }

