    private Task<IEnumerable<TfsTeamDto>> SearchTeams(string? searchText, CancellationToken cancellationToken)
    {
        if (_tfsTeams == null || !_tfsTeams.Any())
            return Task.FromResult(Enumerable.Empty<TfsTeamDto>());

        if (string.IsNullOrWhiteSpace(searchText))
            return Task.FromResult(_tfsTeams.AsEnumerable());

        var filtered = _tfsTeams.Where(team => 
            team.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (!string.IsNullOrEmpty(team.Description) && team.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        );

        return Task.FromResult(filtered);
    }

    private async Task SaveTeam()
    {
        if (!_teamFormValid || _selectedTfsTeam == null) return;

        ClearTeamError();
        _isSavingTeam = true;
        
        try
        {
            var areaPath = _overrideAreaPath ? _teamAreaPath : _selectedTfsTeam.DefaultAreaPath;
            
            // Create team entity with TFS team info
            var team = await TeamService.CreateTeamAsync(
                name: _selectedTfsTeam.Name,
                teamAreaPath: areaPath,
                pictureType: PoTool.Shared.Settings.TeamPictureType.Default,
                defaultPictureId: _selectedPictureId,
                customPicturePath: null,
                projectName: _selectedTfsTeam.ProjectName,
                tfsTeamId: _selectedTfsTeam.Id,
                tfsTeamName: _selectedTfsTeam.Name);
            
            // Track created team ID
            _createdTeamId = team.Id;
            
            // If we have both a product and a team created, link them together
            // If linking fails, it will be caught by outer exception handler
            // User can manually link via Settings UI if needed
            if (_createdProductId.HasValue && _createdTeamId.HasValue)
            {
                var linked = await ProductService.LinkTeamAsync(_createdProductId.Value, _createdTeamId.Value);
                if (linked)
                {
                    _teamSaveResult = new ConnectionTestResult(true, $"Team '{team.Name}' created and linked to product successfully!");
                    Snackbar.Add("Team saved and linked successfully", Severity.Success);
                }
                else
                {
                    // LinkTeamAsync returns false only for 404 errors (product or team not found)
                    _teamSaveResult = new ConnectionTestResult(true, $"Team '{team.Name}' created but product not found for linking");
                    Snackbar.Add("Team saved but linking failed - product not found", Severity.Warning);
                }
            }
            else
            {
                _teamSaveResult = new ConnectionTestResult(true, $"Team '{team.Name}' created successfully!");
                Snackbar.Add("Team saved successfully", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            _teamSaveResult = new ConnectionTestResult(false, "Team save failed.");
            ShowTeamError(ex, "Error saving team");
        }
        finally
        {
            _isSavingTeam = false;
        }
    }

