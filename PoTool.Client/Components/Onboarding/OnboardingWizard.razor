    private Task<IEnumerable<GitRepositoryDto>> SearchRepositories(string? searchText, CancellationToken cancellationToken)
    {
        if (_gitRepositories == null || !_gitRepositories.Any())
            return Task.FromResult(Enumerable.Empty<GitRepositoryDto>());

        // Filter out already selected repositories
        var availableRepos = _gitRepositories.Where(repo => !_selectedRepositoryNames.Contains(repo.Name));

        if (string.IsNullOrWhiteSpace(searchText))
            return Task.FromResult(availableRepos);

        var filtered = availableRepos.Where(repo => 
            repo.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)
        );

        return Task.FromResult(filtered);
    }

