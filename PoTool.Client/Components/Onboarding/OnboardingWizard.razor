@using PoTool.Client.Services
@inject IOnboardingService OnboardingService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

@if (_isVisible)
{
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h5">
                @GetStepTitle()
            </MudText>
            <MudProgressLinear Color="Color.Primary" Value="@GetProgress()" Class="mt-2" />
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="4" Class="pa-4">
                @if (_currentStep == 0)
                {
                    <!-- Step 1: Welcome & Overview -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.WavingHand" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Welcome to PO Companion!</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            PO Companion is your Azure DevOps work item management companion, designed to help Product Owners:
                        </MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                <MudText>View and manage work items in a hierarchical tree structure</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                <MudText>Validate work item relationships and identify issues</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                <MudText>Track pull request metrics and iteration patterns</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                <MudText>Sync with Azure DevOps in real-time</MudText>
                            </MudListItem>
                        </MudList>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Let's get you started in just a few simple steps!
                        </MudText>
                    </MudStack>
                }
                else if (_currentStep == 1)
                {
                    <!-- Step 2: TFS Configuration -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Configure Azure DevOps Connection</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            To connect to your Azure DevOps organization, you'll need:
                        </MudText>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Link" IconColor="Color.Info">
                                <MudText><strong>Organization URL:</strong> Your Azure DevOps organization URL</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Example: https://dev.azure.com/yourorganization</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Folder" IconColor="Color.Info">
                                <MudText><strong>Project Name:</strong> The name of your project</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Key" IconColor="Color.Info">
                                <MudText><strong>Personal Access Token (PAT):</strong> A token with read access to work items</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Your PAT is encrypted and stored securely</MudText>
                            </MudListItem>
                        </MudList>
                        <MudAlert Severity="Severity.Info" Dense="true">
                            You can configure these settings now or skip and do it later from the Configuration page.
                        </MudAlert>
                        <MudButton 
                            Variant="Variant.Filled" 
                            Color="Color.Primary" 
                            StartIcon="@Icons.Material.Filled.Settings"
                            OnClick="NavigateToConfig">
                            Configure Now
                        </MudButton>
                    </MudStack>
                }
                else if (_currentStep == 2)
                {
                    <!-- Step 3: Initial Sync -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Sync" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Sync Your Work Items</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Once configured, you'll need to sync your work items from Azure DevOps.
                        </MudText>
                        
                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1"><strong>Full Sync</strong></MudText>
                                <MudText Typo="Typo.body2">
                                    Downloads all work items from Azure DevOps. Use this for the first sync or after major changes.
                                </MudText>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.subtitle1"><strong>Incremental Sync</strong></MudText>
                                <MudText Typo="Typo.body2">
                                    Downloads only changes since the last sync. Faster for regular updates.
                                </MudText>
                            </MudStack>
                        </MudPaper>

                        <MudAlert Severity="Severity.Info" Dense="true">
                            The first sync may take a few minutes depending on the number of work items in your project.
                        </MudAlert>
                    </MudStack>
                }
                else if (_currentStep == 3)
                {
                    <!-- Step 4: Feature Tour -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Tour" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Key Features</MudText>
                        </MudStack>
                        
                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.FilterList" Color="Color.Primary" />
                                    <MudText Typo="Typo.subtitle1"><strong>Filters and Search</strong></MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    Filter work items by type, state, or search by title. Use validation filters to identify issues with parent progress or missing effort.
                                </MudText>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                                    <MudText Typo="Typo.subtitle1"><strong>Validation</strong></MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    Automatically validate work item relationships and identify configuration issues.
                                </MudText>
                            </MudStack>
                        </MudPaper>

                        <MudPaper Elevation="0" Class="pa-4 mud-background-gray">
                            <MudStack Spacing="2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Keyboard" Color="Color.Info" />
                                    <MudText Typo="Typo.subtitle1"><strong>Keyboard Shortcuts</strong></MudText>
                                </MudStack>
                                <MudText Typo="Typo.body2">
                                    Navigate work items using arrow keys, expand/collapse with Enter, and use Ctrl+A to select all.
                                </MudText>
                            </MudStack>
                        </MudPaper>

                        <MudAlert Severity="Severity.Success" Dense="true">
                            You're all set! Click "Get Started" to begin using PO Companion.
                        </MudAlert>
                    </MudStack>
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Skip" Color="Color.Default">
                @if (_currentStep == 3)
                {
                    <text>Skip for Now</text>
                }
                else
                {
                    <text>Skip Tour</text>
                }
            </MudButton>
            @if (_currentStep > 0)
            {
                <MudButton OnClick="Previous" Color="Color.Default" Variant="Variant.Outlined">
                    Previous
                </MudButton>
            }
            @if (_currentStep < 3)
            {
                <MudButton OnClick="Next" Color="Color.Primary" Variant="Variant.Filled">
                    Next
                </MudButton>
            }
            else
            {
                <MudButton OnClick="Complete" Color="Color.Success" Variant="Variant.Filled">
                    Get Started
                </MudButton>
            }
        </DialogActions>
    </MudDialog>
}

@code {
    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public EventCallback OnCompleted { get; set; }

    private int _currentStep = 0;
    private bool _isVisible = true;

    private string GetStepTitle()
    {
        return _currentStep switch
        {
            0 => "Welcome to PO Companion",
            1 => "Configure Your Connection",
            2 => "Sync Your Work Items",
            3 => "Discover Key Features",
            _ => "Getting Started"
        };
    }

    private double GetProgress()
    {
        return (_currentStep + 1) * 25.0;
    }

    private void Next()
    {
        if (_currentStep < 3)
        {
            _currentStep++;
        }
    }

    private void Previous()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private void NavigateToConfig()
    {
        // Mark as skipped for now, user can return via Help menu
        OnboardingService.MarkOnboardingSkipped();
        MudDialog?.Close(DialogResult.Cancel());
        NavigationManager.NavigateTo("/tfsconfig");
    }

    private async Task Skip()
    {
        OnboardingService.MarkOnboardingSkipped();
        await OnCompleted.InvokeAsync();
        MudDialog?.Close(DialogResult.Cancel());
    }

    private async Task Complete()
    {
        OnboardingService.MarkOnboardingCompleted();
        await OnCompleted.InvokeAsync();
        MudDialog?.Close(DialogResult.Ok(true));
    }
}
