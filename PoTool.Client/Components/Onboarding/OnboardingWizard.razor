@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Shared.Settings
@using System.Text.Json
@inject IOnboardingService OnboardingService
@inject IOnboardingWizardState WizardState
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject TfsConfigService TfsConfigService
@inject ProfileService ProfileService
@inject ProductService ProductService
@inject TeamService TeamService
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar
@inject HttpClient HttpClient

@if (_isVisible)
{
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h5">
                @GetStepTitle()
            </MudText>
            <MudProgressLinear Color="Color.Primary" Value="@GetProgress()" Class="mt-2" />
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="4" Class="pa-4">
                @if (_currentStep == 0)
                {
                    <!-- Step 1: TFS Configuration -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Configure Azure DevOps Connection</MudText>
                        </MudStack>
                        
                        <MudForm @ref="_configForm" @bind-IsValid="_configFormValid">
                            <CompactTextField Value="@_url"
                                         ValueChanged="@((string value) => OnUrlChanged(value))"
                                         Label="Organization URL" 
                                         Placeholder="https://dev.azure.com/yourorg"
                                         Required="true"
                                         HelperText="The URL of your Azure DevOps organization" />

                            <CompactTextField Value="@_project"
                                         ValueChanged="@((string value) => OnProjectChanged(value))"
                                         Label="Project Name" 
                                         Placeholder="MyProject"
                                         Required="true"
                                         HelperText="The name of your project" />

                            <CompactTextField Value="@_defaultAreaPath"
                                         ValueChanged="@((string value) => OnDefaultAreaPathChanged(value))"
                                         Label="Default Area Path" 
                                         Placeholder="e.g., MyProject\Team A"
                                         Required="true"
                                         HelperText="The area path used for work item queries" />

                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                                <strong>Authentication:</strong> Uses Windows credentials (NTLM) of the current user. No additional configuration required.
                            </MudAlert>

                            <MudStack Row="true" Spacing="2" Class="mt-2">
                                <CompactButton Variant="Variant.Filled" 
                                          Color="Color.Primary" 
                                          OnClick="SaveConfig"
                                          Disabled="@(!_configFormValid || _isSaving)"
                                          StartIcon="@Icons.Material.Filled.Check">
                                    @if (_isSaving)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save</span>
                                    }
                                </CompactButton>
                            </MudStack>
                        </MudForm>

                        @if (_progressUpdates.Any())
                        {
                            <MudPaper Elevation="2" Class="pa-3 mt-2">
                                <MudStack Spacing="2">
                                    @foreach (var update in _progressUpdates)
                                    {
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            @if (update.State == "Running")
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                                            }
                                            else if (update.State == "Succeeded")
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                            }
                                            else if (update.State == "Failed")
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
                                            }
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2">@update.Message</MudText>
                                                @if (!string.IsNullOrEmpty(update.Details))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Error">@update.Details</MudText>
                                                }
                                            </MudStack>
                                        </MudStack>
                                    }
                                    @if (_configCompleted.HasValue)
                                    {
                                        <MudProgressLinear Color="@(_configCompleted.Value ? Color.Success : Color.Error)" 
                                                          Value="100" 
                                                          Class="mt-2" />
                                    }
                                    else if (_progressUpdates.Any())
                                    {
                                        var lastUpdate = _progressUpdates.Last();
                                        <MudProgressLinear Color="Color.Info" 
                                                          Value="@(lastUpdate.PercentComplete ?? 0)" 
                                                          Class="mt-2" />
                                    }
                                </MudStack>
                            </MudPaper>
                        }

                        @if (_configErrorResponse != null)
                        {
                            <ErrorDisplay ErrorResponse="@_configErrorResponse" 
                                         OnDismiss="ClearConfigError" />
                        }
                        
                        <MudAlert Severity="Severity.Info" Dense="true">
                            You can configure these settings now or skip and do it later from the Configuration page.
                        </MudAlert>
                    </MudStack>
                }
                else if (_currentStep == 1)
                {
                    <!-- Step 2: Product Owner (Profile) -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Create Product Owner Profile</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Create your Product Owner profile to get started.
                        </MudText>

                        <MudForm @ref="_profileForm" @bind-IsValid="_profileFormValid">
                            <CompactTextField @bind-Value="_profileName" 
                                         Label="Profile Name" 
                                         Placeholder="e.g., John Doe"
                                         Required="true"
                                         HelperText="Your name as Product Owner" />

                            <MudStack Row="true" Spacing="2" Class="mt-2">
                                <CompactButton Variant="Variant.Filled" 
                                          Color="Color.Primary" 
                                          OnClick="SaveProfile"
                                          Disabled="@(!_profileFormValid || _isSavingProfile)"
                                          StartIcon="@Icons.Material.Filled.Save">
                                    @if (_isSavingProfile)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save Profile</span>
                                    }
                                </CompactButton>
                            </MudStack>
                        </MudForm>

                        @if (_profileSaveResult != null)
                        {
                            <MudAlert Severity="@(_profileSaveResult.Success ? Severity.Success : Severity.Error)" Dense="true">
                                @_profileSaveResult.Message
                            </MudAlert>
                        }

                        @if (_profileErrorResponse != null)
                        {
                            <ErrorDisplay ErrorResponse="@_profileErrorResponse" 
                                         OnDismiss="ClearProfileError" />
                        }

                        <MudAlert Severity="Severity.Info" Dense="true">
                            You can skip this step and configure your profile later from the Settings page.
                        </MudAlert>
                    </MudStack>
                }
                else if (_currentStep == 2)
                {
                    <!-- Step 3: Product -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Create Product</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Define a product to manage its backlog.
                        </MudText>

                        <MudForm @ref="_productForm" @bind-IsValid="_productFormValid">
                            <CompactTextField @bind-Value="_productName" 
                                         Label="Product Name" 
                                         Placeholder="e.g., My Application"
                                         Required="true"
                                         HelperText="The name of your product" />

                            <CompactTextField @bind-Value="_backlogRootWorkItemId" 
                                         Label="Backlog Root Work Item ID" 
                                         Placeholder="e.g., 12345"
                                         Required="true"
                                         HelperText="The ID of the root work item for this product's backlog" />

                            <MudStack Row="true" Spacing="2" Class="mt-2">
                                <CompactButton Variant="Variant.Filled" 
                                          Color="Color.Primary" 
                                          OnClick="SaveProduct"
                                          Disabled="@(!_productFormValid || _isSavingProduct)"
                                          StartIcon="@Icons.Material.Filled.Save">
                                    @if (_isSavingProduct)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save Product</span>
                                    }
                                </CompactButton>
                            </MudStack>
                        </MudForm>

                        @if (_productSaveResult != null)
                        {
                            <MudAlert Severity="@(_productSaveResult.Success ? Severity.Success : Severity.Error)" Dense="true">
                                @_productSaveResult.Message
                            </MudAlert>
                        }

                        @if (_productErrorResponse != null)
                        {
                            <ErrorDisplay ErrorResponse="@_productErrorResponse" 
                                         OnDismiss="ClearProductError" />
                        }

                        <MudAlert Severity="Severity.Info" Dense="true">
                            You can skip this step and configure products later from the Settings page.
                        </MudAlert>
                    </MudStack>
                }
                else if (_currentStep == 3)
                {
                    <!-- Step 4: Team -->
                    <MudStack Spacing="4">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">Select Your Team</MudText>
                        </MudStack>
                        <MudText Typo="Typo.body1">
                            Select your team from Azure DevOps. The area path will be automatically derived from the team settings.
                        </MudText>

                        @if (_isLoadingTeams)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                <MudText>Loading teams from TFS...</MudText>
                            </MudStack>
                        }
                        else if (_tfsTeams != null && _tfsTeams.Any())
                        {
                            <MudForm @ref="_teamForm" @bind-IsValid="_teamFormValid">
                                <MudSelect T="TfsTeamDto" 
                                          Label="Select Team" 
                                          @bind-Value="_selectedTfsTeam"
                                          Required="true"
                                          HelperText="Choose your team from Azure DevOps">
                                    @foreach (var team in _tfsTeams)
                                    {
                                        <MudSelectItem Value="@team">
                                            @team.Name
                                            @if (!string.IsNullOrEmpty(team.Description))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"> - @team.Description</MudText>
                                            }
                                        </MudSelectItem>
                                    }
                                </MudSelect>

                                @if (_selectedTfsTeam != null)
                                {
                                    <MudCheckBox @bind-Value="_overrideAreaPath" 
                                                Label="Override area path" 
                                                Color="Color.Primary"
                                                Dense="true" />
                                    
                                    @if (_overrideAreaPath)
                                    {
                                        <CompactTextField @bind-Value="_teamAreaPath" 
                                                         Label="Area Path" 
                                                         Required="true"
                                                         HelperText="Custom area path for this team" />
                                    }
                                    else
                                    {
                                        <CompactTextField Value="@_selectedTfsTeam.DefaultAreaPath" 
                                                         Label="Area Path (Derived from Team)" 
                                                         ReadOnly="true"
                                                         HelperText="This area path is automatically derived from the team settings" />
                                    }

                                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2">Choose Team Picture</MudText>
                                    <MudStack Row="true" Spacing="2" Class="mb-2">
                                        @for (int i = 0; i < 10; i++)
                                        {
                                            var pictureId = i;
                                            <MudTooltip Text="@($"Picture {i}")">
                                                <MudPaper Elevation="@(_selectedPictureId == pictureId ? 3 : 1)" 
                                                         Class="pa-2 cursor-pointer"
                                                         Style="@($"border: 2px solid {(_selectedPictureId == pictureId ? "var(--mud-palette-primary)" : "transparent")}")"
                                                         @onclick="() => _selectedPictureId = pictureId">
                                                    <MudIcon Icon="@GetTeamIcon(pictureId)" Size="Size.Large" />
                                                </MudPaper>
                                            </MudTooltip>
                                        }
                                    </MudStack>
                                }

                                @if (_selectedTfsTeam != null)
                                {
                                    <MudStack Row="true" Spacing="2" Class="mt-2">
                                        <CompactButton Variant="Variant.Filled" 
                                                      Color="Color.Primary" 
                                                      OnClick="SaveTeam"
                                                      Disabled="@(!_teamFormValid || _isSavingTeam)"
                                                      StartIcon="@Icons.Material.Filled.Save">
                                            @if (_isSavingTeam)
                                            {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                                <span>Saving...</span>
                                            }
                                            else
                                            {
                                                <span>Save Team</span>
                                            }
                                        </CompactButton>
                                    </MudStack>
                                }
                            </MudForm>

                            @if (_teamSaveResult != null)
                            {
                                <MudAlert Severity="@(_teamSaveResult.Success ? Severity.Success : Severity.Error)" Dense="true">
                                    @_teamSaveResult.Message
                                </MudAlert>
                            }

                            @if (_teamErrorResponse != null)
                            {
                                <ErrorDisplay ErrorResponse="@_teamErrorResponse" 
                                             OnDismiss="ClearTeamError" />
                            }
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                No teams found. Please ensure TFS configuration is correct and you have access to the project.
                            </MudAlert>
                        }
                        
                        <MudAlert Severity="Severity.Info" Dense="true">
                            You can skip this step and configure teams later from the Settings page.
                        </MudAlert>
                    </MudStack>
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <CompactButton OnClick="Skip" Color="Color.Default">
                Skip Wizard
            </CompactButton>
            @if (_currentStep > 0)
            {
                <CompactButton OnClick="Previous" Color="Color.Default" Variant="Variant.Outlined">
                    Previous
                </CompactButton>
            }
            @if (_currentStep < 3)
            {
                <CompactButton OnClick="Next" 
                              Color="Color.Primary" 
                              Variant="Variant.Filled"
                              Disabled="@IsNextDisabled()">
                    Next
                </CompactButton>
            }
            else
            {
                <CompactButton OnClick="Complete" Color="Color.Success" Variant="Variant.Filled">
                    Get Started
                </CompactButton>
            }
        </DialogActions>
    </MudDialog>
}

@code {
    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public EventCallback OnCompleted { get; set; }

    private int _currentStep = 0;
    private bool _isVisible = true;

    // Configuration form fields
    private MudForm? _configForm;
    private bool _configFormValid;
    private bool _isSaving;
    private string _url = string.Empty;
    private string _project = string.Empty;
    private string _defaultAreaPath = string.Empty;
    private ErrorResponse? _configErrorResponse;
    private List<ProgressUpdate> _progressUpdates = new();
    private bool? _configCompleted;

    // Profile form fields
    private MudForm? _profileForm;
    private bool _profileFormValid;
    private bool _isSavingProfile;
    private string _profileName = string.Empty;
    private int? _createdProfileId;
    private ConnectionTestResult? _profileSaveResult;
    private ErrorResponse? _profileErrorResponse;

    // Product form fields
    private MudForm? _productForm;
    private bool _productFormValid;
    private bool _isSavingProduct;
    private string _productName = string.Empty;
    private string _backlogRootWorkItemId = string.Empty;
    private ConnectionTestResult? _productSaveResult;
    private ErrorResponse? _productErrorResponse;

    // Team selection fields
    private MudForm? _teamForm;
    private bool _teamFormValid;
    private bool _isLoadingTeams;
    private bool _isSavingTeam;
    private List<TfsTeamDto>? _tfsTeams;
    private TfsTeamDto? _selectedTfsTeam;
    private bool _overrideAreaPath;
    private string _teamAreaPath = string.Empty;
    private int _selectedPictureId = 0;
    private ConnectionTestResult? _teamSaveResult;
    private ErrorResponse? _teamErrorResponse;

    protected override async Task OnInitializedAsync()
    {
        await LoadExistingConfig();
    }

    private async Task LoadExistingConfig()
    {
        try
        {
            var config = await TfsConfigService.GetConfigAsync();
            if (config != null)
            {
                _url = config.Url ?? string.Empty;
                _project = config.Project ?? string.Empty;
                _defaultAreaPath = config.DefaultAreaPath ?? string.Empty;
            }
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            // Expected on first launch when no config exists yet
            // Leave fields empty for user to fill in
        }
        catch (Exception)
        {
            // On any other error, still allow wizard to show with empty fields
            // User can fill in configuration manually
        }
    }

    private string GetStepTitle()
    {
        return _currentStep switch
        {
            0 => "Configure Azure DevOps Connection",
            1 => "Create Product Owner Profile",
            2 => "Create Product",
            3 => "Select Your Team",
            _ => "Getting Started"
        };
    }

    private double GetProgress()
    {
        return (_currentStep + 1) * 25.0; // 4 steps (0-3)
    }

    private bool IsNextDisabled()
    {
        // For step 0 (TFS Configuration), require verification and no changes
        if (_currentStep == 0)
        {
            return !WizardState.TfsVerified || !WizardState.CheckTfsFieldsUnchanged(_url, _project, _defaultAreaPath);
        }
        return false;
    }

    private void OnUrlChanged(string value)
    {
        _url = value;
        WizardState.MarkTfsUnverified();
    }

    private void OnProjectChanged(string value)
    {
        _project = value;
        WizardState.MarkTfsUnverified();
    }

    private void OnDefaultAreaPathChanged(string value)
    {
        _defaultAreaPath = value;
        WizardState.MarkTfsUnverified();
    }

    private async Task Next()
    {
        if (_currentStep < 3) // Maximum step is 3
        {
            _currentStep++;
            
            // Load teams when entering team selection step (step 3)
            if (_currentStep == 3 && _configCompleted == true && _tfsTeams == null)
            {
                await LoadTfsTeams();
            }
        }
    }

    private void Previous()
    {
        if (_currentStep > 0)
        {
            _currentStep--;
        }
    }

    private async Task SaveConfig()
    {
        if (!_configFormValid) return;

        ClearConfigError();
        _isSaving = true;
        _progressUpdates.Clear();
        _configCompleted = null;
        
        try
        {
            var requestBody = new
            {
                url = _url,
                project = _project,
                defaultAreaPath = _defaultAreaPath,
                useDefaultCredentials = true,
                timeoutSeconds = 30,
                apiVersion = "7.0"
            };

            var request = new HttpRequestMessage(HttpMethod.Post, "/api/tfsconfig/save-and-verify")
            {
                Content = JsonContent.Create(requestBody)
            };

            var response = await HttpClient.SendAsync(request, HttpCompletionOption.ResponseHeadersRead);
            response.EnsureSuccessStatusCode();

            var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new StreamReader(stream);

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (string.IsNullOrEmpty(line)) continue;

                var update = JsonSerializer.Deserialize<ProgressUpdate>(line, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

                if (update != null)
                {
                    _progressUpdates.Add(update);
                    StateHasChanged();
                }
            }

            var lastUpdate = _progressUpdates.LastOrDefault();
            _configCompleted = lastUpdate?.State == "Succeeded";
            
            if (_configCompleted == true)
            {
                WizardState.MarkTfsVerified(_url, _project, _defaultAreaPath);
                Snackbar.Add("Configuration saved and verified successfully", Severity.Success);
            }
            else
            {
                WizardState.MarkTfsUnverified();
                Snackbar.Add("Configuration verification completed with errors", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _configCompleted = false;
            WizardState.MarkTfsUnverified();
            ShowConfigError(ex, "Error during configuration");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ShowConfigError(Exception ex, string context)
    {
        _configErrorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearConfigError()
    {
        _configErrorResponse = null;
    }

    private async Task SaveProfile()
    {
        if (!_profileFormValid) return;

        ClearProfileError();
        _isSavingProfile = true;
        
        try
        {
            var profile = await ProfileService.CreateAndActivateProfileAsync(_profileName, new List<int>());
            _createdProfileId = profile.Id;
            _profileSaveResult = new ConnectionTestResult(true, $"Profile '{profile.Name}' created and activated successfully!");
            Snackbar.Add("Profile saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            _profileSaveResult = new ConnectionTestResult(false, "Profile save failed.");
            ShowProfileError(ex, "Error saving profile");
        }
        finally
        {
            _isSavingProfile = false;
        }
    }

    private void ShowProfileError(Exception ex, string context)
    {
        _profileErrorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearProfileError()
    {
        _profileErrorResponse = null;
        _profileSaveResult = null;
    }

    private async Task SaveProduct()
    {
        if (!_productFormValid) return;

        ClearProductError();
        _isSavingProduct = true;
        
        try
        {
            if (!int.TryParse(_backlogRootWorkItemId, out int workItemId))
            {
                throw new InvalidOperationException("Backlog Root Work Item ID must be a valid integer.");
            }

            var product = await ProductService.CreateProductAsync(
                _createdProfileId,
                _productName,
                workItemId);
            
            _productSaveResult = new ConnectionTestResult(true, $"Product '{product.Name}' created successfully!");
            Snackbar.Add("Product saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            _productSaveResult = new ConnectionTestResult(false, "Product save failed.");
            ShowProductError(ex, "Error saving product");
        }
        finally
        {
            _isSavingProduct = false;
        }
    }

    private void ShowProductError(Exception ex, string context)
    {
        _productErrorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearProductError()
    {
        _productErrorResponse = null;
        _productSaveResult = null;
    }

    private async Task LoadTfsTeams()
    {
        _isLoadingTeams = true;
        StateHasChanged();

        try
        {
            var response = await HttpClient.GetAsync("/api/startup/tfs-teams");
            response.EnsureSuccessStatusCode();

            _tfsTeams = await response.Content.ReadFromJsonAsync<List<TfsTeamDto>>(new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load teams: {ex.Message}", Severity.Error);
            _tfsTeams = new List<TfsTeamDto>();
        }
        finally
        {
            _isLoadingTeams = false;
            StateHasChanged();
        }
    }

    private async Task SaveTeam()
    {
        if (!_teamFormValid || _selectedTfsTeam == null) return;

        ClearTeamError();
        _isSavingTeam = true;
        
        try
        {
            var areaPath = _overrideAreaPath ? _teamAreaPath : _selectedTfsTeam.DefaultAreaPath;
            
            // Create team entity with TFS team info
            var team = await TeamService.CreateTeamAsync(
                name: _selectedTfsTeam.Name,
                teamAreaPath: areaPath,
                pictureType: PoTool.Shared.Settings.TeamPictureType.Default,
                defaultPictureId: _selectedPictureId,
                customPicturePath: null,
                projectName: _selectedTfsTeam.ProjectName,
                tfsTeamId: _selectedTfsTeam.Id,
                tfsTeamName: _selectedTfsTeam.Name);
            
            _teamSaveResult = new ConnectionTestResult(true, $"Team '{team.Name}' created successfully!");
            Snackbar.Add("Team saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            _teamSaveResult = new ConnectionTestResult(false, "Team save failed.");
            ShowTeamError(ex, "Error saving team");
        }
        finally
        {
            _isSavingTeam = false;
        }
    }

    private void ShowTeamError(Exception ex, string context)
    {
        _teamErrorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearTeamError()
    {
        _teamErrorResponse = null;
        _teamSaveResult = null;
    }

    private string GetTeamIcon(int pictureId)
    {
        return pictureId switch
        {
            0 => Icons.Material.Filled.Groups,
            1 => Icons.Material.Filled.People,
            2 => Icons.Material.Filled.Group,
            3 => Icons.Material.Filled.EmojiPeople,
            4 => Icons.Material.Filled.Diversity3,
            5 => Icons.Material.Filled.Engineering,
            6 => Icons.Material.Filled.Science,
            7 => Icons.Material.Filled.Code,
            8 => Icons.Material.Filled.Build,
            9 => Icons.Material.Filled.Security,
            _ => Icons.Material.Filled.Groups
        };
    }

    private async Task Skip()
    {
        await OnboardingService.MarkOnboardingSkippedAsync();
        await OnCompleted.InvokeAsync();
        MudDialog?.Close(DialogResult.Cancel());
    }

    private async Task Complete()
    {
        await OnboardingService.MarkOnboardingCompletedAsync();
        await OnCompleted.InvokeAsync();
        MudDialog?.Close(DialogResult.Ok(true));
    }

    private record ConnectionTestResult(bool Success, string Message);
    
    private class ProgressUpdate
    {
        public string Phase { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public int? PercentComplete { get; set; }
        public string? Details { get; set; }
    }
    
    // DTO for TFS teams from API
    private class TfsTeamDto
    {
        public string Id { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ProjectName { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string DefaultAreaPath { get; set; } = string.Empty;
    }
}
