@using PoTool.Client.Models

<MudPaper Elevation="1" Class="pa-3" Style="@ResolvedStyle">
    <MudStack Spacing="1">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
            <MudStack Spacing="1">
                <MudText Typo="Typo.subtitle1">@Problem.Title</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Problem.AffectedEntity</MudText>
            </MudStack>

            <MudStack Row="true" Spacing="1">
                @if (Problem.FixFirst)
                {
                    <MudChip T="string" Label="true" Size="Size.Small" Color="Color.Error">Fix first</MudChip>
                }
                <MudChip T="string" Label="true" Size="Size.Small" Color="@ResolveColor()">@Problem.Severity</MudChip>
            </MudStack>
        </MudStack>

        <MudText Typo="Typo.caption" Color="Color.Info">Where: @Problem.Location</MudText>
        <MudText Typo="Typo.body2">Why: @Problem.Reason</MudText>
        <MudText Typo="Typo.body2">Next: @Problem.SuggestedAction</MudText>
        <MudChip T="string" Label="true" Size="Size.Small" Color="@ResolveConfidenceColor()">
            Confidence: @Problem.ExecutionIntent.ConfidenceLevel
        </MudChip>
        <MudText Typo="Typo.caption" Color="Color.Secondary">Impact: @Problem.ExpectedImpact</MudText>

        @if (Problem.ImpactedChildrenCount > 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Impact: @Problem.ImpactedChildrenCount related child item(s)
            </MudText>
        }

        @if (Problem.RootCauseTargetElementId != Problem.TargetElementId)
        {
            <MudText Typo="Typo.caption" Color="Color.Info">
                Part of root cause: @Problem.RootCauseEntity
            </MudText>
        }

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Scope: @ScopeLabel
            </MudText>

            <CompactButton ButtonRole="ButtonRole.Utility"
                           Icon="@Icons.Material.Filled.OpenInNew"
                           OnClick="@(() => OnNavigate.InvokeAsync(Problem.ExecutionIntent))">
                Go to fix location
            </CompactButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public ActionableProblemViewModel Problem { get; set; } = default!;
    [Parameter] public EventCallback<ExecutionIntentViewModel> OnNavigate { get; set; }

    private string ScopeLabel => Problem.Scope switch
    {
        OnboardingProblemScope.Global => "Global / connection",
        OnboardingProblemScope.Project => "Project",
        OnboardingProblemScope.Root => "Product root",
        OnboardingProblemScope.Binding => "Binding",
        _ => Problem.Scope.ToString()
    };

    private string ResolvedStyle => Problem.Severity switch
    {
        OnboardingProblemSeverity.Blocking => "border-left: 4px solid var(--mud-palette-error);",
        _ => "border-left: 4px solid var(--mud-palette-warning);"
    };

    private Color ResolveColor()
        => Problem.Severity == OnboardingProblemSeverity.Blocking
            ? Color.Error
            : Color.Warning;

    private Color ResolveConfidenceColor()
        => Problem.ExecutionIntent.ConfidenceLevel switch
        {
            OnboardingExecutionConfidenceLevel.High => Color.Success,
            OnboardingExecutionConfidenceLevel.Medium => Color.Warning,
            _ => Color.Default
        };
}
