    private async Task CompleteAsync(OnboardingExecutionResult result)
    {
        _lastFeedback = result.Feedback;
        if (result.MutationApplied)
        {
            _deleteReason = string.Empty;
        }

        await OnCompleted.InvokeAsync(result);
    }

    private int ResolveConnectionId()
        => Connection?.Id
           ?? Project?.TfsConnectionId
           ?? ActiveIntent?.ConnectionId
           ?? CurrentFilter.ConnectionId
           ?? 0;

    private int ResolveProjectId()
        => Project?.Id
           ?? Team?.ProjectSourceId
           ?? Pipeline?.ProjectSourceId
           ?? Root?.ProjectSourceId
           ?? Binding?.ProjectSourceId
           ?? ProjectContext?.ProjectId
           ?? ActiveIntent?.ProjectId
           ?? CurrentFilter.ProjectId
           ?? 0;

    private string ResolveConnectionContext()
        => Connection?.OrganizationUrl
           ?? (ResolveConnectionId() > 0 ? $"Connection {ResolveConnectionId()}" : "No connection selected");

    private string ResolveProjectContextLabel()
        => ProjectContext is not null
            ? $"{ProjectContext.ProjectName} ({ProjectContext.ProjectExternalId})"
            : Project?.Snapshot.Name
              ?? Root?.Snapshot.Title
              ?? Binding?.SourceExternalId
              ?? (ResolveProjectId() > 0 ? $"Project {ResolveProjectId()}" : "No project selected");

    private Color ResolveConfidenceColor()
        => ActiveIntent?.ConfidenceLevel switch
        {
            OnboardingExecutionConfidenceLevel.High => Color.Success,
            OnboardingExecutionConfidenceLevel.Medium => Color.Warning,
            _ => Color.Default
        };

    private static Severity ResolveSeverity(OnboardingExecutionFeedbackKind kind)
        => kind switch
        {
            OnboardingExecutionFeedbackKind.Success => Severity.Success,
            OnboardingExecutionFeedbackKind.Warning => Severity.Warning,
            _ => Severity.Error
        };

    private static string? NullIfWhiteSpace(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static int ParsePositiveInt(string value)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : 0;

    private static int? ParsePositiveNullableInt(string value)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : null;
}
