        var index = 0;
        builder.OpenComponent<MudText>(index++);
        builder.AddAttribute(index++, "Typo", Typo.body2);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, $"Project context: {ResolveProjectContextLabel()}")));
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(index++);
        builder.AddAttribute(index++, "Label", "Enabled");
        builder.AddAttribute(index++, "Value", _teamEnabled);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<bool>(this, value => _teamEnabled = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Team external ID");
        builder.AddAttribute(index++, "Value", _teamExternalId);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _teamExternalId = value));
        builder.AddAttribute(index++, "Disabled", Team is not null || _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Display name");
        builder.AddAttribute(index++, "Value", _teamName);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _teamName = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Default area path");
        builder.AddAttribute(index++, "Value", _teamDefaultAreaPath);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _teamDefaultAreaPath = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Description");
        builder.AddAttribute(index++, "Value", _teamDescription);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _teamDescription = value));
        builder.AddAttribute(index++, "Lines", 3);
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.AddContent(index++, RenderActionButtons(
            Team is null ? "Add team" : "Save team",
            ExecuteTeamAsync,
            Team is not null ? "Delete team" : null,
            Team is not null ? ExecuteDeleteTeamAsync : null));
    };

    private RenderFragment RenderPipelineEditor() => builder =>
    {
        var index = 0;
        builder.OpenComponent<MudText>(index++);
        builder.AddAttribute(index++, "Typo", Typo.body2);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, $"Project context: {ResolveProjectContextLabel()}")));
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(index++);
        builder.AddAttribute(index++, "Label", "Enabled");
