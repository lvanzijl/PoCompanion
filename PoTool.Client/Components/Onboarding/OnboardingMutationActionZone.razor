@using MudBlazor
@using PoTool.Client.Components.Common.Compact
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Shared.Onboarding
@inject OnboardingExecutionService ExecutionService

<OnboardingFutureActionZone Title="@ResolvedTitle" Message="@ResolvedMessage">
    @if (_lastFeedback is not null)
    {
        <MudAlert Severity="@ResolveSeverity(_lastFeedback.Kind)" Variant="Variant.Outlined" Dense="true">
            <MudText Typo="Typo.subtitle2">@_lastFeedback.Title</MudText>
            <MudText Typo="Typo.body2">@_lastFeedback.Message</MudText>
            @if (!string.IsNullOrWhiteSpace(_lastFeedback.Details))
            {
                <MudText Typo="Typo.caption">@_lastFeedback.Details</MudText>
            }
        </MudAlert>
    }

    @if (!IsIntentEnabled)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Use <strong>Go to fix location</strong> from a problem or graph action before executing a write.
        </MudText>
    }
    else if (!IsContextMatched)
    {
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            This action zone is ready, but the current execution intent is focused on a different onboarding context.
        </MudText>
    }
    else
    {
        <MudStack Spacing="2">
            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                <MudChip T="string" Label="true" Size="Size.Small" Color="Color.Info">
                    Intent: @ActiveIntent!.SuggestedActionLabel
                </MudChip>
                <MudChip T="string" Label="true" Size="Size.Small" Color="@ResolveConfidenceColor()">
                    Confidence: @ActiveIntent!.ConfidenceLevel
                </MudChip>
            </MudStack>

            @switch (Section)
            {
                case OnboardingGraphSection.Connections:
                    @RenderConnectionEditor()
                    break;
                case OnboardingGraphSection.Projects:
                    @RenderProjectEditor()
                    break;
                case OnboardingGraphSection.Teams:
                    @RenderTeamEditor()
                    break;
                case OnboardingGraphSection.Pipelines:
                    @RenderPipelineEditor()
                    break;
                case OnboardingGraphSection.ProductRoots:
                    @RenderRootEditor()
                    break;
                case OnboardingGraphSection.Bindings:
                    @RenderBindingEditor()
                    break;
            }
        </MudStack>
    }
</OnboardingFutureActionZone>

@code {
    private string _contextKey = string.Empty;
    private OnboardingExecutionFeedbackViewModel? _lastFeedback;

    private string _connectionOrganizationUrl = string.Empty;
    private string _connectionAuthenticationMode = "Pat";
    private string _connectionTimeoutSeconds = "30";
    private string _connectionApiVersion = "7.1";
    private bool _projectEnabled = true;
    private string _projectExternalId = string.Empty;
    private string _projectName = string.Empty;
    private string _projectDescription = string.Empty;
    private bool _teamEnabled = true;
    private string _teamExternalId = string.Empty;
    private string _teamName = string.Empty;
    private string _teamDefaultAreaPath = string.Empty;
    private string _teamDescription = string.Empty;
    private bool _pipelineEnabled = true;
    private string _pipelineExternalId = string.Empty;
    private string _pipelineName = string.Empty;
    private string _pipelineFolder = string.Empty;
    private string _pipelineYamlPath = string.Empty;
    private string _pipelineRepositoryExternalId = string.Empty;
    private string _pipelineRepositoryName = string.Empty;
    private bool _rootEnabled = true;
    private string _rootWorkItemExternalId = string.Empty;
    private string _rootTitle = string.Empty;
    private string _rootWorkItemType = string.Empty;
    private string _rootState = string.Empty;
    private string _rootAreaPath = string.Empty;
    private bool _bindingEnabled = true;
    private OnboardingProductSourceTypeDto _bindingSourceType = OnboardingProductSourceTypeDto.Project;
    private int? _bindingTeamSourceId;
    private int? _bindingPipelineSourceId;
    private string _deleteReason = string.Empty;
    private bool _isBusy;

    [Parameter, EditorRequired] public OnboardingGraphSection Section { get; set; }
    [Parameter] public ExecutionIntentViewModel? ActiveIntent { get; set; }
    [Parameter, EditorRequired] public OnboardingWorkspaceFilter CurrentFilter { get; set; } = new(null, null, null, null);
    [Parameter] public OnboardingTfsConnectionDto? Connection { get; set; }
    [Parameter] public OnboardingProjectSourceDto? Project { get; set; }
    [Parameter] public OnboardingTeamSourceDto? Team { get; set; }
    [Parameter] public OnboardingPipelineSourceDto? Pipeline { get; set; }
    [Parameter] public OnboardingProductRootDto? Root { get; set; }
    [Parameter] public OnboardingProductSourceBindingDto? Binding { get; set; }
    [Parameter] public OnboardingProjectContextViewModel? ProjectContext { get; set; }
    [Parameter] public IReadOnlyList<OnboardingTeamSourceDto> AvailableTeams { get; set; } = Array.Empty<OnboardingTeamSourceDto>();
    [Parameter] public IReadOnlyList<OnboardingPipelineSourceDto> AvailablePipelines { get; set; } = Array.Empty<OnboardingPipelineSourceDto>();
    [Parameter] public EventCallback<OnboardingExecutionResult> OnCompleted { get; set; }

    private bool IsIntentEnabled => ActiveIntent is not null;

    private bool IsContextMatched
    {
        get
        {
            if (ActiveIntent is null || ActiveIntent.NavigationTarget.Section != Section)
            {
                return false;
            }

            return Section switch
            {
                OnboardingGraphSection.Connections => true,
                OnboardingGraphSection.Projects => ProjectContext is null
                    || ActiveIntent.ProjectId == ProjectContext.ProjectId
                    || ActiveIntent.ProjectId == Project?.Id,
                OnboardingGraphSection.Teams or OnboardingGraphSection.Pipelines or OnboardingGraphSection.ProductRoots
                    => ProjectContext?.ProjectId is null || ActiveIntent.ProjectId == ProjectContext.ProjectId,
                OnboardingGraphSection.Bindings
                    => Root is null
                        || ActiveIntent.RootId == Root.Id
                        || (Binding is not null && ActiveIntent.BindingId == Binding.Id),
                _ => false
            };
        }
    }

    private string ResolvedTitle => Section switch
    {
        OnboardingGraphSection.Connections => "Connection action zone",
        OnboardingGraphSection.Projects => "Project action zone",
        OnboardingGraphSection.Teams => "Team action zone",
        OnboardingGraphSection.Pipelines => "Pipeline action zone",
        OnboardingGraphSection.ProductRoots => "Product-root action zone",
        OnboardingGraphSection.Bindings => "Binding action zone",
        _ => "Action zone"
    };

    private string ResolvedMessage => Section switch
    {
        OnboardingGraphSection.Connections => "Create, update, or delete the onboarding connection only from the active execution intent.",
        OnboardingGraphSection.Projects => "Link or maintain a project only from the active execution intent.",
        OnboardingGraphSection.Teams => "Assign or maintain a team only from the active execution intent.",
        OnboardingGraphSection.Pipelines => "Assign or maintain a pipeline only from the active execution intent.",
        OnboardingGraphSection.ProductRoots => "Add or maintain a product root only from the active execution intent.",
        OnboardingGraphSection.Bindings => "Create or maintain a binding only from the active execution intent.",
        _ => string.Empty
    };

    protected override void OnParametersSet()
    {
        var nextKey = string.Join(
            "|",
            Section,
            ActiveIntent?.IntentType,
            ActiveIntent?.ConnectionId,
            ActiveIntent?.ProjectId,
            ActiveIntent?.RootId,
            ActiveIntent?.BindingId,
            Connection?.Id,
            Connection?.Audit.UpdatedAtUtc.Ticks,
            Project?.Id,
            Project?.Audit.UpdatedAtUtc.Ticks,
            Team?.Id,
            Team?.Audit.UpdatedAtUtc.Ticks,
            Pipeline?.Id,
            Pipeline?.Audit.UpdatedAtUtc.Ticks,
            Root?.Id,
            Root?.Audit.UpdatedAtUtc.Ticks,
            Binding?.Id,
            Binding?.Audit.UpdatedAtUtc.Ticks,
            ProjectContext?.ProjectId);

        if (nextKey == _contextKey)
        {
            return;
        }

        _contextKey = nextKey;
        _lastFeedback = null;
        _deleteReason = string.Empty;

        _connectionOrganizationUrl = Connection?.OrganizationUrl ?? string.Empty;
        _connectionAuthenticationMode = Connection?.AuthenticationMode ?? "Pat";
        _connectionTimeoutSeconds = (Connection?.TimeoutSeconds ?? 30).ToString();
        _connectionApiVersion = Connection?.ApiVersion ?? "7.1";

        _projectEnabled = Project?.Enabled ?? true;
        _projectExternalId = Project?.ProjectExternalId ?? string.Empty;
        _projectName = Project?.Snapshot.Name ?? string.Empty;
        _projectDescription = Project?.Snapshot.Description ?? string.Empty;

        _teamEnabled = Team?.Enabled ?? true;
        _teamExternalId = Team?.TeamExternalId ?? string.Empty;
        _teamName = Team?.Snapshot.Name ?? string.Empty;
        _teamDefaultAreaPath = Team?.Snapshot.DefaultAreaPath ?? string.Empty;
        _teamDescription = Team?.Snapshot.Description ?? string.Empty;

        _pipelineEnabled = Pipeline?.Enabled ?? true;
        _pipelineExternalId = Pipeline?.PipelineExternalId ?? string.Empty;
        _pipelineName = Pipeline?.Snapshot.Name ?? string.Empty;
        _pipelineFolder = Pipeline?.Snapshot.Folder ?? string.Empty;
        _pipelineYamlPath = Pipeline?.Snapshot.YamlPath ?? string.Empty;
        _pipelineRepositoryExternalId = Pipeline?.Snapshot.RepositoryExternalId ?? string.Empty;
        _pipelineRepositoryName = Pipeline?.Snapshot.RepositoryName ?? string.Empty;

        _rootEnabled = Root?.Enabled ?? true;
        _rootWorkItemExternalId = Root?.WorkItemExternalId ?? string.Empty;
        _rootTitle = Root?.Snapshot.Title ?? string.Empty;
        _rootWorkItemType = Root?.Snapshot.WorkItemType ?? string.Empty;
        _rootState = Root?.Snapshot.State ?? string.Empty;
        _rootAreaPath = Root?.Snapshot.AreaPath ?? string.Empty;

        _bindingEnabled = Binding?.Enabled ?? true;
        _bindingSourceType = Binding?.SourceType ?? OnboardingProductSourceTypeDto.Project;
        _bindingTeamSourceId = Binding?.TeamSourceId ?? AvailableTeams.FirstOrDefault()?.Id;
        _bindingPipelineSourceId = Binding?.PipelineSourceId ?? AvailablePipelines.FirstOrDefault()?.Id;
    }

    private RenderFragment RenderConnectionEditor() => builder =>
    {
        var index = 0;
        builder.OpenComponent<MudText>(index++);
        builder.AddAttribute(index++, "Typo", Typo.body2);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, Connection is null ? "Create the onboarding connection." : "Update or remove the current onboarding connection.")));
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Organization URL");
        builder.AddAttribute(index++, "Value", _connectionOrganizationUrl);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _connectionOrganizationUrl = value));
        builder.AddAttribute(index++, "Disabled", Connection is not null || _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Authentication mode");
        builder.AddAttribute(index++, "Value", _connectionAuthenticationMode);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _connectionAuthenticationMode = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Timeout seconds");
        builder.AddAttribute(index++, "Value", _connectionTimeoutSeconds);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _connectionTimeoutSeconds = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "API version");
        builder.AddAttribute(index++, "Value", _connectionApiVersion);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _connectionApiVersion = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.AddContent(index++, RenderActionButtons(
            Connection is null ? "Create connection" : "Save connection",
            ExecuteConnectionAsync,
            Connection is not null ? "Delete connection" : null,
            Connection is not null ? ExecuteDeleteConnectionAsync : null));
    };

    private RenderFragment RenderProjectEditor() => builder =>
    {
        var index = 0;
        builder.OpenComponent<MudText>(index++);
        builder.AddAttribute(index++, "Typo", Typo.body2);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, $"Connection context: {ResolveConnectionContext()}")));
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(index++);
        builder.AddAttribute(index++, "Label", "Enabled");
        builder.AddAttribute(index++, "Value", _projectEnabled);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<bool>(this, value => _projectEnabled = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Project external ID");
        builder.AddAttribute(index++, "Value", _projectExternalId);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _projectExternalId = value));
        builder.AddAttribute(index++, "Disabled", Project is not null || _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Display name");
        builder.AddAttribute(index++, "Value", _projectName);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _projectName = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.OpenComponent<CompactTextField<string>>(index++);
        builder.AddAttribute(index++, "Label", "Description");
        builder.AddAttribute(index++, "Value", _projectDescription);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _projectDescription = value));
        builder.AddAttribute(index++, "Lines", 3);
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        builder.AddContent(index++, RenderActionButtons(
            Project is null ? "Link project" : "Save project",
            ExecuteProjectAsync,
            Project is not null ? "Delete project" : null,
            Project is not null ? ExecuteDeleteProjectAsync : null));
    };

    private RenderFragment RenderTeamEditor() => builder =>
