    private RenderFragment RenderBindingEditor() => builder =>
    {
        var index = 0;
        builder.OpenComponent<MudText>(index++);
        builder.AddAttribute(index++, "Typo", Typo.body2);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, $"Root context: {Root?.Snapshot.Title ?? Binding?.SourceExternalId ?? "Select a product root"}")));
        builder.CloseComponent();

        builder.OpenComponent<MudSwitch<bool>>(index++);
        builder.AddAttribute(index++, "Label", "Enabled");
        builder.AddAttribute(index++, "Value", _bindingEnabled);
        builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<bool>(this, value => _bindingEnabled = value));
        builder.AddAttribute(index++, "Disabled", _isBusy);
        builder.CloseComponent();

        if (Binding is not null)
        {
            builder.OpenComponent<MudText>(index++);
            builder.AddAttribute(index++, "Typo", Typo.body2);
            builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content => content.AddContent(0, $"Immutable source: {Binding.SourceType} → {Binding.SourceExternalId}")));
            builder.CloseComponent();
        }
        else
        {
            builder.OpenComponent<CompactSelect<OnboardingProductSourceTypeDto>>(index++);
            builder.AddAttribute(index++, "Label", "Source type");
            builder.AddAttribute(index++, "Value", _bindingSourceType);
            builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<OnboardingProductSourceTypeDto>(this, value => _bindingSourceType = value));
            builder.AddAttribute(index++, "Disabled", _isBusy);
            builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content =>
            {
                var nested = 0;
                foreach (var option in Enum.GetValues<OnboardingProductSourceTypeDto>())
                {
                    content.OpenComponent<MudSelectItem<OnboardingProductSourceTypeDto>>(nested++);
                    content.AddAttribute(nested++, "Value", option);
                    content.AddAttribute(nested++, "ChildContent", (RenderFragment)(text => text.AddContent(0, option.ToString())));
                    content.CloseComponent();
                }
            }));
            builder.CloseComponent();

            if (_bindingSourceType == OnboardingProductSourceTypeDto.Team)
            {
                builder.OpenComponent<CompactSelect<int?>>(index++);
                builder.AddAttribute(index++, "Label", "Team source");
                builder.AddAttribute(index++, "Value", _bindingTeamSourceId);
                builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<int?>(this, value => _bindingTeamSourceId = value));
                builder.AddAttribute(index++, "Disabled", _isBusy);
                builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content =>
                {
                    var nested = 0;
                    foreach (var team in AvailableTeams)
                    {
                        content.OpenComponent<MudSelectItem<int?>>(nested++);
                        content.AddAttribute(nested++, "Value", team.Id);
                        content.AddAttribute(nested++, "ChildContent", (RenderFragment)(text => text.AddContent(0, $"{team.Snapshot.Name} ({team.TeamExternalId})")));
                        content.CloseComponent();
                    }
                }));
                builder.CloseComponent();
            }
            else if (_bindingSourceType == OnboardingProductSourceTypeDto.Pipeline)
            {
                builder.OpenComponent<CompactSelect<int?>>(index++);
                builder.AddAttribute(index++, "Label", "Pipeline source");
                builder.AddAttribute(index++, "Value", _bindingPipelineSourceId);
                builder.AddAttribute(index++, "ValueChanged", EventCallback.Factory.Create<int?>(this, value => _bindingPipelineSourceId = value));
                builder.AddAttribute(index++, "Disabled", _isBusy);
                builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content =>
                {
                    var nested = 0;
                    foreach (var pipeline in AvailablePipelines)
                    {
                        content.OpenComponent<MudSelectItem<int?>>(nested++);
                        content.AddAttribute(nested++, "Value", pipeline.Id);
                        content.AddAttribute(nested++, "ChildContent", (RenderFragment)(text => text.AddContent(0, $"{pipeline.Snapshot.Name} ({pipeline.PipelineExternalId})")));
                        content.CloseComponent();
                    }
                }));
                builder.CloseComponent();
            }
        }

        builder.AddContent(index++, RenderActionButtons(
            Binding is null ? "Create binding" : "Save binding",
            ExecuteBindingAsync,
            Binding is not null ? "Delete binding" : null,
            Binding is not null ? ExecuteDeleteBindingAsync : null));
    };

    private RenderFragment RenderActionButtons(
        string primaryLabel,
        Func<Task> primaryAction,
        string? deleteLabel,
        Func<Task>? deleteAction) => builder =>
    {
        var index = 0;
        builder.OpenComponent<MudStack>(index++);
        builder.AddAttribute(index++, "Spacing", 1);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(content =>
        {
            var nested = 0;
            content.OpenComponent<CompactButton>(nested++);
            content.AddAttribute(nested++, "ButtonRole", ButtonRole.Action);
            content.AddAttribute(nested++, "Disabled", _isBusy);
            content.AddAttribute(nested++, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, async () => await primaryAction()));
            content.AddAttribute(nested++, "ChildContent", (RenderFragment)(text => text.AddContent(0, primaryLabel)));
            content.CloseComponent();

            if (deleteAction is not null && !string.IsNullOrWhiteSpace(deleteLabel))
            {
                content.OpenComponent<CompactTextField<string>>(nested++);
                content.AddAttribute(nested++, "Label", "Deletion reason");
                content.AddAttribute(nested++, "Value", _deleteReason);
                content.AddAttribute(nested++, "ValueChanged", EventCallback.Factory.Create<string>(this, value => _deleteReason = value));
                content.AddAttribute(nested++, "Disabled", _isBusy);
                content.CloseComponent();

                content.OpenComponent<CompactButton>(nested++);
                content.AddAttribute(nested++, "ButtonRole", ButtonRole.Critical);
                content.AddAttribute(nested++, "Disabled", _isBusy);
                content.AddAttribute(nested++, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, async () => await deleteAction()));
                content.AddAttribute(nested++, "ChildContent", (RenderFragment)(text => text.AddContent(0, deleteLabel)));
                content.CloseComponent();
            }
        }));
        builder.CloseComponent();
    };

    private async Task ExecuteConnectionAsync()
    {
        if (!IsContextMatched || ActiveIntent is null)
        {
            return;
        }

        _isBusy = true;
        try
        {
            var result = Connection is null
                ? await ExecutionService.CreateConnectionAsync(
                    ActiveIntent,
                    new CreateTfsConnectionRequest(_connectionOrganizationUrl, _connectionAuthenticationMode, ParsePositiveInt(_connectionTimeoutSeconds), _connectionApiVersion),
                    CurrentFilter)
                : await ExecutionService.UpdateConnectionAsync(
                    ActiveIntent,
                    Connection.Id,
                    new UpdateTfsConnectionRequest(_connectionAuthenticationMode, ParsePositiveNullableInt(_connectionTimeoutSeconds), _connectionApiVersion, null, null),
                    CurrentFilter);
            await CompleteAsync(result);
        }
        finally
        {
            _isBusy = false;
        }
    }

