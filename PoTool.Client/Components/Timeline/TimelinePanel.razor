@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@using PoTool.Client.Services
@inject IWorkItemsClient WorkItemsClient

@* Timeline Panel - Reusable component for embedding state timeline into workspaces *@

<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Search" Class="mr-2" />
        Work Item State Timeline
    </MudText>
    
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudNumericField @bind-Value="_selectedWorkItemId" 
                         Label="Work Item ID" 
                         Variant="Variant.Outlined"
                         Min="1"
                         Style="max-width: 200px;" />
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Primary" 
                   OnClick="LoadTimeline"
                   Disabled="@(!_selectedWorkItemId.HasValue || _selectedWorkItemId.Value <= 0 || _timelineState.UiState == UiDataState.Loading)"
                   StartIcon="@Icons.Material.Filled.Search">
            Analyze
        </MudButton>
    </MudStack>
</MudPaper>

<CanonicalDataStateView TData="WorkItemStateTimelineDto"
                        State="@_timelineState"
                        Subject="Work item timeline"
                        EmptyTitle="No timeline data found"
                        EmptyMessage="No timeline data found for the selected work item."
                        FailedMessage="Work item timeline could not be loaded right now."
                        OnRecovery="@LoadTimeline">
    <NotRequestedContent>
        <MudAlert Severity="Severity.Info">Enter a Work Item ID and click Analyze to see state timeline.</MudAlert>
    </NotRequestedContent>
    <ChildContent Context="timelineData">
    @* Work Item Summary Card *@
    <MudCard Elevation="2" Class="mb-4">
        <MudCardContent>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h6">@timelineData.Title</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        ID: @timelineData.WorkItemId | Type: @timelineData.Type
                    </MudText>
                </div>
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption">
                        <strong>Cycle Time:</strong> @FormatTimeSpan(timelineData.TotalCycleTime)
                    </MudText>
                    <MudText Typo="Typo.caption">
                        <strong>Time In Progress:</strong> @FormatTimeSpan(timelineData.TotalTimeInProgress)
                    </MudText>
                </MudStack>
            </MudStack>
        </MudCardContent>
    </MudCard>

    @* Bottlenecks Alert *@
    @if (timelineData.Bottlenecks.Any())
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <MudText Typo="Typo.subtitle2" Class="mb-2">⚠️ @timelineData.Bottlenecks.Count Bottleneck(s) Identified</MudText>
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                @foreach (var bottleneck in timelineData.Bottlenecks.OrderByDescending(b => b.Severity).Take(3))
                {
                    <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(bottleneck.Severity)">
                        @bottleneck.State: @FormatTimeSpan(bottleneck.TimeSpent)
                    </MudChip>
                }
            </MudStack>
        </MudAlert>
    }

    @* State Transitions Table *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.h6" GutterBottom="true">State Transitions</MudText>
        <MudTable Items="@timelineData.StateHistory.Take(10)" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>From</MudTh>
                <MudTh>To</MudTh>
                <MudTh>Time in State</MudTh>
                <MudTh>Transition Date</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="From">
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(context.FromState)">
                        @(string.IsNullOrEmpty(context.FromState) ? "Created" : context.FromState)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="To">
                    <MudChip T="string" Size="Size.Small" Color="@GetStateColor(context.ToState)">
                        @context.ToState
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Time">@FormatTimeSpan(context.TimeInPreviousState)</MudTd>
                <MudTd DataLabel="Date">@context.TransitionDate.LocalDateTime.ToString("MMM dd HH:mm")</MudTd>
            </RowTemplate>
        </MudTable>
        @if (timelineData.StateHistory.Count > 10)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                Showing 10 of @timelineData.StateHistory.Count transitions
            </MudText>
        }
    </MudPaper>
    </ChildContent>
</CanonicalDataStateView>

@code {
    [Parameter]
    public int? InitialWorkItemId { get; set; }

    private int? _selectedWorkItemId;
    private DataStateViewModel<WorkItemStateTimelineDto> _timelineState = DataStateViewModel<WorkItemStateTimelineDto>.NotRequested();

    protected override async Task OnInitializedAsync()
    {
        if (InitialWorkItemId.HasValue)
        {
            _selectedWorkItemId = InitialWorkItemId;
            await LoadTimeline();
        }
    }

    private async Task LoadTimeline()
    {
        if (!_selectedWorkItemId.HasValue || _selectedWorkItemId.Value <= 0)
            return;

        _timelineState = DataStateViewModel<WorkItemStateTimelineDto>.Loading();
        StateHasChanged();

        try
        {
            var response = GeneratedCacheEnvelopeHelper.ToDataStateResult(
                await WorkItemsClient.GetStateTimelineAsync(_selectedWorkItemId.Value));
            _timelineState = DataStateViewModel<WorkItemStateTimelineDto>.FromResult(response);
        }
        catch (Exception)
        {
            _timelineState = DataStateViewModel<WorkItemStateTimelineDto>.Failed("Work item timeline could not be loaded right now.");
        }

        StateHasChanged();
    }

    private string FormatTimeSpan(TimeSpan span)
    {
        if (span.TotalDays >= 1)
            return $"{span.TotalDays:F1}d";
        if (span.TotalHours >= 1)
            return $"{span.TotalHours:F1}h";
        return $"{span.TotalMinutes:F0}m";
    }

    private Color GetSeverityColor(BottleneckSeverity severity)
    {
        return severity switch
        {
            BottleneckSeverity.High or BottleneckSeverity.Critical => Color.Error,
            BottleneckSeverity.Medium => Color.Warning,
            BottleneckSeverity.Low => Color.Info,
            _ => Color.Default
        };
    }

    private Color GetStateColor(string? state)
    {
        return state?.ToLower() switch
        {
            "new" or "to do" => Color.Default,
            "active" or "in progress" or "doing" => Color.Info,
            "resolved" or "done" or "closed" => Color.Success,
            "removed" => Color.Error,
            _ => Color.Default
        };
    }
}
