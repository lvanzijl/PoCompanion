@page "/home/onboarding"
@using System.Web
@using Microsoft.AspNetCore.Components.Rendering
@using PoTool.Client.Components.Onboarding
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Shared.Onboarding
@inherits WorkspaceBase
@inject IFeatureFlagService FeatureFlagService
@inject IJSRuntime JS
@inject IOnboardingWorkspaceService OnboardingWorkspaceService
@inject OnboardingWorkspaceViewModelFactory ViewModelFactory

<PageTitle>Onboarding Workspace - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4">
    <MudStack Spacing="3">
        <MudPaper Elevation="1" Class="pa-3">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.h4">Onboarding Workspace</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Intent-first onboarding workspace. Use the graph or problem-first views to reach the right execution context, then execute safe onboarding mutations from the prepared action zones.
                    </MudText>
                </MudStack>

                <MudStack Row="true" Spacing="1">
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Disabled="@(_viewMode == OnboardingWorkspaceViewMode.Graph)"
                                   Icon="@Icons.Material.Filled.AccountTree"
                                   OnClick="ShowGraphViewAsync">
                        Graph view
                    </CompactButton>
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Disabled="@(_viewMode == OnboardingWorkspaceViewMode.Problems)"
                                   Icon="@Icons.Material.Filled.PriorityHigh"
                                   OnClick="ShowProblemViewAsync">
                        Problem-first view
                    </CompactButton>
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.Refresh"
                                   OnClick="RefreshAsync">
                        Refresh
                    </CompactButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!_isEnabled)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                The onboarding workspace feature flag is disabled.
            </MudAlert>
        }
        else
        {
            <MudPaper Elevation="1" Class="pa-3">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="3">
                        <CompactSelect T="int?"
                                       Label="Connection"
                                       Value="@_filter.ConnectionId"
                                       ValueChanged="OnConnectionChangedAsync"
                                       Clearable="true">
                            @foreach (var option in _viewModel.FilterOptions.Connections)
                            {
                                <MudSelectItem T="int?" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </CompactSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <CompactSelect T="int?"
                                       Label="Project"
                                       Value="@_filter.ProjectId"
                                       ValueChanged="OnProjectChangedAsync"
                                       Clearable="true">
                            @foreach (var option in _viewModel.FilterOptions.Projects)
                            {
                                <MudSelectItem T="int?" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </CompactSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <CompactSelect T="int?"
                                       Label="Product root"
                                       Value="@_filter.ProductRootId"
                                       ValueChanged="OnRootChangedAsync"
                                       Clearable="true">
                            @foreach (var option in _viewModel.FilterOptions.ProductRoots)
                            {
                                <MudSelectItem T="int?" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </CompactSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <CompactSelect T="OnboardingConfigurationStatus?"
                                       Label="Status"
                                       Value="@_filter.Status"
                                       ValueChanged="OnStatusChangedAsync"
                                       Clearable="true">
                            @foreach (var option in _viewModel.FilterOptions.Statuses)
                            {
                                <MudSelectItem T="OnboardingConfigurationStatus?" Value="@option.Value">@option.Label</MudSelectItem>
                            }
                        </CompactSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (_executionFeedback is not null)
            {
                <MudAlert Severity="@ResolveExecutionFeedbackSeverity(_executionFeedback.Kind)" Variant="Variant.Outlined">
                    <MudText Typo="Typo.subtitle2">@_executionFeedback.Title</MudText>
                    <MudText Typo="Typo.body2">@_executionFeedback.Message</MudText>
                    @if (!string.IsNullOrWhiteSpace(_executionFeedback.Details))
                    {
                        <MudText Typo="Typo.caption">@_executionFeedback.Details</MudText>
                    }
                </MudAlert>
            }

            @if (_viewModel.LoadState == OnboardingWorkspaceLoadState.Loading)
            {
                <MudPaper Elevation="1" Class="pa-6">
                    <MudProgressCircular Indeterminate="true" Color="Color.Info" />
                    <MudText Typo="Typo.body2" Class="mt-2">Loading onboarding workspace…</MudText>
                </MudPaper>
            }
            else if (_viewModel.LoadState == OnboardingWorkspaceLoadState.Failed)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    @_viewModel.ErrorMessage
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@_viewModel.Message</MudAlert>

                @if (_viewModel.Summary is not null)
                {
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h5">Global summary</MudText>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <OnboardingStatusBadge Status="@_viewModel.Summary.OverallStatus" />
                                <MudChip T="string" Label="true" Size="Size.Small">Connection: @_viewModel.Summary.ConnectionStatus</MudChip>
                                <MudChip T="string" Label="true" Size="Size.Small">Data sources: @_viewModel.Summary.DataSourceSetupStatus</MudChip>
                                <MudChip T="string" Label="true" Size="Size.Small">Domain: @_viewModel.Summary.DomainConfigurationStatus</MudChip>
                                @if (_viewModel.ProblemSummary?.HasProblems == true)
                                {
                                    <MudChip T="string" Label="true" Size="Size.Small" Color="Color.Error">
                                        @_viewModel.ProblemSummary.BlockingCount blocker(s)
                                    </MudChip>
                                    <MudChip T="string" Label="true" Size="Size.Small" Color="Color.Warning">
                                        @_viewModel.ProblemSummary.WarningCount warning(s)
                                    </MudChip>
                                }
                            </MudStack>
                            <MudGrid Spacing="2">
                                <MudItem xs="6" sm="4" md="2"><MudText Typo="Typo.caption">Projects</MudText><MudText Typo="Typo.h6">@_viewModel.Summary.Counts.ProjectSourcesValid/@_viewModel.Summary.Counts.ProjectSourcesTotal</MudText></MudItem>
                                <MudItem xs="6" sm="4" md="2"><MudText Typo="Typo.caption">Teams</MudText><MudText Typo="Typo.h6">@_viewModel.Summary.Counts.TeamSourcesValid/@_viewModel.Summary.Counts.TeamSourcesTotal</MudText></MudItem>
                                <MudItem xs="6" sm="4" md="2"><MudText Typo="Typo.caption">Pipelines</MudText><MudText Typo="Typo.h6">@_viewModel.Summary.Counts.PipelineSourcesValid/@_viewModel.Summary.Counts.PipelineSourcesTotal</MudText></MudItem>
                                <MudItem xs="6" sm="4" md="2"><MudText Typo="Typo.caption">Roots</MudText><MudText Typo="Typo.h6">@_viewModel.Summary.Counts.ProductRootsValid/@_viewModel.Summary.Counts.ProductRootsTotal</MudText></MudItem>
                                <MudItem xs="6" sm="4" md="2"><MudText Typo="Typo.caption">Bindings</MudText><MudText Typo="Typo.h6">@_viewModel.Summary.Counts.BindingsValid/@_viewModel.Summary.Counts.BindingsTotal</MudText></MudItem>
                            </MudGrid>

                            @if (_viewModel.Summary.Blockers.Count > 0)
                            {
                                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                                    <MudText Typo="Typo.subtitle2">Visible blockers</MudText>
                                    <MudList T="string" Dense="true">
                                        @foreach (var blocker in _viewModel.Summary.Blockers)
                                        {
                                            <MudListItem T="string">@blocker.Message</MudListItem>
                                        }
                                    </MudList>
                                </MudAlert>
                            }

                            @if (_viewModel.Summary.Warnings.Count > 0)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                    <MudText Typo="Typo.subtitle2">Visible warnings</MudText>
                                    <MudList T="string" Dense="true">
                                        @foreach (var warning in _viewModel.Summary.Warnings)
                                        {
                                            <MudListItem T="string">@warning.Message</MudListItem>
                                        }
                                    </MudList>
                                </MudAlert>
                            }
                        </MudStack>
                    </MudPaper>
                }

                @if (_viewModel.ProblemSummary?.HasProblems == true)
                {
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h5">Top blockers</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                This panel is ordered only by existing blocker/warning severity, impacted child scope, and current graph relationships so users can see what to fix first within 30 seconds.
                            </MudText>

                            @if (_viewModel.ProblemSummary.TopBlockers.Count == 0)
                            {
                                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">
                                    No blockers are visible in the current filter scope.
                                </MudAlert>
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    @foreach (var problem in _viewModel.ProblemSummary.TopBlockers)
                                    {
                                     <MudItem xs="12" md="6">
                                            <OnboardingRootCauseCard RootCause="@problem" OnNavigate="GoToFixLocationAsync" />
                                     </MudItem>
                                 }
                             </MudGrid>
                            }
                        </MudStack>
                    </MudPaper>
                }

                @if (_viewMode == OnboardingWorkspaceViewMode.Problems)
                {
                    @RenderProblemFirstView()
                }
                else
                {
                    @RenderGraphView()
                }
            }
        }
    </MudStack>
</MudContainer>

@code {
    private bool _isEnabled;
    private bool _hasLoaded;
    private bool _connectionsExpanded;
    private bool _projectsExpanded;
    private bool _teamsExpanded;
    private bool _pipelinesExpanded;
    private bool _productRootsExpanded;
    private bool _bindingsExpanded;
    private string? _pendingScrollTarget;
    private string? _highlightedTargetElementId;
    private ExecutionIntentViewModel? _activeExecutionIntent;
    private OnboardingExecutionFeedbackViewModel? _executionFeedback;
    private OnboardingWorkspaceViewMode _viewMode = OnboardingWorkspaceViewMode.Graph;
    private OnboardingWorkspaceFilter _filter = new(null, null, null, null);
    private OnboardingWorkspaceViewModel _viewModel = null!;
    private PendingExecutionNavigation? _pendingExecutionNavigation;

    protected override void OnInitialized()
    {
        ParseContextQueryParameters();
        _viewModel = ViewModelFactory.CreateLoading(_filter);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            _isEnabled = FeatureFlagService.IsEnabled(FeatureFlagKeys.OnboardingWorkspace);
            if (!_isEnabled)
            {
                NavigationManager.NavigateTo(WorkspaceRoutes.Home, replace: true);
                return;
            }

            if (!_hasLoaded)
            {
                _hasLoaded = true;
                await LoadAsync();
            }
        }

        if (!string.IsNullOrWhiteSpace(_pendingScrollTarget))
        {
            var scrollTarget = _pendingScrollTarget;
            _pendingScrollTarget = null;
            await JS.InvokeVoidAsync("PoTool.Navigation.scrollToElement", scrollTarget);
        }
    }

    private async Task ShowGraphViewAsync()
    {
        _viewMode = OnboardingWorkspaceViewMode.Graph;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowProblemViewAsync()
    {
        _viewMode = OnboardingWorkspaceViewMode.Problems;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync()
        => await LoadAsync();

    private async Task OnConnectionChangedAsync(int? value)
    {
        _activeExecutionIntent = null;
        _executionFeedback = null;
        _filter = _filter with
        {
            ConnectionId = value,
            ProjectId = null,
            ProductRootId = null
        };
        await LoadAsync();
    }

    private async Task OnProjectChangedAsync(int? value)
    {
        _activeExecutionIntent = null;
        _executionFeedback = null;
        _filter = _filter with
        {
            ProjectId = value,
            ProductRootId = null
        };
        await LoadAsync();
    }

    private async Task OnRootChangedAsync(int? value)
    {
        _activeExecutionIntent = null;
        _executionFeedback = null;
        _filter = _filter with { ProductRootId = value };
        await LoadAsync();
    }

    private async Task OnStatusChangedAsync(OnboardingConfigurationStatus? value)
    {
        _activeExecutionIntent = null;
        _executionFeedback = null;
        _filter = _filter with { Status = value };
        await LoadAsync();
    }

    private async Task NavigateToProblemAsync(ActionableProblemViewModel problem)
    {
        _viewMode = OnboardingWorkspaceViewMode.Graph;
        ExpandSection(problem.GraphSection);
        _highlightedTargetElementId = problem.TargetElementId;
        _pendingScrollTarget = problem.TargetElementId;
        await InvokeAsync(StateHasChanged);
    }

    private async Task NavigateToRootCauseAsync(OnboardingRootCauseGroupViewModel rootCause)
    {
        _viewMode = OnboardingWorkspaceViewMode.Graph;
        ExpandSection(rootCause.GraphSection);
        _highlightedTargetElementId = rootCause.TargetElementId;
        _pendingScrollTarget = rootCause.TargetElementId;
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToFixLocationAsync(ExecutionIntentViewModel intent)
    {
        _viewMode = OnboardingWorkspaceViewMode.Graph;
        _executionFeedback = null;
        _filter = new OnboardingWorkspaceFilter(
            intent.ConnectionId,
            intent.ProjectId,
            intent.RootId,
            null);

        _pendingExecutionNavigation = new PendingExecutionNavigation(
            intent.NavigationTarget.TargetElementId,
            intent.NavigationTarget.ExpandedSections,
            intent.IntentType);

        NavigationManager.NavigateTo(intent.NavigationTarget.Route, replace: true);
        await LoadAsync();
    }

    private async Task OnMutationCompletedAsync(OnboardingExecutionResult result)
    {
        _executionFeedback = result.Feedback;

        if (result.RefreshedData is null)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        _filter = result.AppliedFilter;
        _viewModel = ViewModelFactory.Create(result.RefreshedData);
        ApplyGraphSectionDefaults();
        _pendingExecutionNavigation = new PendingExecutionNavigation(
            result.Intent.NavigationTarget.TargetElementId,
            result.Intent.NavigationTarget.ExpandedSections,
            result.Intent.IntentType);
        ApplyPendingExecutionNavigation();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _viewModel = ViewModelFactory.CreateLoading(_filter);
        await InvokeAsync(StateHasChanged);

        try
        {
            var data = await OnboardingWorkspaceService.GetWorkspaceDataAsync(_filter);
            _viewModel = ViewModelFactory.Create(data);
            ApplyGraphSectionDefaults();
            ApplyPendingExecutionNavigation();
        }
        catch (HttpRequestException exception)
        {
            _viewModel = ViewModelFactory.CreateFailure(_filter, exception.Message);
            ApplyGraphSectionDefaults();
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ApplyGraphSectionDefaults()
    {
        _connectionsExpanded = GetSectionState(OnboardingGraphSection.Connections).DefaultExpanded;
        _projectsExpanded = GetSectionState(OnboardingGraphSection.Projects).DefaultExpanded;
        _teamsExpanded = GetSectionState(OnboardingGraphSection.Teams).DefaultExpanded;
        _pipelinesExpanded = GetSectionState(OnboardingGraphSection.Pipelines).DefaultExpanded;
        _productRootsExpanded = GetSectionState(OnboardingGraphSection.ProductRoots).DefaultExpanded;
        _bindingsExpanded = GetSectionState(OnboardingGraphSection.Bindings).DefaultExpanded;
    }

    private void ExpandSection(OnboardingGraphSection section)
    {
        switch (section)
        {
            case OnboardingGraphSection.Connections:
                _connectionsExpanded = true;
                break;
            case OnboardingGraphSection.Projects:
                _projectsExpanded = true;
                break;
            case OnboardingGraphSection.Teams:
                _teamsExpanded = true;
                break;
            case OnboardingGraphSection.Pipelines:
                _pipelinesExpanded = true;
                break;
            case OnboardingGraphSection.ProductRoots:
                _productRootsExpanded = true;
                break;
            case OnboardingGraphSection.Bindings:
                _bindingsExpanded = true;
                break;
        }
    }

    protected override void ParseContextQueryParameters()
    {
        base.ParseContextQueryParameters();

        var context = ParseExecutionNavigationContext(NavigationManager.Uri);
        if (context is null)
        {
            return;
        }

        _filter = new OnboardingWorkspaceFilter(
            context.ConnectionId,
            context.ProjectId,
            context.RootId,
            null);

        _pendingExecutionNavigation = new PendingExecutionNavigation(
            context.TargetElementId,
            [context.Section],
            context.IntentType);
    }

    private static ParsedExecutionNavigationContext? ParseExecutionNavigationContext(string uri)
    {
        var absoluteUri = Uri.TryCreate(uri, UriKind.Absolute, out var parsedAbsolute)
            ? parsedAbsolute
            : new Uri(new Uri("http://localhost"), uri);

        var query = HttpUtility.ParseQueryString(absoluteUri.Query);
        if (!Enum.TryParse<OnboardingGraphSection>(query[OnboardingExecutionIntentQueryKeys.Section], out var section))
        {
            return null;
        }

        var targetElementId = query[OnboardingExecutionIntentQueryKeys.TargetElementId];
        if (string.IsNullOrWhiteSpace(targetElementId))
        {
            return null;
        }

        return new ParsedExecutionNavigationContext(
            ParseNullableInt(query[OnboardingExecutionIntentQueryKeys.ConnectionId]),
            ParseNullableInt(query[OnboardingExecutionIntentQueryKeys.ProjectId]),
            ParseNullableInt(query[OnboardingExecutionIntentQueryKeys.RootId]),
            section,
            targetElementId,
            query[OnboardingExecutionIntentQueryKeys.IntentType]);
    }

    private void ApplyPendingExecutionNavigation()
    {
        if (_pendingExecutionNavigation is null)
        {
            return;
        }

        foreach (var section in _pendingExecutionNavigation.ExpandedSections)
        {
            ExpandSection(section);
        }

        _highlightedTargetElementId = _pendingExecutionNavigation.TargetElementId;
        _pendingScrollTarget = _pendingExecutionNavigation.TargetElementId;
        _activeExecutionIntent = FindExecutionIntent(_pendingExecutionNavigation.TargetElementId, _pendingExecutionNavigation.IntentType);
        _pendingExecutionNavigation = null;
    }

    private static int? ParseNullableInt(string? value)
        => int.TryParse(value, out var parsed) ? parsed : null;

    private RenderFragment RenderProblemFirstView() => builder =>
    {
        builder.OpenComponent<MudPaper>(0);
        builder.AddAttribute(1, "Elevation", 1);
        builder.AddAttribute(2, "Class", "pa-3");
        builder.AddAttribute(3, "ChildContent", (RenderFragment)(contentBuilder =>
        {
            var index = 0;
            contentBuilder.OpenComponent<MudStack>(index++);
            contentBuilder.AddAttribute(index++, "Spacing", 3);
            contentBuilder.AddAttribute(index++, "ChildContent", (RenderFragment)(stackBuilder =>
            {
                var nested = 0;
                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.h5);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Problem-first view")));
                stackBuilder.CloseComponent();

                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.body2);
                stackBuilder.AddAttribute(nested++, "Color", Color.Secondary);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Root-cause-aware blockers appear before warnings and now include the suggested next step, grouped impact, and the visible issues they unblock.")));
                stackBuilder.CloseComponent();

                RenderRootCauseCategory(stackBuilder, ref nested, "Top blockers", _viewModel.ProblemSummary?.TopBlockers ?? [], Severity.Error);
                RenderRootCauseCategory(stackBuilder, ref nested, "Other blockers", _viewModel.ProblemSummary?.OtherBlockers ?? [], Severity.Error);
                RenderRootCauseCategory(stackBuilder, ref nested, "Warnings", _viewModel.ProblemSummary?.Warnings ?? [], Severity.Warning);

                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.h6);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Root causes")));
                stackBuilder.CloseComponent();

                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.body2);
                stackBuilder.AddAttribute(nested++, "Color", Color.Secondary);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Multiple visible symptoms with the same reason and upstream entity are grouped under one root cause so repeated issues do not dominate the workspace.")));
                stackBuilder.CloseComponent();

                if (_viewModel.RootCauseGroups.Count == 0)
                {
                    stackBuilder.OpenComponent<MudAlert>(nested++);
                    stackBuilder.AddAttribute(nested++, "Severity", Severity.Success);
                    stackBuilder.AddAttribute(nested++, "Variant", Variant.Outlined);
                    stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "No root causes are visible in the current filter scope.")));
                    stackBuilder.CloseComponent();
                }
                else
                {
                    stackBuilder.AddContent(nested++, RenderRootCauseGroups());
                }

                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.h6);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Derived issues")));
                stackBuilder.CloseComponent();

                stackBuilder.OpenComponent<MudText>(nested++);
                stackBuilder.AddAttribute(nested++, "Typo", Typo.body2);
                stackBuilder.AddAttribute(nested++, "Color", Color.Secondary);
                stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "Underlying visible issues remain available by scope so grouped symptoms are never hidden completely.")));
                stackBuilder.CloseComponent();

                foreach (var group in _viewModel.ProblemGroups)
                {
                    stackBuilder.OpenComponent<MudPaper>(nested++);
                    stackBuilder.AddAttribute(nested++, "Elevation", 0);
                    stackBuilder.AddAttribute(nested++, "Class", "pa-3");
                    stackBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(groupBuilder =>
                    {
                        var groupIndex = 0;
                        groupBuilder.OpenComponent<MudText>(groupIndex++);
                        groupBuilder.AddAttribute(groupIndex++, "Typo", Typo.subtitle1);
                        groupBuilder.AddAttribute(groupIndex++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, group.Title)));
                        groupBuilder.CloseComponent();

                        groupBuilder.OpenComponent<MudGrid>(groupIndex++);
                        groupBuilder.AddAttribute(groupIndex++, "Spacing", 2);
                        groupBuilder.AddAttribute(groupIndex++, "ChildContent", (RenderFragment)(gridBuilder =>
                        {
                            var problemIndex = 0;
                            foreach (var problem in group.Items)
                            {
                                gridBuilder.OpenComponent<MudItem>(problemIndex++);
                                gridBuilder.AddAttribute(problemIndex++, "xs", 12);
                                gridBuilder.AddAttribute(problemIndex++, "md", 6);
                                gridBuilder.AddAttribute(problemIndex++, "ChildContent", (RenderFragment)(itemBuilder =>
                                {
                                    itemBuilder.OpenComponent<OnboardingProblemCard>(problemIndex++);
                                    itemBuilder.AddAttribute(problemIndex++, "Problem", problem);
                                    itemBuilder.AddAttribute(problemIndex++, "OnNavigate", EventCallback.Factory.Create<ExecutionIntentViewModel>(this, GoToFixLocationAsync));
                                    itemBuilder.CloseComponent();
                                }));
                                gridBuilder.CloseComponent();
                            }
                        }));
                        groupBuilder.CloseComponent();
                    }));
                    stackBuilder.CloseComponent();
                }
            }));
            contentBuilder.CloseComponent();
        }));
        builder.CloseComponent();
    };

    private void RenderRootCauseCategory(RenderTreeBuilder builder, ref int index, string title, IReadOnlyList<OnboardingRootCauseGroupViewModel> items, Severity severity)
    {
        builder.OpenComponent<MudAlert>(index++);
        builder.AddAttribute(index++, "Severity", severity);
        builder.AddAttribute(index++, "Variant", Variant.Outlined);
        builder.AddAttribute(index++, "ChildContent", (RenderFragment)(contentBuilder =>
        {
            var nested = 0;
            contentBuilder.OpenComponent<MudText>(nested++);
            contentBuilder.AddAttribute(nested++, "Typo", Typo.subtitle2);
            contentBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, title)));
            contentBuilder.CloseComponent();

            if (items.Count == 0)
            {
                contentBuilder.OpenComponent<MudText>(nested++);
                contentBuilder.AddAttribute(nested++, "Typo", Typo.body2);
                contentBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(textBuilder => textBuilder.AddContent(0, "None visible in the current filter scope.")));
                contentBuilder.CloseComponent();
                return;
            }

            contentBuilder.OpenComponent<MudGrid>(nested++);
            contentBuilder.AddAttribute(nested++, "Spacing", 2);
            contentBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(gridBuilder =>
            {
                var gridIndex = 0;
                foreach (var item in items)
                {
                    gridBuilder.OpenComponent<MudItem>(gridIndex++);
                    gridBuilder.AddAttribute(gridIndex++, "xs", 12);
                    gridBuilder.AddAttribute(gridIndex++, "md", 6);
                    gridBuilder.AddAttribute(gridIndex++, "ChildContent", (RenderFragment)(itemBuilder =>
                    {
                        itemBuilder.OpenComponent<OnboardingRootCauseCard>(gridIndex++);
                        itemBuilder.AddAttribute(gridIndex++, "RootCause", item);
                        itemBuilder.AddAttribute(gridIndex++, "OnNavigate", EventCallback.Factory.Create<ExecutionIntentViewModel>(this, GoToFixLocationAsync));
                        itemBuilder.CloseComponent();
                    }));
                    gridBuilder.CloseComponent();
                }
            }));
            contentBuilder.CloseComponent();
