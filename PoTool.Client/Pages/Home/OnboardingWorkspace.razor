    private void RenderGroupedEntities<TItem>(
        RenderTreeBuilder builder,
        IReadOnlyList<OnboardingProjectGroupViewModel<TItem>> groups,
        string emptyMessage,
        string? placeholderTitle,
        string? placeholderMessage,
        Func<RenderTreeBuilder, int, OnboardingProjectGroupViewModel<TItem>, TItem, int> renderItem)
    {
        if (groups.Count == 0)
        {
            RenderEmptyState(builder, emptyMessage);
            return;
        }

        var index = 0;
        foreach (var group in groups)
        {
            builder.OpenComponent<MudPaper>(index++);
            builder.AddAttribute(index++, "Elevation", 1);
            builder.AddAttribute(index++, "Class", "pa-3 mb-3");
            builder.AddAttribute(index++, "ChildContent", (RenderFragment)(groupBuilder =>
            {
                var nested = 0;
                groupBuilder.OpenComponent<MudText>(nested++);
                groupBuilder.AddAttribute(nested++, "Typo", Typo.h6);
                groupBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(titleBuilder => titleBuilder.AddContent(0, $"{group.Project.ProjectName} ({group.Project.ProjectExternalId})")));
                groupBuilder.CloseComponent();

                groupBuilder.OpenComponent<MudGrid>(nested++);
                groupBuilder.AddAttribute(nested++, "Spacing", 2);
                groupBuilder.AddAttribute(nested++, "ChildContent", (RenderFragment)(gridBuilder =>
                {
                    var cardIndex = 0;
                    foreach (var item in group.Items)
                    {
                        gridBuilder.OpenComponent<MudItem>(cardIndex++);
                        gridBuilder.AddAttribute(cardIndex++, "xs", 12);
                        gridBuilder.AddAttribute(cardIndex++, "md", 6);
                        gridBuilder.AddAttribute(cardIndex++, "ChildContent", (RenderFragment)(itemBuilder =>
                        {
                            cardIndex = renderItem(itemBuilder, cardIndex, group, item);
                        }));
                        gridBuilder.CloseComponent();
                    }
                }));
                groupBuilder.CloseComponent();

                var projectContext = group.Project;
                var highlightedTeam = typeof(TItem) == typeof(OnboardingTeamSourceDto)
                    ? GetHighlightedTeam(group.Project.ProjectId)
                    : null;
                var highlightedPipeline = typeof(TItem) == typeof(OnboardingPipelineSourceDto)
                    ? GetHighlightedPipeline(group.Project.ProjectId)
                    : null;
                var highlightedRoot = typeof(TItem) == typeof(OnboardingProductRootDto)
                    ? GetHighlightedRoot(group.Project.ProjectId)
                    : null;
                var section = typeof(TItem) == typeof(OnboardingTeamSourceDto)
                    ? OnboardingGraphSection.Teams
                    : typeof(TItem) == typeof(OnboardingPipelineSourceDto)
                        ? OnboardingGraphSection.Pipelines
                        : OnboardingGraphSection.ProductRoots;

                groupBuilder.OpenComponent<OnboardingMutationActionZone>(nested++);
                groupBuilder.AddAttribute(nested++, "Section", section);
                groupBuilder.AddAttribute(nested++, "ActiveIntent", _activeExecutionIntent);
                groupBuilder.AddAttribute(nested++, "CurrentFilter", _filter);
                groupBuilder.AddAttribute(nested++, "ProjectContext", projectContext);
                groupBuilder.AddAttribute(nested++, "Team", highlightedTeam);
                groupBuilder.AddAttribute(nested++, "Pipeline", highlightedPipeline);
                groupBuilder.AddAttribute(nested++, "Root", highlightedRoot);
                groupBuilder.AddAttribute(nested++, "OnCompleted", EventCallback.Factory.Create<OnboardingExecutionResult>(this, OnMutationCompletedAsync));
                groupBuilder.CloseComponent();
            }));
            builder.CloseComponent();
        }
    }

    private void RenderEmptyState(RenderTreeBuilder builder, string message)
    {
        builder.OpenComponent<MudAlert>(0);
        builder.AddAttribute(1, "Severity", Severity.Info);
        builder.AddAttribute(2, "Variant", Variant.Outlined);
        builder.AddAttribute(3, "ChildContent", (RenderFragment)(contentBuilder => contentBuilder.AddContent(4, message)));
        builder.CloseComponent();
    }

    private void RenderProjectScopedEmptyActionZone(RenderTreeBuilder builder, int index, OnboardingGraphSection section)
    {
        var project = _viewModel.Projects.FirstOrDefault(item => item.Id == (_activeExecutionIntent?.ProjectId ?? _filter.ProjectId));
        builder.OpenComponent<OnboardingMutationActionZone>(index);
        builder.AddAttribute(index + 1, "Section", section);
        builder.AddAttribute(index + 2, "ActiveIntent", _activeExecutionIntent);
        builder.AddAttribute(index + 3, "CurrentFilter", _filter);
        builder.AddAttribute(index + 4, "ProjectContext", project is null ? null : new OnboardingProjectContextViewModel(project.Id, project.ProjectExternalId, project.Snapshot.Name));
        builder.AddAttribute(index + 5, "Project", section == OnboardingGraphSection.Projects ? project : null);
        builder.AddAttribute(index + 6, "OnCompleted", EventCallback.Factory.Create<OnboardingExecutionResult>(this, OnMutationCompletedAsync));
        builder.CloseComponent();
    }

    private void RenderBindingScopedEmptyActionZone(RenderTreeBuilder builder, int index)
    {
        var root = _viewModel.ProductRootGroups
            .SelectMany(group => group.Items)
            .FirstOrDefault(item => item.Id == (_activeExecutionIntent?.RootId ?? _filter.ProductRootId));
        var project = root is null
            ? null
            : _viewModel.Projects.FirstOrDefault(item => item.Id == root.ProjectSourceId);

        builder.OpenComponent<OnboardingMutationActionZone>(index);
        builder.AddAttribute(index + 1, "Section", OnboardingGraphSection.Bindings);
        builder.AddAttribute(index + 2, "ActiveIntent", _activeExecutionIntent);
        builder.AddAttribute(index + 3, "CurrentFilter", _filter);
        builder.AddAttribute(index + 4, "Root", root);
        builder.AddAttribute(index + 5, "ProjectContext", project is null ? null : new OnboardingProjectContextViewModel(project.Id, project.ProjectExternalId, project.Snapshot.Name));
        builder.AddAttribute(index + 6, "AvailableTeams", project is null ? Array.Empty<OnboardingTeamSourceDto>() : GetAvailableTeams(project.Id));
        builder.AddAttribute(index + 7, "AvailablePipelines", project is null ? Array.Empty<OnboardingPipelineSourceDto>() : GetAvailablePipelines(project.Id));
        builder.AddAttribute(index + 8, "OnCompleted", EventCallback.Factory.Create<OnboardingExecutionResult>(this, OnMutationCompletedAsync));
        builder.CloseComponent();
    }

    private string? GetSuggestedAction(string targetElementId)
        => GetPrimaryProblemForTarget(targetElementId)?.SuggestedAction;

    private ExecutionIntentViewModel? GetExecutionIntent(string targetElementId)
        => GetPrimaryProblemForTarget(targetElementId)?.ExecutionIntent;

    private OnboardingExecutionConfidenceLevel? GetConfidenceLevel(string targetElementId)
        => GetExecutionIntent(targetElementId)?.ConfidenceLevel;

    private string? GetRootCauseHint(string targetElementId)
    {
        var problem = GetPrimaryProblemForTarget(targetElementId);
        return problem is null || problem.RootCauseTargetElementId == targetElementId
            ? null
            : $"Part of root cause: {problem.RootCauseEntity}";
    }

    private bool IsHighlighted(string targetElementId)
        => string.Equals(_highlightedTargetElementId, targetElementId, StringComparison.Ordinal);

    private ActionableProblemViewModel? GetPrimaryProblemForTarget(string targetElementId)
        => _viewModel.ProblemGroups
            .SelectMany(group => group.Items)
            .Where(problem => problem.TargetElementId == targetElementId)
            .OrderBy(problem => problem.Severity)
            .ThenByDescending(problem => problem.ImpactedChildrenCount)
            .ThenBy(problem => problem.Title, StringComparer.OrdinalIgnoreCase)
            .FirstOrDefault();

    private ExecutionIntentViewModel? FindExecutionIntent(string targetElementId, string? intentType)
    {
        var problemIntent = _viewModel.ProblemGroups
            .SelectMany(group => group.Items)
            .Where(problem => problem.TargetElementId == targetElementId
                && (string.IsNullOrWhiteSpace(intentType) || string.Equals(problem.ExecutionIntent.IntentType, intentType, StringComparison.Ordinal)))
            .OrderBy(problem => problem.Severity)
            .ThenByDescending(problem => problem.ImpactedChildrenCount)
            .Select(problem => problem.ExecutionIntent)
            .FirstOrDefault();

        return problemIntent
            ?? _viewModel.RootCauseGroups
                .Where(group => group.TargetElementId == targetElementId
                    && (string.IsNullOrWhiteSpace(intentType) || string.Equals(group.ExecutionIntent.IntentType, intentType, StringComparison.Ordinal)))
                .Select(group => group.ExecutionIntent)
                .FirstOrDefault();
    }

    private OnboardingTfsConnectionDto? GetHighlightedConnection()
        => _viewModel.Connections.FirstOrDefault(item => IsHighlighted($"connection-{item.Id}"));

    private OnboardingProjectSourceDto? GetHighlightedProject()
        => _viewModel.Projects.FirstOrDefault(item => IsHighlighted($"project-{item.Id}"));

    private OnboardingTeamSourceDto? GetHighlightedTeam(int projectId)
        => _viewModel.TeamGroups
            .Where(group => group.Project.ProjectId == projectId)
            .SelectMany(group => group.Items)
            .FirstOrDefault(item => IsHighlighted($"team-{item.Id}"));

    private OnboardingPipelineSourceDto? GetHighlightedPipeline(int projectId)
        => _viewModel.PipelineGroups
            .Where(group => group.Project.ProjectId == projectId)
            .SelectMany(group => group.Items)
            .FirstOrDefault(item => IsHighlighted($"pipeline-{item.Id}"));

    private OnboardingProductRootDto? GetHighlightedRoot(int projectId)
        => _viewModel.ProductRootGroups
            .Where(group => group.Project.ProjectId == projectId)
            .SelectMany(group => group.Items)
            .FirstOrDefault(item => IsHighlighted($"root-{item.Id}"));

    private OnboardingProductSourceBindingDto? GetHighlightedBinding(int rootId)
        => _viewModel.BindingGroups
            .Where(group => group.Root.RootId == rootId)
            .SelectMany(group => group.Bindings)
            .FirstOrDefault(item => IsHighlighted($"binding-{item.Id}"));

    private IReadOnlyList<OnboardingTeamSourceDto> GetAvailableTeams(int projectId)
        => _viewModel.TeamGroups
            .Where(group => group.Project.ProjectId == projectId)
            .SelectMany(group => group.Items)
            .ToList();

    private IReadOnlyList<OnboardingPipelineSourceDto> GetAvailablePipelines(int projectId)
        => _viewModel.PipelineGroups
            .Where(group => group.Project.ProjectId == projectId)
            .SelectMany(group => group.Items)
            .ToList();

    private static Severity ResolveExecutionFeedbackSeverity(OnboardingExecutionFeedbackKind kind)
        => kind switch
        {
            OnboardingExecutionFeedbackKind.Success => Severity.Success,
            OnboardingExecutionFeedbackKind.Warning => Severity.Warning,
            _ => Severity.Error
        };

    private string GetSectionDisplayTitle(OnboardingGraphSection section)
    {
        var state = GetSectionState(section);
        if (state.BlockingCount == 0 && state.WarningCount == 0)
        {
            return state.Title;
        }

        return $"{state.Title} — {state.BlockingCount} blocker(s), {state.WarningCount} warning(s)";
    }

    private OnboardingGraphSectionStateViewModel GetSectionState(OnboardingGraphSection section)
        => _viewModel.GraphSections.FirstOrDefault(item => item.Section == section)
           ?? new OnboardingGraphSectionStateViewModel(section, section.ToString(), $"section-{section}", 0, 0, false);

    private sealed record PendingExecutionNavigation(
        string TargetElementId,
        IReadOnlyList<OnboardingGraphSection> ExpandedSections,
        string? IntentType);

    private sealed record ParsedExecutionNavigationContext(
        int? ConnectionId,
        int? ProjectId,
        int? RootId,
        OnboardingGraphSection Section,
        string TargetElementId,
        string? IntentType);
}
