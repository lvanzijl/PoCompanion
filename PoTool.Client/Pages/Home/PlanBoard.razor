    private async Task<List<ProjectDto>> LoadAvailableProjectsAsync(IReadOnlyCollection<ProductDto> products)
    {
        var productIds = products.Select(product => product.Id).ToHashSet();
        var projects = await ProjectService.GetAllProjectsAsync();

        return projects
            .Where(project => project.ProductIds.Any(productIds.Contains))
            .OrderBy(project => project.Name)
            .ToList();
    }

    private void ResolveInitialProjectSelection(WorkspaceQueryContext context)
    {
        var requestedProjectKey = string.IsNullOrWhiteSpace(RouteProjectAlias)
            ? context.ProjectAlias
            : RouteProjectAlias;

        var selectedProject = ResolveProject(requestedProjectKey);
        if (selectedProject == null && context.ProductId.HasValue)
        {
            selectedProject = _projects.FirstOrDefault(project => project.ProductIds.Contains(context.ProductId.Value));
        }

        _selectedProjectRouteKey = selectedProject?.Alias;
    }

    private void ApplyProjectFilter()
    {
        var selectedProject = ResolveProject(_selectedProjectRouteKey);
        _products = selectedProject == null
            ? _allProducts
            : _allProducts.Where(product => selectedProject.ProductIds.Contains(product.Id)).ToList();
    }

    private async Task LoadProjectPlanningSummaryAsync()
    {
        _projectPlanningSummary = string.IsNullOrWhiteSpace(_selectedProjectRouteKey)
            ? null
            : await ProjectService.GetPlanningSummaryAsync(_selectedProjectRouteKey);
    }

    private async Task NavigateToCurrentScopeAsync(int? productId, bool loadBoard)
    {
        var route = string.IsNullOrWhiteSpace(_selectedProjectRouteKey)
            ? WorkspaceRoutes.PlanBoard
            : WorkspaceRoutes.GetProjectPlanBoard(_selectedProjectRouteKey);

        NavigationManager.NavigateTo(
            WorkspaceQueryContextHelper.BuildRoute(
                route,
                new WorkspaceQueryContext(_selectedProjectRouteKey, productId)),
            forceLoad: false);

        if (productId == null)
        {
            ClearBoard();
            return;
        }

        if (loadBoard)
        {
            await LoadBoardAsync(productId.Value);
        }
    }

    private void ClearBoard()
    {
        _selectedProductRootIds = [];
        _allWorkItems = new List<WorkItemDto>();
        _sprintColumns = new List<SprintColumn>();
        _candidateTree = new List<PlanBoardCandidateNode>();
        _sprintItems = new Dictionary<string, List<SprintDragItem>>();
    }

    private ProjectDto? ResolveProject(string? projectRouteKey)
    {
        if (string.IsNullOrWhiteSpace(projectRouteKey))
        {
            return null;
        }

        return _projects.FirstOrDefault(project =>
            string.Equals(project.Alias, projectRouteKey, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(project.Id, projectRouteKey, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatProjectLabel(ProjectDto project)
        => string.Equals(project.Name, project.Alias, StringComparison.OrdinalIgnoreCase)
            ? project.Name
            : $"{project.Name} ({project.Alias})";

    private bool HasPlanningGap()
        => _projectPlanningSummary is { TotalPBIs: > 0 } &&
           _projectPlanningSummary.UnplannedPBIs / (double)_projectPlanningSummary.TotalPBIs > 0.5d;

    private string GetPlanningGapLabel()
    {
        if (_projectPlanningSummary is null || _projectPlanningSummary.TotalPBIs == 0)
        {
            return "Planning gap unavailable";
        }

        var ratio = _projectPlanningSummary.UnplannedPBIs / (double)_projectPlanningSummary.TotalPBIs * 100d;
        return HasPlanningGap()
            ? $"{ratio:F0}% of PBIs are unplanned"
            : $"{ratio:F0}% unplanned";
    }

    private string GetProductImbalanceLabel()
    {
        if (_projectPlanningSummary is null || _projectPlanningSummary.TotalEffort <= 0 || _projectPlanningSummary.Products.Count == 0)
        {
            return "N/A";
        }

        var leadingProduct = _projectPlanningSummary.Products.MaxBy(static product => product.TotalEffort);
        if (leadingProduct == null)
        {
            return "N/A";
        }

        var share = leadingProduct.TotalEffort / (double)_projectPlanningSummary.TotalEffort * 100d;
        return share > 60d
            ? $"{leadingProduct.ProductName} {share:F0}%"
            : "Balanced";
    }

    private static string FormatCapacity(double capacity) => capacity <= 0 ? "N/A" : $"{capacity:F1}";

    private static Color GetProjectRiskColor(bool isRisk) => isRisk ? Color.Warning : Color.Success;

    private async Task LoadCapacityCalibrationAsync(List<SprintDto> allTeamSprints, int productId)
    {
        if (_activeProfileId == null) return;

        var completedSprintIds = allTeamSprints
            .Where(s => s.EndUtc.HasValue && s.EndUtc.Value <= DateTimeOffset.UtcNow)
            .OrderByDescending(s => s.EndUtc)
            .Take(HistoricalSprintsForCalibration)
            .Select(s => s.Id)
            .ToList();

        if (completedSprintIds.Count == 0)
        {
            _sprintCapacity = null;
            _capacityCalibrationFilterMetadata = null;
            _capacityCalibrationState = new DataStateViewModel<DeliveryQueryResponseDto<CapacityCalibrationDto>>(
                DataStateDto.Empty,
                Reason: "No completed sprints are available for calibration.");
            return;
        }

        _capacityCalibrationState = DataStateViewModel<DeliveryQueryResponseDto<CapacityCalibrationDto>>.Loading();
        var calibrationResponse = await MetricsStateService.GetCapacityCalibrationStateAsync(
            _activeProfileId.Value,
            completedSprintIds,
            new[] { productId },
            CancellationToken.None);
        _capacityCalibrationState = DataStateViewModel<DeliveryQueryResponseDto<CapacityCalibrationDto>>.FromResponse(
            calibrationResponse,
            "Capacity calibration data could not be loaded right now.");
        if (_capacityCalibrationState.State == DataStateDto.Available && _capacityCalibrationState.Data is not null)
        {
            _capacityCalibrationFilterMetadata = CanonicalClientResponseFactory.Create(_capacityCalibrationState.Data).FilterMetadata;
            var calibration = _capacityCalibrationState.Data.Data;
            _sprintCapacity = calibration.MedianVelocity > 0 ? calibration.MedianVelocity : null;
            return;
        }

        _capacityCalibrationFilterMetadata = null;
        _sprintCapacity = null;
    }

    private SprintCapacityState GetSprintCapacityState(string zoneId)
    {
        var items = _sprintItems.GetValueOrDefault(zoneId) ?? [];
        var assigned = items.Sum(i => i.Effort ?? 0);

        if (!_sprintCapacity.HasValue || _sprintCapacity.Value <= 0)
            return new SprintCapacityState(0, assigned, 0, 0, 0, false);

        var capacity = (int)Math.Round(_sprintCapacity.Value);
        var remaining = capacity - assigned;
        var utilization = Math.Min(100, assigned / _sprintCapacity.Value * 100);
        var isOvercommitted = assigned > capacity;
        var overAmount = isOvercommitted ? assigned - capacity : 0;

        return new SprintCapacityState(capacity, assigned, remaining, utilization, overAmount, isOvercommitted);
    }

    private static Color GetCapacityColor(double utilization) => utilization switch
    {
        > 100 => Color.Error,
        >= 85 => Color.Warning,
        _ => Color.Success
    };

    private static string GetWorkItemTypeLabel(string workItemType) =>
        PlanBoardWorkItemRules.GetTypeLabel(workItemType);

    private static Color GetWorkItemTypeColor(string workItemType) =>
        string.Equals(PlanBoardWorkItemRules.GetTypeLabel(workItemType), WorkItemTypeHelper.Bug, StringComparison.OrdinalIgnoreCase)
            ? Color.Error
            : Color.Info;

    // ── Private types ──────────────────────────────────────────────────────────

    private sealed class SprintColumn
    {
        public int SprintId { get; init; }
        public required string Name { get; init; }
        public required string Path { get; init; }
        public required string ZoneId { get; init; }
        public DateTimeOffset? StartUtc { get; init; }
        public DateTimeOffset? EndUtc { get; init; }
    }

    private sealed class SprintDragItem
    {
        public int TfsId { get; init; }
        public required string Title { get; init; }
        public required string WorkItemType { get; init; }
        public string? FeatureTitle { get; init; }
        public int? Effort { get; init; }
        public string IterationPath { get; set; } = string.Empty;
    }

    private sealed record SprintCapacityState(
        int Capacity,
        int Assigned,
        int Remaining,
        double Utilization,
        int OverAmount,
        bool IsOvercommitted)
    {
        public bool HasCapacity => Capacity > 0;
    }
