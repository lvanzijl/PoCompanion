@page "/planning/plan-board"
@page "/planning/{RouteProjectAlias}/plan-board"
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Shared.Metrics
@using PoTool.Shared.Planning
@implements IDisposable
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject ProjectService ProjectService
@inject GlobalFilterStore GlobalFilterStore
@inject GlobalFilterRouteService GlobalFilterRouteService
@inject ProductPlanningBoardClientService ProductPlanningBoardClientService
@inject NavigationManager NavigationManager
@inject ILogger<PlanBoard> Logger

<PageTitle>Plan Board - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-4">
    <MudStack Spacing="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h4">Plan Board</MudText>
                    </MudStack>
                    <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @ProductPlanningBoardUxText.HeaderSummary
                    </MudText>
                </MudStack>

                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                    @if (_isBusy)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    }
                    <CompactButton ButtonRole="ButtonRole.Action"
                                   Icon="@Icons.Material.Filled.Refresh"
                                   Disabled="@(!_selectedProductId.HasValue || _isBusy)"
                                   OnClick="ReloadBoardAsync">
                        Reload from saved plan
                    </CompactButton>
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.Restore"
                                   Disabled="@(!_selectedProductId.HasValue || _isBusy)"
                                   OnClick="ResetBoardAsync">
                        Undo all changes
                    </CompactButton>
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.CalendarMonth"
                                   OnClick="NavigateToPlanning">
                        Planning
                    </CompactButton>
                    @if (!string.IsNullOrWhiteSpace(_selectedProjectRouteKey))
                    {
                        <CompactButton ButtonRole="ButtonRole.Action"
                                       Icon="@Icons.Material.Filled.FolderSpecial"
                                       OnClick="NavigateToOverview">
                            Overview
                        </CompactButton>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>

        <CanonicalDataStateView TData="ProjectPlanningSummaryDto"
                                State="@ProjectPlanningSummaryState"
                                ProductOwnerId="@_activeProfileId"
                                Subject="Project planning summary"
                                EmptyTitle="No project planning summary available"
                                EmptyMessage="No project planning summary is available for the selected scope."
                                FailedMessage="Project planning summary could not be loaded right now."
                                OnRecovery="@LoadProjectPlanningSummaryAsync">
            <NotRequestedContent>
            </NotRequestedContent>
            <ChildContent Context="projectPlanningSummary">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">Project planning summary</MudText>
                                <MudText Typo="Typo.h6">@projectPlanningSummary.ProjectAlias</MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                                    @projectPlanningSummary.PlannedPBIs planned · @projectPlanningSummary.UnplannedPBIs unplanned
                                </MudChip>
                                <MudChip T="string" Variant="Variant.Outlined" Color="@GetProjectRiskColor(HasPlanningGap(projectPlanningSummary))">
                                    @GetPlanningGapLabel(projectPlanningSummary)
                                </MudChip>
                                <MudChip T="string" Variant="Variant.Outlined" Color="@GetProjectRiskColor(projectPlanningSummary.OvercommitIndicator)">
                                    @(projectPlanningSummary.OvercommitIndicator ? "Overcommitted across products" : "Capacity window within range")
                                </MudChip>
                            </MudStack>
                        </MudStack>

                        <MudGrid Spacing="2">
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Planned effort</MudText>
                                    <MudText Typo="Typo.h6">@projectPlanningSummary.PlannedEffort / @projectPlanningSummary.TotalEffort</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Capacity / sprint</MudText>
                                    <MudText Typo="Typo.h6">@FormatCapacity(projectPlanningSummary.CapacityPerSprint)</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Product imbalance</MudText>
                                    <MudText Typo="Typo.h6">@GetProductImbalanceLabel(projectPlanningSummary)</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                </MudPaper>
            </ChildContent>
        </CanonicalDataStateView>

        <CanonicalDataStateView TData="ProductPlanningBoardRenderModel"
                                State="@BoardRenderState"
                                ProductOwnerId="@_activeProfileId"
                                Subject="Product planning board"
                                EmptyTitle="No roadmap epics are available"
                                EmptyMessage="The selected product has no active roadmap epics for the planning board."
                                InvalidMessage="Adjust the current product scope to load the planning board."
                                FailedMessage="The planning board could not be loaded right now."
                                OnRecovery="@RetryBoardLoadAsync">
            <NotRequestedContent>
                <MudPaper Elevation="1" Class="pa-8">
                    <MudStack AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Select a product to start planning</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Use the shared planning scope above this page to select one product, then the planning board will load its roadmap epics.
                        </MudText>
                    </MudStack>
                </MudPaper>
            </NotRequestedContent>
            <ChildContent Context="renderModel">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.overline" Color="Color.Secondary">Product planning board</MudText>
                                <MudText Typo="Typo.h5">@renderModel.Board.ProductName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Plan the epic sequence here with explicit controls and automatic parallel lanes.
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                <MudChip T="string" Variant="Variant.Filled" Color="@GetBoardStatusColor(renderModel.StatusKind)">
                                    @renderModel.StatusLabel
                                </MudChip>
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary">
                                    @renderModel.Tracks.Count track@(renderModel.Tracks.Count == 1 ? string.Empty : "s") derived automatically
                                </MudChip>
                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                                    @renderModel.Board.EpicItems.Count epic@(renderModel.Board.EpicItems.Count == 1 ? string.Empty : "s")
                                </MudChip>
                                @if (renderModel.BlockingDiagnosticCount > 0)
                                {
                                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Error">
                                        @renderModel.BlockingDiagnosticCount blocking issue@(renderModel.BlockingDiagnosticCount == 1 ? string.Empty : "s")
                                    </MudChip>
                                }
                                else if (renderModel.HasValidationIssues)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">
                                        @renderModel.Board.Issues.Count planning issue@(renderModel.Board.Issues.Count == 1 ? string.Empty : "s")
                                    </MudChip>
                                }
                                @if (renderModel.RecoveredEpicCount > 0)
                                {
                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary" Class="planning-board-chip--tertiary">
                                        @renderModel.RecoveredEpicCount epic@(renderModel.RecoveredEpicCount == 1 ? string.Empty : "s") imported from existing data
                                    </MudChip>
                                }
                                @if (renderModel.DriftedEpicCount > 0)
                                {
                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning" Class="planning-board-chip--secondary">
                                        @renderModel.DriftedEpicCount epic@(renderModel.DriftedEpicCount == 1 ? string.Empty : "s") out of sync with TFS
                                    </MudChip>
                                }
                            </MudStack>
                        </MudStack>

                        <MudText Typo="Typo.body2" Color="Color.Secondary">@renderModel.StatusDetail</MudText>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="planning-board-authority-banner">
                            @(renderModel.HasBlockingDiagnostics
                                ? ProductPlanningBoardUxText.AuthoritySummaryWithBlockingIssues
                                : ProductPlanningBoardUxText.AuthoritySummary)
                        </MudAlert>

                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                            Drag &amp; drop is intentionally unavailable here. Every planning change uses explicit buttons and deterministic API operations.
                        </MudAlert>

                        @if (!string.IsNullOrWhiteSpace(_boardFeedbackMessage))
                        {
                            <MudAlert Severity="@_boardFeedbackSeverity" Variant="Variant.Outlined" Dense="true">
                                @_boardFeedbackMessage
                            </MudAlert>
                        }

                        @if (renderModel.Board.Issues.Count > 0)
                        {
                            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Planning checks</MudText>
                                    <MudList T="string" Dense="true" Class="planning-board-issue-list">
                                        @foreach (var issue in renderModel.Board.Issues)
                                        {
                                            <MudListItem T="string">
                                                <MudText Typo="Typo.body2">@FormatIssueText(issue)</MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudStack>
                            </MudAlert>
                        }

                        @if ((renderModel.Board.Diagnostics?.Count ?? 0) > 0)
                        {
                            <MudAlert Severity="@(renderModel.HasBlockingDiagnostics ? Severity.Error : Severity.Warning)" Variant="Variant.Outlined">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.subtitle2">TFS sync and planning details</MudText>
                                    <MudList T="string" Dense="true" Class="planning-board-issue-list">
                                        @foreach (var diagnostic in renderModel.Board.Diagnostics!)
                                        {
                                            <MudListItem T="string">
                                                <MudText Typo="Typo.body2">@FormatDiagnosticText(diagnostic)</MudText>
                                            </MudListItem>
                                        }
                                    </MudList>
                                </MudStack>
                            </MudAlert>
                        }
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-3">
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var sprint in renderModel.SprintColumns)
                        {
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Default">
                                @sprint.Label
                            </MudChip>
                        }
                    </MudStack>
                </MudPaper>

                @foreach (var track in renderModel.Tracks)
                {
                    <MudPaper Elevation="1" Class="@GetTrackPaperClass(track)">
                        <MudStack Spacing="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                    <MudStack Spacing="0">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.h6">@track.Title</MudText>
                                            <MudChip T="string" Variant="Variant.Outlined" Color="@(track.IsMainLane ? Color.Primary : Color.Info)">
                                                @(track.IsMainLane ? "Main plan" : "Parallel work")
                                            </MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@track.Subtitle</MudText>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @track.Epics.Count epic@(track.Epics.Count == 1 ? string.Empty : "s") · automatic lane placement
                                </MudText>
                            </MudStack>

                            @if (track.Epics.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                    This track is currently empty.
                                </MudAlert>
                            }
                            else
                            {
                                <div class="planning-board-track-grid" style="@GetTrackGridStyle(renderModel.MaxSprintCount)">
                                    @foreach (var epic in track.Epics)
                                    {
                                        <MudCard Class="@GetEpicCardClass(epic)" Style="@GetEpicGridStyle(epic)">
                                            <MudCardContent Class="pa-3">
                                                <MudStack Spacing="2">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Wrap="Wrap.Wrap">
                                                        <MudStack Spacing="1">
                                                            <MudText Typo="Typo.subtitle2">#@epic.RoadmapOrder · @epic.EpicTitle</MudText>
                                                            <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                                                @if (epic.IsChanged)
                                                                {
                                                                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary">Changed</MudChip>
                                                                }
                                                                @if (epic.IsAffected)
                                                                {
                                                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Info" Class="planning-board-chip--secondary">Affected</MudChip>
                                                                }
                                                                @if (epic.Issues.Count > 0)
                                                                {
                                                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning">
                                                                        @epic.Issues.Count warning@(epic.Issues.Count == 1 ? string.Empty : "s")
                                                                    </MudChip>
                                                                }
                                                                @if (epic.IntentSource == PlanningBoardIntentSource.Recovered)
                                                                {
                                                                    <MudChip T="string" Variant="Variant.Text" Color="Color.Secondary" Class="planning-board-chip--tertiary">
                                                                        @GetIntentSourceLabel(epic)
                                                                    </MudChip>
                                                                }
                                                                @if (epic.DriftStatus.HasValue && epic.DriftStatus.Value != PlanningBoardDriftStatus.NoDrift)
                                                                {
                                                                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Warning" Class="planning-board-chip--secondary">
                                                                        @FormatDriftStatus(epic.DriftStatus.Value)
                                                                    </MudChip>
                                                                }
                                                            </MudStack>
                                                        </MudStack>
                                                        <MudStack Spacing="0" AlignItems="AlignItems.End">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(epic.TrackIndex == 0 ? "Main plan lane" : $"Parallel lane {epic.TrackIndex}")</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Duration @epic.DurationInSprints sprint@(epic.DurationInSprints == 1 ? string.Empty : "s")</MudText>
                                                        </MudStack>
                                                    </MudStack>

                                                    <MudGrid Spacing="1">
                                                        <MudItem xs="6" md="3">
                                                            <MudPaper Outlined="true" Class="pa-2 planning-board-metric">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Chosen start</MudText>
                                                                <MudText Typo="Typo.body2">Sprint @(epic.PlannedStartSprintIndex + 1)</MudText>
                                                            </MudPaper>
                                                        </MudItem>
                                                        <MudItem xs="6" md="3">
                                                            <MudPaper Outlined="true" Class="pa-2 planning-board-metric">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Scheduled start</MudText>
                                                                <MudText Typo="Typo.body2">Sprint @(epic.ComputedStartSprintIndex + 1)</MudText>
                                                            </MudPaper>
                                                        </MudItem>
                                                        <MudItem xs="6" md="3">
                                                            <MudPaper Outlined="true" Class="pa-2 planning-board-metric">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Planned finish</MudText>
                                                                <MudText Typo="Typo.body2">Sprint @epic.EndSprintIndexExclusive</MudText>
                                                            </MudPaper>
                                                        </MudItem>
                                                        <MudItem xs="6" md="3">
                                                            <MudPaper Outlined="true" Class="pa-2 planning-board-metric">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Work lane</MudText>
                                                                <MudText Typo="Typo.body2">@(epic.TrackIndex == 0 ? "Main plan" : $"Parallel {epic.TrackIndex}")</MudText>
                                                            </MudPaper>
                                                        </MudItem>
                                                    </MudGrid>

                                                    @if (epic.Issues.Count > 0)
                                                    {
                                                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                                                            <MudList T="string" Dense="true" Class="planning-board-issue-list">
                                                                @foreach (var issue in epic.Issues)
                                                                {
                                                                    <MudListItem T="string">
                                                                        <MudText Typo="Typo.body2">@ProductPlanningBoardUxText.TranslateVisibleText(issue.Message)</MudText>
                                                                    </MudListItem>
                                                                }
                                                            </MudList>
                                                        </MudAlert>
                                                    }

                                                    @if ((epic.Diagnostics?.Count ?? 0) > 0)
                                                    {
                                                        <MudAlert Severity="@GetDiagnosticSeverity(epic.Diagnostics!)" Variant="Variant.Outlined" Dense="true">
                                                            <MudList T="string" Dense="true" Class="planning-board-issue-list">
                                                                @foreach (var diagnostic in epic.Diagnostics!)
                                                                {
                                                                    <MudListItem T="string">
                                                                        <MudText Typo="Typo.body2">@ProductPlanningBoardUxText.TranslateVisibleText(diagnostic.Message)</MudText>
                                                                    </MudListItem>
                                                                }
                                                            </MudList>
                                                        </MudAlert>
                                                    }

                                                    @if (_epicActionMessages.TryGetValue(epic.EpicId, out var actionMessage) && !string.IsNullOrWhiteSpace(actionMessage))
                                                    {
                                                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                                            @actionMessage
                                                        </MudAlert>
                                                    }

                                                    <MudDivider />

                                                    <MudText Typo="Typo.subtitle2">Planning actions</MudText>
                                                    <MudGrid Spacing="1">
                                                        <MudItem xs="12" md="6">
                                                            <MudStack Spacing="1" Class="planning-board-action-group">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Move only this Epic</MudText>
                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                                                                    <MudNumericField T="int"
                                                                                     Label="Sprint change"
                                                                                     Variant="Variant.Outlined"
                                                                                     Margin="Margin.Dense"
                                                                                     Value="@GetActionState(epic.EpicId).MoveDelta"
                                                                                     ValueChanged="@(value => SetMoveDelta(epic.EpicId, value))"
                                                                                     Class="planning-board-number-field" />
                                                                    <CompactButton ButtonRole="ButtonRole.Action"
                                                                                   Icon="@Icons.Material.Filled.SwapHoriz"
                                                                                   Disabled="@_isBusy"
                                                                                   OnClick="@(_ => ExecuteMoveAsync(epic.EpicId))">
                                                                        Move Epic
                                                                    </CompactButton>
                                                                </MudStack>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">This will only move this Epic. Use a positive or negative sprint change; a change of zero has no effect and is not allowed.</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="12" md="6">
                                                            <MudStack Spacing="1" Class="planning-board-action-group">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Move this and shift following work</MudText>
                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                                                                    <MudNumericField T="int"
                                                                                     Label="Sprint change"
                                                                                     Variant="Variant.Outlined"
                                                                                     Margin="Margin.Dense"
                                                                                     Value="@GetActionState(epic.EpicId).SpacingDelta"
                                                                                     ValueChanged="@(value => SetSpacingDelta(epic.EpicId, value))"
                                                                                     Class="planning-board-number-field" />
                                                                    <CompactButton ButtonRole="ButtonRole.Action"
                                                                                   Icon="@Icons.Material.Filled.SpaceBar"
                                                                                   Disabled="@_isBusy"
                                                                                   OnClick="@(_ => ExecuteAdjustSpacingAsync(epic.EpicId))">
                                                                        Move + shift
                                                                    </CompactButton>
                                                                </MudStack>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">This will move this Epic and the work after it.</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="12" md="6">
                                                            <MudStack Spacing="1" Class="planning-board-action-group">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Move everything after this</MudText>
                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                                                                    <MudNumericField T="int"
                                                                                     Label="Sprint change"
                                                                                     Variant="Variant.Outlined"
                                                                                     Margin="Margin.Dense"
                                                                                     Value="@GetActionState(epic.EpicId).ShiftDelta"
                                                                                     ValueChanged="@(value => SetShiftDelta(epic.EpicId, value))"
                                                                                     Class="planning-board-number-field" />
                                                                    <CompactButton ButtonRole="ButtonRole.Action"
                                                                                   Icon="@Icons.Material.Filled.TrendingFlat"
                                                                                   Disabled="@_isBusy"
                                                                                   OnClick="@(_ => ExecuteShiftPlanAsync(epic.EpicId))">
                                                                        Shift following work
                                                                    </CompactButton>
                                                                </MudStack>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">This will move only the Epics after this one.</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="12" md="6">
                                                            <MudStack Spacing="1" Class="planning-board-action-group">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Change priority order</MudText>
                                                                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.End">
                                                                    <MudNumericField T="int"
                                                                                     Label="New priority"
                                                                                     Variant="Variant.Outlined"
                                                                                     Margin="Margin.Dense"
                                                                                     Min="1"
                                                                                     Value="@GetActionState(epic.EpicId).ReorderTarget"
                                                                                     ValueChanged="@(value => SetReorderTarget(epic.EpicId, value))"
                                                                                     Class="planning-board-number-field" />
                                                                    <CompactButton ButtonRole="ButtonRole.Action"
                                                                                   Icon="@Icons.Material.Filled.FormatListNumbered"
                                                                                   Disabled="@_isBusy"
                                                                                   OnClick="@(_ => ExecuteReorderAsync(epic.EpicId))">
                                                                        Update order
                                                                    </CompactButton>
                                                                </MudStack>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">This changes roadmap priority without asking you to manage tracks.</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                        <MudItem xs="12" md="6">
                                                            <MudStack Spacing="1" Class="planning-board-action-group">
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Parallel work</MudText>
                                                                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                                                    <CompactButton ButtonRole="ButtonRole.Action"
                                                                                   Icon="@Icons.Material.Filled.CallSplit"
                                                                                   Disabled="@(_isBusy || epic.TrackIndex > 0)"
                                                                                   OnClick="@(_ => ExecuteRunInParallelAsync(epic.EpicId))">
                                                                        Create parallel work
                                                                    </CompactButton>
                                                                    <CompactButton ButtonRole="ButtonRole.Utility"
                                                                                   Icon="@Icons.Material.Filled.CallMerge"
                                                                                   Disabled="@(_isBusy || epic.TrackIndex == 0)"
                                                                                   OnClick="@(_ => ExecuteReturnToMainAsync(epic.EpicId))">
                                                                        Return to main plan
                                                                    </CompactButton>
                                                                </MudStack>
                                                                <MudText Typo="Typo.caption" Color="Color.Secondary">This will create or remove parallel work. Track numbers are always derived automatically.</MudText>
                                                            </MudStack>
                                                        </MudItem>
                                                        @if (epic.CanReconcileProjection)
                                                        {
                                                            <MudItem xs="12" md="6">
                                                                <MudStack Spacing="1" Class="planning-board-action-group">
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Update TFS reported dates</MudText>
                                                                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                                                        <CompactButton ButtonRole="ButtonRole.Utility"
                                                                                       Icon="@Icons.Material.Filled.SyncProblem"
                                                                                       Disabled="@_isBusy"
                                                                                       OnClick="@(_ => ExecuteReconcileProjectionAsync(epic.EpicId))">
                                                                            Update TFS dates
                                                                        </CompactButton>
                                                                    </MudStack>
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">This refreshes the dates reported to TFS from the plan shown here without changing the plan itself.</MudText>
                                                                </MudStack>
                                                            </MudItem>
                                                        }
                                                    </MudGrid>
                                                </MudStack>
                                            </MudCardContent>
                                        </MudCard>
                                    }
                                </div>
                            }
                        </MudStack>
                    </MudPaper>
                }
            </ChildContent>
        </CanonicalDataStateView>
    </MudStack>
</MudContainer>

@code {
    [Parameter]
    public string? RouteProjectAlias { get; set; }

    private readonly record struct BoardFeedback(string Message, Severity Severity);

    private sealed class EpicActionState
    {
        public int MoveDelta { get; set; } = 1;
        public int SpacingDelta { get; set; } = 1;
        public int ShiftDelta { get; set; } = 1;
        public int ReorderTarget { get; set; } = 1;
    }

    private List<BreadcrumbItem> _breadcrumbs = new();
    private List<ProjectDto> _projects = new();
    private List<ProductDto> _allProducts = new();
    private List<ProductDto> _products = new();
    private CacheBackedClientResult<ProjectPlanningSummaryDto>? _projectPlanningSummaryState;
    private DataStateViewModel<ProductPlanningBoardDto> _boardState = DataStateViewModel<ProductPlanningBoardDto>.NotRequested();
    private ProductPlanningBoardRenderModel? _renderModel;
    private string? _selectedProjectRouteKey;
    private int? _activeProfileId;
    private bool _isBusy;
    private string? _contextError;
    private IDisposable? _filterSubscription;
    private BoardFeedback? _boardFeedback;
    private readonly Dictionary<int, EpicActionState> _epicActionState = new();
    private readonly Dictionary<int, string> _epicActionMessages = new();

    private int? _selectedProductId => GlobalProductSelectionHelper.ResolveSingleProductId(GlobalFilterStore.GetState(), _products);
    private string? _boardFeedbackMessage => _boardFeedback?.Message;
    private Severity _boardFeedbackSeverity => _boardFeedback?.Severity ?? Severity.Info;

    private DataStateViewModel<ProjectPlanningSummaryDto> ProjectPlanningSummaryState
        => string.IsNullOrWhiteSpace(_selectedProjectRouteKey) || _projectPlanningSummaryState is null
            ? DataStateViewModel<ProjectPlanningSummaryDto>.NotRequested()
            : _projectPlanningSummaryState.ToViewModel("Project planning summary could not be loaded right now.");

    private DataStateViewModel<ProductPlanningBoardRenderModel> BoardRenderState
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(_contextError))
            {
                return DataStateViewModel<ProductPlanningBoardRenderModel>.Invalid(_contextError);
            }

            if (!_selectedProductId.HasValue)
            {
                return DataStateViewModel<ProductPlanningBoardRenderModel>.NotRequested();
            }

            if (_boardState.Data is not null && _renderModel is not null && _boardState.UiState == UiDataState.Ready)
            {
                return DataStateViewModel<ProductPlanningBoardRenderModel>.Ready(_renderModel);
            }

            return _boardState.UiState switch
            {
                UiDataState.Loading => DataStateViewModel<ProductPlanningBoardRenderModel>.Loading(_boardState.Reason),
                UiDataState.EmptyButValid => DataStateViewModel<ProductPlanningBoardRenderModel>.Empty(_boardState.Reason ?? "The selected product has no active roadmap epics for the planning board."),
                UiDataState.Invalid => DataStateViewModel<ProductPlanningBoardRenderModel>.Invalid(_boardState.Reason),
                UiDataState.Failed => DataStateViewModel<ProductPlanningBoardRenderModel>.Failed(_boardState.Reason ?? "The planning board could not be loaded right now."),
                _ => DataStateViewModel<ProductPlanningBoardRenderModel>.NotRequested()
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Planning", WorkspaceRoutes.PlanningWorkspace, icon: Icons.Material.Filled.CalendarMonth),
            new("Plan Board", null, disabled: true, icon: Icons.Material.Filled.ViewColumn)
        };

        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }

            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            _activeProfileId = activeProfile.Id;

            _allProducts = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            _projects = await LoadAvailableProjectsAsync(_allProducts);
            await SyncStoreFromCurrentRouteAsync();

            var context = WorkspaceQueryContextHelper.Parse(NavigationManager.Uri);
            ResolveInitialProjectSelection(context);
            ApplyProjectFilter();
            RefreshContextError();
            await LoadProjectPlanningSummaryAsync();

            if (!string.IsNullOrWhiteSpace(_contextError))
            {
                ClearBoard();
            }
            else if (_selectedProductId.HasValue)
            {
                await LoadBoardAsync(_selectedProductId.Value, successFeedback: null);
            }
            else
            {
                ClearBoard();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error initializing the planning board page.");
            _boardState = DataStateViewModel<ProductPlanningBoardDto>.Failed("The planning page could not be initialized right now.");
            _boardFeedback = new BoardFeedback("The planning page could not be initialized right now.", Severity.Error);
        }
    }

    private async Task ReloadBoardAsync()
    {
        if (!_selectedProductId.HasValue || _isBusy)
        {
            return;
        }

        await LoadBoardAsync(_selectedProductId.Value, new BoardFeedback("Board reloaded from the saved plan.", Severity.Info));
    }

    private async Task ResetBoardAsync()
    {
        if (!_selectedProductId.HasValue || _isBusy)
        {
            return;
        }

        _isBusy = true;
        try
        {
            var result = await ProductPlanningBoardClientService.ResetAsync(_selectedProductId.Value);
            HandleBoardResult(result, "Undo all current board changes.", epicId: null, successFeedback: new BoardFeedback("All current board changes were undone.", Severity.Success));
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ExecuteMoveAsync(int epicId)
    {
        var state = GetActionState(epicId);
        if (!ValidateDelta(epicId, state.MoveDelta, "Move only this Epic requires a non-zero sprint change."))
        {
            return;
        }

        await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.MoveEpicBySprintsAsync(_selectedProductId!.Value, new ProductPlanningEpicDeltaRequest(epicId, state.MoveDelta)), "Move Epic");
    }

    private async Task ExecuteAdjustSpacingAsync(int epicId)
    {
        var state = GetActionState(epicId);
        if (!ValidateDelta(epicId, state.SpacingDelta, "Move this and shift following work requires a non-zero sprint change."))
        {
            return;
        }

        await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.AdjustSpacingBeforeAsync(_selectedProductId!.Value, new ProductPlanningEpicDeltaRequest(epicId, state.SpacingDelta)), "Move + shift");
    }

    private async Task ExecuteShiftPlanAsync(int epicId)
    {
        var state = GetActionState(epicId);
        if (!ValidateDelta(epicId, state.ShiftDelta, "Move everything after this requires a non-zero sprint change."))
        {
            return;
        }

        await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.ShiftPlanAsync(_selectedProductId!.Value, new ProductPlanningEpicDeltaRequest(epicId, state.ShiftDelta)), "Shift following work");
    }

    private async Task ExecuteReorderAsync(int epicId)
    {
        var state = GetActionState(epicId);
        if (state.ReorderTarget < 1)
        {
            _epicActionMessages[epicId] = "Change priority order requires a value of 1 or higher.";
            return;
        }

        await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.ReorderEpicAsync(_selectedProductId!.Value, new ReorderProductPlanningEpicRequest(epicId, state.ReorderTarget)), "Update order");
    }

    private async Task ExecuteRunInParallelAsync(int epicId)
        => await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.RunInParallelAsync(_selectedProductId!.Value, new ProductPlanningEpicRequest(epicId)), "Create parallel work");

    private async Task ExecuteReturnToMainAsync(int epicId)
        => await ExecuteEpicOperationAsync(epicId, () => ProductPlanningBoardClientService.ReturnToMainAsync(_selectedProductId!.Value, new ProductPlanningEpicRequest(epicId)), "Return to main plan");

    private async Task ExecuteReconcileProjectionAsync(int epicId)
        => await ExecuteEpicOperationAsync(
            epicId,
            () => ProductPlanningBoardClientService.ReconcileProjectionAsync(_selectedProductId!.Value, new ProductPlanningEpicRequest(epicId)),
            "Update TFS dates",
            new BoardFeedback("TFS dates were updated from the plan shown on this board.", Severity.Success));

    private async Task ExecuteEpicOperationAsync(
        int epicId,
        Func<Task<ProductPlanningBoardClientResult>> operation,
        string actionName,
        BoardFeedback? successFeedback = null)
    {
        if (!_selectedProductId.HasValue || _isBusy)
        {
            return;
        }

        _isBusy = true;
        try
        {
            var result = await operation();
            HandleBoardResult(
                result,
                $"{actionName} failed.",
                epicId,
                successFeedback ?? new BoardFeedback($"{actionName} applied. Review changed and affected highlights below.", Severity.Success));
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void HandleBoardResult(ProductPlanningBoardClientResult result, string fallbackError, int? epicId, BoardFeedback? successFeedback)
    {
        if (result.IsSuccess && result.Board is not null)
        {
            ApplyBoard(result.Board);
            _boardState = result.Board.EpicItems.Count == 0
                ? DataStateViewModel<ProductPlanningBoardDto>.Empty("The selected product has no active roadmap epics for the planning board.")
                : DataStateViewModel<ProductPlanningBoardDto>.Ready(result.Board);
            _boardFeedback = successFeedback;
            if (epicId.HasValue)
            {
                _epicActionMessages.Remove(epicId.Value);
            }

            return;
        }

        var message = string.IsNullOrWhiteSpace(result.ErrorMessage) ? fallbackError : result.ErrorMessage;
        _boardFeedback = new BoardFeedback(message!, result.IsNotFound ? Severity.Warning : Severity.Error);
        if (epicId.HasValue)
        {
            _epicActionMessages[epicId.Value] = message!;
        }

        _boardState = result.IsNotFound
            ? DataStateViewModel<ProductPlanningBoardDto>.Invalid(message)
            : DataStateViewModel<ProductPlanningBoardDto>.Failed(message);
    }

    private async Task LoadBoardAsync(int productId, BoardFeedback? successFeedback)
    {
        _boardState = DataStateViewModel<ProductPlanningBoardDto>.Loading();
        _isBusy = true;
        _boardFeedback = null;
        StateHasChanged();

        try
        {
            var result = await ProductPlanningBoardClientService.GetBoardAsync(productId);
            HandleBoardResult(result, "The planning board could not be loaded right now.", epicId: null, successFeedback);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ApplyBoard(ProductPlanningBoardDto board)
    {
        _renderModel = ProductPlanningBoardRenderModelFactory.Create(board);
        foreach (var epic in board.EpicItems)
        {
            if (!_epicActionState.TryGetValue(epic.EpicId, out var actionState))
            {
                actionState = new EpicActionState();
                _epicActionState[epic.EpicId] = actionState;
            }

            actionState.ReorderTarget = epic.RoadmapOrder;
        }

        var activeEpicIds = board.EpicItems.Select(static epic => epic.EpicId).ToHashSet();
        foreach (var staleEpicId in _epicActionState.Keys.Where(epicId => !activeEpicIds.Contains(epicId)).ToArray())
        {
            _epicActionState.Remove(staleEpicId);
        }

        foreach (var staleEpicId in _epicActionMessages.Keys.Where(epicId => !activeEpicIds.Contains(epicId)).ToArray())
        {
            _epicActionMessages.Remove(staleEpicId);
        }
    }

    private EpicActionState GetActionState(int epicId)
    {
        if (_epicActionState.TryGetValue(epicId, out var actionState))
        {
            return actionState;
        }

        actionState = new EpicActionState();
        _epicActionState[epicId] = actionState;
        return actionState;
    }

    private bool ValidateDelta(int epicId, int delta, string message)
    {
        if (delta != 0)
        {
            _epicActionMessages.Remove(epicId);
            return true;
        }

        _epicActionMessages[epicId] = message;
        return false;
    }

    private void SetMoveDelta(int epicId, int value)
    {
        GetActionState(epicId).MoveDelta = value;
        _epicActionMessages.Remove(epicId);
    }

    private void SetSpacingDelta(int epicId, int value)
    {
        GetActionState(epicId).SpacingDelta = value;
        _epicActionMessages.Remove(epicId);
    }

    private void SetShiftDelta(int epicId, int value)
    {
        GetActionState(epicId).ShiftDelta = value;
        _epicActionMessages.Remove(epicId);
    }

    private void SetReorderTarget(int epicId, int value)
    {
        GetActionState(epicId).ReorderTarget = value;
        _epicActionMessages.Remove(epicId);
    }

    private string GetTrackGridStyle(int maxSprintCount) => $"grid-template-columns: repeat({Math.Max(1, maxSprintCount)}, minmax(12rem, 1fr));";

    private static string GetEpicGridStyle(PlanningBoardEpicItemDto epic) => $"grid-column: {epic.ComputedStartSprintIndex + 1} / span {Math.Max(1, epic.DurationInSprints)};";

    private static string GetTrackPaperClass(ProductPlanningTrackRow track)
        => track.IsMainLane
            ? "pa-4 planning-board-track planning-board-track--main"
            : "pa-4 planning-board-track planning-board-track--parallel";

    private static string GetEpicCardClass(PlanningBoardEpicItemDto epic)
    {
        var classes = new List<string> { "planning-board-epic" };

        if (epic.IsChanged)
        {
            classes.Add("planning-board-epic--changed");
        }
        else if (epic.IsAffected)
        {
            classes.Add("planning-board-epic--affected");
        }

        if (epic.DriftStatus.HasValue && epic.DriftStatus.Value != PlanningBoardDriftStatus.NoDrift)
        {
            classes.Add("planning-board-epic--sync");
        }

        if (epic.IntentSource == PlanningBoardIntentSource.Recovered)
        {
            classes.Add("planning-board-epic--imported");
        }

        return string.Join(' ', classes);
    }

    private static string GetIntentSourceLabel(PlanningBoardEpicItemDto epic)
        => ProductPlanningBoardUxText.GetIntentSourceLabel(epic);

    private static Color GetBoardStatusColor(ProductPlanningBoardStatusKind statusKind)
        => statusKind switch
        {
            ProductPlanningBoardStatusKind.Warning => Color.Warning,
            ProductPlanningBoardStatusKind.Changed => Color.Primary,
            _ => Color.Success
        };

    private static string FormatIssueText(PlanningBoardIssueDto issue)
        => issue.EpicId.HasValue
            ? $"Epic {issue.EpicId.Value}: {ProductPlanningBoardUxText.TranslateVisibleText(issue.Message)}"
            : ProductPlanningBoardUxText.TranslateVisibleText(issue.Message);

    private static string FormatDiagnosticText(PlanningBoardDiagnosticDto diagnostic)
        => diagnostic.EpicId.HasValue
            ? $"Epic {diagnostic.EpicId.Value}: {ProductPlanningBoardUxText.TranslateVisibleText(diagnostic.Message)}"
            : ProductPlanningBoardUxText.TranslateVisibleText(diagnostic.Message);

    private static string FormatDriftStatus(PlanningBoardDriftStatus driftStatus)
        => ProductPlanningBoardUxText.GetDriftLabel(driftStatus);

    private static Severity GetDiagnosticSeverity(IReadOnlyList<PlanningBoardDiagnosticDto> diagnostics)
    {
        if (diagnostics.Any(static diagnostic => diagnostic.IsBlocking || string.Equals(diagnostic.Severity, "Error", StringComparison.OrdinalIgnoreCase)))
        {
            return Severity.Error;
        }

        return diagnostics.Any(static diagnostic => string.Equals(diagnostic.Severity, "Warning", StringComparison.OrdinalIgnoreCase))
            ? Severity.Warning
            : Severity.Info;
    }

    private async Task NavigateToPlanning()
        => NavigationManager.NavigateTo(
            await GlobalFilterRouteService.BuildPlanningPageUriAsync(
                "PlanningWorkspace",
                _selectedProjectRouteKey,
                _selectedProductId,
                WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri)));

    private async Task NavigateToOverview()
    {
        if (string.IsNullOrWhiteSpace(_selectedProjectRouteKey))
        {
            return;
        }

        NavigationManager.NavigateTo(
            await GlobalFilterRouteService.BuildPlanningPageUriAsync(
                "ProjectPlanningOverview",
                _selectedProjectRouteKey,
                _selectedProductId,
                WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri)));
    }

    private async Task<List<ProjectDto>> LoadAvailableProjectsAsync(IReadOnlyCollection<ProductDto> products)
    {
        var productIds = products.Select(product => product.Id).ToHashSet();
        var projects = await ProjectService.GetAllProjectsAsync();

        return projects
            .Where(project => project.ProductIds.Any(productIds.Contains))
            .OrderBy(project => project.Name)
            .ToList();
    }

    private void ResolveInitialProjectSelection(WorkspaceQueryContext context)
    {
        var requestedProjectKey = string.IsNullOrWhiteSpace(RouteProjectAlias)
            ? context.ProjectAlias
            : RouteProjectAlias;

        var selectedProject = ResolveProject(requestedProjectKey);
        if (selectedProject == null && context.ProductId.HasValue)
        {
            selectedProject = _projects.FirstOrDefault(project => project.ProductIds.Contains(context.ProductId.Value));
        }

        _selectedProjectRouteKey = selectedProject?.Alias;
    }

    private void ApplyProjectFilter()
    {
        var selectedProject = ResolveProject(_selectedProjectRouteKey);
        _products = selectedProject == null
            ? _allProducts
            : _allProducts.Where(product => selectedProject.ProductIds.Contains(product.Id)).ToList();
        RefreshContextError();
    }

    private async Task LoadProjectPlanningSummaryAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedProjectRouteKey))
        {
            _projectPlanningSummaryState = CacheBackedClientResult<ProjectPlanningSummaryDto>.Empty();
            return;
        }

        _projectPlanningSummaryState = await ProjectService.GetPlanningSummaryAsync(_selectedProjectRouteKey);
    }

    private async Task RetryBoardLoadAsync()
        => await (_selectedProductId.HasValue
            ? LoadBoardAsync(_selectedProductId.Value, successFeedback: null)
            : Task.CompletedTask);

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _activeProfileId);

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(HandleGlobalFilterChangedAsync);

    private async Task HandleGlobalFilterChangedAsync()
    {
        if (_activeProfileId is null || _allProducts.Count == 0)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var context = WorkspaceQueryContextHelper.Parse(NavigationManager.Uri);
        ResolveInitialProjectSelection(context);
        ApplyProjectFilter();
        await LoadProjectPlanningSummaryAsync();

        if (!string.IsNullOrWhiteSpace(_contextError))
        {
            ClearBoard();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (_selectedProductId.HasValue)
        {
            await LoadBoardAsync(_selectedProductId.Value, successFeedback: null);
        }
        else
        {
            ClearBoard();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void RefreshContextError()
    {
        var usage = GlobalFilterStore.CurrentUsage;
        if (usage?.Status == FilterResolutionStatus.Invalid && usage.StateIssues.Count > 0)
        {
            _contextError = string.Join(" ", usage.StateIssues);
            return;
        }

        var invalidProductIds = GlobalProductSelectionHelper.ResolveUnavailableSelectedProductIds(GlobalFilterStore.GetState(), _products);
        _contextError = invalidProductIds.Count > 0
            ? $"Selected global product '{string.Join(", ", invalidProductIds)}' is not available in the current plan board scope."
            : null;
    }

    private ProjectDto? ResolveProject(string? projectRouteKey)
    {
        if (string.IsNullOrWhiteSpace(projectRouteKey))
        {
            return null;
        }

        return _projects.FirstOrDefault(project =>
            string.Equals(project.Alias, projectRouteKey, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(project.Id, projectRouteKey, StringComparison.OrdinalIgnoreCase));
    }

    private void ClearBoard()
    {
        _boardState = DataStateViewModel<ProductPlanningBoardDto>.NotRequested();
        _renderModel = null;
        _boardFeedback = null;
        _epicActionState.Clear();
        _epicActionMessages.Clear();
    }

    private static bool HasPlanningGap(ProjectPlanningSummaryDto projectPlanningSummary)
        => projectPlanningSummary.TotalPBIs > 0 &&
           projectPlanningSummary.UnplannedPBIs / (double)projectPlanningSummary.TotalPBIs > 0.5d;

    private static string GetPlanningGapLabel(ProjectPlanningSummaryDto projectPlanningSummary)
    {
        if (projectPlanningSummary.TotalPBIs == 0)
        {
            return "Planning gap unavailable";
        }

        var ratio = projectPlanningSummary.UnplannedPBIs / (double)projectPlanningSummary.TotalPBIs * 100d;
        return HasPlanningGap(projectPlanningSummary)
            ? $"{ratio:F0}% of PBIs are unplanned"
            : $"{ratio:F0}% unplanned";
    }

    private static string GetProductImbalanceLabel(ProjectPlanningSummaryDto projectPlanningSummary)
    {
        if (projectPlanningSummary.TotalEffort <= 0 || projectPlanningSummary.Products.Count == 0)
        {
            return "N/A";
        }

        var leadingProduct = projectPlanningSummary.Products.MaxBy(static product => product.TotalEffort);
        if (leadingProduct == null)
        {
            return "N/A";
        }

        var share = leadingProduct.TotalEffort / (double)projectPlanningSummary.TotalEffort * 100d;
        return share > 60d
            ? $"{leadingProduct.ProductName} {share:F0}%"
            : "Balanced";
    }

    private static string FormatCapacity(double capacity) => capacity <= 0 ? "N/A" : $"{capacity:F1}";

    private static Color GetProjectRiskColor(bool isRisk) => isRisk ? Color.Warning : Color.Success;

    public void Dispose() => _filterSubscription?.Dispose();
}
