@page "/home"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Shared.Metrics
@implements IDisposable
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject CacheSyncService CacheSyncService
@inject WorkspaceSignalService WorkspaceSignalService
@inject HomeProductBarMetricsService HomeProductBarMetricsService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Home - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h4">
            Product Owner Dashboard
        </MudText>

        @if (_showNoProfileAlert)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4" Style="width: 100%;">
                <MudText Typo="Typo.h6" Style="color: inherit;">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2" />
                    No user selected — please select a user to continue
                </MudText>
                <MudText Typo="Typo.body2" Class="mt-1" Style="color: inherit;">
                    Use the profile selector in the top bar to select or add a user.
                </MudText>
            </MudAlert>
        }
        else if (!string.IsNullOrWhiteSpace(_profileLoadError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">
                @_profileLoadError
            </MudAlert>
        }

        <MudStack Spacing="2" Class="dashboard-workspaces">
            <MudPaper Elevation="1" Class="pa-3 dashboard-section dashboard-product-bar">
                <div class="dashboard-product-bar__chips" role="group" aria-label="Product selector">
                    @if (_showNoProfileAlert)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Select a Product Owner profile to load dashboard context.
                        </MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(_productsLoadError))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error">
                            @_productsLoadError
                        </MudText>
                    }
                    else if (_isProductsLoading)
                    {
                        @for (var index = 0; index < 4; index++)
                        {
                            <MudSkeleton Class="dashboard-chip-skeleton"
                                         SkeletonType="SkeletonType.Rectangle"
                                         Height="28px"
                                         Width="96px" />
                        }
                    }
                    else if (_products.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            No products configured for this Product Owner.
                        </MudText>
                    }
                    else
                    {
                        <MudButton Variant="@GetProductChipVariant(null)"
                                   Color="@GetProductChipColor(null)"
                                   OnClick="@(() => SelectProductAsync(null))"
                                   Size="Size.Small"
                                   Class="product-context-button">
                            All Products
                        </MudButton>

                        @foreach (var product in _products)
                        {
                            <MudButton Variant="@GetProductChipVariant(product.Id)"
                                       Color="@GetProductChipColor(product.Id)"
                                       OnClick="@(() => SelectProductAsync(product.Id))"
                                       Size="Size.Small"
                                       Class="product-context-button">
                                @product.Name
                            </MudButton>
                        }
                    }
                </div>

                <div class="dashboard-product-bar__metrics" aria-live="polite">
                    @if (_showNoProfileAlert)
                    {
                        <MudText Typo="Typo.body2" Class="dashboard-product-bar__metrics-text">
                            Choose a profile to load context metrics.
                        </MudText>
                    }
                    else if (_isProductMetricsLoading)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="240px" Height="24px" />
                    }
                    else if (!string.IsNullOrWhiteSpace(_productMetricsError))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Error" Class="dashboard-product-bar__metrics-text">
                            @_productMetricsError
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="dashboard-product-bar__metrics-text">
                            <span class="dashboard-product-bar__metric">
                                <span>@GetSprintMetricLabel()</span>
                                <span class="dashboard-product-bar__metric-value">@FormatSprintProgress()</span>
                            </span>
                            <span class="dashboard-product-bar__separator">&bull;</span>
                            <span class="dashboard-product-bar__metric">
                                <span class="dashboard-product-bar__metric-value">@(_productBarMetrics?.BugCount ?? 0)</span>
                                <span>@GetBugMetricLabel(_productBarMetrics?.BugCount ?? 0)</span>
                            </span>
                            <span class="dashboard-product-bar__separator">&bull;</span>
                            <span class="dashboard-product-bar__metric">
                                <span class="dashboard-product-bar__metric-value">@(_productBarMetrics?.ChangesTodayCount ?? 0)</span>
                                <span>@GetChangesTodayLabel(_productBarMetrics?.ChangesTodayCount ?? 0)</span>
                            </span>
                        </MudText>
                    }
                </div>
            </MudPaper>

            <div class="dashboard-sync-status dashboard-section" role="status" aria-live="polite">
                @if (_isSyncStatusLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="20px" />
                }
                else if (!string.IsNullOrWhiteSpace(_syncStatusError))
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@_syncStatusError</MudText>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetLastSyncLabel()</MudText>
                }

                <div class="dashboard-sync-status__actions">
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.Sync"
                                   OnClick="TriggerManualSyncAsync"
                                   Disabled="@(_profileId == null || _isSyncing || _isProfileLoading)">
                        @(_isSyncing ? "Syncing..." : "Sync")
                    </CompactButton>

                    @if (_isProfileLoading)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="140px" Height="20px" />
                    }
                    else
                    {
                        <MudLink Href="@WorkspaceRoutes.HomeChanges"
                                 Color="Color.Primary"
                                 Underline="Underline.Always"
                                 Typo="Typo.body2">
                            What's new since sync
                        </MudLink>
                    }
                </div>
            </div>

            <MudText Typo="Typo.overline" Color="Color.Secondary">Workspaces</MudText>
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <NavigationTileCard Title="Health"
                                        Subtitle="@GetWorkspaceTileSubtitle(_healthSignalState)"
                                        Icon="@Icons.Material.Filled.HealthAndSafety"
                                        IconColor="Color.Success"
                                        AriaLabel="@(GetWorkspaceAriaLabel("Health", GetWorkspaceTileAriaText(_healthSignalState)))"
                                        OnClick="NavigateToHealth">
                        @RenderWorkspaceTileStatus(_healthSignalState)
                    </NavigationTileCard>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <NavigationTileCard Title="Delivery"
                                        Subtitle="@GetWorkspaceTileSubtitle(_deliverySignalState)"
                                        Icon="@Icons.Material.Filled.CheckCircle"
                                        IconColor="Color.Secondary"
                                        AriaLabel="@(GetWorkspaceAriaLabel("Delivery", GetWorkspaceTileAriaText(_deliverySignalState)))"
                                        OnClick="NavigateToDelivery">
                        @RenderWorkspaceTileStatus(_deliverySignalState)
                    </NavigationTileCard>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <NavigationTileCard Title="Trends"
                                        Subtitle="@GetWorkspaceTileSubtitle(_trendsSignalState)"
                                        Icon="@Icons.Material.Filled.Timeline"
                                        IconColor="Color.Info"
                                        AriaLabel="@(GetWorkspaceAriaLabel("Trends", GetWorkspaceTileAriaText(_trendsSignalState)))"
                                        OnClick="NavigateToTrends">
                        @RenderWorkspaceTileStatus(_trendsSignalState)
                    </NavigationTileCard>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <NavigationTileCard Title="Planning"
                                        Subtitle="@GetWorkspaceTileSubtitle(_planningSignalState)"
                                        Icon="@Icons.Material.Filled.CalendarMonth"
                                        IconColor="Color.Warning"
                                        AriaLabel="@(GetWorkspaceAriaLabel("Planning", GetWorkspaceTileAriaText(_planningSignalState)))"
                                        OnClick="NavigateToPlanning">
                        @RenderWorkspaceTileStatus(_planningSignalState)
                    </NavigationTileCard>
                </MudItem>
            </MudGrid>
        </MudStack>

        <MudPaper Elevation="1" Class="pa-2 dashboard-section">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Quick Actions</MudText>

                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <CompactButton ButtonRole="ButtonRole.Action"
                                   Icon="@Icons.Material.Filled.FactCheck"
                                   OnClick="NavigateToValidationTriage"
                                   Disabled="@(_profileId == null)"
                                   Class="dashboard-quick-action">
                        Validation Triage
                    </CompactButton>
                    <CompactButton ButtonRole="ButtonRole.Action"
                                   Icon="@Icons.Material.Filled.BugReport"
                                   OnClick='() => NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage)'
                                   Disabled="@(_profileId == null)"
                                   Class="dashboard-quick-action">
                        Bug Triage
                    </CompactButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private const string ProductMetricsUnavailableMessage = "Context metrics unavailable.";
    private const string SyncStatusUnavailableMessage = "Last sync unavailable.";
    private const string ProductsUnavailableMessage = "Product context unavailable.";
    private const string WorkspaceSignalUnavailableMessage = "Signal unavailable.";
    private const int SyncStatusCheckDelayMs = 3000;

    private readonly WorkspaceTileState _healthSignalState = new(WorkspaceSignalSet.Neutral.Health);
    private readonly WorkspaceTileState _deliverySignalState = new(WorkspaceSignalSet.Neutral.Delivery);
    private readonly WorkspaceTileState _trendsSignalState = new(WorkspaceSignalSet.Neutral.Trends);
    private readonly WorkspaceTileState _planningSignalState = new(WorkspaceSignalSet.Neutral.Planning);

    private CancellationTokenSource _lifetimeCts = new();
    private CancellationTokenSource? _contextLoadCts;
    private bool _isProfileLoading = true;
    private bool _isProductsLoading = true;
    private bool _isProductMetricsLoading = true;
    private bool _isSyncStatusLoading = true;
    private bool _isSyncing;
    private bool _showNoProfileAlert;
    private string? _profileLoadError;
    private string? _productsLoadError;
    private string? _productMetricsError;
    private string? _syncStatusError;
    private int? _profileId;
    private int? _selectedProductId;
    private DateTimeOffset? _lastSyncTime;
    private List<ProductDto> _products = new();
    private HomeProductBarMetricsDto? _productBarMetrics;
    private CanonicalFilterMetadata? _productBarFilterMetadata;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadHomeAsync();
        }
    }

    public void Dispose()
    {
        _contextLoadCts?.Cancel();
        _contextLoadCts?.Dispose();
        _lifetimeCts.Cancel();
        _lifetimeCts.Dispose();
    }

    private async Task LoadHomeAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync(_lifetimeCts.Token);
            _isProfileLoading = false;

            if (activeProfile == null)
            {
                ShowNoProfileState();
                await InvokeAsync(StateHasChanged);
                return;
            }

            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            _showNoProfileAlert = false;
            _profileLoadError = null;

            await InvokeAsync(StateHasChanged);

            var syncTask = LoadSyncStatusAsync(_lifetimeCts.Token);
            await LoadProductsAsync(_lifetimeCts.Token);
            await RefreshContextDataAsync();
            await syncTask;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _isProfileLoading = false;
            _profileLoadError = "Unable to load the Home dashboard. Please refresh the page.";
            _showNoProfileAlert = false;
            SetStaticUnavailableState();
            await InvokeAsync(StateHasChanged);
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
    }

    private void ShowNoProfileState()
    {
        _showNoProfileAlert = true;
        _profileLoadError = null;
        _products = [];
        _productsLoadError = null;
        _isProductsLoading = false;
        _isProductMetricsLoading = false;
        _productMetricsError = null;
        _productBarMetrics = null;
        _isSyncStatusLoading = false;
        _syncStatusError = null;
        _lastSyncTime = null;
        SetWorkspaceSignalsTo(WorkspaceSignalSet.Neutral);
    }

    private void SetStaticUnavailableState()
    {
        _isProductsLoading = false;
        _productsLoadError = ProductsUnavailableMessage;
        _isProductMetricsLoading = false;
        _productMetricsError = ProductMetricsUnavailableMessage;
        _isSyncStatusLoading = false;
        _syncStatusError = SyncStatusUnavailableMessage;
        SetWorkspaceErrors();
    }

    private async Task LoadProductsAsync(CancellationToken cancellationToken)
    {
        _isProductsLoading = true;
        _productsLoadError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (_profileId is null)
            {
                _products = [];
                return;
            }

            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value, cancellationToken)).ToList();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception)
        {
            _products = [];
            _productsLoadError = ProductsUnavailableMessage;
            SetWorkspaceErrors();
        }
        finally
        {
            _isProductsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadSyncStatusAsync(CancellationToken cancellationToken)
    {
        _isSyncStatusLoading = true;
        _syncStatusError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (_profileId is null)
            {
                _lastSyncTime = null;
                return;
            }

            var cacheState = await CacheSyncService.GetCacheStatusAsync(_profileId.Value, cancellationToken);
            if (cacheState == null)
            {
                _lastSyncTime = null;
                _syncStatusError = SyncStatusUnavailableMessage;
                return;
            }

            _lastSyncTime = cacheState.LastSuccessfulSync;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception)
        {
            _lastSyncTime = null;
            _syncStatusError = SyncStatusUnavailableMessage;
        }
        finally
        {
            _isSyncStatusLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshContextDataAsync()
    {
        if (_profileId is null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(_productsLoadError))
        {
            _isProductMetricsLoading = true;
            _productMetricsError = null;
            _productBarMetrics = null;
            SetWorkspaceErrors();
            await InvokeAsync(StateHasChanged);

            await LoadProductBarMetricsAsync(_lifetimeCts.Token);
            return;
        }

        _contextLoadCts?.Cancel();
        _contextLoadCts?.Dispose();
        _contextLoadCts = CancellationTokenSource.CreateLinkedTokenSource(_lifetimeCts.Token);

        var contextToken = _contextLoadCts.Token;
        var metricsTask = LoadProductBarMetricsAsync(contextToken);
        var workspaceSignalsTask = LoadWorkspaceSignalsAsync(contextToken);

        try
        {
            await Task.WhenAll(metricsTask, workspaceSignalsTask);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadProductBarMetricsAsync(CancellationToken cancellationToken)
    {
        _isProductMetricsLoading = true;
        _productMetricsError = null;
        _productBarMetrics = null;
        _productBarFilterMetadata = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (_profileId is null)
            {
                return;
            }

            var metricsResponse = await HomeProductBarMetricsService.GetAsync(
                _profileId.Value,
                _selectedProductId,
                cancellationToken);

            cancellationToken.ThrowIfCancellationRequested();

            if (metricsResponse == null)
            {
                _productMetricsError = ProductMetricsUnavailableMessage;
                return;
            }

            _productBarFilterMetadata = metricsResponse.FilterMetadata;
            _productBarMetrics = metricsResponse.Data;
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception)
        {
            _productBarFilterMetadata = null;
            _productMetricsError = ProductMetricsUnavailableMessage;
        }
        finally
        {
            _isProductMetricsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadWorkspaceSignalsAsync(CancellationToken cancellationToken)
    {
        if (_profileId is null)
        {
            SetWorkspaceSignalsTo(WorkspaceSignalSet.Neutral);
            await InvokeAsync(StateHasChanged);
            return;
        }

        StartWorkspaceSignalLoading();
        await InvokeAsync(StateHasChanged);

        var loadTasks = new[]
        {
            LoadWorkspaceSignalAsync(
                _healthSignalState,
                token => WorkspaceSignalService.GetHealthSignalAsync(_products, _selectedProductId, token),
                cancellationToken),
            LoadWorkspaceSignalAsync(
                _deliverySignalState,
                token => WorkspaceSignalService.GetDeliverySignalAsync(_profileId.Value, _products, _selectedProductId, token),
                cancellationToken),
            LoadWorkspaceSignalAsync(
                _trendsSignalState,
                token => WorkspaceSignalService.GetTrendsSignalAsync(_profileId.Value, _products, _selectedProductId, token),
                cancellationToken),
            LoadWorkspaceSignalAsync(
                _planningSignalState,
                token => WorkspaceSignalService.GetPlanningSignalAsync(_profileId.Value, _products, _selectedProductId, token),
                cancellationToken)
        };

        try
        {
            await Task.WhenAll(loadTasks);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadWorkspaceSignalAsync(
        WorkspaceTileState state,
        Func<CancellationToken, Task<string>> loader,
        CancellationToken cancellationToken)
    {
        try
        {
            var signalText = await loader(cancellationToken);
            cancellationToken.ThrowIfCancellationRequested();
            state.SetLoaded(signalText);
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception)
        {
            state.SetError(WorkspaceSignalUnavailableMessage);
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartWorkspaceSignalLoading()
    {
        _healthSignalState.StartLoading();
        _deliverySignalState.StartLoading();
        _trendsSignalState.StartLoading();
        _planningSignalState.StartLoading();
    }

    private void SetWorkspaceSignalsTo(WorkspaceSignalSet signals)
    {
        _healthSignalState.SetLoaded(signals.Health);
        _deliverySignalState.SetLoaded(signals.Delivery);
        _trendsSignalState.SetLoaded(signals.Trends);
        _planningSignalState.SetLoaded(signals.Planning);
    }

    private void SetWorkspaceErrors()
    {
        _healthSignalState.SetError(WorkspaceSignalUnavailableMessage);
        _deliverySignalState.SetError(WorkspaceSignalUnavailableMessage);
        _trendsSignalState.SetError(WorkspaceSignalUnavailableMessage);
        _planningSignalState.SetError(WorkspaceSignalUnavailableMessage);
    }

    private string BuildContextQuery(string? additionalParams = null)
    {
        var parameters = new List<string>();

        if (_selectedProductId.HasValue)
        {
            parameters.Add($"productId={_selectedProductId.Value}");
        }

        if (!string.IsNullOrEmpty(additionalParams))
        {
            parameters.Add(additionalParams);
        }

        return parameters.Count > 0 ? $"?{string.Join("&", parameters)}" : string.Empty;
    }

    private async Task SelectProductAsync(int? productId)
    {
        if (_profileId is null)
        {
            return;
        }

        _selectedProductId = productId;
        await RefreshContextDataAsync();
    }

    private Color GetProductChipColor(int? productId)
    {
        return _selectedProductId == productId
            ? Color.Primary
            : Color.Default;
    }

    private Variant GetProductChipVariant(int? productId)
    {
        return _selectedProductId == productId
            ? Variant.Filled
            : Variant.Outlined;
    }

    private string GetLastSyncLabel()
    {
        return _lastSyncTime.HasValue
            ? $"Last sync: {_lastSyncTime.Value.ToLocalTime():g}"
            : "Last sync: --";
    }

    private string GetSprintMetricLabel()
    {
        return _selectedProductId.HasValue
            ? "Sprint progress"
            : "Team Sprint";
    }

    private string FormatSprintProgress()
    {
        return _productBarMetrics?.SprintProgressPercentage is int percentage
            ? $"{percentage}%"
            : "—";
    }

    private static string GetBugMetricLabel(int count)
    {
        return count == 1 ? "Bug" : "Bugs";
    }

    private static string GetChangesTodayLabel(int count)
    {
        return count == 1 ? "change today" : "changes today";
    }

    private static string GetWorkspaceAriaLabel(string title, string signalText)
    {
        return $"{title} workspace — {signalText}";
    }

    private static string GetWorkspaceTileSubtitle(WorkspaceTileState state)
    {
        if (state.IsLoading)
        {
            return "Loading signal…";
        }

        return state.HasError ? state.ErrorMessage! : state.SignalText;
    }

    private static string GetWorkspaceTileAriaText(WorkspaceTileState state)
    {
        return state.IsLoading ? "Loading signal" : GetWorkspaceTileSubtitle(state);
    }

    private RenderFragment RenderWorkspaceTileStatus(WorkspaceTileState state) => builder =>
    {
        if (state.IsLoading)
        {
            builder.OpenComponent<MudProgressLinear>(0);
            builder.AddAttribute(1, nameof(MudProgressLinear.Color), Color.Primary);
            builder.AddAttribute(2, nameof(MudProgressLinear.Indeterminate), true);
            builder.AddAttribute(3, nameof(MudProgressLinear.Class), "home-workspace-tile__progress");
            builder.CloseComponent();
            return;
        }

        if (!state.HasError)
        {
            return;
        }

        builder.OpenComponent<MudText>(10);
        builder.AddAttribute(11, nameof(MudText.Typo), Typo.caption);
        builder.AddAttribute(12, nameof(MudText.Color), Color.Error);
        builder.AddAttribute(13, nameof(MudText.Class), "home-workspace-tile__error");
        builder.AddContent(14, state.ErrorMessage);
        builder.CloseComponent();
    };

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.DeliveryWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToValidationTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private async Task TriggerManualSyncAsync()
    {
        if (_profileId == null || _isSyncing)
        {
            return;
        }

        try
        {
            _isSyncing = true;
            await InvokeAsync(StateHasChanged);

            var result = await CacheSyncService.TriggerSyncAsync(_profileId.Value, _lifetimeCts.Token);

            if (result.Success)
            {
                Snackbar.Add("Cache sync started. Your data will be refreshed shortly.", Severity.Info);

                await Task.Delay(SyncStatusCheckDelayMs, _lifetimeCts.Token);

                var cacheState = await CacheSyncService.GetCacheStatusAsync(_profileId.Value, _lifetimeCts.Token);
                if (cacheState != null &&
                    (cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.Success ||
                     cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings ||
                     cacheState.LastSuccessfulSync.HasValue))
                {
                    _lastSyncTime = cacheState.LastSuccessfulSync;
                    _syncStatusError = null;
                    var severity = cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings
                        ? Severity.Warning
                        : Severity.Success;
                    var message = cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings
                        ? cacheState.LastErrorMessage ?? "Cache sync completed with warnings."
                        : "Cache sync completed successfully!";
                    Snackbar.Add(message, severity);
                }
                else if (cacheState != null && cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.InProgress)
                {
                    Snackbar.Add("Sync is still in progress. Data will be updated when complete.", Severity.Info);
                }
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to start cache sync.", Severity.Warning);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error triggering sync: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSyncing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed class WorkspaceTileState(string defaultSignalText)
    {
        public string DefaultSignalText { get; } = defaultSignalText;

        public string SignalText { get; private set; } = defaultSignalText;

        public bool IsLoading { get; private set; } = true;

        public string? ErrorMessage { get; private set; }

        public bool HasError => !string.IsNullOrWhiteSpace(ErrorMessage);

        public void StartLoading()
        {
            SignalText = DefaultSignalText;
            ErrorMessage = null;
            IsLoading = true;
        }

        public void SetLoaded(string signalText)
        {
            SignalText = string.IsNullOrWhiteSpace(signalText) ? DefaultSignalText : signalText;
            ErrorMessage = null;
            IsLoading = false;
        }

        public void SetError(string errorMessage)
        {
            SignalText = DefaultSignalText;
            ErrorMessage = errorMessage;
            IsLoading = false;
        }
    }
}
