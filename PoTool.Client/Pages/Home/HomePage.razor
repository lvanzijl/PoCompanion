@page "/home"
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject WorkItemService WorkItemService
@inject CacheSyncService CacheSyncService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Home - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4">
    <MudStack Spacing="3">
        <MudText Typo="Typo.h4">
            Product Owner Dashboard
        </MudText>

        @if (_showNoProfileAlert)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4" Style="width: 100%;">
                <MudText Typo="Typo.h6" Style="color: inherit;">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2" />
                    No user selected — please select a user to continue
                </MudText>
                <MudText Typo="Typo.body2" Class="mt-1" Style="color: inherit;">
                    Use the profile selector in the top bar to select or add a user.
                </MudText>
            </MudAlert>
        }

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        }
        else if (!_showNoProfileAlert)
        {
            <MudPaper Elevation="1" Class="pa-3 dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Products</MudText>

                    @if (_products.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            No products configured for this Product Owner.
                        </MudText>
                    }
                    else
                    {
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudButton Variant="@GetProductChipVariant(null)"
                                       Color="@GetProductChipColor(null)"
                                       OnClick="@(() => SelectProduct(null))"
                                       Size="Size.Small"
                                       Class="product-context-button">
                                All Products
                            </MudButton>

                            @foreach (var product in _products)
                            {
                                <MudButton Variant="@GetProductChipVariant(product.Id)"
                                           Color="@GetProductChipColor(product.Id)"
                                           OnClick="@(() => SelectProduct(product.Id))"
                                           Size="Size.Small"
                                           Class="product-context-button">
                                    @product.Name
                                </MudButton>
                            }
                        </MudStack>
                    }

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Active: @GetActiveProductLabel()
                    </MudText>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-3 dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Workspaces</MudText>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <DashboardWorkspaceCard Title="Health"
                                                    Description="Backlog maturity and refinement readiness"
                                                    Icon="@Icons.Material.Filled.HealthAndSafety"
                                                    IconColor="Color.Success"
                                                    OnClick="NavigateToHealth" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <DashboardWorkspaceCard Title="Delivery"
                                                    Description="Delivered work per sprint or period"
                                                    Icon="@Icons.Material.Filled.CheckCircle"
                                                    IconColor="Color.Secondary"
                                                    OnClick="NavigateToDelivery" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <DashboardWorkspaceCard Title="Trends"
                                                    Description="Structural behaviour across recent sprints"
                                                    Icon="@Icons.Material.Filled.Timeline"
                                                    IconColor="Color.Info"
                                                    OnClick="NavigateToTrends" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <DashboardWorkspaceCard Title="Planning"
                                                    Description="Decision support for upcoming work"
                                                    Icon="@Icons.Material.Filled.CalendarMonth"
                                                    IconColor="Color.Warning"
                                                    OnClick="NavigateToPlanning" />
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-3 dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Quick Actions</MudText>

                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.FactCheck"
                                   OnClick="NavigateToValidationTriage"
                                   Size="Size.Small">
                            Validation Triage
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.BugReport"
                                   OnClick='() => NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage)'
                                   Size="Size.Small">
                            Bug Triage
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-3 dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">Quick Status</MudText>

                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Outlined"
                                   Color="@GetHealthStatusColor()"
                                   StartIcon="@Icons.Material.Filled.FactCheck"
                                   OnClick="NavigateToValidationTriage"
                                   Size="Size.Small">
                            @_workItemsWithIssues Issues
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="@GetBugStatusColor()"
                                   StartIcon="@Icons.Material.Filled.BugReport"
                                   OnClick='() => NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage)'
                                   Size="Size.Small">
                            @_activeBugCount Bugs
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Inventory2"
                                   OnClick="NavigateToWorkItemExplorer"
                                   Size="Size.Small">
                            @_totalWorkItems Work Items
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.History"
                                   OnClick="NavigateToHomeChanges"
                                   Size="Size.Small">
                            @GetLastSyncLabel()
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Sync"
                                   OnClick="TriggerManualSyncAsync"
                                   Disabled="@_isSyncing"
                                   Size="Size.Small">
                            @(_isSyncing ? "Syncing..." : "Sync")
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-3 dashboard-section">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Advanced Tools</MudText>

                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="NavigateToWorkItemExplorer"
                                   Size="Size.Small">
                            Work Item Explorer
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

<style>
    .dashboard-section {
        width: 100%;
    }

    .product-context-button {
        border-radius: 999px;
        min-width: 0;
        text-transform: none;
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private bool _showNoProfileAlert = false;
    private int? _profileId;
    
    // Health signal data
    private int _totalWorkItems = 0;
    private int _workItemsWithIssues = 0;
    private int _activeBugCount = 0;
    
    // Sync state
    private DateTimeOffset? _lastSyncTime;
    
    // Context propagation - product/team filter
    private int? _selectedProductId;
    private List<PoTool.Client.ApiClient.ProductDto> _products = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        try
        {
            // Get the active profile - mandatory for Home navigation
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                // No profile selected — stay on /home and show red prompt
                _showNoProfileAlert = true;
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Load products for context filter
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            // Load last sync time for "What's New Since Last Sync" display
            var cacheState = await CacheSyncService.GetCacheStatusAsync(_profileId.Value);
            _lastSyncTime = cacheState?.LastSuccessfulSync;
            
            // Load health signals
            await LoadHealthSignalsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    /// <summary>
    /// Builds query string with product context if selected.
    /// </summary>
    private string BuildContextQuery(string? additionalParams = null)
    {
        var parameters = new List<string>();
        
        if (_selectedProductId.HasValue)
        {
            parameters.Add($"productId={_selectedProductId.Value}");
        }
        
        if (!string.IsNullOrEmpty(additionalParams))
        {
            parameters.Add(additionalParams);
        }
        
        return parameters.Count > 0 ? "?" + string.Join("&", parameters) : "";
    }

    private void SelectProduct(int? productId)
    {
        _selectedProductId = productId;
    }

    private string GetActiveProductLabel()
    {
        return _selectedProductId.HasValue
            ? _products.FirstOrDefault(product => product.Id == _selectedProductId.Value)?.Name ?? "Product"
            : "All Products";
    }

    private Color GetProductChipColor(int? productId)
    {
        return _selectedProductId == productId
            ? Color.Primary
            : Color.Default;
    }

    private Variant GetProductChipVariant(int? productId)
    {
        return _selectedProductId == productId
            ? Variant.Filled
            : Variant.Outlined;
    }

    private string GetLastSyncLabel()
    {
        return _lastSyncTime.HasValue
            ? $"Last Sync: {_lastSyncTime.Value.ToLocalTime():HH:mm}"
            : "Last Sync: --";
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.DeliveryWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToWorkItemExplorer()
    {
        // Task-driven entry always uses all products/teams
        NavigationManager.NavigateTo($"{WorkspaceRoutes.WorkItems}?allProducts=true&allTeams=true");
    }

    private void NavigateToValidationTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void NavigateToHomeChanges()
    {
        NavigationManager.NavigateTo("/home/changes");
    }

    private async Task LoadHealthSignalsAsync()
    {
        try
        {
            // Load work items with validation data
            var workItemsWithValidation = await WorkItemService.GetAllWithValidationAsync();
            var workItemsList = workItemsWithValidation.ToList();
            
            _totalWorkItems = workItemsList.Count;
            
            // Count items with validation issues (unique work items)
            var itemsWithIssues = workItemsList.Where(wi => wi.ValidationIssues?.Count > 0).ToList();
            _workItemsWithIssues = itemsWithIssues.Count;
            
            // Count active bugs from the same dataset (avoid duplicate API call)
            _activeBugCount = workItemsList.Count(wi => 
                wi.Type?.Equals("Bug", StringComparison.OrdinalIgnoreCase) == true &&
                wi.State?.Equals("Closed", StringComparison.OrdinalIgnoreCase) != true &&
                wi.State?.Equals("Resolved", StringComparison.OrdinalIgnoreCase) != true);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading health signals: {ex.Message}", Severity.Warning);
            // Keep defaults (0s) if loading fails
        }
    }
    
    /// <summary>
    /// Gets the health level based on fixed thresholds.
    /// Decision #2: Health Signal Thresholds
    /// - 0 items = Healthy (Green)
    /// - 1-9 items = Low (Info/Blue)
    /// - 10-49 items = Warning (Yellow)
    /// - 50+ items = Error (Red)
    /// </summary>
    private int GetHealthLevel(int count) => count switch
    {
        0 => 0,       // Healthy
        < 10 => 1,    // Low
        < 50 => 2,    // Warning
        _ => 3        // Error
    };
    
    private Color GetHealthStatusColor()
    {
        return GetHealthLevel(_workItemsWithIssues) switch
        {
            0 => Color.Success,
            1 => Color.Info,
            2 => Color.Warning,
            _ => Color.Error
        };
    }
    
    private Color GetBugStatusColor()
    {
        return GetHealthLevel(_activeBugCount) switch
        {
            0 => Color.Success,
            1 => Color.Info,
            2 => Color.Warning,
            _ => Color.Error
        };
    }
    
    /// <summary>
    /// Triggers a manual cache sync for the current profile.
    /// </summary>
    private async Task TriggerManualSyncAsync()
    {
        if (_profileId == null || _isSyncing)
            return;
            
        const int syncCheckDelayMs = 3000; // Allow time for sync to start and potentially complete quickly
            
        try
        {
            _isSyncing = true;
            StateHasChanged();
            
            var result = await CacheSyncService.TriggerSyncAsync(_profileId.Value);
            
            if (result.Success)
            {
                Snackbar.Add("Cache sync started. Your data will be refreshed shortly.", Severity.Info);
                
                // Wait for sync to potentially complete, then check status
                await Task.Delay(syncCheckDelayMs);
                
                // Check sync status
                var cacheState = await CacheSyncService.GetCacheStatusAsync(_profileId.Value);
                if (cacheState != null && 
                    (cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.Success ||
                     cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings ||
                     cacheState.LastSuccessfulSync.HasValue))
                {
                    // Reload health signals after successful sync
                    await LoadHealthSignalsAsync();
                    _lastSyncTime = cacheState.LastSuccessfulSync;
                    var severity = cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings
                        ? Severity.Warning
                        : Severity.Success;
                    var message = cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.SuccessWithWarnings
                        ? cacheState.LastErrorMessage ?? "Cache sync completed with warnings."
                        : "Cache sync completed successfully!";
                    Snackbar.Add(message, severity);
                }
                else if (cacheState != null && cacheState.SyncStatus == PoTool.Shared.Settings.CacheSyncStatusDto.InProgress)
                {
                    Snackbar.Add("Sync is still in progress. Data will be updated when complete.", Severity.Info);
                }
            }
            else
            {
                Snackbar.Add(result.Message ?? "Failed to start cache sync.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error triggering sync: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSyncing = false;
            StateHasChanged();
        }
    }
}
