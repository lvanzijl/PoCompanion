@page "/home/pull-requests"
@using PoTool.Client.Components.Charts
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Shared.DataState
@using PoTool.Shared.PullRequests
@using System.Web
@inject IProfileService ProfileService
@inject PullRequestStateService PullRequestStateService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject GlobalFilterStore GlobalFilterStore
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Pull Request Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* ── Workspace Header ────────────────────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Pull Request Insights</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Context / Filters (collapsible) ───────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  Style="cursor:pointer;" @onclick="() => _filterExpanded = !_filterExpanded">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" />
                <MudText Typo="Typo.h6">Context</MudText>
                @if (!_filterExpanded && (_selectedTeamId.HasValue || _selectedSprintId.HasValue))
                {
                    @* Summary chips shown when collapsed *@
                    @if (_selectedTeamId.HasValue)
                    {
                        var teamName = _teams.FirstOrDefault(t => t.Id == _selectedTeamId)?.Name;
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Group">@teamName</MudChip>
                    }
                    @if (_selectedSprintId.HasValue)
                    {
                        var sprintName = _sprints.FirstOrDefault(s => s.Id == _selectedSprintId)?.Name;
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.CalendarMonth">@sprintName</MudChip>
                    }
                }
            </MudStack>
            <MudIconButton Icon="@(_filterExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                           Size="Size.Small"
                           Color="Color.Default"
                           OnClick="() => _filterExpanded = !_filterExpanded" />
        </MudStack>

        <MudCollapse Expanded="_filterExpanded">
            <MudDivider Class="my-3" />
            <MudGrid Spacing="2">
            @* Team selector *@
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int?"
                           Value="_selectedTeamId"
                           Label="Team"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           ValueChanged="OnTeamChanged">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                    @foreach (var team in _teams)
                    {
                        <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @* Sprint quick-select (visible once a team is chosen) *@
            @if (_sprints.Count > 0)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="int?"
                               Value="_selectedSprintId"
                               Label="Sprint (optional)"
                               Variant="Variant.Outlined"
                               ValueChanged="OnSprintChanged">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select sprint…</MudSelectItem>
                        @foreach (var sprint in _sprints)
                        {
                            <MudSelectItem T="int?" Value="@sprint.Id">
                                @sprint.Name
                                @if (sprint.StartUtc.HasValue)
                                {
                                    <text> (@sprint.StartUtc.Value.ToString("MMM yyyy"))</text>
                                }
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }

            @* Repository filter *@
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           Value="@(_selectedRepository ?? string.Empty)"
                           Label="Repository (optional)"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           ValueChanged="OnRepositoryStringChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All Repositories</MudSelectItem>
                    @foreach (var repo in _availableRepositories)
                    {
                        <MudSelectItem T="string" Value="@repo">@repo</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        </MudCollapse>
    </MudPaper>

    <CanonicalFilterMetadataNotice Metadata="_filterNotice" />

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_dataState.State == DataStateDto.NotReady)
    {
        <DataStatePanel State="@_dataState.State" Title="Pull request insights are syncing" Message="@(_dataState.Reason ?? "Pull request insights will load once the cache is ready.")" ProductOwnerId="@_profileId" />
    }
    else if (_dataState.State == DataStateDto.Failed)
    {
        <DataStatePanel State="@_dataState.State" Title="Pull request insights failed to load" Message="@(_dataState.Reason ?? "Pull request insights could not be loaded right now.")" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
    }
    else if (_data != null)
    {
        @* ── Section 1: Global Summary chips ─────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Summary
                @if (!string.IsNullOrEmpty(_data.TeamName))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">@_data.TeamName</MudChip>
                }
            </MudText>

            <MudGrid Spacing="2">
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Primary">@_data.Summary.TotalPrs</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total PRs</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-success);">@(_data.Summary.MergeRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Merge Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-error);">@(_data.Summary.AbandonRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Abandon Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-warning);">@(_data.Summary.ChangesRequestedRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Rework Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Info">@FormatLifetime(_data.Summary.MedianLifetimeHours)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Median Lifetime</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Warning">@FormatLifetime(_data.Summary.P90LifetimeHours)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">P90 Lifetime</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Section 2: PR Scatter Chart ─────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4" id="pr-scatter-section">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.ScatterPlot" Class="mr-2" />
                        PR Scatter — Lifetime vs. Creation Date
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        X: PR creation date &nbsp;|&nbsp; Y: PR lifetime &nbsp;|&nbsp; Color: outcome &nbsp;|&nbsp; Shape: repository
                    </MudText>
                </MudStack>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    @if (!string.IsNullOrEmpty(_filteredAuthor))
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                                 Icon="@Icons.Material.Filled.Person"
                                 OnClose="ClearAuthorFilter"
                                 CloseIcon="@Icons.Material.Filled.Close">
                            @_filteredAuthor
                        </MudChip>
                    }
                    @if (_highlightedPrId.HasValue)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => _highlightedPrId = null">
                            Clear highlight
                        </MudButton>
                    }
                </MudStack>
            </MudStack>

            <PullRequestScatterSvg Data="@_data.ScatterPoints"
                                   Height="380"
                                   HighlightedPrId="@_highlightedPrId"
                                   FilteredAuthor="@_filteredAuthor"
                                   ShowMedianLine="true"
                                   ShowP90Line="true"
                                   MedianLifetimeHours="@_data.Summary.MedianLifetimeHours"
                                   P90LifetimeHours="@_data.Summary.P90LifetimeHours"
                                   OnPointClick="OnScatterPointClick" />
        </MudPaper>

        @* ── Section 3: Top 3 Problematic PRs ────────────────────────── *@
        @if (_data.Top3Problematic.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Class="mr-2" />
                    Top 3 Friction PRs
                    <MudTooltip Text="Ranked by composite score: lifetime × review cycles × files changed × comments">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Class="ml-1" />
                    </MudTooltip>
                </MudText>

                <MudGrid Spacing="2">
                    @foreach (var pr in _data.Top3Problematic)
                    {
                        <MudItem xs="12" md="4">
                            <MudCard Elevation="1"
                                     Style="@GetCardStyle(pr.Id)"
                                     @onclick="() => ToggleHighlight(pr.Id)">
                                <MudCardContent Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="word-break: break-word;">@pr.Title</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(pr.Status)" Variant="Variant.Text">@pr.Status</MudChip>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@pr.Repository</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                            @pr.Author
                                        </MudText>
                                        <MudDivider Class="my-1" />
                                        <MudGrid Spacing="1">
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    <strong>⏱ @FormatLifetime(pr.LifetimeHours)</strong>
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    <strong>🔄 @pr.ReviewCycles cycles</strong>
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    📁 @pr.FilesChanged files
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    💬 @pr.CommentCount comments
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                        @if (!string.IsNullOrEmpty(pr.Url))
                                        {
                                            <MudLink Href="@pr.Url" Target="_blank" Typo="Typo.caption"
                                                     Color="Color.Primary" Class="mt-1">
                                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Size="Size.Small" Class="mr-1" />Open in Azure DevOps
                                            </MudLink>
                                        }
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
                @if (_highlightedPrId.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" />
                        PR highlighted in scatter chart. Click again to clear.
                    </MudText>
                }
            </MudPaper>
        }

        @* ── Section 4: Longest PR Table ─────────────────────────────── *@
        @if (_data.LongestPrs.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.TableChart" Color="Color.Warning" />
                            <MudText Typo="Typo.h6">Longest Open PRs (top 20)</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_data.LongestPrs.Count PR(s)</MudChip>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudTable Items="@_data.LongestPrs" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                            <HeaderContent>
                                <MudTh>PR</MudTh>
                                <MudTh>Repository</MudTh>
                                <MudTh>Author</MudTh>
                                <MudTh>Lifetime</MudTh>
                                <MudTh>Review Cycles</MudTh>
                                <MudTh>Files Changed</MudTh>
                                <MudTh>Comments</MudTh>
                                <MudTh>Status</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="PR">
                                    <MudText Typo="Typo.body2" Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                        @if (!string.IsNullOrEmpty(context.Url))
                                        {
                                            <MudLink Href="@context.Url" Target="_blank" Color="Color.Default">@context.Title</MudLink>
                                        }
                                        else
                                        {
                                            @context.Title
                                        }
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="Repository">
                                    <MudText Typo="Typo.body2">@context.Repository</MudText>
                                </MudTd>
                                <MudTd DataLabel="Author">
                                    <MudText Typo="Typo.body2">@context.Author</MudText>
                                </MudTd>
                                <MudTd DataLabel="Lifetime">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.LifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Review Cycles">
                                    <MudText Typo="Typo.body2">@context.ReviewCycles</MudText>
                                </MudTd>
                                <MudTd DataLabel="Files Changed">
                                    <MudText Typo="Typo.body2">@context.FilesChanged</MudText>
                                </MudTd>
                                <MudTd DataLabel="Comments">
                                    <MudText Typo="Typo.body2">@context.CommentCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="Status">
                                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Text">@context.Status</MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>
        }

        @* ── Section 5: Repository Breakdown ─────────────────────────── *@
        @if (_data.RepositoryBreakdown.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Info" />
                            <MudText Typo="Typo.h6">Repository Breakdown</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_data.RepositoryBreakdown.Count repo(s)</MudChip>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudTable Items="@_data.RepositoryBreakdown" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                            <HeaderContent>
                                <MudTh>Repository</MudTh>
                                <MudTh>PR Count</MudTh>
                                <MudTh>Merge %</MudTh>
                                <MudTh>Abandon %</MudTh>
                                <MudTh>Median Lifetime</MudTh>
                                <MudTh>P90 Lifetime</MudTh>
                                <MudTh>Avg Review Cycles</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Repository">
                                    <MudText Typo="Typo.body2">@context.Repository</MudText>
                                </MudTd>
                                <MudTd DataLabel="PR Count">
                                    <MudText Typo="Typo.body2">@context.PrCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="Merge %">
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success);">@(context.MergePct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Abandon %">
                                    <MudText Typo="Typo.body2" Style="@(context.AbandonPct > 20 ? "color: var(--mud-palette-error);" : "")">@(context.AbandonPct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Median Lifetime">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.MedianLifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="P90 Lifetime">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.P90LifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Avg Review Cycles">
                                    <MudText Typo="Typo.body2">@(context.AvgReviewCycles.HasValue ? context.AvgReviewCycles.Value.ToString("F1") : "—")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>
        }

        @* ── Section 6: Author Breakdown ──────────────────────────────── *@
        @if (_data.AuthorBreakdown.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Secondary" />
                            <MudText Typo="Typo.h6">Author Breakdown</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_data.AuthorBreakdown.Count author(s)</MudChip>
                            @if (!string.IsNullOrEmpty(_filteredAuthor))
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">Filtered: @_filteredAuthor</MudChip>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 mt-1">
                            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" /> Click a row to filter the scatter chart to that author.
                        </MudText>
                        <MudTable Items="@_data.AuthorBreakdown" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Class="mt-1"
                                  RowStyleFunc="@((r, _) => r.Author == _filteredAuthor ? "cursor: pointer; background: var(--mud-palette-action-hover-bg);" : "cursor: pointer;")">
                            <HeaderContent>
                                <MudTh>Author</MudTh>
                                <MudTh>PR Count</MudTh>
                                <MudTh>Merge %</MudTh>
                                <MudTh>Abandon %</MudTh>
                                <MudTh>Rework %</MudTh>
                                <MudTh>Median Lifetime</MudTh>
                                <MudTh>Avg Review Cycles</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Author" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@context.Author</MudText>
                                        @if (context.Author == _filteredAuthor)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" Color="Color.Secondary" />
                                        }
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="PR Count" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2">@context.PrCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="Merge %" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success);">@(context.MergePct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Abandon %" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2" Style="@(context.AbandonPct > 20 ? "color: var(--mud-palette-error);" : "")">@(context.AbandonPct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Rework %" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2" Style="@(context.ReworkPct > 30 ? "color: var(--mud-palette-warning);" : "")">@(context.ReworkPct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Median Lifetime" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.MedianLifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Avg Review Cycles" @onclick="() => ToggleAuthorFilter(context.Author)">
                                    <MudText Typo="Typo.body2">@(context.AvgReviewCycles.HasValue ? context.AvgReviewCycles.Value.ToString("F1") : "—")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>
        }

        @* ── Empty state ──────────────────────────────────────────────── *@
        @if (_data.Summary.TotalPrs == 0)
        {
            <MudPaper Elevation="2" Class="pa-6">
                <MudAlert Severity="Severity.Info">
                    No pull request data found for the selected filters and date range.
                    Try expanding the date range or selecting a different team.
                </MudAlert>
            </MudPaper>
        }
    }

</MudContainer>

@* ── PR Detail Drawer ─────────────────────────────────────────────────── *@
<MudDrawer @bind-Open="_prDrawerOpen"
           Anchor="Anchor.End"
           Elevation="4"
           Width="360px"
           Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
            <MudText Typo="Typo.h6">PR Detail</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="() => _prDrawerOpen = false"
                           Size="Size.Small" />
        </MudStack>
    </MudDrawerHeader>

    @if (_drawerPr is not null)
    {
        <MudContainer Class="px-4 py-2">

            @* Status chip *@
            <MudChip T="string"
                     Color="@GetStatusColor(_drawerPr.ColorCategory)"
                     Size="Size.Medium"
                     Class="mb-3">
                @FormatCategoryLabel(_drawerPr.ColorCategory)
            </MudChip>

            @* Title *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Title</MudText>
            <MudText Typo="Typo.body2" Class="mb-3" Style="word-break: break-word;">
                @_drawerPr.Title
            </MudText>

            @* Author *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Author</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@_drawerPr.Author</MudText>

            @* Repository *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Repository</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@_drawerPr.Repository</MudText>

            @* Created *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Created</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                @_drawerPr.CreatedDate.ToLocalTime().ToString("ddd MMM d, yyyy HH:mm")
            </MudText>

            <MudDivider Class="my-2" />

            @* Lifetime *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Lifetime</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@FormatLifetime(_drawerPr.LifetimeHours)</MudText>

            @* Review Cycles *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Review Cycles</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                @_drawerPr.ReviewCycles
                @if (_drawerPr.ReviewCycles > 1)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text" Class="ml-1">rework</MudChip>
                }
            </MudText>

            @* Files Changed *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Files Changed</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@_drawerPr.FilesChanged</MudText>

            @* Comments *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Comments</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@_drawerPr.CommentCount</MudText>

            @* Azure DevOps deep-link *@
            @if (!string.IsNullOrEmpty(_drawerPr.Url))
            {
                <MudDivider Class="my-3" />
                <MudButton Href="@_drawerPr.Url"
                           Target="_blank"
                           Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           FullWidth="true">
                    Open in Azure DevOps
                </MudButton>
            }

        </MudContainer>
    }
</MudDrawer>

@code {
    // ── State ─────────────────────────────────────────────────────────────
    private bool _isLoading = true;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Filter panel state
    private bool _filterExpanded = true;

    // Filters
    private int? _selectedTeamId;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string? _selectedRepository;
    private List<TeamDto> _teams = new();
    private List<string> _availableRepositories = new();

    // Sprint quick-select
    private List<SprintDto> _sprints = new();
    private int? _selectedSprintId;

    // Data
    private int? _profileId;
    private PullRequestInsightsDto? _data;
    private CanonicalFilterNoticeModel? _filterNotice;
    private DataStateViewModel<PullRequestQueryResponseDto<PullRequestInsightsDto>> _dataState = DataStateViewModel<PullRequestQueryResponseDto<PullRequestInsightsDto>>.NotRequested();

    // Interaction
    private int? _highlightedPrId;
    private string? _filteredAuthor;

    // Drawer
    private bool _prDrawerOpen;
    private PrScatterPointDto? _drawerPr;

    /// <summary>
    /// Fallback sprint duration (days) used when the selected sprint has no EndUtc set.
    /// Most teams use 2-week sprints; this is applied only as a last resort.
    /// </summary>
    private const int DefaultSprintDurationDays = 14;
    private IDisposable? _filterSubscription;

    // ── Init ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync(); // ensure profile guard
            _profileId = activeProfile?.Id;
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();

            // Default: last 6 months
            _fromDate = DateTime.UtcNow.AddMonths(-6).Date;
            _toDate   = DateTime.UtcNow.Date;

            await SyncStoreFromCurrentRouteAsync();
            ApplyStoreState();

            if (_selectedTeamId.HasValue)
            {
                await LoadSprintsForTeamAsync(_selectedTeamId.Value);
                if (_selectedSprintId.HasValue && !_sprints.Any(s => s.Id == _selectedSprintId.Value))
                {
                    _selectedSprintId = null;
                }
            }

            await LoadInsightsAsync();

            UpdateBreadcrumbs();
        }
        catch (Exception)
        {
            _errorMessage = "Pull request insights could not be loaded right now. Try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Data loading ─────────────────────────────────────────────────────

    private async Task LoadInsightsAsync()
    {
        try
        {
            var from = _fromDate.HasValue
                ? new DateTimeOffset(_fromDate.Value, TimeSpan.Zero)
                : DateTimeOffset.UtcNow.AddMonths(-6);

            var to = _toDate.HasValue
                ? new DateTimeOffset(_toDate.Value.AddDays(1).AddSeconds(-1), TimeSpan.Zero)
                : DateTimeOffset.UtcNow;

            _dataState = DataStateViewModel<PullRequestQueryResponseDto<PullRequestInsightsDto>>.Loading();
            var response = await PullRequestStateService.GetInsightsStateAsync(_profileId!.Value, _selectedSprintId, _selectedTeamId, _selectedRepository, CancellationToken.None);
            _dataState = DataStateViewModel<PullRequestQueryResponseDto<PullRequestInsightsDto>>.FromResponse(response, "Pull request insights could not be loaded right now.");
            if (_dataState.State is DataStateDto.NotReady or DataStateDto.Failed)
            {
                _data = null;
                _filterNotice = null;
                return;
            }

            var envelope = _dataState.Data;
            _filterNotice = envelope is null ? null : CanonicalClientResponseFactory.CreateNotice(CanonicalClientResponseFactory.Create(envelope).FilterMetadata);
            _data = envelope?.Data;

            // Populate repository filter list from scatter data
            _availableRepositories = _data?.ScatterPoints
                .Select(p => p.Repository)
                .Distinct()
                .OrderBy(r => r)
                .ToList() ?? new List<string>();

            // Collapse filter panel once data is loaded successfully
            if (_data != null)
            {
                _filterExpanded = false;
            }
        }
        catch (Exception)
        {
            _errorMessage = "Pull request insights could not be loaded right now. Try again later.";
        }
    }

    // ── Filter handlers ───────────────────────────────────────────────────

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId  = teamId;
        _highlightedPrId = null;
        _filteredAuthor  = null;
        _selectedSprintId = null;
        _sprints.Clear();
        await SyncStoreFromLocalStateAsync();

        if (teamId.HasValue)
        {
            _fromDate = DateTime.UtcNow.AddMonths(-6).Date;
            _toDate   = DateTime.UtcNow.Date;
            await LoadSprintsForTeamAsync(teamId.Value);
        }
        else
        {
            _fromDate = DateTime.UtcNow.AddMonths(-6).Date;
            _toDate   = DateTime.UtcNow.Date;
        }

        await ReloadAsync();
    }

    private async Task LoadSprintsForTeamAsync(int teamId)
    {
        try
        {
            var sprints = await SprintService.GetSprintsForTeamAsync(teamId);
            _sprints = sprints
                .Where(s => s.StartUtc.HasValue)
                .OrderByDescending(s => s.StartUtc)
                .ToList();
        }
        catch (Exception ex)
        {
            _sprints.Clear();
            Snackbar.Add($"Could not load sprints: {ex.Message}", Severity.Warning);
        }
    }

    private async Task OnSprintChanged(int? sprintId)
    {
        _selectedSprintId = sprintId;
        _highlightedPrId  = null;
        _filteredAuthor   = null;

        if (sprintId.HasValue)
        {
            var sprint = _sprints.FirstOrDefault(s => s.Id == sprintId.Value);
            if (sprint?.StartUtc.HasValue == true)
            {
                _fromDate = sprint.StartUtc.Value.UtcDateTime.Date;
                _toDate   = sprint.EndUtc?.UtcDateTime.Date ?? _fromDate.Value.AddDays(DefaultSprintDurationDays);
            }
        }

        await SyncStoreFromLocalStateAsync();
        await ReloadAsync();
    }

    private async Task OnRepositoryChanged(string? repo)
    {
        _selectedRepository = repo;
        _highlightedPrId    = null;
        _filteredAuthor     = null;
        await ReloadAsync();
    }

    private async Task OnRepositoryStringChanged(string repo)
    {
        await OnRepositoryChanged(string.IsNullOrEmpty(repo) ? null : repo);
    }

    private async Task ReloadAsync()
    {
        _isLoading    = true;
        _errorMessage = null;
        _prDrawerOpen = false;
        StateHasChanged();
        await LoadInsightsAsync();
        _isLoading = false;
        StateHasChanged();
    }

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(
            NavigationManager.Uri,
            _profileId,
            new FilterLocalBridgeState(RollingWindow: 180, RollingUnit: FilterTimeUnit.Days, TeamId: _selectedTeamId, SprintId: _selectedSprintId));

    private async Task SyncStoreFromLocalStateAsync()
        => await GlobalFilterStore.SetStateAsync(
            NavigationManager.Uri,
            _profileId,
            new FilterLocalBridgeState(
                TeamId: _selectedTeamId,
                SprintId: _selectedSprintId,
                RollingWindow: _selectedSprintId.HasValue ? 1 : 180,
                RollingUnit: _selectedSprintId.HasValue ? FilterTimeUnit.Sprint : FilterTimeUnit.Days),
            FilterUpdateSource.Ui);

    private void ApplyStoreState()
    {
        var state = GlobalFilterStore.GetState();
        _selectedTeamId = state.TeamId;
        if (state.Time.Mode is FilterTimeMode.Sprint or FilterTimeMode.Rolling)
        {
            _selectedSprintId = state.Time.SprintId;
        }
    }

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(() =>
        {
            ApplyStoreState();
            StateHasChanged();
        });

    public void Dispose()
    {
        _filterSubscription?.Dispose();
    }

    // ── Scatter interaction ───────────────────────────────────────────────

    private async Task OnScatterPointClick(PrScatterPointDto pt)
    {
        // Toggle highlight on scatter, and open the detail drawer for the clicked PR
        _highlightedPrId = _highlightedPrId == pt.Id ? null : pt.Id;
        _drawerPr   = pt;
        _prDrawerOpen = true;
        StateHasChanged();

        // Scroll the scatter section into view so the drawer opens next to it
        try
        {
            await JS.InvokeVoidAsync("PoTool.Navigation.scrollToElement", "pr-scatter-section");
        }
        catch
        {
            // JS interop failures (e.g. during pre-render) are non-critical
        }
    }

    private void ToggleHighlight(int prId)
    {
        _highlightedPrId = _highlightedPrId == prId ? null : prId;
    }

    private bool IsHighlighted(int prId) => _highlightedPrId == prId;

    private string GetCardStyle(int prId) =>
        IsHighlighted(prId)
            ? "cursor: pointer; transition: border 0.2s; border: 2px solid var(--mud-palette-primary);"
            : "cursor: pointer; transition: border 0.2s; border: 2px solid transparent;";

    // ── Author filter interaction ─────────────────────────────────────────

    private void ToggleAuthorFilter(string author)
    {
        _filteredAuthor = _filteredAuthor == author ? null : author;
    }

    private void ClearAuthorFilter()
    {
        _filteredAuthor = null;
    }

    // ── Display helpers ───────────────────────────────────────────────────

    private static string FormatLifetime(double? h)
    {
        if (!h.HasValue || h.Value <= 0) return "—";
        if (h.Value >= 168) { int w = (int)(h.Value / 168); int d = (int)((h.Value % 168) / 24); return d > 0 ? $"{w}w {d}d" : $"{w}w"; }
        if (h.Value >= 24)  { int d = (int)(h.Value / 24); int hr = (int)(h.Value % 24); return hr > 0 ? $"{d}d {hr}h" : $"{d}d"; }
        return $"{h.Value:F0}h";
    }

    private static Color GetStatusColor(string status) =>
        status.ToLowerInvariant() switch
        {
            "completed"      => Color.Success,
            "abandoned"      => Color.Error,
            "merged-clean"   => Color.Success,
            "merged-rework"  => Color.Warning,
            _                => Color.Default
        };

    private static string FormatCategoryLabel(string category) =>
        category.ToLowerInvariant() switch
        {
            "merged-clean"  => "Merged (clean)",
            "merged-rework" => "Merged (rework)",
            "abandoned"     => "Abandoned",
            _               => "Active"
        };

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home",         WorkspaceRoutes.Home,            icon: Icons.Material.Filled.Home),
            new("Trends (Past)",WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pull Request Insights", null, disabled: true,   icon: Icons.Material.Filled.MergeType)
        };
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
}
