@page "/home/pull-requests"
@using PoTool.Client.Components.Charts
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Shared.PullRequests
@using System.Web
@inject IProfileService ProfileService
@inject IPullRequestsClient PullRequestsClient
@inject TeamService TeamService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pull Request Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* ── Workspace Header ────────────────────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Pull Request Insights</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Context / Filters ───────────────────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
            Context
        </MudText>

        <MudGrid Spacing="2">
            @* Team selector *@
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="int?"
                           Value="_selectedTeamId"
                           Label="Team"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           ValueChanged="OnTeamChanged">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                    @foreach (var team in _teams)
                    {
                        <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @* Date range: From *@
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="From"
                               Date="_fromDate"
                               DateChanged="OnFromDateChanged"
                               Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" />
            </MudItem>

            @* Date range: To *@
            <MudItem xs="12" sm="6" md="3">
                <MudDatePicker Label="To"
                               Date="_toDate"
                               DateChanged="OnToDateChanged"
                               Variant="Variant.Outlined"
                               DateFormat="yyyy-MM-dd" />
            </MudItem>

            @* Repository filter *@
            <MudItem xs="12" sm="6" md="3">
                <MudSelect T="string"
                           Value="@(_selectedRepository ?? string.Empty)"
                           Label="Repository (optional)"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           ValueChanged="OnRepositoryStringChanged">
                    <MudSelectItem T="string" Value="@string.Empty">All Repositories</MudSelectItem>
                    @foreach (var repo in _availableRepositories)
                    {
                        <MudSelectItem T="string" Value="@repo">@repo</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
    }
    else if (_data != null)
    {
        @* ── Section 1: Global Summary chips ─────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Summary
                @if (!string.IsNullOrEmpty(_data.TeamName))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="ml-2">@_data.TeamName</MudChip>
                }
            </MudText>

            <MudGrid Spacing="2">
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Primary">@_data.Summary.TotalPrs</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total PRs</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-success);">@(_data.Summary.MergeRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Merge Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-error);">@(_data.Summary.AbandonRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Abandon Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Style="color: var(--mud-palette-warning);">@(_data.Summary.ChangesRequestedRatePct.ToString("F0"))%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Rework Rate</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Info">@FormatLifetime(_data.Summary.MedianLifetimeHours)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Median Lifetime</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="4" md="2">
                    <MudPaper Elevation="1" Class="pa-3 text-center">
                        <MudText Typo="Typo.h5" Color="Color.Warning">@FormatLifetime(_data.Summary.P90LifetimeHours)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">P90 Lifetime</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Section 2: Top 3 Problematic PRs ────────────────────────── *@
        @if (_data.Top3Problematic.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Class="mr-2" />
                    Top 3 Friction PRs
                    <MudTooltip Text="Ranked by composite score: lifetime × review cycles × files changed × comments">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Default" Class="ml-1" />
                    </MudTooltip>
                </MudText>

                <MudGrid Spacing="2">
                    @foreach (var pr in _data.Top3Problematic)
                    {
                        <MudItem xs="12" md="4">
                            <MudCard Elevation="1"
                                     Style="@GetCardStyle(pr.Id)"
                                     @onclick="() => ToggleHighlight(pr.Id)">
                                <MudCardContent Class="pa-3">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.subtitle2" Style="word-break: break-word;">@pr.Title</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(pr.Status)" Variant="Variant.Text">@pr.Status</MudChip>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@pr.Repository</MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" />
                                            @pr.Author
                                        </MudText>
                                        <MudDivider Class="my-1" />
                                        <MudGrid Spacing="1">
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    <strong>⏱ @FormatLifetime(pr.LifetimeHours)</strong>
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    <strong>🔄 @pr.ReviewCycles cycles</strong>
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    📁 @pr.FilesChanged files
                                                </MudText>
                                            </MudItem>
                                            <MudItem xs="6">
                                                <MudText Typo="Typo.caption">
                                                    💬 @pr.CommentCount comments
                                                </MudText>
                                            </MudItem>
                                        </MudGrid>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
                @if (_highlightedPrId.HasValue)
                {
                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="mt-2">
                        <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Size="Size.Small" />
                        PR highlighted in scatter chart. Click again to clear.
                    </MudText>
                }
            </MudPaper>
        }

        @* ── Section 3: PR Scatter Chart ─────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.ScatterPlot" Class="mr-2" />
                        PR Scatter — Lifetime vs. Creation Date
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        X: PR creation date &nbsp;|&nbsp; Y: PR lifetime &nbsp;|&nbsp; Color: outcome &nbsp;|&nbsp; Shape: repository
                    </MudText>
                </MudStack>
                @if (_highlightedPrId.HasValue)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => _highlightedPrId = null">
                        Clear highlight
                    </MudButton>
                }
            </MudStack>

            <PullRequestScatterSvg Data="@_data.ScatterPoints"
                                   Height="380"
                                   HighlightedPrId="@_highlightedPrId"
                                   ShowMedianLine="true"
                                   ShowP90Line="true"
                                   MedianLifetimeHours="@_data.Summary.MedianLifetimeHours"
                                   P90LifetimeHours="@_data.Summary.P90LifetimeHours"
                                   OnPointClick="OnScatterPointClick" />
        </MudPaper>

        @* ── Section 4: Longest PR Table ─────────────────────────────── *@
        @if (_data.LongestPrs.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.TableChart" Class="mr-2" />
                    Longest Open PRs (top 20)
                </MudText>

                <MudTable Items="@_data.LongestPrs" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>PR</MudTh>
                        <MudTh>Repository</MudTh>
                        <MudTh>Author</MudTh>
                        <MudTh>Lifetime</MudTh>
                        <MudTh>Review Cycles</MudTh>
                        <MudTh>Files Changed</MudTh>
                        <MudTh>Comments</MudTh>
                        <MudTh>Status</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="PR">
                            <MudText Typo="Typo.body2" Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                @context.Title
                            </MudText>
                        </MudTd>
                        <MudTd DataLabel="Repository">
                            <MudText Typo="Typo.body2">@context.Repository</MudText>
                        </MudTd>
                        <MudTd DataLabel="Author">
                            <MudText Typo="Typo.body2">@context.Author</MudText>
                        </MudTd>
                        <MudTd DataLabel="Lifetime">
                            <MudText Typo="Typo.body2">@FormatLifetime(context.LifetimeHours)</MudText>
                        </MudTd>
                        <MudTd DataLabel="Review Cycles">
                            <MudText Typo="Typo.body2">@context.ReviewCycles</MudText>
                        </MudTd>
                        <MudTd DataLabel="Files Changed">
                            <MudText Typo="Typo.body2">@context.FilesChanged</MudText>
                        </MudTd>
                        <MudTd DataLabel="Comments">
                            <MudText Typo="Typo.body2">@context.CommentCount</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Text">@context.Status</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @* ── Section 5: Repository Breakdown ─────────────────────────── *@
        @if (_data.RepositoryBreakdown.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.FolderOpen" Color="Color.Info" />
                            <MudText Typo="Typo.h6">Repository Breakdown</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@_data.RepositoryBreakdown.Count repo(s)</MudChip>
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudTable Items="@_data.RepositoryBreakdown" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Class="mt-2">
                            <HeaderContent>
                                <MudTh>Repository</MudTh>
                                <MudTh>PR Count</MudTh>
                                <MudTh>Merge %</MudTh>
                                <MudTh>Abandon %</MudTh>
                                <MudTh>Median Lifetime</MudTh>
                                <MudTh>P90 Lifetime</MudTh>
                                <MudTh>Avg Review Cycles</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Repository">
                                    <MudText Typo="Typo.body2">@context.Repository</MudText>
                                </MudTd>
                                <MudTd DataLabel="PR Count">
                                    <MudText Typo="Typo.body2">@context.PrCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="Merge %">
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-success);">@(context.MergePct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Abandon %">
                                    <MudText Typo="Typo.body2" Style="@(context.AbandonPct > 20 ? "color: var(--mud-palette-error);" : "")">@(context.AbandonPct.ToString("F0"))%</MudText>
                                </MudTd>
                                <MudTd DataLabel="Median Lifetime">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.MedianLifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="P90 Lifetime">
                                    <MudText Typo="Typo.body2">@FormatLifetime(context.P90LifetimeHours)</MudText>
                                </MudTd>
                                <MudTd DataLabel="Avg Review Cycles">
                                    <MudText Typo="Typo.body2">@(context.AvgReviewCycles.HasValue ? context.AvgReviewCycles.Value.ToString("F1") : "—")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </ChildContent>
                </MudExpansionPanel>
            </MudPaper>
        }

        @* ── Empty state ──────────────────────────────────────────────── *@
        @if (_data.Summary.TotalPrs == 0)
        {
            <MudPaper Elevation="2" Class="pa-6">
                <MudAlert Severity="Severity.Info">
                    No pull request data found for the selected filters and date range.
                    Try expanding the date range or selecting a different team.
                </MudAlert>
            </MudPaper>
        }
    }

</MudContainer>

@code {
    // ── State ─────────────────────────────────────────────────────────────
    private bool _isLoading = true;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Filters
    private int? _selectedTeamId;
    private DateTime? _fromDate;
    private DateTime? _toDate;
    private string? _selectedRepository;
    private List<PoTool.Client.ApiClient.TeamDto> _teams = new();
    private List<string> _availableRepositories = new();

    // Data
    private PullRequestInsightsDto? _data;

    // Interaction
    private int? _highlightedPrId;

    // ── Init ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await ProfileService.GetActiveProfileAsync(); // ensure profile guard
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();

            // Default: last 6 months
            _fromDate = DateTime.UtcNow.AddMonths(-6).Date;
            _toDate   = DateTime.UtcNow.Date;

            ParseQueryParameters();
            await LoadInsightsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var qs  = HttpUtility.ParseQueryString(uri.Query);

        if (int.TryParse(qs["teamId"], out var tid))
            _selectedTeamId = tid;
    }

    // ── Data loading ─────────────────────────────────────────────────────

    private async Task LoadInsightsAsync()
    {
        try
        {
            var from = _fromDate.HasValue
                ? new DateTimeOffset(_fromDate.Value, TimeSpan.Zero)
                : DateTimeOffset.UtcNow.AddMonths(-6);

            var to = _toDate.HasValue
                ? new DateTimeOffset(_toDate.Value.AddDays(1).AddSeconds(-1), TimeSpan.Zero)
                : DateTimeOffset.UtcNow;

            _data = await PullRequestsClient.GetInsightsAsync(
                teamId:         _selectedTeamId,
                fromDate:       from,
                toDate:         to,
                repositoryName: _selectedRepository,
                CancellationToken.None);

            // Populate repository filter list from scatter data
            _availableRepositories = _data?.ScatterPoints
                .Select(p => p.Repository)
                .Distinct()
                .OrderBy(r => r)
                .ToList() ?? new List<string>();
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            _data = null;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading PR insights: {ex.Message}";
        }
    }

    // ── Filter handlers ───────────────────────────────────────────────────

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        _highlightedPrId = null;
        await ReloadAsync();
    }

    private async Task OnFromDateChanged(DateTime? date)
    {
        _fromDate = date;
        _highlightedPrId = null;
        await ReloadAsync();
    }

    private async Task OnToDateChanged(DateTime? date)
    {
        _toDate = date;
        _highlightedPrId = null;
        await ReloadAsync();
    }

    private async Task OnRepositoryChanged(string? repo)
    {
        _selectedRepository = repo;
        _highlightedPrId = null;
        await ReloadAsync();
    }

    private async Task OnRepositoryStringChanged(string repo)
    {
        await OnRepositoryChanged(string.IsNullOrEmpty(repo) ? null : repo);
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();
        await LoadInsightsAsync();
        _isLoading = false;
        StateHasChanged();
    }

    // ── Scatter interaction ───────────────────────────────────────────────

    private void OnScatterPointClick(PrScatterPointDto pt)
    {
        _highlightedPrId = _highlightedPrId == pt.Id ? null : pt.Id;
    }

    private void ToggleHighlight(int prId)
    {
        _highlightedPrId = _highlightedPrId == prId ? null : prId;
    }

    private bool IsHighlighted(int prId) => _highlightedPrId == prId;

    private string GetCardStyle(int prId) =>
        IsHighlighted(prId)
            ? "cursor: pointer; transition: border 0.2s; border: 2px solid var(--mud-palette-primary);"
            : "cursor: pointer; transition: border 0.2s; border: 2px solid transparent;";

    // ── Display helpers ───────────────────────────────────────────────────

    private static string FormatLifetime(double? h)
    {
        if (!h.HasValue || h.Value <= 0) return "—";
        if (h.Value >= 168) { int w = (int)(h.Value / 168); int d = (int)((h.Value % 168) / 24); return d > 0 ? $"{w}w {d}d" : $"{w}w"; }
        if (h.Value >= 24)  { int d = (int)(h.Value / 24); int hr = (int)(h.Value % 24); return hr > 0 ? $"{d}d {hr}h" : $"{d}d"; }
        return $"{h.Value:F0}h";
    }

    private static Color GetStatusColor(string status) =>
        status.ToLowerInvariant() switch
        {
            "completed" => Color.Success,
            "abandoned" => Color.Error,
            _           => Color.Default
        };

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home",         WorkspaceRoutes.Home,            icon: Icons.Material.Filled.Home),
            new("Trends (Past)",WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pull Request Insights", null, disabled: true,   icon: Icons.Material.Filled.MergeType)
        };
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
}
