@page "/home/pull-requests"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using System.Web
@inject IProfileService ProfileService
@inject PullRequestService PullRequestService
@inject IPullRequestsClient PullRequestsClient
@inject ProductService ProductService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pull Request Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Pull Request Insights
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @_errorMessage
        </MudAlert>
    }
    else
    {
        @* Team & Product Selectors *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
                    Filters
                </MudText>
                
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnProductChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @* Metrics Grid *@
        <MudGrid Spacing="3">
            @* Lead Time to Merge *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Lead Time to Merge"
                           Result="_leadTimeToMerge"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Cycle Time *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Cycle Time"
                           Result="_cycleTime"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Time to First Review *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Time to First Review"
                           Result="_timeToFirstReview"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Review Duration *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Review Duration"
                           Result="_reviewDuration"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* PR Size - Lines Changed *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="PR Size (Lines Changed)"
                           Result="_prSizeLines"
                           ValueFormat="MetricValueFormat.Count"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* PR Size - Files Changed *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="PR Size (Files Changed)"
                           Result="_prSizeFiles"
                           ValueFormat="MetricValueFormat.Count"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Rework Rate *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Rework Rate (Post-Review Commits)"
                           Result="_reworkRate"
                           ValueFormat="MetricValueFormat.Count"
                           ItemLabel="PRs"
                           IsLoading="_metricsLoading" />
            </MudItem>
        </MudGrid>

        @* Sprint Range Selector for Trend Charts *@
        <MudPaper Elevation="2" Class="pa-4 mt-4 mb-2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Class="mr-1" />
                    Sprint Trends
                </MudText>
                <MudSelect T="int?"
                           Value="_trendTeamId"
                           Label="Team (for sprint range)"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true"
                           ValueChanged="OnTrendTeamChanged"
                           Style="min-width: 180px;">
                    <MudSelectItem T="int?" Value="@((int?)null)">Select team…</MudSelectItem>
                    @foreach (var team in _teams)
                    {
                        <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (_trendTeamId.HasValue && _trendSprints.Any())
                {
                    <MudSelect T="int?"
                               Value="_fromSprintId"
                               Label="From Sprint"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Clearable="true"
                               ValueChanged="OnFromSprintChanged"
                               Style="min-width: 200px;">
                        @foreach (var sprint in _trendSprints)
                        {
                            <MudSelectItem T="int?" Value="@sprint.Id">
                                @sprint.Name (@(sprint.StartUtc?.ToString("MMM yyyy") ?? "?"))
                            </MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="int?"
                               Value="_toSprintId"
                               Label="To Sprint"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Clearable="true"
                               ValueChanged="OnToSprintChanged"
                               Style="min-width: 200px;">
                        @foreach (var sprint in _trendSprints)
                        {
                            <MudSelectItem T="int?" Value="@sprint.Id">
                                @sprint.Name (@(sprint.StartUtc?.ToString("MMM yyyy") ?? "?"))
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudStack>
        </MudPaper>

        @* 2×2 Sprint Trend Charts *@
        @if (_trendsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
        }

        @if (_sprintTrendData != null && _sprintTrendData.Sprints.Count > 0)
        {
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px;" class="pr-trend-grid">

                @* Chart 1: Median PR Size per Sprint *@
                <MudPaper Elevation="2" Class="pa-3" Style="min-height: 260px;">
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Median PR Size per Sprint</MudText>
                            <TrendSlopeBadge StartValue="@_prSizeStart"
                                             EndValue="@_prSizeEnd"
                                             LowerIsBetter="true"
                                             MetricLabel="PR size" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @(_sprintTrendData.Sprints.Any(s => s.PrSizeIsLinesChanged)
                                ? "Lines changed (LinesAdded + LinesDeleted)"
                                : "Files changed (fallback — lines data unavailable)")
                        </MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_prSizeChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="180px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Chart 2: Median Time to First Review per Sprint *@
                <MudPaper Elevation="2" Class="pa-3" Style="min-height: 260px;">
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Median Time to First Review per Sprint</MudText>
                            <TrendSlopeBadge StartValue="@_ttfrStart"
                                             EndValue="@_ttfrEnd"
                                             LowerIsBetter="true"
                                             MetricLabel="time to first review" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Hours: PR created → first non-author comment</MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_ttfrChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="180px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Chart 3: Median Time to Merge per Sprint *@
                <MudPaper Elevation="2" Class="pa-3" Style="min-height: 260px;">
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Median Time to Merge per Sprint</MudText>
                            <TrendSlopeBadge StartValue="@_ttmMedianStart"
                                             EndValue="@_ttmMedianEnd"
                                             LowerIsBetter="true"
                                             MetricLabel="median time to merge" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Hours: PR created → completed (median)</MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_ttmMedianChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="180px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Chart 4: P90 Time to Merge per Sprint *@
                <MudPaper Elevation="2" Class="pa-3" Style="min-height: 260px;">
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">P90 Time to Merge per Sprint</MudText>
                            <TrendSlopeBadge StartValue="@_ttmP90Start"
                                             EndValue="@_ttmP90End"
                                             LowerIsBetter="true"
                                             MetricLabel="P90 time to merge" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Hours: 90th percentile (gaps = &lt;3 PRs)</MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_ttmP90ChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="180px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

            </div>
        }
        else if (!_trendsLoading && _trendTeamId.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                No sprint trend data available. Select a sprint range to view trends.
            </MudAlert>
        }

        @if (_pullRequests.Count == 0 && !_metricsLoading)
        {
            <MudPaper Elevation="2" Class="pa-6 mt-4">
                <MudAlert Severity="Severity.Info">
                    @if (_products.Count == 0)
                    {
                        <text>No products configured. Please configure products in your profile settings to view pull request data.</text>
                    }
                    else if (_selectedProductId.HasValue)
                    {
                        var selectedProduct = _products.FirstOrDefault(p => p.Id == _selectedProductId.Value);
                        var productName = selectedProduct?.Name ?? "selected product";
                        <text>No pull request data found for @productName and the selected time range.</text>
                    }
                    else if (_selectedTeamId.HasValue)
                    {
                        var selectedTeam = _teams.FirstOrDefault(t => t.Id == _selectedTeamId.Value);
                        var teamName = selectedTeam?.Name ?? "selected team";
                        <text>No pull request data found for @teamName and the selected time range. The team may not be linked to any products with pull request data.</text>
                    }
                    else
                    {
                        <text>No pull request data found for the selected filters and time range.</text>
                    }
                </MudAlert>
            </MudPaper>
        }
    }
</MudContainer>

<style>
    /* Responsive 2x2 grid: 2 columns on desktop, 1 column on narrow screens */
    @@media (max-width: 768px) {
        .pr-trend-grid {
            grid-template-columns: 1fr !important;
        }
    }
    .trend-slope-badge {
        font-size: 0.7rem;
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Selectors
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    
    // PR Data
    private List<PullRequestDto> _pullRequests = new();
    private List<PullRequestMetricsDto> _metrics = new();
    private Dictionary<int, List<PullRequestCommentDto>> _prComments = new();
    private Dictionary<int, List<PullRequestIterationDto>> _prIterations = new();
    
    // Calculated Metrics
    private MetricResult? _leadTimeToMerge;
    private MetricResult? _cycleTime;
    private MetricResult? _timeToFirstReview;
    private MetricResult? _reviewDuration;
    private MetricResult? _prSizeLines;
    private MetricResult? _prSizeFiles;
    private MetricResult? _reworkRate;
    
    // Sprint Trend state
    private int? _trendTeamId;
    private int? _fromSprintId;
    private int? _toSprintId;
    private List<SprintDto> _trendSprints = new();
    private bool _trendsLoading = false;
    private PoTool.Shared.PullRequests.GetPrSprintTrendsResponse? _sprintTrendData;
    private string[] _trendXAxisLabels = Array.Empty<string>();
    private List<ChartSeries> _prSizeChartSeries = new();
    private List<ChartSeries> _ttfrChartSeries = new();
    private List<ChartSeries> _ttmMedianChartSeries = new();
    private List<ChartSeries> _ttmP90ChartSeries = new();
    // TrendSlopeBadge endpoint values derived from first/last non-null sprint data points
    private double? _prSizeStart, _prSizeEnd;
    private double? _ttfrStart, _ttfrEnd;
    private double? _ttmMedianStart, _ttmMedianEnd;
    private double? _ttmP90Start, _ttmP90End;
    
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true
    };
    
    // Calculator
    private readonly PullRequestInsightsCalculator _calculator = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Load teams and products
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            // Parse URL parameters
            ParseQueryParameters();
            
            // Load PR data and calculate metrics
            await LoadPullRequestDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading pull request insights: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        // Parse teamId
        var teamIdStr = queryParams["teamId"];
        if (!string.IsNullOrEmpty(teamIdStr) && int.TryParse(teamIdStr, out var teamId))
        {
            _selectedTeamId = teamId;
        }
        
        // Parse productId
        var productIdStr = queryParams["productId"];
        if (!string.IsNullOrEmpty(productIdStr) && int.TryParse(productIdStr, out var productId))
        {
            _selectedProductId = productId;
        }
    }
    
    private async Task LoadPullRequestDataAsync()
    {
        _metricsLoading = true;
        StateHasChanged();
        
        try
        {
            // Determine product IDs to filter by
            List<int>? productIds = null;
            
            if (_selectedProductId.HasValue)
            {
                // Specific product selected
                productIds = new List<int> { _selectedProductId.Value };
            }
            else if (_selectedTeamId.HasValue)
            {
                // Team selected: find all products linked to this team
                var selectedTeam = _teams.FirstOrDefault(t => t.Id == _selectedTeamId.Value);
                if (selectedTeam != null)
                {
                    // Filter products that have this team in their TeamIds list
                    productIds = _products
                        .Where(p => p.TeamIds != null && p.TeamIds.Contains(_selectedTeamId.Value))
                        .Select(p => p.Id)
                        .ToList();
                }
                else
                {
                    // Team not found, show no PRs
                    productIds = new List<int>();
                }
            }
            else
            {
                // Default: Load PRs for all user's products when no specific filter is selected
                // This ensures the cached read provider returns relevant data
                productIds = _products.Select(p => p.Id).ToList();
            }
            
            // Build product IDs string
            var productIdsStr = productIds != null && productIds.Any() ? string.Join(",", productIds) : null;
            
            // Load PRs (filtered by product, last 6 months)
            var fromDate = DateTimeOffset.UtcNow.AddMonths(-6);
            _pullRequests = (await PullRequestService.GetFilteredAsync(
                productIds: productIdsStr,
                fromDate: fromDate
            )).ToList();
            
            // Load metrics
            _metrics = (await PullRequestService.GetMetricsAsync(
                productIds: productIdsStr,
                fromDate: fromDate
            )).ToList();
            
            // Load comments and iterations for each PR in parallel
            var prIds = _pullRequests.Select(pr => pr.Id).ToList();
            var commentTasks = prIds.Select(async prId =>
            {
                try
                {
                    var comments = await PullRequestService.GetCommentsAsync(prId);
                    return (prId, comments: comments.ToList());
                }
                catch (Exception)
                {
                    return (prId, comments: new List<PullRequestCommentDto>());
                }
            });
            
            var iterationTasks = prIds.Select(async prId =>
            {
                try
                {
                    var iterations = await PullRequestService.GetIterationsAsync(prId);
                    return (prId, iterations: iterations.ToList());
                }
                catch (Exception)
                {
                    return (prId, iterations: new List<PullRequestIterationDto>());
                }
            });
            
            var commentResults = await Task.WhenAll(commentTasks);
            var iterationResults = await Task.WhenAll(iterationTasks);
            
            _prComments.Clear();
            foreach (var (prId, comments) in commentResults)
            {
                _prComments[prId] = comments;
            }
            
            _prIterations.Clear();
            foreach (var (prId, iterations) in iterationResults)
            {
                _prIterations[prId] = iterations;
            }
            
            // Calculate metrics
            CalculateMetrics();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load pull request data: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }
    
    private void CalculateMetrics()
    {
        _leadTimeToMerge = _calculator.CalculateLeadTimeToMerge(_pullRequests);
        _cycleTime = _calculator.CalculateCycleTime(_pullRequests);
        _timeToFirstReview = _calculator.CalculateTimeToFirstReview(_pullRequests, _prComments);
        _reviewDuration = _calculator.CalculateReviewDuration(_pullRequests, _prComments);
        
        var prSize = _calculator.CalculatePRSize(_metrics);
        _prSizeLines = prSize.LinesChanged;
        _prSizeFiles = prSize.FilesChanged;
        
        _reworkRate = _calculator.CalculateReworkRate(_pullRequests, _prComments, _prIterations);
    }
    
    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        UpdateUrlParameters();
        await LoadPullRequestDataAsync();
    }
    
    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        UpdateUrlParameters();
        await LoadPullRequestDataAsync();
    }
    
    private void UpdateUrlParameters()
    {
        var queryParams = new List<string>();
        
        if (_selectedTeamId.HasValue)
        {
            queryParams.Add($"teamId={_selectedTeamId.Value}");
        }
        
        if (_selectedProductId.HasValue)
        {
            queryParams.Add($"productId={_selectedProductId.Value}");
        }
        
        var queryString = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : "";
        var newUrl = $"{WorkspaceRoutes.PrOverview}{queryString}";
        
        NavigationManager.NavigateTo(newUrl, forceLoad: false);
    }

    // Sprint Trend handlers
    private async Task OnTrendTeamChanged(int? teamId)
    {
        _trendTeamId = teamId;
        _fromSprintId = null;
        _toSprintId = null;
        _trendSprints.Clear();
        _sprintTrendData = null;
        ClearTrendCharts();

        if (teamId.HasValue)
        {
            try
            {
                var sprints = (await SprintService.GetSprintsForTeamAsync(teamId.Value))
                    .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
                    .OrderBy(s => s.StartUtc)
                    .ToList();
                _trendSprints = sprints;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error loading sprints: {ex.Message}", Severity.Warning);
            }
        }

        StateHasChanged();
    }

    private async Task OnFromSprintChanged(int? sprintId)
    {
        _fromSprintId = sprintId;
        await LoadSprintTrendsAsync();
    }

    private async Task OnToSprintChanged(int? sprintId)
    {
        _toSprintId = sprintId;
        await LoadSprintTrendsAsync();
    }

    private async Task LoadSprintTrendsAsync()
    {
        if (!_fromSprintId.HasValue || !_toSprintId.HasValue)
        {
            _sprintTrendData = null;
            ClearTrendCharts();
            StateHasChanged();
            return;
        }

        _trendsLoading = true;
        StateHasChanged();

        try
        {
            // Build ordered list of sprint IDs between from and to (inclusive)
            var fromSprint = _trendSprints.FirstOrDefault(s => s.Id == _fromSprintId.Value);
            var toSprint = _trendSprints.FirstOrDefault(s => s.Id == _toSprintId.Value);

            if (fromSprint == null || toSprint == null)
                return;

            // Ensure from <= to (swap if needed)
            if (fromSprint.StartUtc > toSprint.StartUtc)
                (fromSprint, toSprint) = (toSprint, fromSprint);

            var selectedSprintIds = _trendSprints
                .Where(s => s.StartUtc >= fromSprint.StartUtc && s.StartUtc <= toSprint.StartUtc)
                .Select(s => s.Id)
                .ToList();

            if (selectedSprintIds.Count == 0)
                return;

            // Determine product scope (mirror the metrics filter selection)
            IEnumerable<int>? productFilter = null;
            if (_selectedProductId.HasValue)
            {
                productFilter = new[] { _selectedProductId.Value };
            }
            else if (_selectedTeamId.HasValue)
            {
                var teamProducts = _products
                    .Where(p => p.TeamIds != null && p.TeamIds.Contains(_selectedTeamId.Value))
                    .Select(p => p.Id)
                    .ToList();
                if (teamProducts.Count > 0)
                    productFilter = teamProducts;
            }

            var productIdsString = productFilter != null ? string.Join(",", productFilter) : null;
            _sprintTrendData = await PullRequestsClient.GetSprintTrendsAsync(
                selectedSprintIds,
                productIds: productIdsString,
                teamId: productFilter == null ? _trendTeamId : null,
                CancellationToken.None);

            if (_sprintTrendData?.Success == true)
            {
                BuildTrendCharts();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sprint trends: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _trendsLoading = false;
            StateHasChanged();
        }
    }

    private void BuildTrendCharts()
    {
        if (_sprintTrendData == null || _sprintTrendData.Sprints.Count == 0)
            return;

        var sprints = _sprintTrendData.Sprints.OrderBy(s => s.StartUtc ?? DateTimeOffset.MaxValue).ToList();
        _trendXAxisLabels = sprints.Select(s => s.SprintName).ToArray();

        // Charts use 0 for missing data points (gap indication in caption)
        _prSizeChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median PR Size", Data = sprints.Select(s => s.MedianPrSize ?? 0).ToArray() }
        };
        _ttfrChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median TTFR (h)", Data = sprints.Select(s => s.MedianTimeToFirstReviewHours ?? 0).ToArray() }
        };
        _ttmMedianChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median TTM (h)", Data = sprints.Select(s => s.MedianTimeToMergeHours ?? 0).ToArray() }
        };
        _ttmP90ChartSeries = new List<ChartSeries>
        {
            new() { Name = "P90 TTM (h)", Data = sprints.Select(s => s.P90TimeToMergeHours ?? 0).ToArray() }
        };

        // Compute slope badge endpoints from first and last sprint with non-null data
        _prSizeStart = sprints.FirstOrDefault(s => s.MedianPrSize.HasValue)?.MedianPrSize;
        _prSizeEnd = sprints.LastOrDefault(s => s.MedianPrSize.HasValue)?.MedianPrSize;
        _ttfrStart = sprints.FirstOrDefault(s => s.MedianTimeToFirstReviewHours.HasValue)?.MedianTimeToFirstReviewHours;
        _ttfrEnd = sprints.LastOrDefault(s => s.MedianTimeToFirstReviewHours.HasValue)?.MedianTimeToFirstReviewHours;
        _ttmMedianStart = sprints.FirstOrDefault(s => s.MedianTimeToMergeHours.HasValue)?.MedianTimeToMergeHours;
        _ttmMedianEnd = sprints.LastOrDefault(s => s.MedianTimeToMergeHours.HasValue)?.MedianTimeToMergeHours;
        _ttmP90Start = sprints.FirstOrDefault(s => s.P90TimeToMergeHours.HasValue)?.P90TimeToMergeHours;
        _ttmP90End = sprints.LastOrDefault(s => s.P90TimeToMergeHours.HasValue)?.P90TimeToMergeHours;
    }

    private void ClearTrendCharts()
    {
        _trendXAxisLabels = Array.Empty<string>();
        _prSizeChartSeries = new();
        _ttfrChartSeries = new();
        _ttmMedianChartSeries = new();
        _ttmP90ChartSeries = new();
        _prSizeStart = _prSizeEnd = null;
        _ttfrStart = _ttfrEnd = null;
        _ttmMedianStart = _ttmMedianEnd = null;
        _ttmP90Start = _ttmP90End = null;
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("PR Insights", null, disabled: true, icon: Icons.Material.Filled.Insights)
        };
    }
    
    private void NavigateToHome()
