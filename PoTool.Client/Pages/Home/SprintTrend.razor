@page "/home/sprint-trend"
@page "/home/delivery/sprint"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using SharedDeliveryBuildQualityDto = PoTool.Shared.BuildQuality.DeliveryBuildQualityDto
@using PoTool.Shared.Metrics
@using PoTool.Shared.WorkItems
@implements IDisposable
@inject IProfileService ProfileService
@inject TeamService TeamService
@inject SprintService SprintService
@inject ProductService ProductService
@inject SprintDeliveryMetricsService SprintDeliveryMetricsService
@inject TfsConfigService TfsConfigService
@inject NavigationManager NavigationManager
@inject IBuildQualityService BuildQualityService

<PageTitle>Sprint Delivery - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.RunCircle" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Sprint Delivery
                    </MudText>
                </MudStack>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Stakeholder sprint delivery report — what was delivered during this sprint
                </MudText>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Inventory2"
                           OnClick="NavigateToDelivery">
                    Back to Delivery
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Spacing="3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                    Sprint Navigation
                </MudText>
            </MudStack>

            @if (_isContextLoading)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="40px" Height="40px" />
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="220px" Height="36px" />
                        <MudSkeleton SkeletonType="SkeletonType.Text" Width="180px" Height="24px" />
                    </MudStack>
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="40px" Height="40px" />
                </MudStack>
            }
            else if (!string.IsNullOrWhiteSpace(_contextErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_contextErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryContextLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (_currentSprint is null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No sprint navigation data is available for this Product Owner.
                </MudAlert>
            }
            else
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   Disabled="@(!CanNavigatePrevious())"
                                   OnClick="NavigateToPreviousSprintAsync"
                                   aria-label="Previous Sprint" />

                    <MudStack AlignItems="AlignItems.Center" Spacing="0">
                        <MudText Typo="Typo.h5" Align="Align.Center">
                            @_currentSprint.Name
                        </MudText>
                        @if (_currentSprint.StartUtc != null && _currentSprint.EndUtc != null)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @_currentSprint.StartUtc.Value.ToString("MMM d") — @_currentSprint.EndUtc.Value.ToString("MMM d, yyyy")
                            </MudText>
                        }
                    </MudStack>

                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Color="Color.Primary"
                                   Variant="Variant.Outlined"
                                   Disabled="@(!CanNavigateNext())"
                                   OnClick="NavigateToNextSprintAsync"
                                   aria-label="Next Sprint" />
                </MudStack>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-2" />
                Build Quality
            </MudText>

            @if (_isBuildQualityLoading)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="148px" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="148px" />
                    </MudItem>
                </MudGrid>
            }
            else if (!string.IsNullOrWhiteSpace(_buildQualityErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_buildQualityErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryBuildQualityLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (_sprintBuildQuality is null)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    Build Quality is unavailable for the selected sprint.
                </MudAlert>
            }
            else
            {
                <BuildQualityCompactComponent Result="@_sprintBuildQuality.Summary"
                                              Title="@($"{_sprintBuildQuality.SprintName} summary")"
                                              Elevation="0" />

                @if (_sprintBuildQuality.Products.Any())
                {
                    <MudText Typo="Typo.subtitle2">Products</MudText>
                    <MudGrid Spacing="2">
                        @foreach (var product in _sprintBuildQuality.Products.OrderBy(product => product.ProductName, StringComparer.OrdinalIgnoreCase))
                        {
                            <MudItem xs="12" md="6" lg="4" @key="product.ProductId">
                                <BuildQualityCompactComponent Result="@product.Result"
                                                              Title="@product.ProductName"
                                                              Elevation="0" />
                            </MudItem>
                        }
                    </MudGrid>
                }
            }
        </MudStack>
    </MudPaper>

    @if (_drillDownLevel > DrillDownLevel.Portfolio)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               Size="Size.Small"
                               Color="Color.Primary"
                                OnClick="DrillUp"
                                aria-label="Go back to previous level" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.Dashboard"
                                   OnClick="RestorePortfolioLevel">
                        Portfolio
                    </CompactButton>

                    @if (_selectedProductName is not null)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">/</MudText>
                        @if (_drillDownLevel == DrillDownLevel.Product)
                        {
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Class="mr-1" />
                                @_selectedProductName
                            </MudText>
                        }
                        else
                        {
                            <CompactButton ButtonRole="ButtonRole.Utility"
                                           Icon="@Icons.Material.Filled.Inventory2"
                                           OnClick="RestoreProductLevel">
                                @_selectedProductName
                            </CompactButton>
                        }
                    }

                    @if (_selectedEpicName is not null && _drillDownLevel >= DrillDownLevel.Epic)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">/</MudText>
                        @if (_drillDownLevel == DrillDownLevel.Epic)
                        {
                            <MudText Typo="Typo.body2">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Small" Class="mr-1" />
                                @_selectedEpicName
                            </MudText>
                        }
                        else
                        {
                            <CompactButton ButtonRole="ButtonRole.Utility"
                                           Icon="@Icons.Material.Filled.AccountTree"
                                           OnClick="RestoreEpicLevel">
                                @_selectedEpicName
                            </CompactButton>
                        }
                    }

                    @if (_selectedFeatureName is not null && _drillDownLevel == DrillDownLevel.Feature)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">/</MudText>
                        <MudText Typo="Typo.body2">
                            <MudIcon Icon="@Icons.Material.Filled.FeaturedPlayList" Size="Size.Small" Class="mr-1" />
                            @_selectedFeatureName
                        </MudText>
                    }
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (_drillDownLevel == DrillDownLevel.Portfolio)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-1" />
                All Products — Sprint Summary
            </MudText>

            @if (_isSummaryLoading)
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="5">
                        <MudGrid Spacing="2">
                            @for (var index = 0; index < 5; index++)
                            {
                                <MudItem xs="12">
                                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="86px" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudItem>
                    <MudItem xs="12" md="7">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="278px" />
                    </MudItem>
                </MudGrid>
            }
            else if (!string.IsNullOrWhiteSpace(_summaryErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_summaryErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetrySummaryLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (_productMetrics.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No delivery data is available for the selected sprint.
                </MudAlert>
            }
            else
            {
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="@(GetActiveProducts().Count > 1 ? 5 : 12)">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Completed PBIs</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Success">@_completedPbiCount</MudText>
                                    @if (_hasPreviousSprint)
                                    {
                                        var diff = _completedPbiCount - _prevCompletedPbiCount;
                                        <MudText Typo="Typo.caption" Color="@(diff >= 0 ? Color.Success : Color.Error)">
                                            @FormatSignedInt(diff) vs previous sprint
                                        </MudText>
                                    }
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Delivered Story Points</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Info">@FormatStoryPoints(_completedPbiStoryPoints)</MudText>
                                    @if (_hasPreviousSprint)
                                    {
                                        var diff = _completedPbiStoryPoints - _prevCompletedPbiStoryPoints;
                                        <MudText Typo="Typo.caption" Color="@(diff >= 0 ? Color.Success : Color.Error)">
                                            @FormatSignedStoryPoints(diff) vs previous sprint
                                        </MudText>
                                    }
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Scope Change (Δ Effort hours)</MudText>
                                    <MudText Typo="Typo.h5"
                                             Color="@(_sprintEffortDelta > 0 ? Color.Warning : _sprintEffortDelta < 0 ? Color.Info : Color.Default)">
                                        @FormatSignedInt(_sprintEffortDelta) hours
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Completed Features</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Primary">@_completedFeatureCount</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs (Created / Worked / Closed)</MudText>
                                    <MudText Typo="Typo.h5">@_bugsCreatedCount / @_bugsWorkedCount / @_bugsClosedCount</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    @if (GetActiveProducts().Count > 1)
                    {
                        <MudItem xs="12" md="7">
                            <MudPaper Elevation="1" Class="pa-3" Style="height: 100%;">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                                    <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Small" Class="mr-1" />
                                    Story point distribution by product
                                </MudText>
                                <MudStack Spacing="2">
                                    @foreach (var item in GetProductBarChartData())
                                    {
                                        <MudGrid Spacing="1" Class="align-center">
                                            <MudItem xs="5">
                                                <MudTooltip Text="@item.Label">
                                                    <MudText Typo="Typo.caption" Class="text-truncate d-block">@TruncateBarLabel(item.Label)</MudText>
                                                </MudTooltip>
                                            </MudItem>
                                            <MudItem xs="5">
                                                <MudProgressLinear Value="@item.Percent" Max="100" Color="Color.Primary" Rounded="true" Size="Size.Medium" />
                                            </MudItem>
                                            <MudItem xs="2">
                                                <MudText Typo="Typo.caption" Align="Align.Right">@item.Percent.ToString("F0")%</MudText>
                                            </MudItem>
                                        </MudGrid>
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudPaper>

        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Class="mr-1" />
                Product Delivery — click a product to drill down
            </MudText>

            @if (_isSummaryLoading)
            {
                @for (var rowIndex = 0; rowIndex < 4; rowIndex++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Height="28px" Width="100%" Class="mb-1" />
                }
            }
            else if (!string.IsNullOrWhiteSpace(_summaryErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_summaryErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetrySummaryLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (GetActiveProducts().Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No products show delivery activity in this sprint.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th style="width: 150px; text-align: right;">Delivered Story Points</th>
                            <th style="width: 110px; text-align: right;">Completed PBIs</th>
                            <th style="width: 130px; text-align: right;">Completed Features</th>
                            <th style="width: 120px; text-align: right;">Scope Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in GetActiveProducts())
                        {
                            var completedFeatures = GetProductCompletedFeatures(product.Id);
                            var scopeChange = GetProductSprintEffortDelta(product.Id);
                            <tr style="cursor: pointer;"
                                role="button"
                                tabindex="0"
                                @onclick="@(() => DrillIntoProductAsync(product.Id, product.Name))"
                                @onkeydown="@(args => HandleDrillDownKeyAsync(args, () => DrillIntoProductAsync(product.Id, product.Name)))">
                                <td>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Primary" />
                                        <MudText Typo="Typo.body2"><strong>@product.Name</strong></MudText>
                                        @if (IsProductApproximate(product.Id))
                                        {
                                            <MudTooltip Text="@GetProductApproximationTooltip(product.Id, product.Name)">
                                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                            </MudTooltip>
                                        }
                                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                                    </MudStack>
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2" Color="Color.Success">@FormatStoryPoints(GetProductCompletedStoryPoints(product.Id))</MudText>
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2">@GetProductCompletedPbis(product.Id)</MudText>
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2">@completedFeatures</MudText>
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2"
                                             Color="@(scopeChange > 0 ? Color.Warning : scopeChange < 0 ? Color.Info : Color.Default)">
                                        @FormatSignedInt(scopeChange) hours
                                    </MudText>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>
    }

    @if (_drillDownLevel == DrillDownLevel.Product && _selectedProductId.HasValue)
    {
        var selectedProductAnalytics = GetProductAnalytics(_selectedProductId.Value);
        var productEpics = GetVisibleEpicsForProduct(_selectedProductId.Value);
        if (selectedProductAnalytics is not null)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-1" />
                    Canonical Product Summary — @_selectedProductName
                </MudText>

                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Product Progress">
                            <CanonicalNullablePercentage Value="@selectedProductAnalytics.Progress.ProductProgress"
                                                         ShowProgressBar="true"
                                                         ProgressColor="Color.Success"
                                                         ValueColor="Color.Success" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Forecast Consumed">
                            <CanonicalForecastValue Value="@selectedProductAnalytics.Progress.ProductForecastConsumed"
                                                    Suffix=" hours"
                                                    ValueColor="Color.Info" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Forecast Remaining">
                            <CanonicalForecastValue Value="@selectedProductAnalytics.Progress.ProductForecastRemaining"
                                                    Suffix=" hours"
                                                    ValueColor="Color.Warning" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Excluded Epics">
                            <MudText Typo="Typo.body2">@selectedProductAnalytics.Progress.ExcludedEpicsCount</MudText>
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Included Epics">
                            <MudText Typo="Typo.body2">@selectedProductAnalytics.Progress.IncludedEpicsCount</MudText>
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" lg="2">
                        <AnalyticsMetricCard Title="Total Weight">
                            <MudText Typo="Typo.body2">@selectedProductAnalytics.Progress.TotalWeight.ToString("0.##")</MudText>
                        </AnalyticsMetricCard>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-3" />

                <MudText Typo="Typo.subtitle2" Class="mb-2">Snapshot Comparison</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="4">
                        <AnalyticsMetricCard Title="Progress Delta">
                            <CanonicalDeltaValue Value="@selectedProductAnalytics.Comparison.ProgressDelta" Suffix="%" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <AnalyticsMetricCard Title="Forecast Consumed Delta">
                            <CanonicalDeltaValue Value="@selectedProductAnalytics.Comparison.ForecastConsumedDelta" Suffix=" hours" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <AnalyticsMetricCard Title="Forecast Remaining Delta">
                            <CanonicalDeltaValue Value="@selectedProductAnalytics.Comparison.ForecastRemainingDelta" Suffix=" hours" />
                        </AnalyticsMetricCard>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-3" />

                <MudText Typo="Typo.subtitle2" Class="mb-2">Planning Quality</MudText>
                <CanonicalPlanningQuality PlanningQuality="@selectedProductAnalytics.PlanningQuality" />

                <MudDivider Class="my-3" />

                <MudText Typo="Typo.subtitle2" Class="mb-2">Insights</MudText>
                <CanonicalInsightList Insights="@selectedProductAnalytics.Insights" />
            </MudPaper>
        }
        else if (!_isSummaryLoading && string.IsNullOrWhiteSpace(_summaryErrorMessage))
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Canonical product analytics are unavailable for the selected sprint.
            </MudAlert>
        }

        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-1" />
                Epic Delivery — @_selectedProductName — click an epic to drill down
            </MudText>
            @if (_isDetailsLoading)
            {
                @for (var rowIndex = 0; rowIndex < 5; rowIndex++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Height="28px" Width="100%" Class="mb-1" />
                }
            }
            else if (!string.IsNullOrWhiteSpace(_detailsErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_detailsErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryDetailsLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (productEpics.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No epic activity data available for this sprint.
                </MudAlert>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <MudSimpleTable Dense="true" Striped="true" Hover="true">
                        <thead>
                            <tr>
                                <th>Epic</th>
                                <th style="width: 180px;">Progress</th>
                                <th style="width: 140px; text-align: right;">Forecast Consumed</th>
                                <th style="width: 140px; text-align: right;">Forecast Remaining</th>
                                <th style="width: 120px; text-align: right;">Excluded Features</th>
                                <th style="width: 120px; text-align: right;">Included Features</th>
                                <th style="width: 100px; text-align: right;">Total Weight</th>
                                <th style="width: 60px; text-align: center;">History</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var epic in productEpics)
                            {
                                <tr style="cursor: pointer;"
                                    role="button"
                                    tabindex="0"
                                    @onclick="@(() => DrillIntoEpicAsync(epic.EpicId, epic.EpicTitle))"
                                    @onkeydown="@(args => HandleDrillDownKeyAsync(args, () => DrillIntoEpicAsync(epic.EpicId, epic.EpicTitle)))">
                                    <td>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <span style="@GetEpicColorSquareStyle(_selectedProductId.Value, epic.EpicId)"></span>
                                            @if (_tfsConfig != null && !string.IsNullOrEmpty(_tfsConfig.Url) && !string.IsNullOrEmpty(_tfsConfig.Project))
                                            {
                                                <MudLink Href="@TfsUrlBuilder.BuildWorkItemUrl(_tfsConfig.Url, _tfsConfig.Project, epic.EpicId)"
                                                         Target="_blank"
                                                         Typo="Typo.body2"
                                                         @onclick:stopPropagation="true">#@epic.EpicId</MudLink>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2" Class="mr-1">#@epic.EpicId</MudText>
                                            }
                                            <MudText Typo="Typo.body2"><strong>@epic.EpicTitle</strong></MudText>
                                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                                        </MudStack>
                                    </td>
                                    <td>
                                        <CanonicalNullablePercentage Value="@epic.AggregatedProgress"
                                                                     ShowProgressBar="true"
                                                                     ProgressColor="Color.Success"
                                                                     ValueColor="Color.Success" />
                                    </td>
                                    <td style="text-align: right;">
                                        <CanonicalForecastValue Value="@epic.ForecastConsumedEffort"
                                                                Suffix=" hours" />
                                    </td>
                                    <td style="text-align: right;">
                                        <CanonicalForecastValue Value="@epic.ForecastRemainingEffort"
                                                                Suffix=" hours" />
                                    </td>
                                    <td style="text-align: right;">
                                        <MudText Typo="Typo.body2">@epic.ExcludedFeaturesCount</MudText>
                                    </td>
                                    <td style="text-align: right;">
                                        <MudText Typo="Typo.body2">@epic.IncludedFeaturesCount</MudText>
                                    </td>
                                    <td style="text-align: right;">
                                        <MudText Typo="Typo.body2">@epic.TotalWeight.ToString("0.##")</MudText>
                                    </td>
                                    <td style="text-align: center;" @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.History"
                                                       Size="Size.Small"
                                                       Color="Color.Info"
                                                       aria-label="Show activities for this epic"
                                                       Href="@BuildWorkItemActivityUrl(epic.EpicId)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            }
        </MudPaper>
    }

    @if (_drillDownLevel == DrillDownLevel.Epic && _selectedEpicId.HasValue)
    {
        var epicFeatures = GetVisibleFeaturesForEpic(_selectedEpicId.Value);
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.FeaturedPlayList" Class="mr-1" />
                Feature Delivery — @_selectedEpicName — click a feature to see completed PBIs
            </MudText>
            @if (_isDetailsLoading)
            {
                @for (var rowIndex = 0; rowIndex < 5; rowIndex++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Height="28px" Width="100%" Class="mb-1" />
                }
            }
            else if (!string.IsNullOrWhiteSpace(_detailsErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_detailsErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryDetailsLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (epicFeatures.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No features with sprint activity found for this epic.
                </MudAlert>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <MudSimpleTable Dense="true" Striped="true" Hover="true">
                        <thead>
                            <tr>
                                <th>Feature</th>
                                <th style="width: 120px;">Calculated</th>
                                <th style="width: 120px;">Override</th>
                                <th style="width: 120px;">Effective</th>
                                <th style="width: 120px; text-align: right;">Effort</th>
                                <th style="width: 140px; text-align: right;">Forecast Consumed</th>
                                <th style="width: 140px; text-align: right;">Forecast Remaining</th>
                                <th style="width: 100px; text-align: right;">Weight</th>
                                <th style="width: 100px; text-align: center;">Excluded</th>
                                <th style="width: 80px; text-align: right;">PBIs ✓</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var feature in epicFeatures)
                            {
                                <tr style="cursor: pointer;"
                                    role="button"
                                    tabindex="0"
                                    @onclick="@(() => DrillIntoFeatureAsync(feature.FeatureId, feature.FeatureTitle))"
                                    @onkeydown="@(args => HandleDrillDownKeyAsync(args, () => DrillIntoFeatureAsync(feature.FeatureId, feature.FeatureTitle)))">
                                    <td>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            @if (_tfsConfig != null && !string.IsNullOrEmpty(_tfsConfig.Url) && !string.IsNullOrEmpty(_tfsConfig.Project))
                                            {
                                                <MudLink Href="@TfsUrlBuilder.BuildWorkItemUrl(_tfsConfig.Url, _tfsConfig.Project, feature.FeatureId)"
                                                         Target="_blank"
                                                         Typo="Typo.body2"
                                                         @onclick:stopPropagation="true">#@feature.FeatureId</MudLink>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.body2">#@feature.FeatureId</MudText>
                                            }
                                            <MudText Typo="Typo.body2"><strong>@feature.FeatureTitle</strong></MudText>
                                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Color="Color.Default" />
                                        </MudStack>
                                    </td>
                                    <td>
                                        <CanonicalNullablePercentage Value="@feature.CalculatedProgress" />
                                    </td>
                                    <td>
                                        <CanonicalNullablePercentage Value="@feature.Override" UnknownLabel="Not set" />
                                    </td>
                                    <td>
                                        <CanonicalNullablePercentage Value="@feature.EffectiveProgress"
                                                                     ShowProgressBar="true"
                                                                     ProgressColor="Color.Success"
                                                                     ValueColor="Color.Success" />
                                    </td>
                                    <td style="text-align: right;">
                                        <CanonicalForecastValue Value="@feature.Effort" Suffix=" hours" />
                                    </td>
                                    <td style="text-align: right;">
                                        <CanonicalForecastValue Value="@feature.ForecastConsumedEffort" Suffix=" hours" />
                                    </td>
                                    <td style="text-align: right;">
                                        <CanonicalForecastValue Value="@feature.ForecastRemainingEffort" Suffix=" hours" />
                                    </td>
                                    <td style="text-align: right;">
                                        <MudText Typo="Typo.body2">@feature.Weight.ToString("0.##")</MudText>
                                    </td>
                                    <td style="text-align: center;">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                            @(feature.IsExcluded ? "Yes" : "No")
                                        </MudChip>
                                    </td>
                                    <td style="text-align: right;">
                                        <MudText Typo="Typo.body2">@feature.SprintCompletedPbiCount</MudText>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            }
        </MudPaper>
    }

    @if (_drillDownLevel == DrillDownLevel.Feature && _selectedFeatureId.HasValue)
    {
        var selectedFeature = GetFeatureProgress(_selectedFeatureId.Value);
        var completedPbis = GetCompletedPbisForFeature(_selectedFeatureId.Value);
        if (selectedFeature is not null)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Tune" Class="mr-1" />
                    Canonical Feature Summary — @_selectedFeatureName
                </MudText>

                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Calculated Progress">
                            <CanonicalNullablePercentage Value="@selectedFeature.CalculatedProgress" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Override">
                            <CanonicalNullablePercentage Value="@selectedFeature.Override" UnknownLabel="Not set" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Effective Progress">
                            <CanonicalNullablePercentage Value="@selectedFeature.EffectiveProgress"
                                                         ShowProgressBar="true"
                                                         ProgressColor="Color.Success"
                                                         ValueColor="Color.Success" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Effort">
                            <CanonicalForecastValue Value="@selectedFeature.Effort" Suffix=" hours" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Forecast Consumed">
                            <CanonicalForecastValue Value="@selectedFeature.ForecastConsumedEffort" Suffix=" hours" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Forecast Remaining">
                            <CanonicalForecastValue Value="@selectedFeature.ForecastRemainingEffort" Suffix=" hours" />
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Weight">
                            <MudText Typo="Typo.body2">@selectedFeature.Weight.ToString("0.##")</MudText>
                        </AnalyticsMetricCard>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="3">
                        <AnalyticsMetricCard Title="Excluded">
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                @(selectedFeature.IsExcluded ? "Yes" : "No")
                            </MudChip>
                        </AnalyticsMetricCard>
                    </MudItem>
                </MudGrid>

                @if (selectedFeature.ValidationSignals.Count > 0)
                {
                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Validation Signals</MudText>
                    <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var signal in selectedFeature.ValidationSignals)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@signal</MudChip>
                        }
                    </MudStack>
                }
            </MudPaper>
        }
        else if (!_isDetailsLoading && string.IsNullOrWhiteSpace(_detailsErrorMessage))
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                Canonical feature analytics are unavailable for this sprint.
            </MudAlert>
        }

        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.subtitle1" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-1" />
                Completed PBIs — @_selectedFeatureName
            </MudText>
            @if (_isDetailsLoading)
            {
                @for (var rowIndex = 0; rowIndex < 5; rowIndex++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Text" Height="28px" Width="100%" Class="mb-1" />
                }
            }
            else if (!string.IsNullOrWhiteSpace(_detailsErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.body2">@_detailsErrorMessage</MudText>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RetryDetailsLoadAsync">
                            Retry
                        </MudButton>
                    </MudStack>
                </MudAlert>
            }
            else if (completedPbis.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No PBIs completed during this sprint for this feature.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Work Item</th>
                            <th>Title</th>
                            <th style="width: 140px;">Completed</th>
                            <th style="width: 120px; text-align: right;">Story Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pbi in completedPbis)
                        {
                            <tr>
                                <td>
                                    @if (_tfsConfig != null && !string.IsNullOrEmpty(_tfsConfig.Url) && !string.IsNullOrEmpty(_tfsConfig.Project))
                                    {
                                        <MudLink Href="@TfsUrlBuilder.BuildWorkItemUrl(_tfsConfig.Url, _tfsConfig.Project, pbi.TfsId)"
                                                 Target="_blank"
                                                 Typo="Typo.body2">#@pbi.TfsId</MudLink>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2">#@pbi.TfsId</MudText>
                                    }
                                </td>
                                <td>
                                    <MudText Typo="Typo.body2">@pbi.Title</MudText>
                                </td>
                                <td>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(pbi.ClosedDate.HasValue ? pbi.ClosedDate.Value.ToString("MMM d, yyyy") : "—")
                                    </MudText>
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2">@pbi.Effort</MudText>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                    Total: @completedPbis.Count PBI(s), @completedPbis.Sum(p => p.Effort) story points
                </MudText>
            }
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isContextLoading = true;
    private string? _contextErrorMessage;
    private bool _isSummaryLoading = true;
    private string? _summaryErrorMessage;
    private CanonicalFilterMetadata? _summaryFilterMetadata;
    private bool _isBuildQualityLoading = true;
    private string? _buildQualityErrorMessage;
    private CanonicalFilterMetadata? _buildQualityFilterMetadata;
    private bool _isDetailsLoading;
    private string? _detailsErrorMessage;
    private CanonicalFilterMetadata? _detailsFilterMetadata;
    private bool _detailsLoaded;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private TfsConfigDto? _tfsConfig;
    private SharedDeliveryBuildQualityDto? _sprintBuildQuality;

    private enum DrillDownLevel { Portfolio, Product, Epic, Feature }
    private DrillDownLevel _drillDownLevel = DrillDownLevel.Portfolio;
    private int? _selectedProductId;
    private string? _selectedProductName;
    private int? _selectedEpicId;
    private string? _selectedEpicName;
    private int? _selectedFeatureId;
    private string? _selectedFeatureName;

    private List<TeamDto> _teams = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private List<ProductDto> _products = new();
    private List<ProductDto> _filteredProducts = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;

    private int _completedPbiCount;
    private double _completedPbiStoryPoints;
    private int _sprintEffortDelta;
    private int _completedFeatureCount;
    private int _bugsCreatedCount;
    private int _bugsWorkedCount;
    private int _bugsClosedCount;
    private int _missingEffortCount;
    private bool _isApproximate;
    private List<string> _approximateProducts = new();
    private Dictionary<int, ProductMetrics> _productMetrics = new();

    private int _prevCompletedPbiCount;
    private double _prevCompletedPbiStoryPoints;
    private bool _hasPreviousSprint;

    private List<ProductDeliveryAnalyticsDto> _productAnalytics = new();
    private List<FeatureProgressDto> _featureProgress = new();
    private List<EpicProgressDto> _epicProgress = new();

    private bool _isStale;
    private DateTimeOffset? _projectionsAsOfUtc;
    private List<SprintTrendMetricsDto> _trendMetrics = new();

    private readonly CancellationTokenSource _lifetimeCts = new();
    private CancellationTokenSource? _contextLoadCts;
    private CancellationTokenSource? _summaryLoadCts;
    private CancellationTokenSource? _detailsLoadCts;
    private CancellationTokenSource? _buildQualityLoadCts;

    private static readonly string[] DefaultPiePalette =
    [
        "#2979FF",
        "#1DE9B6",
        "#FFC400",
        "#FF9100",
        "#651FFF",
        "#00E676",
        "#00B0FF",
        "#26A69A",
    ];

    protected override void OnInitialized()
    {
        UpdateBreadcrumbs();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = LoadContextAsync();
        }

        return Task.CompletedTask;
    }

    private async Task LoadContextAsync()
    {
        CancelContextLoad();
        CancelSummaryLoad();
        CancelDetailsLoad();
        CancelBuildQualityLoad();

        var cancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_lifetimeCts.Token);
        _contextLoadCts = cancellationTokenSource;

        _isContextLoading = true;
        _contextErrorMessage = null;
        _isSummaryLoading = true;
        _summaryErrorMessage = null;
        ResetSummaryData();
        ResetDetailsData();
        await InvokeAsync(StateHasChanged);

        try
        {
            var cancellationToken = cancellationTokenSource.Token;
            var profileTask = ProfileService.GetActiveProfileAsync(cancellationToken);
            var teamsTask = TeamService.GetAllTeamsAsync(includeArchived: false, cancellationToken: cancellationToken);
            var configTask = TfsConfigService.GetConfigAsync(cancellationToken);

            var activeProfile = await profileTask;
            _profileId = activeProfile?.Id;

            if (_profileId is null)
            {
            _contextErrorMessage = "No active profile selected.";
            _isSummaryLoading = false;
            _isBuildQualityLoading = false;
            return;
        }

            var productsTask = ProductService.GetProductsByOwnerAsync(_profileId.Value, cancellationToken);

            _teams = (await teamsTask).ToList();
            _products = (await productsTask).ToList();
            _tfsConfig = await configTask;

            var sprintTasks = _teams.Select(team => LoadTeamSprintsSafeAsync(team.Id, cancellationToken));
            var sprintSets = await Task.WhenAll(sprintTasks);
            _allSprints = sprintSets
                .SelectMany(sprints => sprints)
                .GroupBy(sprint => sprint.Id)
                .Select(group => group.First())
                .ToList();

            ApplySprintFilters();
            FindCurrentSprint();
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _contextErrorMessage = $"Failed to load sprint context: {ex.Message}";
            _isSummaryLoading = false;
            return;
        }
        finally
        {
            _isContextLoading = false;
            await InvokeAsync(StateHasChanged);
        }

        if (_currentSprint is not null)
        {
            await Task.WhenAll(
                LoadSummaryAsync(),
                LoadBuildQualityAsync());
        }
        else
        {
            _isSummaryLoading = false;
            _isBuildQualityLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<IReadOnlyList<SprintDto>> LoadTeamSprintsSafeAsync(int teamId, CancellationToken cancellationToken)
    {
        try
        {
            return (await SprintService.GetSprintsForTeamAsync(teamId, cancellationToken)).ToList();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch
        {
            return Array.Empty<SprintDto>();
        }
    }

    private async Task RetryContextLoadAsync()
    {
        if (_lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        await LoadContextAsync();
    }

    private async Task RetrySummaryLoadAsync()
    {
        if (_lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        await LoadSummaryAsync();
    }

    private async Task RetryBuildQualityLoadAsync()
    {
        if (_lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        await LoadBuildQualityAsync();
    }

    private async Task RetryDetailsLoadAsync()
    {
        if (_lifetimeCts.IsCancellationRequested)
        {
            return;
        }

        await LoadDetailsAsync();
    }

    private void ApplySprintFilters()
    {
        _filteredSprints = _allSprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .ToList();

        _filteredProducts = _products.ToList();
    }

    private void FindCurrentSprint()
    {
        var now = DateTimeOffset.UtcNow;
        _currentSprintIndex = _filteredSprints.FindIndex(s =>
            s.StartUtc <= now && s.EndUtc >= now);

        if (_currentSprintIndex < 0 && _filteredSprints.Count > 0)
        {
            _currentSprintIndex = _filteredSprints.FindLastIndex(s => s.EndUtc <= now);
            if (_currentSprintIndex < 0)
            {
                _currentSprintIndex = _filteredSprints.Count - 1;
            }
        }

        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadSummaryAsync()
    {
        CancelSummaryLoad();
        CancelDetailsLoad();
        ResetSummaryData();
        ResetDetailsData();

        if (!_profileId.HasValue || _currentSprint is null)
        {
            _isSummaryLoading = false;
            _summaryErrorMessage = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_lifetimeCts.Token);
        _summaryLoadCts = cancellationTokenSource;
        _isSummaryLoading = true;
        _summaryErrorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var sprintIds = new List<int> { _currentSprint.Id };
            if (_currentSprintIndex > 0)
            {
                sprintIds.Insert(0, _filteredSprints[_currentSprintIndex - 1].Id);
            }

            var response = await SprintDeliveryMetricsService.GetSprintTrendMetricsAsync(
                _profileId.Value,
                sprintIds,
                recompute: false,
                includeDetails: false,
                cancellationToken: cancellationTokenSource.Token);
            _summaryFilterMetadata = response.FilterMetadata;

            if (!response.Data.Success || response.Data.Metrics is null)
            {
                _summaryErrorMessage = response.Data.ErrorMessage ?? "Sprint summary unavailable right now.";
                return;
            }

            ApplySummaryMetrics(response.Data);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _summaryFilterMetadata = null;
            _summaryErrorMessage = $"Sprint summary unavailable right now: {ex.Message}";
        }
        finally
        {
            _isSummaryLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadBuildQualityAsync()
    {
        CancelBuildQualityLoad();
        _sprintBuildQuality = null;

        if (!_profileId.HasValue || _currentSprint is null)
        {
            _isBuildQualityLoading = false;
            _buildQualityErrorMessage = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_lifetimeCts.Token);
        _buildQualityLoadCts = cancellationTokenSource;
        _isBuildQualityLoading = true;
        _buildQualityErrorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var buildQualityResponse = await BuildQualityService.GetSprintAsync(
                _profileId.Value,
                _currentSprint.Id,
                cancellationTokenSource.Token);
            _buildQualityFilterMetadata = buildQualityResponse.FilterMetadata;
            _sprintBuildQuality = buildQualityResponse.Data;
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _buildQualityFilterMetadata = null;
            _buildQualityErrorMessage = $"Build Quality unavailable right now: {ex.Message}";
        }
        finally
        {
            _isBuildQualityLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplySummaryMetrics(GetSprintTrendMetricsResponse response)
    {
        _isStale = response.IsStale;
        _projectionsAsOfUtc = response.ProjectionsAsOfUtc;

        _trendMetrics = response.Metrics?
            .OrderBy(metric => metric.StartUtc ?? DateTimeOffset.MaxValue)
            .ToList() ?? new List<SprintTrendMetricsDto>();
        _productAnalytics = response.ProductAnalytics?.ToList() ?? new List<ProductDeliveryAnalyticsDto>();

        var currentMetrics = _trendMetrics.LastOrDefault();
        if (currentMetrics is null)
        {
            return;
        }

        var filteredProductMetrics = currentMetrics.ProductMetrics.ToList();
        _completedPbiCount = filteredProductMetrics.Sum(metric => metric.CompletedPbiCount);
        _completedPbiStoryPoints = filteredProductMetrics.Sum(metric => metric.CompletedPbiStoryPoints);
        _bugsCreatedCount = filteredProductMetrics.Sum(metric => metric.BugsCreatedCount);
        _bugsWorkedCount = filteredProductMetrics.Sum(metric => metric.BugsWorkedCount);
        _bugsClosedCount = filteredProductMetrics.Sum(metric => metric.BugsClosedCount);
        _missingEffortCount = filteredProductMetrics.Sum(metric => metric.MissingEffortCount);
        _sprintEffortDelta = filteredProductMetrics.Sum(metric => metric.ScopeChangeEffort ?? 0);
        _completedFeatureCount = filteredProductMetrics.Sum(metric => metric.CompletedFeatureCount ?? 0);
        _isApproximate = filteredProductMetrics.Any(metric => metric.IsApproximate);
        _approximateProducts = filteredProductMetrics
            .Where(metric => metric.IsApproximate)
            .Select(metric => metric.ProductName)
            .ToList();

        foreach (var productMetric in filteredProductMetrics)
        {
            _productMetrics[productMetric.ProductId] = new ProductMetrics(
                productMetric.CompletedPbiCount,
                productMetric.CompletedPbiStoryPoints,
                productMetric.MissingEffortCount,
                productMetric.IsApproximate,
                productMetric.BugsCreatedCount,
                productMetric.BugsWorkedCount,
                productMetric.BugsClosedCount,
                productMetric.ScopeChangeEffort,
                productMetric.CompletedFeatureCount);
        }

        ExtractComparisonMetrics();
    }

    private async Task LoadDetailsAsync()
    {
        CancelDetailsLoad();
        ResetDetailsData();

        if (!_profileId.HasValue || _currentSprint is null)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_lifetimeCts.Token);
        _detailsLoadCts = cancellationTokenSource;
        _isDetailsLoading = true;
        _detailsErrorMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = await SprintDeliveryMetricsService.GetSprintTrendMetricsAsync(
                _profileId.Value,
                new[] { _currentSprint.Id },
                recompute: false,
                includeDetails: true,
                cancellationToken: cancellationTokenSource.Token);
            _detailsFilterMetadata = response.FilterMetadata;

            if (!response.Data.Success)
            {
                _detailsErrorMessage = response.Data.ErrorMessage ?? "Sprint drilldown unavailable right now.";
                return;
            }

            BuildFeatureProgress(response.Data);
            _detailsLoaded = true;
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _detailsFilterMetadata = null;
            _detailsErrorMessage = $"Sprint drilldown unavailable right now: {ex.Message}";
        }
        finally
        {
            _isDetailsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ResetSummaryData()
    {
        _completedPbiCount = 0;
        _completedPbiStoryPoints = 0;
        _sprintEffortDelta = 0;
        _completedFeatureCount = 0;
        _bugsCreatedCount = 0;
        _bugsWorkedCount = 0;
        _bugsClosedCount = 0;
        _missingEffortCount = 0;
        _isApproximate = false;
        _isStale = false;
        _projectionsAsOfUtc = null;
        _approximateProducts.Clear();
        _productMetrics.Clear();
        _productAnalytics.Clear();
        _trendMetrics.Clear();
        _prevCompletedPbiCount = 0;
        _prevCompletedPbiStoryPoints = 0;
        _hasPreviousSprint = false;
    }

    private void ResetDetailsData()
    {
        _detailsLoaded = false;
        _detailsErrorMessage = null;
        _featureProgress.Clear();
        _epicProgress.Clear();
    }

    private void BuildFeatureProgress(GetSprintTrendMetricsResponse? response)
    {
        _featureProgress = response?.FeatureProgress?.ToList() ?? new List<FeatureProgressDto>();
        _epicProgress = response?.EpicProgress?.ToList() ?? new List<EpicProgressDto>();
    }

    private void ExtractComparisonMetrics()
    {
        if (_trendMetrics.Count >= 2)
        {
            var previousMetrics = _trendMetrics[_trendMetrics.Count - 2];
            var previousProducts = previousMetrics.ProductMetrics.ToList();
            _prevCompletedPbiCount = previousProducts.Sum(metric => metric.CompletedPbiCount);
            _prevCompletedPbiStoryPoints = previousProducts.Sum(metric => metric.CompletedPbiStoryPoints);
            _hasPreviousSprint = true;
            return;
        }

        _prevCompletedPbiCount = 0;
        _prevCompletedPbiStoryPoints = 0;
        _hasPreviousSprint = false;
    }

    private async Task EnsureDetailsLoadedAsync()
    {
        if (_detailsLoaded || _isDetailsLoading)
        {
            return;
        }

        await LoadDetailsAsync();
    }

    private async Task HandleDrillDownKeyAsync(KeyboardEventArgs args, Func<Task> action)
    {
        if (args.Key is "Enter" or " " or "Space" or "Spacebar")
        {
            await action();
        }
    }

    private async Task DrillIntoProductAsync(int productId, string productName)
    {
        _selectedProductId = productId;
        _selectedProductName = productName;
        _selectedEpicId = null;
        _selectedEpicName = null;
        _selectedFeatureId = null;
        _selectedFeatureName = null;
        _drillDownLevel = DrillDownLevel.Product;
        await InvokeAsync(StateHasChanged);
        await EnsureDetailsLoadedAsync();
    }

    private async Task DrillIntoEpicAsync(int epicId, string epicTitle)
    {
        _selectedEpicId = epicId;
        _selectedEpicName = epicTitle;
        _selectedFeatureId = null;
        _selectedFeatureName = null;
        _drillDownLevel = DrillDownLevel.Epic;
        await InvokeAsync(StateHasChanged);
        await EnsureDetailsLoadedAsync();
    }

    private async Task DrillIntoFeatureAsync(int featureId, string featureTitle)
    {
        _selectedFeatureId = featureId;
        _selectedFeatureName = featureTitle;
        _drillDownLevel = DrillDownLevel.Feature;
        await InvokeAsync(StateHasChanged);
        await EnsureDetailsLoadedAsync();
    }

    private void DrillUp()
    {
        switch (_drillDownLevel)
        {
            case DrillDownLevel.Feature:
                RestoreEpicLevel();
                break;
            case DrillDownLevel.Epic:
                RestoreProductLevel();
                break;
            case DrillDownLevel.Product:
                RestorePortfolioLevel();
                break;
        }
    }

    private void ResetDrillDown()
    {
        _drillDownLevel = DrillDownLevel.Portfolio;
        _selectedProductId = null;
        _selectedProductName = null;
        _selectedEpicId = null;
        _selectedEpicName = null;
        _selectedFeatureId = null;
        _selectedFeatureName = null;
    }

    private void RestorePortfolioLevel()
    {
        ResetDrillDown();
    }

    private void RestoreProductLevel()
    {
        if (!_selectedProductId.HasValue || string.IsNullOrWhiteSpace(_selectedProductName))
        {
            RestorePortfolioLevel();
            return;
        }

        _selectedEpicId = null;
        _selectedEpicName = null;
        _selectedFeatureId = null;
        _selectedFeatureName = null;
        _drillDownLevel = DrillDownLevel.Product;
    }

    private void RestoreEpicLevel()
    {
        if (!_selectedEpicId.HasValue || string.IsNullOrWhiteSpace(_selectedEpicName))
        {
            RestoreProductLevel();
            return;
        }

        _selectedFeatureId = null;
        _selectedFeatureName = null;
        _drillDownLevel = DrillDownLevel.Epic;
    }

    private record BarChartItem(string Label, double Percent);

    private List<BarChartItem> GetProductBarChartData()
    {
        var activeProducts = GetActiveProducts();
        var total = activeProducts.Sum(product => GetProductCompletedStoryPoints(product.Id));
        return activeProducts
            .OrderByDescending(product => GetProductCompletedStoryPoints(product.Id))
            .Select(product => new BarChartItem(
                product.Name,
                total > 0 ? GetProductCompletedStoryPoints(product.Id) * 100.0 / total : 0))
            .ToList();
    }

    private static string TruncateBarLabel(string label, int maxLength = 22)
    {
        return label.Length > maxLength ? label[..maxLength] + "…" : label;
    }

    private static string FormatSignedInt(int diff) => diff >= 0 ? $"+{diff}" : $"{diff}";
    private static string FormatSignedStoryPoints(double diff) => diff >= 0 ? $"+{diff:0.##}" : $"{diff:0.##}";
    private static string FormatStoryPoints(double storyPoints) => storyPoints.ToString("0.##");

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Delivery", WorkspaceRoutes.DeliveryWorkspace, icon: Icons.Material.Filled.Inventory2),
            new("Sprint Delivery", null, disabled: true, icon: Icons.Material.Filled.RunCircle)
        };
    }

    private bool CanNavigatePrevious() => _currentSprintIndex > 0;

    private bool CanNavigateNext() =>
        _currentSprintIndex >= 0 && _currentSprintIndex < _filteredSprints.Count - 1;

    private async Task NavigateToPreviousSprintAsync()
    {
        if (!CanNavigatePrevious())
        {
            return;
        }

        _currentSprintIndex--;
        _currentSprint = _filteredSprints[_currentSprintIndex];
        ResetDrillDown();
        await Task.WhenAll(
            LoadSummaryAsync(),
            LoadBuildQualityAsync());
    }

    private async Task NavigateToNextSprintAsync()
    {
        if (!CanNavigateNext())
        {
            return;
        }

        _currentSprintIndex++;
        _currentSprint = _filteredSprints[_currentSprintIndex];
        ResetDrillDown();
        await Task.WhenAll(
            LoadSummaryAsync(),
            LoadBuildQualityAsync());
    }

    private int GetProductCompletedPbis(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.CompletedPbis : 0;
    }

    private double GetProductCompletedStoryPoints(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.CompletedStoryPoints : 0;
    }

    private int GetProductMissingEffort(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.MissingEffort : 0;
    }

    private bool IsProductApproximate(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) && metrics.IsApproximate;
    }

    private int GetProductCompletedFeatures(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.CompletedFeatures ?? 0 : 0;
    }

    private string GetProductApproximationTooltip(int productId, string productName)
    {
        var missingEffort = GetProductMissingEffort(productId);
        return missingEffort > 0
            ? $"{productName}: {missingEffort} PBI(s) are missing effort. Sibling-average approximation was applied for progression."
            : $"{productName}: Approximate progression values were flagged by projection computation for this sprint.";
    }

    private string BuildWorkItemActivityUrl(int workItemId)
    {
        var path = $"{WorkspaceRoutes.SprintDeliveryActivity}/{workItemId}";
        if (!_profileId.HasValue)
        {
            return path;
        }

        var periodStartUtc = _currentSprint?.StartUtc;
        var periodEndUtc = _currentSprint?.EndUtc;

        var query = new List<string> { $"productOwnerId={_profileId.Value}" };
        if (periodStartUtc.HasValue)
        {
            query.Add($"periodStartUtc={Uri.EscapeDataString(periodStartUtc.Value.UtcDateTime.ToString("O"))}");
        }

        if (periodEndUtc.HasValue)
        {
            query.Add($"periodEndUtc={Uri.EscapeDataString(periodEndUtc.Value.UtcDateTime.ToString("O"))}");
        }

        return $"{path}?{string.Join("&", query)}";
    }

    private List<EpicProgressDto> GetEpicProgressForProduct(int productId)
    {
        return _epicProgress
            .Where(epic => epic.ProductId == productId)
            .ToList();
    }

    private List<EpicProgressDto> GetVisibleEpicsForProduct(int productId)
    {
        return GetEpicProgressForProduct(productId);
    }

    private List<FeatureProgressDto> GetVisibleFeaturesForEpic(int epicId)
    {
        return _featureProgress
            .Where(feature => feature.EpicId == epicId
                && (feature.SprintCompletedEffort > 0 || feature.SprintEffortDelta != 0 || feature.SprintCompletedPbiCount > 0))
            .ToList();
    }

    private List<CompletedPbiDto> GetCompletedPbisForFeature(int featureId)
    {
        var feature = _featureProgress.FirstOrDefault(item => item.FeatureId == featureId);
        return feature?.CompletedPbis?.ToList() ?? new List<CompletedPbiDto>();
    }

    private ProductDeliveryAnalyticsDto? GetProductAnalytics(int productId)
    {
        return _productAnalytics.FirstOrDefault(analytics => analytics.ProductId == productId);
    }

    private FeatureProgressDto? GetFeatureProgress(int featureId)
    {
        return _featureProgress.FirstOrDefault(feature => feature.FeatureId == featureId);
    }

    private List<ProductDto> GetActiveProducts()
    {
        return _filteredProducts.Where(product => IsProductActive(product.Id)).ToList();
    }

    private bool IsProductActive(int productId)
    {
        if (!_productMetrics.TryGetValue(productId, out var metrics))
        {
            return false;
        }

        return metrics.CompletedPbis > 0
            || metrics.CompletedStoryPoints > 0
            || metrics.BugsCreated > 0
            || metrics.BugsWorked > 0
            || metrics.BugsClosed > 0
            || metrics.ScopeChangeEffort is not null and not 0;
    }

    private int GetProductSprintEffortDelta(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.ScopeChangeEffort ?? 0 : 0;
    }

    private string GetEpicColor(int index)
    {
        return DefaultPiePalette[index % DefaultPiePalette.Length];
    }

    private int GetEpicColorIndex(int productId, int epicId)
    {
        return GetEpicProgressForProduct(productId)
            .Where(epic => epic.DoneStoryPoints > 0)
            .ToList()
            .FindIndex(epic => epic.EpicId == epicId);
    }

    private string GetEpicColorSquareStyle(int productId, int epicId)
    {
        var index = GetEpicColorIndex(productId, epicId);
        var color = index < 0 ? "#9E9E9E" : GetEpicColor(index);
        return $"width: 10px; height: 10px; border-radius: 2px; display: inline-block; background-color: {color};";
    }

