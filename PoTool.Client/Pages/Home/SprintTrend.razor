        UpdateUrlViewMode();
        await LoadMetricsAsync();
        StateHasChanged();
    }

    private async Task OnTrendLastSprintChanged(int sprintId)
    {
        var index = _filteredSprints.FindIndex(s => s.Id == sprintId);
        if (index >= 0)
        {
            _currentSprintIndex = index;
            _currentSprint = _filteredSprints[index];
            await LoadMetricsAsync();
            StateHasChanged();
        }
    }

    private async Task OnTrendSprintCountChanged(int count)
    {
        _trendSprintCount = Math.Max(1, count);
        await LoadMetricsAsync();
        StateHasChanged();
    }

    private async Task RecomputeMetricsAsync()
    {
        if (!_profileId.HasValue || _currentSprint == null || _isRecomputing)
            return;

        _isRecomputing = true;
        StateHasChanged();

        try
        {
            List<int> sprintIds;
            if (_advancedMode)
            {
                var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
                sprintIds = _filteredSprints
                    .Skip(startIndex)
                    .Take(_currentSprintIndex - startIndex + 1)
                    .Select(s => s.Id)
                    .ToList();
            }
            else
            {
                sprintIds = new List<int> { _currentSprint.Id };
            }

            var response = await SprintTrendService.GetSprintTrendMetricsAsync(
                _profileId.Value,
                sprintIds,
                recompute: true);

            if (response != null && response.Success && response.Metrics != null)
            {
                ResetMetrics();

                _isStale = false;
                _projectionsAsOfUtc = response.ProjectionsAsOfUtc;

                _trendMetrics = response.Metrics
                    .OrderBy(m => m.StartUtc ?? DateTimeOffset.MaxValue)
                    .ToList();

                var currentMetrics = _advancedMode
                    ? _trendMetrics.LastOrDefault()
                    : _trendMetrics.FirstOrDefault();

                if (currentMetrics != null)
                {
                    var filteredProductMetrics = _selectedProductId.HasValue
                        ? currentMetrics.ProductMetrics.Where(m => m.ProductId == _selectedProductId.Value).ToList()
                        : currentMetrics.ProductMetrics.ToList();

                    _completedPbiCount = filteredProductMetrics.Sum(m => m.CompletedPbiCount);
                    _completedPbiEffort = filteredProductMetrics.Sum(m => m.CompletedPbiEffort);
                    _progressionDelta = filteredProductMetrics.Sum(m => m.ProgressionDelta);
                    _bugsCreatedCount = filteredProductMetrics.Sum(m => m.BugsCreatedCount);
                    _bugsWorkedCount = filteredProductMetrics.Sum(m => m.BugsWorkedCount);
                    _bugsClosedCount = filteredProductMetrics.Sum(m => m.BugsClosedCount);
                    _missingEffortCount = filteredProductMetrics.Sum(m => m.MissingEffortCount);
                    _isApproximate = filteredProductMetrics.Any(m => m.IsApproximate);

                    _approximateProducts = filteredProductMetrics
                        .Where(m => m.IsApproximate)
                        .Select(m => m.ProductName)
                        .ToList();

                    foreach (var productMetric in filteredProductMetrics)
                    {
                        _productMetrics[productMetric.ProductId] = new ProductMetrics(
                            productMetric.CompletedPbiCount,
                            productMetric.CompletedPbiEffort,
                            productMetric.ProgressionDelta,
                            productMetric.MissingEffortCount,
                            productMetric.IsApproximate,
                            productMetric.BugsCreatedCount,
                            productMetric.BugsWorkedCount,
                            productMetric.BugsClosedCount);
                    }
                }

                BuildFeatureProgress(response);
                if (_advancedMode) BuildTrendCharts();

                Snackbar.Add("Metrics recomputed successfully.", Severity.Success);
            }
            else
            {
                Snackbar.Add("Recomputation failed.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Recomputation error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRecomputing = false;
            StateHasChanged();
        }
    }

