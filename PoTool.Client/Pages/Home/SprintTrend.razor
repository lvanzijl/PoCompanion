            { nameof(EpicFeaturesDialog.Features), (IReadOnlyList<FeatureProgressDto>)epicFeatures },
            { nameof(EpicFeaturesDialog.TfsUrl), _tfsConfig?.Url },
            { nameof(EpicFeaturesDialog.TfsProject), _tfsConfig?.Project }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<EpicFeaturesDialog>($"Features — {epic.EpicTitle}", parameters, options);
    }

