    private string BuildWorkItemActivityUrl(int workItemId)
    {
        var path = $"{WorkspaceRoutes.SprintDeliveryActivity}/{workItemId}";
        if (!_profileId.HasValue)
        {
            return path;
        }

        var periodStartUtc = _currentSprint?.StartUtc;
        var periodEndUtc = _currentSprint?.EndUtc;

        var query = new List<string> { $"productOwnerId={_profileId.Value}" };
        if (periodStartUtc.HasValue)
        {
            query.Add($"periodStartUtc={Uri.EscapeDataString(periodStartUtc.Value.UtcDateTime.ToString("O"))}");
        }

        if (periodEndUtc.HasValue)
        {
            query.Add($"periodEndUtc={Uri.EscapeDataString(periodEndUtc.Value.UtcDateTime.ToString("O"))}");
        }

        return $"{path}?{string.Join("&", query)}";
    }

    private List<EpicProgressDto> GetEpicProgressForProduct(int productId)
    {
        return _epicProgress
            .Where(e => e.ProductId == productId)
            .ToList();
    }

    /// <summary>
    /// Returns epics for a product that have monitored activity during the sprint.
    /// Visibility is based solely on the presence of at least one non-noise field change
    /// (i.e. not System.ChangedBy / System.ChangedDate) on the epic or any of its
    /// descendants within the sprint window.  The backend already filters the epic list
    /// to activity-only epics, so no additional delivery-gate is applied here.
    /// Do NOT filter on Delivered pts, Δ Effort, Features ✓, or PBIs ✓ — those are
    /// metrics, not visibility rules (see issue: Fix Epic Visibility Using Monitored Activity).
    /// </summary>
    private List<EpicProgressDto> GetVisibleEpicsForProduct(int productId)
    {
        return GetEpicProgressForProduct(productId);
    }

    /// <summary>
    /// Returns true when a product has any delivery signal in the current sprint.
    /// Products with Delivered=0 AND ΔEffort=0 AND no PBI/bug activity are hidden.
    /// </summary>
    private bool IsProductActive(int productId)
    {
        if (!_productMetrics.TryGetValue(productId, out var metrics))
            return false;

        return metrics.CompletedPbis > 0
            || metrics.CompletedEffort > 0
            || metrics.BugsCreated > 0
            || metrics.BugsWorked > 0
            || metrics.BugsClosed > 0
            || GetProductSprintEffortDelta(productId) != 0;
    }

    /// <summary>
    /// Aggregates SprintEffortDelta from all visible epics for the given product.
    /// </summary>
    private int GetProductSprintEffortDelta(int productId)
    {
        return GetEpicProgressForProduct(productId).Sum(e => e.SprintEffortDelta);
    }

