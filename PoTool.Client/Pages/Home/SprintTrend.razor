    private string GetProductApproximationTooltip(int productId, string productName)
    {
        var missingEffort = GetProductMissingEffort(productId);
        return missingEffort > 0
            ? $"{productName}: {missingEffort} PBI(s) are missing effort. Sibling-average approximation was applied for progression."
            : $"{productName}: Approximate progression values were flagged by projection computation for this sprint.";
    }

