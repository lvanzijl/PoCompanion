    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);

        // view=zoom forces single-sprint (zoom) mode; anything else (missing or "trend") defaults to multi-sprint
        _advancedMode = queryParams["view"] != "zoom";
    }

    private void UpdateUrlViewMode()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);

        if (_advancedMode)
        {
            queryParams.Remove("view");
        }
        else
        {
            queryParams["view"] = "zoom";
        }

        var newQuery = queryParams.ToString();
        var newUrl = string.IsNullOrEmpty(newQuery)
            ? uri.AbsolutePath
            : $"{uri.AbsolutePath}?{newQuery}";

        NavigationManager.NavigateTo(newUrl, forceLoad: false, replace: true);
    }

