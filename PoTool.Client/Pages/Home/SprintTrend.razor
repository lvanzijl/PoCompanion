    private List<BarChartItem> GetProductBarChartData()
    {
        var total = _filteredProducts.Sum(p => (double)GetProductCompletedEffort(p.Id));
        return _filteredProducts
            .OrderByDescending(p => GetProductCompletedEffort(p.Id))
            .Select(p => new BarChartItem(
                p.Name,
                total > 0 ? GetProductCompletedEffort(p.Id) * 100.0 / total : 0))
            .ToList();
    }

