@page "/home/sprint-trend"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Shared.Metrics
@using System.Web
@inject IProfileService ProfileService
@inject TeamService TeamService
@inject SprintService SprintService
@inject ProductService ProductService
@inject SprintTrendService SprintTrendService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Sprint Trend - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.RunCircle" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Sprint Trend
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Back to Trends
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Sprint Navigation with Back/Forward Arrows *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                        Sprint Navigation
                    </MudText>
                    
                    <MudToggleIconButton Toggled="@_advancedMode"
                                         ToggledChanged="OnAdvancedModeToggled"
                                         Icon="@Icons.Material.Filled.BarChart"
                                         ToggledIcon="@Icons.Material.Filled.BarChart"
                                         Color="Color.Default"
                                         ToggledColor="Color.Primary"
                                         Variant="Variant.Outlined"
                                         ToggledSize="Size.Medium"
                                         Size="Size.Medium" />
                </MudStack>

                @if (!_advancedMode)
                {
                    @* Single sprint navigation *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigatePrevious())"
                                       OnClick="NavigateToPreviousSprint"
                                       aria-label="Previous Sprint" />
                        
                        <MudText Typo="Typo.h5" Align="Align.Center">
                            @(_currentSprint?.Name ?? "No sprint selected")
                        </MudText>
                        
                        @if (_currentSprint?.StartUtc != null && _currentSprint?.EndUtc != null)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @_currentSprint.StartUtc.Value.ToString("MMM d") — @_currentSprint.EndUtc.Value.ToString("MMM d, yyyy")
                            </MudText>
                        }
                        
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigateNext())"
                                       OnClick="NavigateToNextSprint"
                                       aria-label="Next Sprint" />
                    </MudStack>
                }
                else
                {
                    @* Advanced mode: multi-sprint trend view *@
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        Showing trend data for the previous @_trendSprintCount sprints (up to and including the currently selected sprint).
                    </MudAlert>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="3">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigatePrevious())"
                                       OnClick="NavigateToPreviousSprint"
                                       aria-label="Previous Sprint" />
                        
                        <MudText Typo="Typo.h6" Align="Align.Center">
                            @GetTrendRangeLabel()
                        </MudText>
                        
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigateNext())"
                                       OnClick="NavigateToNextSprint"
                                       aria-label="Next Sprint" />
                    </MudStack>
                }

                @* Filters *@
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Clearable="true"
                                   ValueChanged="OnProductFilterChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _filteredProducts)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @* Information Notice *@
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Sprint Trend</strong> shows progression metrics derived from activity events.
                <br/>
                <strong>Completed PBIs:</strong> PBIs that transitioned to Done during the sprint.
                <strong>Progression:</strong> Effort-weighted feature completion delta.
                <br/>
                <em>Bug "Worked On" = any child task had a state change during the sprint.</em>
            </MudText>
        </MudAlert>

        @* Warnings for missing effort / approximate data *@
        @if (_isApproximate)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                <strong>Approximate data:</strong> @_missingEffortCount PBI(s) have missing effort.
                Sibling-average approximation was used. State and progression values are marked as approximate.
                @if (_approximateProducts.Count > 0)
                {
                    <br/>
                    <em>Affected products: @string.Join(", ", _approximateProducts)</em>
                }
            </MudAlert>
        }

        @* Metrics Summary Cards *@
        <MudGrid Spacing="3" Class="mb-4">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Completed PBIs</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">@_completedPbiCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_completedPbiEffort pts effort</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Progression Delta
                            @if (_isApproximate)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Class="ml-1" />
                            }
                        </MudText>
                        <MudText Typo="Typo.h4" Color="Color.Primary">@(_progressionDelta.ToString("F1"))%</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">feature/epic forward movement</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs Created</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Error">@_bugsCreatedCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">new bugs in sprint</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
            
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs Closed</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success">@_bugsClosedCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">resolved in sprint</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Phase 2: Multi-sprint trend graphs *@
        @if (_advancedMode && _trendMetrics.Count > 1)
        {
            @* Progression Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                    Progression per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Bar"
                          ChartSeries="@_progressionChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Completed PBIs Count Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                    Completed PBIs (Count) per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_completedPbiCountChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Completed PBI Effort Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Class="mr-2" />
                    Completed PBI Effort per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_completedPbiEffortChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Bug Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
                    Bug Activity Trend
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_bugTrendChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>
        }

        @* Product Metrics (single sprint or advanced mode) *@
        @if (_filteredProducts.Count > 0)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-2" />
                    Progression by Product
                </MudText>

                @if (!_advancedMode && _filteredProducts.Count > 1 && _productMetrics.Values.Any(m => m.CompletedPbis > 0))
                {
                    @* Single sprint, multiple products → pie chart *@
                    <MudChart ChartType="ChartType.Pie"
                              InputData="@GetPieChartData()"
                              InputLabels="@GetPieChartLabels()"
                              Width="300px"
                              Height="300px" />
                }
                
                <MudGrid Spacing="3" Class="mt-3">
                    @foreach (var product in _filteredProducts)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            <MudText Typo="Typo.subtitle1">@product.Name</MudText>
                                            @if (IsProductApproximate(product.Id))
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                            }
                                        </MudStack>
                                    </CardHeaderContent>
                                </MudCardHeader>
                                <MudCardContent>
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Completed PBIs:</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Success">
                                                @GetProductCompletedPbis(product.Id) items
                                            </MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Effort:</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Info">
                                                @GetProductCompletedEffort(product.Id) pts
                                            </MudText>
                                        </MudStack>
                                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                                            <MudText Typo="Typo.body2">Progression:</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Primary">
                                                @(GetProductProgression(product.Id).ToString("F1"))%
                                            </MudText>
                                        </MudStack>
                                        @if (GetProductMissingEffort(product.Id) > 0)
                                        {
                                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                <MudText Typo="Typo.body2" Color="Color.Warning">Missing effort:</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Warning">
                                                    @GetProductMissingEffort(product.Id) PBI(s)
                                                </MudText>
                                            </MudStack>
                                        }
                                        <MudProgressLinear Color="Color.Success" 
                                                          Value="@GetProductProgression(product.Id)" 
                                                          Max="100" 
                                                          Class="mt-2" />
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        @* Phase 3: Feature/Epic Progress Table *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Assessment" Class="mr-2" />
                Feature Progress
            </MudText>
            
            @if (_featureProgress.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    No feature progress data available for the selected sprint.
                    Ensure work items are synced and products are configured.
                </MudAlert>
            }
            else
            {
                <MudSimpleTable Dense="true" Striped="true" Hover="true">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Feature</th>
                            <th style="width: 200px;">Progress</th>
                            <th style="width: 100px; text-align: right;">Done / Total</th>
                            <th style="width: 60px; text-align: center;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var feature in _featureProgress)
                        {
                            <tr>
                                <td>
                                    <MudText Typo="Typo.body2">
                                        @GetProductName(feature.ProductId)
                                    </MudText>
                                </td>
                                <td>
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2"><strong>@feature.FeatureTitle</strong></MudText>
                                        @if (!string.IsNullOrEmpty(feature.EpicTitle))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">Epic: @feature.EpicTitle</MudText>
                                        }
                                    </MudStack>
                                </td>
                                <td>
                                    <MudProgressLinear Color="@GetProgressColor(feature.ProgressPercent)"
                                                      Value="@feature.ProgressPercent"
                                                      Max="100" />
                                </td>
                                <td style="text-align: right;">
                                    <MudText Typo="Typo.body2">@feature.DoneEffort / @feature.TotalEffort</MudText>
                                </td>
                                <td style="text-align: center;">
                                    @if (feature.IsDone)
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2">@feature.ProgressPercent%</MudText>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
        </MudPaper>

        @* Bug Activity Section *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
                Bug Activity
            </MudText>
            
            <MudAlert Severity="Severity.Normal" Dense="true">
                Bug "Worked On" is defined as: any child Task had a state change during the sprint.
            </MudAlert>
            
            <MudStack Row="true" Spacing="4" Class="mt-3">
                <MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Created</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Error">@_bugsCreatedCount</MudText>
                </MudStack>
                <MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Worked On</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Warning">@_bugsWorkedCount</MudText>
                </MudStack>
                <MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Closed</MudText>
                    <MudText Typo="Typo.h5" Color="Color.Success">@_bugsClosedCount</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private const int TrendSprintCount = 10;
    
    private bool _isLoading = true;
    private string? _errorMessage;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Selection state
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private bool _advancedMode;
    private int _trendSprintCount = TrendSprintCount;
    private List<TeamDto> _teams = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private List<ProductDto> _products = new();
    private List<ProductDto> _filteredProducts = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;
    
    // Current sprint metrics
    private int _completedPbiCount;
    private int _completedPbiEffort;
    private double _progressionDelta;
    private int _bugsCreatedCount;
    private int _bugsWorkedCount;
    private int _bugsClosedCount;
    private int _missingEffortCount;
    private bool _isApproximate;
    private List<string> _approximateProducts = new();
    private Dictionary<int, ProductMetrics> _productMetrics = new();
    
    // Feature progress (Phase 3)
    private List<FeatureProgressDto> _featureProgress = new();
    
    // Trend data (Phase 2)
    private List<SprintTrendMetricsDto> _trendMetrics = new();
    private List<ChartSeries> _progressionChartSeries = new();
    private List<ChartSeries> _completedPbiCountChartSeries = new();
    private List<ChartSeries> _completedPbiEffortChartSeries = new();
    private List<ChartSeries> _bugTrendChartSeries = new();
    private string[] _trendXAxisLabels = Array.Empty<string>();
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        YAxisLines = true,
        XAxisLines = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            
            if (_profileId == null)
            {
                _errorMessage = "No active profile selected.";
                return;
            }
            
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value)).ToList();
            _filteredProducts = _products.ToList();
            
            // Load all sprints for all teams under this PO
            _allSprints.Clear();
            foreach (var team in _teams)
            {
                try
                {
                    var teamSprints = (await SprintService.GetSprintsForTeamAsync(team.Id)).ToList();
                    _allSprints.AddRange(teamSprints);
                }
                catch { /* skip teams without sprints */ }
            }

            ApplySprintFilters();
            FindCurrentSprint();
            
            await LoadMetricsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplySprintFilters()
    {
        // Filter sprints by team if selected
        var sprints = _allSprints.AsEnumerable();
        
        if (_selectedTeamId.HasValue)
        {
            sprints = sprints.Where(s => s.TeamId == _selectedTeamId.Value);
        }
        
        _filteredSprints = sprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .ToList();
        
        // Filter products by selected product
        _filteredProducts = _selectedProductId.HasValue
            ? _products.Where(p => p.Id == _selectedProductId.Value).ToList()
            : _products.ToList();
    }

    private void FindCurrentSprint()
    {
        // Default to current sprint or the latest past sprint
        var now = DateTimeOffset.UtcNow;
        _currentSprintIndex = _filteredSprints.FindIndex(s =>
            s.StartUtc <= now && s.EndUtc >= now);

        if (_currentSprintIndex < 0 && _filteredSprints.Count > 0)
        {
            _currentSprintIndex = _filteredSprints.FindLastIndex(s => s.EndUtc <= now);
            if (_currentSprintIndex < 0)
            {
                _currentSprintIndex = _filteredSprints.Count - 1;
            }
        }

        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadMetricsAsync()
    {
        ResetMetrics();
        
        if (!_profileId.HasValue || _currentSprint == null)
        {
            return;
        }

        try
        {
            List<int> sprintIds;
            
            if (_advancedMode)
            {
                // Load previous N sprints up to and including current
                var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
                sprintIds = _filteredSprints
                    .Skip(startIndex)
                    .Take(_currentSprintIndex - startIndex + 1)
                    .Select(s => s.Id)
                    .ToList();
            }
            else
            {
                sprintIds = new List<int> { _currentSprint.Id };
            }

            if (sprintIds.Count == 0)
            {
                return;
            }

            var response = await SprintTrendService.GetSprintTrendMetricsAsync(
                _profileId.Value,
                sprintIds,
                recompute: false);

            if (response == null || !response.Success || response.Metrics == null)
            {
                return;
            }

            // Filter by product if selected
            var metrics = response.Metrics;
            
            _trendMetrics = metrics
                .OrderBy(m => m.StartUtc ?? DateTimeOffset.MaxValue)
                .ToList();
            
            // Aggregate current sprint metrics (last one in trend or single)
            var currentMetrics = _advancedMode
                ? _trendMetrics.LastOrDefault()
                : _trendMetrics.FirstOrDefault();
            
            if (currentMetrics != null)
            {
                var filteredProductMetrics = _selectedProductId.HasValue
                    ? currentMetrics.ProductMetrics.Where(m => m.ProductId == _selectedProductId.Value).ToList()
                    : currentMetrics.ProductMetrics.ToList();

                _completedPbiCount = filteredProductMetrics.Sum(m => m.CompletedPbiCount);
                _completedPbiEffort = filteredProductMetrics.Sum(m => m.CompletedPbiEffort);
                _progressionDelta = filteredProductMetrics.Sum(m => m.ProgressionDelta);
                _bugsCreatedCount = filteredProductMetrics.Sum(m => m.BugsCreatedCount);
                _bugsWorkedCount = filteredProductMetrics.Sum(m => m.BugsWorkedCount);
                _bugsClosedCount = filteredProductMetrics.Sum(m => m.BugsClosedCount);
                _missingEffortCount = filteredProductMetrics.Sum(m => m.MissingEffortCount);
                _isApproximate = filteredProductMetrics.Any(m => m.IsApproximate);
                
                _approximateProducts = filteredProductMetrics
                    .Where(m => m.IsApproximate)
                    .Select(m => m.ProductName)
                    .ToList();

                foreach (var productMetric in filteredProductMetrics)
                {
                    _productMetrics[productMetric.ProductId] = new ProductMetrics(
                        productMetric.CompletedPbiCount,
                        productMetric.CompletedPbiEffort,
                        productMetric.ProgressionDelta,
                        productMetric.MissingEffortCount,
                        productMetric.IsApproximate);
                }
            }
            
            // Build feature progress from real resolved hierarchy data
            BuildFeatureProgress(response);
            
            // Build trend charts if in advanced mode
            if (_advancedMode)
            {
                BuildTrendCharts();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sprint trend metrics: {ex.Message}", Severity.Warning);
        }
    }

    private void ResetMetrics()
    {
        _completedPbiCount = 0;
        _completedPbiEffort = 0;
        _progressionDelta = 0;
        _bugsCreatedCount = 0;
        _bugsWorkedCount = 0;
        _bugsClosedCount = 0;
        _missingEffortCount = 0;
        _isApproximate = false;
        _approximateProducts.Clear();
        _productMetrics.Clear();
        _featureProgress.Clear();
        _trendMetrics.Clear();
        _progressionChartSeries.Clear();
        _completedPbiCountChartSeries.Clear();
        _completedPbiEffortChartSeries.Clear();
        _bugTrendChartSeries.Clear();
        _trendXAxisLabels = Array.Empty<string>();
    }

    private void BuildFeatureProgress(GetSprintTrendMetricsResponse? response)
    {
        _featureProgress.Clear();
        
        if (response?.FeatureProgress == null || response.FeatureProgress.Count == 0)
            return;
        
        // Apply product filter if selected
        var features = _selectedProductId.HasValue
            ? response.FeatureProgress.Where(f => f.ProductId == _selectedProductId.Value).ToList()
            : response.FeatureProgress.ToList();
        
        _featureProgress = features;
    }

    private void BuildTrendCharts()
    {
        if (_trendMetrics.Count == 0) return;
        
        _trendXAxisLabels = _trendMetrics
            .Select(m => m.SprintName)
            .ToArray();
        
        var filteredProducts = _filteredProducts;
        var hasMultipleProducts = filteredProducts.Count > 1;
        
        if (hasMultipleProducts)
        {
            // Per-product series
            _progressionChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return pm?.ProgressionDelta ?? 0;
                }).ToArray()
            }).ToList();
            
            _completedPbiCountChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return (double)(pm?.CompletedPbiCount ?? 0);
                }).ToArray()
            }).ToList();
            
            _completedPbiEffortChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return (double)(pm?.CompletedPbiEffort ?? 0);
                }).ToArray()
            }).ToList();
        }
        else
        {
            // Single total series
            _progressionChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Progression %",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return pm?.ProgressionDelta ?? 0;
                        }
                        return m.TotalProgressionDelta;
                    }).ToArray()
                }
            };
            
            _completedPbiCountChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Completed PBIs",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return (double)(pm?.CompletedPbiCount ?? 0);
                        }
                        return (double)m.TotalCompletedPbiCount;
                    }).ToArray()
                }
            };
            
            _completedPbiEffortChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Completed Effort",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return (double)(pm?.CompletedPbiEffort ?? 0);
                        }
                        return (double)m.TotalCompletedPbiEffort;
                    }).ToArray()
                }
            };
        }
        
        // Bug trend chart — always uses total series (Created / Worked / Closed)
        _bugTrendChartSeries = new List<ChartSeries>
        {
            new()
            {
                Name = "Created",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsCreatedCount ?? 0);
                    }
                    return (double)m.TotalBugsCreatedCount;
                }).ToArray()
            },
            new()
            {
                Name = "Worked On",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsWorkedCount ?? 0);
                    }
                    return (double)m.TotalBugsWorkedCount;
                }).ToArray()
            },
            new()
            {
                Name = "Closed",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsClosedCount ?? 0);
                    }
                    return (double)m.TotalBugsClosedCount;
                }).ToArray()
            }
        };
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Sprint Trend", null, disabled: true, icon: Icons.Material.Filled.RunCircle)
        };
    }

    private bool CanNavigatePrevious() => _currentSprintIndex > 0;
    private bool CanNavigateNext() => _currentSprintIndex >= 0 && _currentSprintIndex < _filteredSprints.Count - 1;

    private async Task NavigateToPreviousSprint()
    {
        if (CanNavigatePrevious())
        {
            _currentSprintIndex--;
            _currentSprint = _filteredSprints[_currentSprintIndex];
            await LoadMetricsAsync();
            StateHasChanged();
        }
    }

    private async Task NavigateToNextSprint()
    {
        if (CanNavigateNext())
        {
            _currentSprintIndex++;
            _currentSprint = _filteredSprints[_currentSprintIndex];
            await LoadMetricsAsync();
            StateHasChanged();
        }
    }

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        ApplySprintFilters();
        FindCurrentSprint();
        await LoadMetricsAsync();
        StateHasChanged();
    }

    private async Task OnProductFilterChanged(int? productId)
    {
        _selectedProductId = productId;
        _filteredProducts = productId.HasValue
            ? _products.Where(p => p.Id == productId.Value).ToList()
            : _products.ToList();
        await LoadMetricsAsync();
        StateHasChanged();
    }

    private async Task OnAdvancedModeToggled(bool toggled)
    {
        _advancedMode = toggled;
        await LoadMetricsAsync();
        StateHasChanged();
    }

    private string GetTrendRangeLabel()
    {
        if (_trendMetrics.Count == 0) return "No data";
        var first = _trendMetrics.First();
        var last = _trendMetrics.Last();
        return $"{first.SprintName} → {last.SprintName} ({_trendMetrics.Count} sprints)";
    }

    private int GetProductCompletedPbis(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.CompletedPbis : 0;
    }

    private int GetProductCompletedEffort(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.CompletedEffort : 0;
    }

    private double GetProductProgression(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.Progression : 0;
    }

    private int GetProductMissingEffort(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) ? metrics.MissingEffort : 0;
    }

    private bool IsProductApproximate(int productId)
    {
        return _productMetrics.TryGetValue(productId, out var metrics) && metrics.IsApproximate;
    }

    private string GetProductName(int productId)
    {
        return _products.FirstOrDefault(p => p.Id == productId)?.Name ?? "Unknown";
    }

    private double[] GetPieChartData()
    {
        return _filteredProducts
            .Select(p => (double)GetProductCompletedPbis(p.Id))
            .ToArray();
    }

    private string[] GetPieChartLabels()
    {
        return _filteredProducts.Select(p => p.Name).ToArray();
    }

    private Color GetProgressColor(int progress)
    {
        return progress switch
        {
            >= 90 => Color.Success,
            >= 50 => Color.Warning,
            _ => Color.Error
        };
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.TrendsWorkspace);
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }

    private record ProductMetrics(int CompletedPbis, int CompletedEffort, double Progression, int MissingEffort, bool IsApproximate);
}
