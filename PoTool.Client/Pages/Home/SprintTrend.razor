@page "/home/sprint-trend"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Shared.Metrics
@using PoTool.Shared.WorkItems
@using System.Web
@inject IProfileService ProfileService
@inject TeamService TeamService
@inject SprintService SprintService
@inject ProductService ProductService
@inject SprintTrendService SprintTrendService
@inject TfsConfigService TfsConfigService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Sprint Trend - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.RunCircle" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Sprint Trend
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Back to Trends
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Sprint Navigation with Back/Forward Arrows *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                        Sprint Navigation
                    </MudText>
                    
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2" Color="@(_advancedMode ? Color.Primary : Color.Default)">
                            @(_advancedMode ? "Trend (Multi-sprint)" : "Zoom (Single sprint)")
                        </MudText>
                        <MudTooltip Text="@(_advancedMode ? "Click to switch to Zoom (Single sprint)" : "Click to switch to Trend (Multi-sprint)")">
                            <MudToggleIconButton Toggled="@_advancedMode"
                                                 ToggledChanged="OnAdvancedModeToggled"
                                                 Icon="@Icons.Material.Filled.BarChart"
                                                 ToggledIcon="@Icons.Material.Filled.BarChart"
                                                 Color="Color.Default"
                                                 ToggledColor="Color.Primary"
                                                 Variant="Variant.Outlined"
                                                 ToggledSize="Size.Medium"
                                                 Size="Size.Medium" />
                        </MudTooltip>
                    </MudStack>
                </MudStack>

                @if (!_advancedMode)
                {
                    @* Single sprint navigation *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigatePrevious())"
                                       OnClick="NavigateToPreviousSprint"
                                       aria-label="Previous Sprint" />
                        
                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudText Typo="Typo.h5" Align="Align.Center">
                                @(_currentSprint?.Name ?? "No sprint selected")
                            </MudText>
                            @if (_currentSprint?.StartUtc != null && _currentSprint?.EndUtc != null)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_currentSprint.StartUtc.Value.ToString("MMM d") — @_currentSprint.EndUtc.Value.ToString("MMM d, yyyy")
                                </MudText>
                            }
                        </MudStack>
                        
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigateNext())"
                                       OnClick="NavigateToNextSprint"
                                       aria-label="Next Sprint" />
                    </MudStack>
                }
                else
                {
                    @* Advanced mode: multi-sprint trend view *@
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        Showing trend data for the previous @_trendSprintCount sprints ending at the selected sprint.
                    </MudAlert>
                    
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" Label="Last sprint to show"
                                       Value="@(_currentSprint?.Id ?? 0)"
                                       ValueChanged="OnTrendLastSprintChanged"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       FullWidth="true">
                                @foreach (var sprint in _filteredSprints)
                                {
                                    <MudSelectItem Value="@sprint.Id">@sprint.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField T="int" Label="Number of sprints to show"
                                             Value="@_trendSprintCount"
                                             ValueChanged="OnTrendSprintCountChanged"
                                             Min="1"
                                             Max="@MaxAvailableSprints"
                                             Variant="Variant.Outlined"
                                             FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" aria-label="Current sprint range">@GetTrendRangeLabel()</MudText>
                        </MudItem>
                    </MudGrid>
                }

            </MudStack>
        </MudPaper>

        @* Single-sprint: aggregated summary across all products *@
        @if (!_advancedMode && _productMetrics.Count > 0)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-1" />
                    All Products — Sprint Summary
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="12" md="@(_filteredProducts.Count > 1 ? 4 : 12)">
                        <MudGrid Spacing="2">
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Completed PBIs</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Success">@_completedPbiCount</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Effort</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Info">@_completedPbiEffort pts</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Progression Δ</MudText>
                                    <MudText Typo="Typo.h5" Color="Color.Primary">@_progressionDelta.ToString("F1")%</MudText>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12">
                                <MudPaper Elevation="1" Class="pa-3">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs (Created / Worked / Closed)</MudText>
                                    <MudText Typo="Typo.h5">@_bugsCreatedCount / @_bugsWorkedCount / @_bugsClosedCount</MudText>
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    </MudItem>
                    @if (_filteredProducts.Count > 1)
                    {
                        <MudItem xs="12" md="8">
                            <MudChart ChartType="ChartType.Pie"
                                      InputData="@GetAllProductsPieData()"
                                      InputLabels="@GetAllProductsPieLabels()"
                                      LegendPosition="Position.Right"
                                      Width="100%"
                                      Height="250px"
                                      ChartOptions="@_pieChartOptions" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        @* Phase 2: Multi-sprint trend graphs *@
        @if (_advancedMode && _trendMetrics.Count > 1)
        {
            @* Progression Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                    Progression per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Bar"
                          ChartSeries="@_progressionChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Completed PBIs Count Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                    Completed PBIs (Count) per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_completedPbiCountChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Completed PBI Effort Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.FitnessCenter" Class="mr-2" />
                    Completed PBI Effort per Sprint
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_completedPbiEffortChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>

            @* Bug Trend Chart *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
                    Bug Activity Trend
                </MudText>
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_bugTrendChartSeries"
                          XAxisLabels="@_trendXAxisLabels"
                          Width="100%"
                          Height="300px"
                          ChartOptions="@_chartOptions" />
            </MudPaper>
        }

        @if (_filteredProducts.Count > 0)
        {
            <MudExpansionPanels MultiExpansion="true" Class="mb-4">
                @foreach (var product in _filteredProducts)
                {
                    var productEpics = GetEpicProgressForProduct(product.Id);
                    <MudExpansionPanel Expanded="@(_filteredProducts.Count == 1)">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" />
                                <MudText Typo="Typo.h6">@product.Name</MudText>
                                @if (IsProductApproximate(product.Id))
                                {
                                    <MudTooltip Text="@GetProductApproximationTooltip(product.Id, product.Name)">
                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
                                    </MudTooltip>
                                }
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-1" />
                                Progression by Product
                            </MudText>
                            <MudGrid Spacing="2" Class="mb-4">
                                <MudItem xs="12" md="@(HasEpicPieChart(product.Id) ? 4 : 12)">
                                    <MudGrid Spacing="2">
                                        <MudItem xs="12">
                                            <MudPaper Elevation="1" Class="pa-3">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Completed PBIs</MudText>
                                                <MudText Typo="Typo.h5" Color="Color.Success">@GetProductCompletedPbis(product.Id)</MudText>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudPaper Elevation="1" Class="pa-3">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Effort</MudText>
                                                <MudText Typo="Typo.h5" Color="Color.Info">@GetProductCompletedEffort(product.Id) pts</MudText>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudPaper Elevation="1" Class="pa-3">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Progression Δ</MudText>
                                                <MudText Typo="Typo.h5" Color="Color.Primary">@GetProductProgression(product.Id).ToString("F1")%</MudText>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="12">
                                            <MudPaper Elevation="1" Class="pa-3">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs (Created / Worked / Closed)</MudText>
                                                <MudText Typo="Typo.h6">@GetProductBugsCreated(product.Id) / @GetProductBugsWorked(product.Id) / @GetProductBugsClosed(product.Id)</MudText>
                                            </MudPaper>
                                        </MudItem>
                                    </MudGrid>
                                </MudItem>
                                @if (HasEpicPieChart(product.Id))
                                {
                                    <MudItem xs="12" md="8">
                                        <MudChart ChartType="ChartType.Pie"
                                                  InputData="@GetEpicPieChartData(product.Id)"
                                                  InputLabels="@GetEpicPieChartLabels(product.Id)"
                                                  LegendPosition="Position.Right"
                                                  Width="100%"
                                                  Height="300px"
                                                  ChartOptions="@_pieChartOptions" />
                                    </MudItem>
                                }
                            </MudGrid>

                            <MudText Typo="Typo.subtitle1" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-1" />
                                Epic Progress
                            </MudText>
                            @if (productEpics.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                                    No epic progress data available.
                                </MudAlert>
                            }
                            else
                            {
                                <MudSimpleTable Dense="true" Striped="true" Hover="true" Class="mb-4">
                                    <thead>
                                        <tr>
                                            <th style="width: 100px;">ID</th>
                                            <th>Epic</th>
                                            <th style="width: 200px;">Progress</th>
                                            <th style="width: 120px; text-align: right;">Sprint Scored</th>
                                            <th style="width: 120px; text-align: right;">Features</th>
                                            <th style="width: 80px; text-align: center;">Sprint Δ%</th>
                                            <th style="width: 100px; text-align: center;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var epic in productEpics)
                                        {
                                            <tr>
                                                <td>
                                                    @if (_tfsConfig != null && !string.IsNullOrEmpty(_tfsConfig.Url) && !string.IsNullOrEmpty(_tfsConfig.Project))
                                                    {
                                                        <MudLink Href="@TfsUrlBuilder.BuildWorkItemUrl(_tfsConfig.Url, _tfsConfig.Project, epic.EpicId)"
                                                                 Target="_blank"
                                                                 Typo="Typo.body2">#@epic.EpicId</MudLink>
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body2">#@epic.EpicId</MudText>
                                                    }
                                                </td>
                                                <td>
                                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                        <span style="@GetEpicColorSquareStyle(product.Id, epic.EpicId)"></span>
                                                        <MudText Typo="Typo.body2"><strong>@epic.EpicTitle</strong></MudText>
                                                    </MudStack>
                                                </td>
                                                <td>
                                                    <MudProgressLinear Color="@GetProgressColor(epic.ProgressPercent)"
                                                                      Value="@epic.ProgressPercent"
                                                                      Max="100" />
                                                </td>
                                                <td style="text-align: right;">
                                                    <MudText Typo="Typo.body2">@epic.SprintCompletedEffort pts</MudText>
                                                </td>
                                                <td style="text-align: right;">
                                                    <MudText Typo="Typo.body2">@epic.DoneFeatureCount / @epic.FeatureCount done</MudText>
                                                </td>
                                                <td style="text-align: center;">
                                                    <MudText Typo="Typo.body2" Color="@GetProgressColor((int)epic.SprintProgressionDelta)">@epic.SprintProgressionDelta.ToString("F1")%</MudText>
                                                </td>
                                                <td style="text-align: center;">
                                                    <MudIconButton Icon="@Icons.Material.Filled.History"
                                                                   Size="Size.Small"
                                                                   Color="Color.Info"
                                                                   aria-label="Show activities for this epic"
                                                                   Href="@BuildWorkItemActivityUrl(epic.EpicId)" />
                                                    <MudIconButton Icon="@Icons.Material.Filled.List"
                                                                   Size="Size.Small"
                                                                   Color="Color.Primary"
                                                                   aria-label="Show features for this epic"
                                                                   OnClick="@(() => ShowEpicFeaturesAsync(epic))" />
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    }
</MudContainer>

@code {
    private const int TrendSprintCount = 10;
    
    private bool _isLoading = true;
    private string? _errorMessage;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // TFS configuration (for work item links)
    private TfsConfigDto? _tfsConfig;
    
    // Selection state
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private bool _advancedMode = true;
    private int _trendSprintCount = TrendSprintCount;
    private List<TeamDto> _teams = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private List<ProductDto> _products = new();
    private List<ProductDto> _filteredProducts = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;
    
    // Current sprint metrics
    private int _completedPbiCount;
    private int _completedPbiEffort;
    private double _progressionDelta;
    private int _bugsCreatedCount;
    private int _bugsWorkedCount;
    private int _bugsClosedCount;
    private int _missingEffortCount;
    private bool _isApproximate;
    private List<string> _approximateProducts = new();
    private Dictionary<int, ProductMetrics> _productMetrics = new();
    
    // Feature progress (Phase 3)
    private List<FeatureProgressDto> _featureProgress = new();
    private List<EpicProgressDto> _epicProgress = new();
    
    // Staleness detection
    private bool _isStale;
    private bool _isRecomputing;
    private DateTimeOffset? _projectionsAsOfUtc;
    private const int MaxEpicPieLabelLength = 40;
    
    // Trend data (Phase 2)
    private List<SprintTrendMetricsDto> _trendMetrics = new();
    private List<ChartSeries> _progressionChartSeries = new();
    private List<ChartSeries> _completedPbiCountChartSeries = new();
    private List<ChartSeries> _completedPbiEffortChartSeries = new();
    private List<ChartSeries> _bugTrendChartSeries = new();
    private string[] _trendXAxisLabels = Array.Empty<string>();
    private static readonly string[] DefaultPiePalette =
    [
        "#2979FF",
        "#1DE9B6",
        "#FFC400",
        "#FF9100",
        "#651FFF",
        "#00E676",
        "#00B0FF",
        "#26A69A",
    ];
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        YAxisLines = true,
        XAxisLines = true
    };

    private ChartOptions _pieChartOptions = new()
    {
        ShowLegend = true,
        ChartPalette = DefaultPiePalette
    };

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            
            if (_profileId == null)
            {
                _errorMessage = "No active profile selected.";
                return;
            }
            
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value)).ToList();
            _filteredProducts = _products.ToList();
            
            // Load TFS config for work item links
            _tfsConfig = await TfsConfigService.GetConfigAsync();
            
            // Load all sprints for all teams under this PO
            _allSprints.Clear();
            foreach (var team in _teams)
            {
                try
                {
                    var teamSprints = (await SprintService.GetSprintsForTeamAsync(team.Id)).ToList();
                    _allSprints.AddRange(teamSprints);
                }
                catch { /* skip teams without sprints */ }
            }

            ApplySprintFilters();
            FindCurrentSprint();
            
            await LoadMetricsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplySprintFilters()
    {
        // Filter sprints by team if selected
        var sprints = _allSprints.AsEnumerable();
        
        if (_selectedTeamId.HasValue)
        {
            sprints = sprints.Where(s => s.TeamId == _selectedTeamId.Value);
        }
        
        _filteredSprints = sprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .ToList();
        
        // Filter products by selected product
        _filteredProducts = _selectedProductId.HasValue
            ? _products.Where(p => p.Id == _selectedProductId.Value).ToList()
            : _products.ToList();
    }

    private void FindCurrentSprint()
    {
        // Default to current sprint or the latest past sprint
        var now = DateTimeOffset.UtcNow;
        _currentSprintIndex = _filteredSprints.FindIndex(s =>
            s.StartUtc <= now && s.EndUtc >= now);

        if (_currentSprintIndex < 0 && _filteredSprints.Count > 0)
        {
            _currentSprintIndex = _filteredSprints.FindLastIndex(s => s.EndUtc <= now);
            if (_currentSprintIndex < 0)
            {
                _currentSprintIndex = _filteredSprints.Count - 1;
            }
        }

        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadMetricsAsync()
    {
        ResetMetrics();
        
        if (!_profileId.HasValue || _currentSprint == null)
        {
            return;
        }

        try
        {
            List<int> sprintIds;
            
            if (_advancedMode)
            {
                // Load previous N sprints up to and including current
                var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
                sprintIds = _filteredSprints
                    .Skip(startIndex)
                    .Take(_currentSprintIndex - startIndex + 1)
                    .Select(s => s.Id)
                    .ToList();
            }
            else
            {
                sprintIds = new List<int> { _currentSprint.Id };
            }

            if (sprintIds.Count == 0)
            {
                return;
            }

            var response = await SprintTrendService.GetSprintTrendMetricsAsync(
                _profileId.Value,
                sprintIds,
                recompute: true);

            if (response == null || !response.Success || response.Metrics == null)
            {
                return;
            }

            // Capture staleness info
            _isStale = response.IsStale;
            _projectionsAsOfUtc = response.ProjectionsAsOfUtc;

            // Filter by product if selected
            var metrics = response.Metrics;
            
            _trendMetrics = metrics
                .OrderBy(m => m.StartUtc ?? DateTimeOffset.MaxValue)
                .ToList();
            
            // Aggregate current sprint metrics (last one in trend or single)
            var currentMetrics = _advancedMode
                ? _trendMetrics.LastOrDefault()
                : _trendMetrics.FirstOrDefault();
            
            if (currentMetrics != null)
            {
                var filteredProductMetrics = _selectedProductId.HasValue
                    ? currentMetrics.ProductMetrics.Where(m => m.ProductId == _selectedProductId.Value).ToList()
                    : currentMetrics.ProductMetrics.ToList();

                _completedPbiCount = filteredProductMetrics.Sum(m => m.CompletedPbiCount);
                _completedPbiEffort = filteredProductMetrics.Sum(m => m.CompletedPbiEffort);
                _progressionDelta = filteredProductMetrics.Sum(m => m.ProgressionDelta);
                _bugsCreatedCount = filteredProductMetrics.Sum(m => m.BugsCreatedCount);
                _bugsWorkedCount = filteredProductMetrics.Sum(m => m.BugsWorkedCount);
                _bugsClosedCount = filteredProductMetrics.Sum(m => m.BugsClosedCount);
                _missingEffortCount = filteredProductMetrics.Sum(m => m.MissingEffortCount);
                _isApproximate = filteredProductMetrics.Any(m => m.IsApproximate);
                
                _approximateProducts = filteredProductMetrics
                    .Where(m => m.IsApproximate)
                    .Select(m => m.ProductName)
                    .ToList();

                foreach (var productMetric in filteredProductMetrics)
                {
                    _productMetrics[productMetric.ProductId] = new ProductMetrics(
                        productMetric.CompletedPbiCount,
                        productMetric.CompletedPbiEffort,
                        productMetric.ProgressionDelta,
                        productMetric.MissingEffortCount,
                        productMetric.IsApproximate,
                        productMetric.BugsCreatedCount,
                        productMetric.BugsWorkedCount,
                        productMetric.BugsClosedCount);
                }
            }
            
            // Build feature progress from real resolved hierarchy data
            BuildFeatureProgress(response);
            
            // Build trend charts if in advanced mode
            if (_advancedMode)
            {
                BuildTrendCharts();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading sprint trend metrics: {ex.Message}", Severity.Warning);
        }
    }

    private void ResetMetrics()
    {
        _completedPbiCount = 0;
        _completedPbiEffort = 0;
        _progressionDelta = 0;
        _bugsCreatedCount = 0;
        _bugsWorkedCount = 0;
        _bugsClosedCount = 0;
        _missingEffortCount = 0;
        _isApproximate = false;
        _isStale = false;
        _projectionsAsOfUtc = null;
        _approximateProducts.Clear();
        _productMetrics.Clear();
        _featureProgress.Clear();
        _epicProgress.Clear();
        _trendMetrics.Clear();
        _progressionChartSeries.Clear();
        _completedPbiCountChartSeries.Clear();
        _completedPbiEffortChartSeries.Clear();
        _bugTrendChartSeries.Clear();
        _trendXAxisLabels = Array.Empty<string>();
    }

    private void BuildFeatureProgress(GetSprintTrendMetricsResponse? response)
    {
        _featureProgress.Clear();
        _epicProgress.Clear();
        
        if (response?.FeatureProgress == null || response.FeatureProgress.Count == 0)
            return;
        
        // Apply product filter if selected
        var features = _selectedProductId.HasValue
            ? response.FeatureProgress.Where(f => f.ProductId == _selectedProductId.Value).ToList()
            : response.FeatureProgress.ToList();
        
        _featureProgress = features;

        // Build epic progress
        if (response.EpicProgress != null && response.EpicProgress.Count > 0)
        {
            _epicProgress = _selectedProductId.HasValue
                ? response.EpicProgress.Where(e => e.ProductId == _selectedProductId.Value).ToList()
                : response.EpicProgress.ToList();
        }
    }

    private void BuildTrendCharts()
    {
        if (_trendMetrics.Count == 0) return;
        
        _trendXAxisLabels = _trendMetrics
            .Select(m => m.SprintName)
            .ToArray();
        
        var filteredProducts = _filteredProducts;
        var hasMultipleProducts = filteredProducts.Count > 1;
        
        if (hasMultipleProducts)
        {
            // Per-product series
            _progressionChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return pm?.ProgressionDelta ?? 0;
                }).ToArray()
            }).ToList();
            
            _completedPbiCountChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return (double)(pm?.CompletedPbiCount ?? 0);
                }).ToArray()
            }).ToList();
            
            _completedPbiEffortChartSeries = filteredProducts.Select(p => new ChartSeries
            {
                Name = p.Name,
                Data = _trendMetrics.Select(m =>
                {
                    var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == p.Id);
                    return (double)(pm?.CompletedPbiEffort ?? 0);
                }).ToArray()
            }).ToList();
        }
        else
        {
            // Single total series
            _progressionChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Progression %",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return pm?.ProgressionDelta ?? 0;
                        }
                        return m.TotalProgressionDelta;
                    }).ToArray()
                }
            };
            
            _completedPbiCountChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Completed PBIs",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return (double)(pm?.CompletedPbiCount ?? 0);
                        }
                        return (double)m.TotalCompletedPbiCount;
                    }).ToArray()
                }
            };
            
            _completedPbiEffortChartSeries = new List<ChartSeries>
            {
                new()
                {
                    Name = "Completed Effort",
                    Data = _trendMetrics.Select(m =>
                    {
                        if (_selectedProductId.HasValue)
                        {
                            var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                            return (double)(pm?.CompletedPbiEffort ?? 0);
                        }
                        return (double)m.TotalCompletedPbiEffort;
                    }).ToArray()
                }
            };
        }
        
        // Bug trend chart — always uses total series (Created / Worked / Closed)
        _bugTrendChartSeries = new List<ChartSeries>
        {
            new()
            {
                Name = "Created",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsCreatedCount ?? 0);
                    }
                    return (double)m.TotalBugsCreatedCount;
                }).ToArray()
            },
            new()
            {
                Name = "Worked On",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsWorkedCount ?? 0);
                    }
                    return (double)m.TotalBugsWorkedCount;
                }).ToArray()
            },
            new()
            {
                Name = "Closed",
                Data = _trendMetrics.Select(m =>
                {
                    if (_selectedProductId.HasValue)
                    {
                        var pm = m.ProductMetrics.FirstOrDefault(pm => pm.ProductId == _selectedProductId.Value);
                        return (double)(pm?.BugsClosedCount ?? 0);
                    }
                    return (double)m.TotalBugsClosedCount;
                }).ToArray()
            }
        };
    }

