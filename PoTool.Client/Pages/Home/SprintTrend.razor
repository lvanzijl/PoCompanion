    private void CancelContextLoad()
    {
        _contextLoadCts?.Cancel();
        _contextLoadCts?.Dispose();
        _contextLoadCts = null;
    }

    private void CancelSummaryLoad()
    {
        _summaryLoadCts?.Cancel();
        _summaryLoadCts?.Dispose();
        _summaryLoadCts = null;
    }

    private void CancelDetailsLoad()
    {
        _detailsLoadCts?.Cancel();
        _detailsLoadCts?.Dispose();
        _detailsLoadCts = null;
    }

    private void CancelBuildQualityLoad()
    {
        _buildQualityLoadCts?.Cancel();
        _buildQualityLoadCts?.Dispose();
        _buildQualityLoadCts = null;
    }

    public void Dispose()
    {
        CancelContextLoad();
        CancelSummaryLoad();
        CancelDetailsLoad();
        CancelBuildQualityLoad();
        _lifetimeCts.Cancel();
        _lifetimeCts.Dispose();
    }

    private record ProductMetrics(
        int CompletedPbis,
        double CompletedStoryPoints,
        int MissingEffort,
        bool IsApproximate,
        int BugsCreated,
        int BugsWorked,
        int BugsClosed,
        int? ScopeChangeEffort,
        int? CompletedFeatures);
}
