    {
        return _epicProgress
            .Where(e => e.ProductId == productId)
            .ToList();
    }

    private bool HasEpicPieChart(int productId)
    {
        return GetEpicProgressForProduct(productId).Count(e => e.DoneEffort > 0) > 1;
    }

    private double[] GetEpicPieChartData(int productId)
    {
        return GetEpicProgressForProduct(productId)
            .Where(e => e.DoneEffort > 0)
            .Select(e => (double)e.DoneEffort)
            .ToArray();
    }

    private string[] GetEpicPieChartLabels(int productId)
    {
        var productEpics = GetEpicProgressForProduct(productId)
            .Where(e => e.DoneEffort > 0)
            .ToList();
        var totalDoneEffort = productEpics.Sum(e => e.DoneEffort);

        return productEpics
            .Select(epic =>
            {
                var percent = totalDoneEffort > 0
                    ? (epic.DoneEffort / (double)totalDoneEffort) * 100d
                    : 0d;
                var title = epic.EpicTitle.Length > MaxEpicPieLabelLength
                    ? epic.EpicTitle[..MaxEpicPieLabelLength] + "…"
                    : epic.EpicTitle;
                return $"{percent:F1}% — {title}";
            })
            .ToArray();
    }

