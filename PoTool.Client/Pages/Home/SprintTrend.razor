    private string GetEpicColorSquareStyle(int productId, int epicId)
    {
        var index = GetEpicColorIndex(productId, epicId);
        var color = index < 0 ? "#9E9E9E" : GetEpicColor(index);
        return $"width: 10px; height: 10px; border-radius: 2px; display: inline-block; background-color: {color};";
    }

