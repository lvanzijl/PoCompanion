    private string BuildWorkItemActivityUrl(int workItemId)
    {
        var path = $"{WorkspaceRoutes.SprintTrendActivity}/{workItemId}";
        if (!_profileId.HasValue)
        {
            return path;
        }

        var periodStartUtc = _currentSprint?.StartUtc;
        var periodEndUtc = _currentSprint?.EndUtc;

        if (_advancedMode && _trendMetrics.Count > 0)
        {
            periodStartUtc = _trendMetrics.First().StartUtc ?? periodStartUtc;
            periodEndUtc = _trendMetrics.Last().EndUtc ?? periodEndUtc;
        }

        var query = new List<string> { $"productOwnerId={_profileId.Value}" };
        if (periodStartUtc.HasValue)
        {
            query.Add($"periodStartUtc={Uri.EscapeDataString(periodStartUtc.Value.UtcDateTime.ToString("O"))}");
        }

        if (periodEndUtc.HasValue)
        {
            query.Add($"periodEndUtc={Uri.EscapeDataString(periodEndUtc.Value.UtcDateTime.ToString("O"))}");
        }

        if (!_advancedMode)
        {
            query.Add("view=zoom");
        }

        return $"{path}?{string.Join("&", query)}";
    }

    private double[] GetAllProductsPieData()
    {
        return _filteredProducts
            .Select(p => (double)GetProductCompletedEffort(p.Id))
            .ToArray();
    }

    private string[] GetAllProductsPieLabels()
    {
        var totalEffort = _filteredProducts.Sum(p => GetProductCompletedEffort(p.Id));
        return _filteredProducts
            .Select(p =>
            {
                var effort = GetProductCompletedEffort(p.Id);
                var percent = totalEffort > 0 ? (effort / (double)totalEffort) * 100d : 0d;
                return $"{percent:F1}% — {p.Name}";
            })
            .ToArray();
    }

