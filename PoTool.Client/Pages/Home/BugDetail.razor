@page "/home/bugs/detail"
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using System.Web
@inject WorkItemService WorkItemService
@inject ProductService ProductService
@inherits WorkspaceBase

<PageTitle>Bug Detail - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Bug Detail
                    </MudText>
                    @if (_bugId.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">#@_bugId</MudChip>
                    }
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NavigateBack">
                    Back
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_missingContextError != null)
    {
        <GuidedRecoveryState Title="Choose a bug first"
                             Message="@_missingContextError.UserMessage"
                             AdditionalInfo="@_missingContextError.Suggestion"
                             PrimaryActionText="Open Bug Insights"
                             PrimaryActionHref="@BuildContextRoute(WorkspaceRoutes.BugOverview)"
                             SecondaryActionText="Go home"
                             SecondaryActionHref="@BuildContextRoute(WorkspaceRoutes.Home)" />
    }
    else if (_errorResponse != null)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" ShowTechnicalDetails="false" Dismissible="false">
            <Actions>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="@BuildContextRoute(WorkspaceRoutes.BugOverview)">
                    Open Bug Insights
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Href="@BuildContextRoute(WorkspaceRoutes.Home)">
                    Home
                </MudButton>
            </Actions>
        </ErrorDisplay>
    }
    else
    {
        @* Bug Information Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Bug Information
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Title" Value="@_bugTitle" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Label="State" Value="@_bugState" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Label="Severity" Value="@_bugSeverity" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
            </MudGrid>
            
            <MudTextField Label="Description" Lines="4" Value="@_bugDescription" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" FullWidth="true" />
        </MudPaper>

        @* Editable Fields Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                Editable Fields
            </MudText>
            
            <MudAlert Severity="Severity.Info" Class="mb-3">
                These are the end-station edits available for this bug.
            </MudAlert>
            
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Severity" @bind-Value="_bugSeverity" Variant="Variant.Outlined" Class="mb-2">
                        <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
                        <MudSelectItem Value="@("High")">High</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("Low")">Low</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Tags" @bind-Value="_bugTags" Variant="Variant.Outlined" Placeholder="Enter tags separated by commas" Class="mb-2" />
                </MudItem>
            </MudGrid>
            
            <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="CancelChanges">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveChanges">
                    Save Changes
                </MudButton>
            </MudStack>
        </MudPaper>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Error" 
                           StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="NavigateToBugOverview">
                    Bug Overview
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private ErrorResponse? _errorResponse;
    private ErrorResponse? _missingContextError;
    private const string UnknownSeverityLabel = "Unknown";
    private const string MissingDescriptionLabel = "No description available.";
    
    // Bug data
    private int? _bugId;
    private string _bugTitle = string.Empty;
    private string _bugState = string.Empty;
    private string _bugSeverity = string.Empty;
    private string _bugDescription = string.Empty;
    private string _bugTags = string.Empty;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            ParseContextQueryParameters();

            if (!await EnsureProfileAsync())
            {
                return;
            }

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                _errorResponse = RouteStateGuard.CreateMissingSelectionError(
                    "An active profile",
                    "Select a profile before opening bug details.");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            ParseQueryParameters();
            if (!_bugId.HasValue)
            {
                _missingContextError = RouteStateGuard.CreateMissingQueryParameterError(
                    "bugId",
                    "Open Bug Insights and choose a bug to see its details.");
                UpdateBreadcrumbs();
                return;
            }

            await LoadBugDataAsync(activeProfile.Id);
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorResponse = RouteStateGuard.CreateSafeErrorResponse(ErrorMessageService, ex, "Bug details");
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        var bugId = queryParams["bugId"];
        if (!string.IsNullOrEmpty(bugId))
        {
            _bugId = int.TryParse(bugId, out var id) ? id : null;
        }
    }
    
    private async Task LoadBugDataAsync(int activeProfileId)
    {
        if (!_bugId.HasValue) return;

        var profileProducts = await ProductService.GetProductsByOwnerAsync(activeProfileId);
        var productIds = profileProducts.Select(product => product.Id).ToArray();
        var bug = await WorkItemService.GetByTfsIdWithValidationAsync(_bugId.Value, productIds);

        if (bug == null || !bug.Type.Equals("Bug", StringComparison.OrdinalIgnoreCase))
        {
            _errorResponse = RouteStateGuard.CreateNotFoundError(
                $"Bug #{_bugId.Value}",
                "Return to Bug Insights and choose a bug from the current profile.");
            return;
        }

        _bugTitle = bug.Title;
        _bugState = bug.State;
        _bugSeverity = bug.Severity ?? UnknownSeverityLabel;
        _bugDescription = string.IsNullOrWhiteSpace(bug.Description) ? MissingDescriptionLabel : bug.Description;
        _bugTags = bug.Tags ?? string.Empty;
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", BuildContextRoute(WorkspaceRoutes.Home), icon: Icons.Material.Filled.Home),
            new("Bug Overview", BuildContextRoute(WorkspaceRoutes.BugOverview), icon: Icons.Material.Filled.BugReport),
            new(_bugId.HasValue ? $"Bug #{_bugId}" : "Bug Detail", null, disabled: true)
        };
    }
    
    private void NavigateBack()
    {
        NavigationManager.NavigateTo(BuildContextRoute(WorkspaceRoutes.BugOverview));
    }
    
    private void NavigateToBugOverview()
    {
        NavigationManager.NavigateTo(BuildContextRoute(WorkspaceRoutes.BugOverview));
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(BuildContextRoute(WorkspaceRoutes.HealthWorkspace));
    }
    
    private async Task CancelChanges()
    {
        if (_profileId.HasValue)
        {
            await LoadBugDataAsync(_profileId.Value);
        }
        Snackbar.Add("Changes cancelled", Severity.Info);
    }
    
    private void SaveChanges()
    {
        // In real implementation, would save to backend
        Snackbar.Add("Changes saved successfully", Severity.Success);
    }
}
