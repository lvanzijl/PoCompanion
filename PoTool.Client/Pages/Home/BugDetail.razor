@page "/home/bugs/detail"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Shared.WorkItems
@using System.Web
@inject IProfileService ProfileService
@inject WorkItemService WorkItemService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Bug Detail - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Bug Detail
                    </MudText>
                    @if (_bugId.HasValue)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default">#@_bugId</MudChip>
                    }
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NavigateBack">
                    Back
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_recoveryMessage != null)
    {
        <GuidedRecoveryPanel Title="@_recoveryTitle"
                             Message="@_recoveryMessage"
                             PrimaryActionLabel="@_recoveryPrimaryActionLabel"
                             PrimaryAction="@_recoveryPrimaryAction"
                             SecondaryActionLabel="Home"
                             SecondaryAction="NavigateToHome" />
    }
    else
    {
        @* Bug Information Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                Bug Information
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Title" Value="@_bugTitle" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Label="State" Value="@_bugState" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudTextField Label="Severity" Value="@_bugSeverity" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" />
                </MudItem>
            </MudGrid>
            
            <MudTextField Label="Description" Lines="4" Value="@_bugDescription" ReadOnly="true" Variant="Variant.Outlined" Class="mb-2" FullWidth="true" />
        </MudPaper>

        @* Bug Actions *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.BuildCircle" Class="mr-2" />
                Bug Actions
            </MudText>
            
            <MudAlert Severity="Severity.Info" Class="mb-3">
                This detail page is read-only. Use Bugs Triage to change severity or triage-related fields for this bug.
            </MudAlert>
            
            <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="NavigateToBugTriage">
                    Open Bugs Triage
                </MudButton>
            </MudStack>
        </MudPaper>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Error" 
                           StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="NavigateToBugOverview">
                    Bug Overview
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string? _recoveryTitle;
    private string? _recoveryMessage;
    private string? _recoveryPrimaryActionLabel;
    private EventCallback _recoveryPrimaryAction;
    
    // Bug data
    private int? _bugId;
    private WorkItemDto? _bug;
    private string _bugTitle = string.Empty;
    private string _bugState = string.Empty;
    private string _bugSeverity = string.Empty;
    private string _bugDescription = string.Empty;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            if (!TryParseBugId())
            {
                UpdateBreadcrumbs();
                return;
            }

            await LoadBugDataAsync();
            UpdateBreadcrumbs();
        }
        catch (ApiException ex)
        {
            SetRecovery(
                "Bug detail unavailable",
                ApiErrorMessageFormatter.ForBugDetail(ex),
                "Go to Bug Insights",
                NavigateToBugOverview);
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            SetRecovery(
                "Bug detail unavailable",
                "Bug details could not be loaded right now. Try again later.",
                "Go to Bug Insights",
                NavigateToBugOverview);
            Snackbar.Add($"Error loading bug detail: {ex.Message}", Severity.Error);
            UpdateBreadcrumbs();
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private bool TryParseBugId()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        var rawBugId = queryParams["bugId"];
        if (string.IsNullOrWhiteSpace(rawBugId))
        {
            SetRecovery(
                "Bug context missing",
                "This page needs a bug ID. Open Bug Insights to select a bug first.",
                "Go to Bug Insights",
                NavigateToBugOverview);
            return false;
        }

        if (!int.TryParse(rawBugId, out var bugId) || bugId <= 0)
        {
            SetRecovery(
                "Invalid bug ID",
                "The bug ID in the URL is invalid. Open Bug Insights to select a valid bug.",
                "Go to Bug Insights",
                NavigateToBugOverview);
            return false;
        }

        _bugId = bugId;
        return true;
    }
    
    private async Task LoadBugDataAsync()
    {
        if (!_bugId.HasValue)
        {
            return;
        }

        _bug = await WorkItemService.GetByTfsIdAsync(_bugId.Value);
        if (_bug is null || !_bug.Type.Equals("Bug", StringComparison.OrdinalIgnoreCase))
        {
            SetRecovery(
                "Bug not found",
                "No bug matched this URL. Open Bug Insights to choose a valid bug.",
                "Go to Bug Insights",
                NavigateToBugOverview);
            return;
        }

        _bugTitle = _bug.Title;
        _bugState = _bug.State;
        _bugSeverity = _bug.Severity ?? "Unknown";
        _bugDescription = string.IsNullOrWhiteSpace(_bug.Description)
            ? "No description is available for this bug."
            : _bug.Description;
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Bug Overview", WorkspaceRoutes.BugOverview, icon: Icons.Material.Filled.BugReport),
            new(_bugId.HasValue ? $"Bug #{_bugId}" : "Bug Detail", null, disabled: true)
        };
    }
    
    private void NavigateBack()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugOverview);
    }
    
    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
    
    private void NavigateToBugOverview()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugOverview);
    }

    private void NavigateToBugTriage()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage);
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.HealthWorkspace);
    }
    
    private void SetRecovery(string title, string message, string primaryActionLabel, Action primaryAction)
    {
        _recoveryTitle = title;
        _recoveryMessage = message;
        _recoveryPrimaryActionLabel = primaryActionLabel;
        _recoveryPrimaryAction = EventCallback.Factory.Create(this, primaryAction);
    }
}
