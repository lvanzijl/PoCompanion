@page "/home/delivery/portfolio"
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Shared.Metrics
@inject IProfileService ProfileService
@inject TeamService TeamService
@inject SprintService SprintService
@inject ProductService ProductService
@inject MetricsStateService MetricsStateService
@inject NavigationManager NavigationManager
@inject GlobalFilterStore GlobalFilterStore
@inject PageFilterExecutionGate PageFilterExecutionGate
@inject GlobalFilterLabelService GlobalFilterLabelService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Portfolio Delivery - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-2 mb-2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Warning" />
                <MudText Typo="Typo.h5">Portfolio Delivery</MudText>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0 d-none d-sm-flex" />
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="NavigateToDelivery">
                Back to Delivery
            </MudButton>
        </MudStack>
    </MudPaper>

    <TrendDataStateView TData="DeliveryQueryResponseDto<PortfolioDeliveryDto>"
                        State="@_dataState"
                        IsLoading="@_isLoading"
                        FilterNotice="@_filterNotice"
                        ProductOwnerId="@_profileId"
                        Subject="Portfolio delivery"
                        InvalidMessage="Adjust the selected team or sprint range to load portfolio delivery."
                        FailedMessage="The portfolio delivery request failed."
                        NotReadyMessage="Portfolio delivery will load once the cache is ready."
                        OnRecovery="@LoadInitialDataAsync">
        <NotRequestedContent>
            @if (_selectedSprintIds.Count == 0 && _sprints.Any())
            {
                <MudPaper Elevation="1" Class="pa-6 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.DateRange" Color="Color.Secondary" Style="font-size: 2.5rem;" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                        Select a sprint range above to view the portfolio delivery snapshot.
                    </MudText>
                </MudPaper>
            }
            else if (!_sprints.Any() && !_isLoading)
            {
                <MudPaper Elevation="1" Class="pa-6 text-center">
                    <MudIcon Icon="@Icons.Material.Filled.Group" Color="Color.Secondary" Style="font-size: 2.5rem;" />
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                        Select a team to load sprints.
                    </MudText>
                </MudPaper>
            }
        </NotRequestedContent>
        <ChildContent Context="_">
        @{ var data = _data!; }
        @if (_deliveryLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-4" />
        }

            @* ── Section header *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1" Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">
                    @if (data.SprintCount == 1)
                    {
                        <text>Single sprint snapshot</text>
                    }
                    else
                    {
                        <text>Aggregated snapshot — @data.SprintCount sprints</text>
                    }
                </MudText>
                @if (data.SprintCount > 1)
                {
                    <MudTooltip Text="Multiple sprints selected. All metrics are aggregated (summed) across the sprint range. This is a composition view — no time trends are shown.">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                    </MudTooltip>
                }
            </MudStack>

            @* ── Portfolio summary metrics ── *@
            <MudPaper Elevation="2" Class="pa-3 mb-3">
                <MudText Typo="Typo.subtitle1" Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-1" Size="Size.Small" />
                    Portfolio Summary
                </MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Completed PBIs</MudText>
                            <MudText Typo="Typo.h5" Color="Color.Success">@data.Summary.TotalCompletedPbis</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Delivered Effort (hours)</MudText>
                            <MudText Typo="Typo.h5">@data.Summary.TotalCompletedEffort</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Avg. Progress</MudText>
                            <MudText Typo="Typo.h5">@data.Summary.AverageProgressPercent.ToString("F0")<MudText Typo="Typo.caption" Color="Color.Secondary" Inline="true">%</MudText></MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs Created</MudText>
                            <MudText Typo="Typo.h5" Color="@(data.Summary.TotalBugsCreated > 0 ? Color.Warning : Color.Default)">@data.Summary.TotalBugsCreated</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs Worked</MudText>
                            <MudText Typo="Typo.h5">@data.Summary.TotalBugsWorked</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6" sm="4" md="2">
                        <MudPaper Outlined="true" Class="pa-2 text-center">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bugs Closed</MudText>
                            <MudText Typo="Typo.h5" Color="@(data.Summary.TotalBugsClosed > 0 ? Color.Success : Color.Default)">@data.Summary.TotalBugsClosed</MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @* ── Product contribution + Feature contribution ── *@
            <MudGrid Spacing="3" Class="mb-3">
                @* Product contribution chart *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-3" Style="height: 100%;">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-1" Size="Size.Small" />
                            Product Contribution (Hours)
                            <MudTooltip Text="Share of delivered effort hours per product across the selected sprint range.">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                            </MudTooltip>
                        </MudText>
                        @if (data.Products.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No delivery data available.</MudText>
                        }
                        else
                        {
                            @foreach (var product in data.Products)
                            {
                                <MudStack Class="mb-2" Spacing="0">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2" Style="max-width: 55%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                                 title="@product.ProductName">
                                            @product.ProductName
                                        </MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @product.CompletedEffort &nbsp; @product.EffortShare.ToString("F0")%
                                        </MudText>
                                    </MudStack>
                                    <MudProgressLinear Value="@product.EffortShare" Max="100"
                                                       Color="Color.Primary" Rounded="true" Size="Size.Medium" />
                                </MudStack>
                            }
                        }
                    </MudPaper>
                </MudItem>

                @* Feature contribution chart *@
                <MudItem xs="12" md="6">
                    <MudPaper Elevation="2" Class="pa-3" Style="height: 100%;">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-1" Size="Size.Small" />
                            Feature Contribution (Story Points)
                            <MudTooltip Text="Top features by delivered story points. Share is relative to total feature delivered story points.">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                            </MudTooltip>
                        </MudText>
                        @if (data.TopFeatures.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No feature delivery data available for the selected sprint range.</MudText>
                        }
                        else
                        {
                            @foreach (var feature in data.TopFeatures)
                            {
                                <MudStack Class="mb-2" Spacing="0">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudStack Spacing="0" Style="max-width: 60%; overflow: hidden;">
                                            <MudText Typo="Typo.body2"
                                                     Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                                     title="@feature.FeatureTitle">
                                                @feature.FeatureTitle
                                            </MudText>
                                            @if (!string.IsNullOrEmpty(feature.EpicTitle))
                                            {
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                                                         title="@feature.EpicTitle">
                                                    @feature.EpicTitle
                                                </MudText>
                                            }
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @FormatStoryPoints(feature.SprintCompletedEffort) &nbsp; @feature.EffortShare.ToString("F0")%
                                        </MudText>
                                    </MudStack>
                                    <MudProgressLinear Value="@feature.EffortShare" Max="100"
                                                       Color="Color.Secondary" Rounded="true" Size="Size.Medium" />
                                </MudStack>
                            }
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @* ── Bug distribution summary ── *@
            @if (data.Products.Any(p => p.BugsCreated > 0 || p.BugsWorked > 0 || p.BugsClosed > 0))
            {
                <MudPaper Elevation="2" Class="pa-3 mb-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-1" Size="Size.Small" />
                        Bug Distribution
                        <MudTooltip Text="Bug activity per product. Products with high creation relative to closure indicate operational pressure.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                        </MudTooltip>
                    </MudText>
                    <MudSimpleTable Dense="true" Hover="true" Striped="true">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th style="text-align: right;">Bugs Created</th>
                                <th style="text-align: right;">Bugs Worked</th>
                                <th style="text-align: right;">Bugs Closed</th>
                                <th style="text-align: right;">Net (Created − Closed)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in data.Products.OrderByDescending(p => p.BugsCreated))
                            {
                                var net = product.BugsCreated - product.BugsClosed;
                                <tr>
                                    <td>@product.ProductName</td>
                                    <td style="text-align: right;">
                                        @if (product.BugsCreated > 0)
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Warning">@product.BugsCreated</MudText>
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </td>
                                    <td style="text-align: right;">@(product.BugsWorked > 0 ? product.BugsWorked.ToString() : "—")</td>
                                    <td style="text-align: right;">
                                        @if (product.BugsClosed > 0)
                                        {
                                            <MudText Typo="Typo.body2" Color="Color.Success">@product.BugsClosed</MudText>
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </td>
                                    <td style="text-align: right;">
                                        @{
                                            var netColor = net > 0 ? Color.Error : (net < 0 ? Color.Success : Color.Default);
                                            var netText = net > 0 ? $"+{net}" : net.ToString();
                                        }
                                        <MudText Typo="Typo.body2" Color="@netColor">@(net == 0 ? "—" : netText)</MudText>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            }
            else if (data.HasData)
            {
                <MudPaper Elevation="2" Class="pa-3 mb-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-1" Size="Size.Small" />
                        Bug Distribution
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No bug activity recorded for the selected sprint range.</MudText>
                </MudPaper>
            }

        </ChildContent>
    </TrendDataStateView>
</MudContainer>

<style>
    .pd-scope-popover {
        min-width: 260px;
        z-index: 1400;
    }
</style>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();

    // State
    private bool _isLoading = true;
    private bool _deliveryLoading;
    private string? _errorMessage;
    private int? _profileId;

    // Teams and sprints
    private List<TeamDto> _teams = new();
    private List<SprintDto> _sprints = new();
    // Popover state
    private bool _teamPopoverOpen;
    private bool _sprintPopoverOpen;
    private bool _scopePopoverOpen;
    private IDisposable? _filterSubscription;
    private int? _selectedTeamId => GlobalFilterStore.GetState().TeamId;
    private int? _fromSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.StartSprintId : null;
    private int? _toSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.EndSprintId : null;

    // Delivery data
    private PortfolioDeliveryDto? _data;
    private DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>> _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.NotRequested();
    private CanonicalFilterNoticeModel? _filterNotice;
    private List<int> _selectedSprintIds = new();

    // ── Computed labels ──────────────────────────────────────────────────────────

    private string ContextTeamLabel =>
        _selectedTeamId.HasValue
            ? GlobalFilterLabelService.FormatTeam(_selectedTeamId.Value)
            : "Select Team";

    private string ContextSprintRangeLabel => GlobalFilterLabelService.FormatSprintRange(_fromSprintId, _toSprintId);

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        await LoadInitialDataAsync();
    }

    private async Task LoadInitialDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _data = null;
            _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.NotRequested();
            _filterNotice = null;

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }

            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);

            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            await SyncStoreFromCurrentRouteAsync();

            UpdateBreadcrumbs();

            if (_selectedTeamId.HasValue)
            {
                await LoadSprintsAsync(_selectedTeamId.Value);

                UpdateContextUrl();
                if (_fromSprintId.HasValue && _toSprintId.HasValue)
                {
                    await LoadDeliveryDataAsync();
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading Portfolio Delivery: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadSprintsAsync(int teamId)
    {
        try
        {
            _sprints = (await SprintService.GetSprintsForTeamAsync(teamId))
                .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
                .OrderBy(s => s.StartUtc)
                .ToList();
        }
        catch
        {
            _sprints = new List<SprintDto>();
        }
    }

    private async Task LoadDeliveryDataAsync()
    {
        var evaluation = PageFilterExecutionGate.Evaluate(GlobalFilterStore.CurrentUsage);
        if (!evaluation.CanExecuteQueries)
        {
            _selectedSprintIds = new List<int>();
            _data = null;
            _filterNotice = null;
            _dataState = TrendUiStateFactory.InvalidFilter<DeliveryQueryResponseDto<PortfolioDeliveryDto>>(
                evaluation,
                "Select a valid team and sprint range to load portfolio delivery.");
            return;
        }

        if (!_profileId.HasValue || !_selectedTeamId.HasValue || !_fromSprintId.HasValue || !_toSprintId.HasValue)
        {
            _selectedSprintIds = new List<int>();
            _data = null;
            _filterNotice = null;
            _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.NotRequested();
            return;
        }

        // Build sprint ID list from the from/to range
        var timeRange = GlobalFilterTrendRequestMapper.ResolveRange(GlobalFilterStore.GetState(), _sprints);
        _selectedSprintIds = timeRange.SprintIds.ToList();
        if (!timeRange.IsResolved || _selectedSprintIds.Count == 0)
        {
            _data = null;
            _filterNotice = null;
            _dataState = TrendUiStateFactory.InvalidFilter<DeliveryQueryResponseDto<PortfolioDeliveryDto>>(
                timeRange.FailureReason ?? "The selected sprint range could not be resolved.",
                [GlobalFilterValidationMapper.Time]);
            return;
        }

        try
        {
            _deliveryLoading = true;
            _data = null;
            StateHasChanged();

            _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.Loading();
            var response = await MetricsStateService.GetPortfolioDeliveryStateAsync(
                _profileId.Value,
                timeRange,
                GlobalFilterStore.GetState().ProductIds.Count > 0 ? GlobalFilterStore.GetState().ProductIds : null,
                CancellationToken.None);
            _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.FromResponse(response, "Portfolio delivery data could not be loaded right now.");
            if (_dataState.UiState is UiDataState.Loading or UiDataState.Failed or UiDataState.Invalid)
            {
                _data = null;
                return;
            }

            var envelope = _dataState.Data;
            _filterNotice = envelope is null ? null : CanonicalClientResponseFactory.CreateNotice(CanonicalClientResponseFactory.Create(envelope).FilterMetadata);
            _data = envelope?.Data.HasData == true ? envelope.Data : null;
            if (_data is null)
            {
                _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.Empty("No data for selected period.");
            }
        }
        catch (Exception)
        {
            _dataState = DataStateViewModel<DeliveryQueryResponseDto<PortfolioDeliveryDto>>.Failed("The portfolio delivery request failed.");
            Snackbar.Add(_dataState.Reason!, Severity.Error);
            _data = null;
            _filterNotice = null;
        }
        finally
        {
            _deliveryLoading = false;
        }
    }

    private List<int> BuildSprintRange(int? fromId, int? toId)
    {
        if (_sprints.Count == 0) return new List<int>();

        var fromIdx = fromId.HasValue ? _sprints.FindIndex(s => s.Id == fromId.Value) : 0;
        var toIdx = toId.HasValue ? _sprints.FindIndex(s => s.Id == toId.Value) : _sprints.Count - 1;

        if (fromIdx < 0) fromIdx = 0;
        if (toIdx < 0) toIdx = _sprints.Count - 1;
        if (fromIdx > toIdx) (fromIdx, toIdx) = (toIdx, fromIdx);

        return _sprints.Skip(fromIdx).Take(toIdx - fromIdx + 1).Select(s => s.Id).ToList();
    }

    // ── Popover toggles ──────────────────────────────────────────────────────────

    private void CloseAllPopovers() { _teamPopoverOpen = false; _sprintPopoverOpen = false; _scopePopoverOpen = false; }

    private void ToggleTeamPopover() { var open = !_teamPopoverOpen; CloseAllPopovers(); _teamPopoverOpen = open; }
    private void ToggleSprintPopover() { var open = !_sprintPopoverOpen; CloseAllPopovers(); _sprintPopoverOpen = open; }
    private void ToggleScopePopover() { var open = !_scopePopoverOpen; CloseAllPopovers(); _scopePopoverOpen = open; }

    // ── Event handlers ───────────────────────────────────────────────────────────

    private async Task OnTeamSelectedFromPopoverAsync(int? teamId)
    {
        _teamPopoverOpen = false;
        await OnTeamChangedAsync(teamId);
    }

    private async Task OnToSprintSelectedFromPopoverAsync(int? sprintId)
    {
        _sprintPopoverOpen = false;
        await OnToSprintChangedAsync(sprintId);
    }

    private async Task OnTeamChangedAsync(int? teamId)
    {
        _sprints = new List<SprintDto>();
        _data = null;
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { TeamId = teamId, FromSprintId = null, ToSprintId = null });

        if (teamId.HasValue)
        {
            await LoadSprintsAsync(teamId.Value);
            UpdateContextUrl();
            if (_fromSprintId.HasValue && _toSprintId.HasValue)
            {
                await LoadDeliveryDataAsync();
            }
        }
        else
        {
            UpdateContextUrl();
        }
    }

    private async Task OnFromSprintChangedAsync(int? sprintId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { FromSprintId = sprintId });
        UpdateContextUrl();
        await LoadDeliveryDataAsync();
    }

    private async Task OnToSprintChangedAsync(int? sprintId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { ToSprintId = sprintId });
        UpdateContextUrl();
        await LoadDeliveryDataAsync();
    }

    // ── Navigation ───────────────────────────────────────────────────────────────

    private void NavigateToDelivery()
    {
        var targetUri = WorkspaceQueryContextHelper.BuildRoute(
            WorkspaceRoutes.DeliveryWorkspace,
            new WorkspaceQueryContext(TeamId: _selectedTeamId, FromSprintId: _fromSprintId, ToSprintId: _toSprintId));
        if (GlobalFilterStore.TryPrepareNavigation(NavigationManager.Uri, targetUri))
        {
            NavigationManager.NavigateTo(targetUri);
        }
    }

    private void UpdateContextUrl()
    {
        var targetUri = WorkspaceQueryContextHelper.BuildRoute(
            WorkspaceRoutes.PortfolioDelivery,
            new WorkspaceQueryContext(TeamId: _selectedTeamId, FromSprintId: _fromSprintId, ToSprintId: _toSprintId));
        if (GlobalFilterStore.TryPrepareNavigation(NavigationManager.Uri, targetUri))
        {
            NavigationManager.NavigateTo(targetUri, forceLoad: false);
        }
    }

    // ── Breadcrumbs ──────────────────────────────────────────────────────────────

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Delivery", WorkspaceRoutes.DeliveryWorkspace, icon: Icons.Material.Filled.CheckCircle),
            new("Portfolio Delivery", null, disabled: true, icon: Icons.Material.Filled.Inventory2)
        };
    }

    private static string FormatStoryPoints(double storyPoints) => storyPoints.ToString("0.##");

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId);

    private FilterLocalBridgeState BuildCurrentLocalBridgeState()
        => FilterLocalBridgeState.FromState(GlobalFilterStore.GetState());

    private async Task UpdateFilterStateAsync(FilterLocalBridgeState localState)
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId, localState, FilterUpdateSource.Ui);

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _filterSubscription?.Dispose();
    }
}
