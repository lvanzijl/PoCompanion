@page "/home/delivery/portfolio"
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@inject NavigationManager NavigationManager

<PageTitle>Portfolio Delivery - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Portfolio Delivery
                    </MudText>
                </MudStack>

                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="NavigateToDelivery">
                    Back to Delivery
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @* Placeholder content *@
    <MudPaper Elevation="2" Class="pa-8 mb-4">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Warning" Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5" Align="Align.Center">
                Portfolio Delivery — Coming Soon
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Style="max-width: 600px;">
                This view will provide an aggregated delivery overview across all products for selected sprint(s).
                It will answer: what did we collectively deliver, and how does that compare across products?
            </MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="NavigateToDelivery">
                Back to Delivery
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Delivery", WorkspaceRoutes.DeliveryWorkspace, icon: Icons.Material.Filled.CheckCircle),
            new("Portfolio Delivery", null, disabled: true, icon: Icons.Material.Filled.Inventory2)
        };
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.DeliveryWorkspace);
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
}
