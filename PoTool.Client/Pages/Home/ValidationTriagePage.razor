@page "/home/validation-triage"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Validation
@using PoTool.Client.ApiClient
@using PoTool.Shared.WorkItems
@inherits WorkspaceBase
@inject WorkItemService WorkItemService
@inject ProductService ProductService

<PageTitle>Validation Triage - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.FactCheck" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Validation Triage</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (ProductId.HasValue && _productName != null)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Size="Size.Small"
                             Color="Color.Primary"
                             OnClose="ClearProductFilter">
                        @_productName
                    </MudChip>
                }
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (_summary != null)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Click <strong>Open queue</strong> to review and fix items in each category.
        </MudText>

        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <TriageCategoryCard Category="@_summary.StructuralIntegrity"
                                    IconColor="Color.Error"
                                    Icon="@Icons.Material.Filled.Error"
                                    OnOpenQueue="@(() => OpenQueue(_summary.StructuralIntegrity.CategoryKey))" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <TriageCategoryCard Category="@_summary.RefinementReadiness"
                                    IconColor="Color.Warning"
                                    Icon="@Icons.Material.Filled.Warning"
                                    OnOpenQueue="@(() => OpenQueue(_summary.RefinementReadiness.CategoryKey))" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <TriageCategoryCard Category="@_summary.RefinementCompleteness"
                                    IconColor="Color.Warning"
                                    Icon="@Icons.Material.Filled.AssignmentLate"
                                    OnOpenQueue="@(() => OpenQueue(_summary.RefinementCompleteness.CategoryKey))" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <TriageCategoryCard Category="@_summary.MissingEffort"
                                    IconColor="Color.Info"
                                    Icon="@Icons.Material.Filled.HourglassEmpty"
                                    OnOpenQueue="@(() => OpenQueue(_summary.MissingEffort.CategoryKey))" />
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private string? _productName;
    private ValidationTriageSummaryDto? _summary;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ParseContextQueryParameters();

            if (!await EnsureProfileAsync())
            {
                return;
            }

            var activeProfile = await ProfileService.GetActiveProfileAsync();

            // Load products for the active profile
            var profileProducts = activeProfile != null
                ? (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList()
                : new List<PoTool.Client.ApiClient.ProductDto>();

            // Resolve product name for context chip
            if (ProductId.HasValue)
            {
                _productName = profileProducts.FirstOrDefault(p => p.Id == ProductId.Value)?.Name;
            }

            // Determine which product IDs to pass to the backend:
            // - If a product context is selected → restrict to that product only
            // - Otherwise → pass all profile products
            int[]? productIds = ProductId.HasValue
                ? new[] { ProductId.Value }
                : profileProducts.Select(p => p.Id).ToArray();

            if (productIds.Length == 0)
            {
                productIds = null;
            }

            _summary = await WorkItemService.GetValidationTriageSummaryAsync(productIds);
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load validation triage data: {ex.Message}";
            Console.WriteLine($"[ValidationTriage] {_loadError}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Health (Now)", WorkspaceRoutes.HealthWorkspace, icon: Icons.Material.Filled.HealthAndSafety),
            new("Validation Triage", null, disabled: true, icon: Icons.Material.Filled.FactCheck)
        };
    }

    private void OpenQueue(string categoryKey)
    {
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery($"category={categoryKey}")}");
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void ClearProductFilter()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.ValidationTriage);
    }
}
