@page "/home/portfolio-progress"
@using PoTool.Client.Components.Analytical
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Shared.Metrics
@using System.Web
@inject IProfileService ProfileService
@inject TeamService TeamService
@inject SprintService SprintService
@inject ProductService ProductService
@inject IMetricsClient MetricsClient
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Portfolio Progress - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Portfolio Progress Trend
                    </MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Timeline"
                       OnClick="NavigateToTrends">
                Back to Trends
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadInitialDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Context row — chips + inline filter controls in one compact bar *@
        <MudPaper Elevation="1" Class="pa-2 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                @* Context chips *@
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Inventory2" Color="Color.Default">
                    @ContextProductLabel
                </MudChip>
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Group" Color="Color.Default">
                    @ContextTeamLabel
                </MudChip>
                @if (_sprints.Any())
                {
                    <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.DateRange" Color="Color.Default">
                        @ContextSprintRangeLabel
                    </MudChip>
                }
                @if (IsCustomScope)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Tune">
                        Custom Scope
                    </MudChip>
                }

                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

                @* Inline filter controls — Product and Team *@
                <MudSelect T="int?"
                           Value="_selectedProductId"
                           Label="Product"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Margin="Margin.Dense"
                           Clearable="true"
                           ValueChanged="OnProductChangedAsync"
                           Style="min-width: 140px; max-width: 180px;">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="int?"
                           Value="_selectedTeamId"
                           Label="Team"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Margin="Margin.Dense"
                           Clearable="true"
                           ValueChanged="OnTeamChangedAsync"
                           Style="min-width: 130px; max-width: 170px;">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                    @foreach (var team in _teams)
                    {
                        <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                    }
                </MudSelect>

                @* Sprint range expander — collapsed by default *@
                @if (_selectedTeamId.HasValue && _sprints.Any())
                {
                    <MudButton Variant="Variant.Text"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.DateRange"
                               EndIcon="@(_filtersExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                               OnClick="@(() => _filtersExpanded = !_filtersExpanded)"
                               Color="Color.Default">
                        Sprint range
                    </MudButton>
                }
            </MudStack>

            @* Sprint range selectors — revealed by "Sprint range" button *@
            @if (_selectedTeamId.HasValue && _sprints.Any())
            {
                <MudCollapse Expanded="_filtersExpanded">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap" Class="pt-2">
                        <MudSelect T="int?"
                                   Value="_fromSprintId"
                                   Label="From Sprint"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   ValueChanged="OnFromSprintChangedAsync"
                                   Style="min-width: 180px; max-width: 220px;">
                            @foreach (var sprint in _sprints)
                            {
                                <MudSelectItem T="int?" Value="@sprint.Id">
                                    @sprint.Name (@(sprint.StartUtc?.ToString("MMM yyyy") ?? "?"))
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudSelect T="int?"
                                   Value="_toSprintId"
                                   Label="To Sprint"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   ValueChanged="OnToSprintChangedAsync"
                                   Style="min-width: 180px; max-width: 220px;">
                            @foreach (var sprint in _sprints)
                            {
                                <MudSelectItem T="int?" Value="@sprint.Id">
                                    @sprint.Name (@(sprint.StartUtc?.ToString("MMM yyyy") ?? "?"))
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>
                </MudCollapse>
            }
        </MudPaper>

        @if (_trendsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Warning" Class="mb-4" />
        }

        @if (_trendData != null)
        {
            @* ── Summary Block ── *@
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-2" />
                            Summary
                        </MudText>

                        @* Classification badge *@
                        @{
                            var (classColor, classIcon, classLabel) = _trendData.Summary.Trajectory switch
                            {
                                PortfolioTrajectory.Contracting => (Color.Success, Icons.Material.Filled.TrendingDown,  "Contracting"),
                                PortfolioTrajectory.Expanding   => (Color.Warning, Icons.Material.Filled.TrendingUp,    "Expanding"),
                                _                               => (Color.Default, Icons.Material.Filled.TrendingFlat,  "Stable")
                            };
                        }
                        <MudChip T="string" Color="@classColor" Icon="@classIcon" Size="Size.Medium">
                            @classLabel
                        </MudChip>

                        <MudTooltip Text="Contracting: backlog shrinking (Net Flow > 0). Expanding: backlog growing (Net Flow < 0). Stable: within tolerance.">
                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                        </MudTooltip>
                    </MudStack>

                    <MudGrid Spacing="2">
                        @* Cumulative Net Flow *@
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Net Flow (cumulative)</MudText>
                                <MudText Typo="Typo.h6">
                                    @if (_trendData.Summary.CumulativeNetFlow.HasValue)
                                    {
                                        var net = _trendData.Summary.CumulativeNetFlow.Value;
                                        var sign = net >= 0 ? "+" : "";
                                        <span style="color: @(net >= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-warning)")">
                                            @($"{sign}{net:F0} pts")
                                        </span>
                                    }
                                    else { <span>N/A</span> }
                                </MudText>
                            </MudPaper>
                        </MudItem>

                        @* Total scope change *@
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Total Scope Change</MudText>
                                    <MudTooltip Text="Total scope per sprint is reconstructed from the activity ledger by undoing effort changes that occurred after each sprint's end. Accuracy improves as more history accumulates in the ledger.">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                    </MudTooltip>
                                </MudStack>
                                <MudText Typo="Typo.h6">
                                    @if (_trendData.Summary.TotalScopeChangePts.HasValue)
                                    {
                                        var pts = _trendData.Summary.TotalScopeChangePts.Value;
                                        var pct = _trendData.Summary.TotalScopeChangePercent;
                                        var sign = pts >= 0 ? "+" : "";
                                        @if (pct.HasValue)
                                        {
                                            @($"{sign}{pts:F0} pts ({sign}{pct:F1}%)")
                                        }
                                        else
                                        {
                                            @($"{sign}{pts:F0} pts")
                                        }
                                    }
                                    else { <span>N/A</span> }
                                </MudText>
                            </MudPaper>
                        </MudItem>

                        @* Remaining effort change *@
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Remaining Effort Change</MudText>
                                <MudText Typo="Typo.h6">
                                    @if (_trendData.Summary.RemainingEffortChangePts.HasValue)
                                    {
                                        var delta = _trendData.Summary.RemainingEffortChangePts.Value;
                                        var sign = delta >= 0 ? "+" : "";
                                        <span style="color: @(delta <= 0 ? "var(--mud-palette-success)" : "var(--mud-palette-warning)")">
                                            @($"{sign}{delta:F0} pts")
                                        </span>
                                    }
                                    else { <span>N/A</span> }
                                </MudText>
                            </MudPaper>
                        </MudItem>

                        @* Sprint range *@
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Outlined="true" Class="pa-3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Sprints</MudText>
                                <MudText Typo="Typo.h6">@_trendData.Sprints.Count sprint(s)</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudStack>
            </MudPaper>

            @* ── Chart Layout — true 2×2 grid ── *@
            @if (_trendData.Sprints.Any(s => s.HasData))
            {
                <MudGrid Spacing="3">

                    @* Cell 1 — Combined Flow (Net emphasis) *@
                    <MudItem xs="12" sm="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3" Style="height: 340px; overflow: hidden;">
                            <MudStack Spacing="0" Class="mb-1">
                                @* Title row with Net Focus toggle *@
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Justify="Justify.SpaceBetween">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.subtitle2">Combined Flow</MudText>
                                        @if (_netFocusOnly)
                                        {
                                            <TrendSlopeBadge StartValue="@_netFlowStart"
                                                             EndValue="@_netFlowEnd"
                                                             LowerIsBetter="false"
                                                             PositiveLabel="Contracting"
                                                             NegativeLabel="Expanding"
                                                             NeutralLabel="Balanced"
                                                             MetricLabel="net flow" />
                                        }
                                    </MudStack>
                                    @* Net focus toggle *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Net only</MudText>
                                        <MudSwitch T="bool"
                                                   Value="_netFocusOnly"
                                                   ValueChanged="OnNetFocusToggled"
                                                   Color="Color.Primary"
                                                   Size="Size.Small" />
                                    </MudStack>
                                </MudStack>
                                @* Net cumulative anchor *@
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-primary); font-weight: 600;">
                                        Net (cumulative): @CumulativeNetFlowLabel
                                    </MudText>
                                    <MudTooltip Text="Added Effort approximates scope inflow using sprint commitment data. It may include re-estimation changes and does not track new backlog item creation directly.">
                                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                    </MudTooltip>
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Net &gt; 0 = backlog shrinking; Net &lt; 0 = expanding
                                </MudText>
                            </MudStack>
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_flowSeries"
                                      XAxisLabels="@_xAxisLabels"
                                      Width="100%"
                                      Height="240px"
                                      ChartOptions="@_flowChartOptions" />
                        </MudPaper>
                    </MudItem>

                    @* Cell 2 — Total Scope Trend (Stock) *@
                    <MudItem xs="12" sm="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3" Style="height: 340px; overflow: hidden;">
                            <MudStack Spacing="0" Class="mb-2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Total Scope Trend</MudText>
                                    <TrendSlopeBadge StartValue="@_scopeStart"
                                                     EndValue="@_scopeEnd"
                                                     LowerIsBetter="true"
                                                     PositiveLabel="Decreasing"
                                                     NegativeLabel="Increasing"
                                                     MetricLabel="total scope" />
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Total effort in scope (pts, excl. Removed) — structural product growth
                                </MudText>
                            </MudStack>
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_scopeSeries"
                                      XAxisLabels="@_xAxisLabels"
                                      Width="100%"
                                      Height="240px"
                                      ChartOptions="@_chartOptions" />
                        </MudPaper>
                    </MudItem>

                    @* Cell 3 — Remaining Effort Ratio (% of Total Scope) *@
                    <MudItem xs="12" sm="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3" Style="height: 340px; overflow: hidden;">
                            <MudStack Spacing="0" Class="mb-2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Remaining Effort Ratio</MudText>
                                    <TrendSlopeBadge StartValue="@_remainingRatioStart"
                                                     EndValue="@_remainingRatioEnd"
                                                     LowerIsBetter="true"
                                                     PositiveLabel="Decreasing"
                                                     NegativeLabel="Increasing"
                                                     MetricLabel="remaining ratio" />
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Remaining effort as % of total scope — backlog load ratio (lower is better)
                                </MudText>
                            </MudStack>
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_remainingSeries"
                                      XAxisLabels="@_xAxisLabels"
                                      Width="100%"
                                      Height="240px"
                                      ChartOptions="@_ratioChartOptions" />
                        </MudPaper>
                    </MudItem>

                    @* Cell 4 — Throughput Trend (Flow Capacity) *@
                    <MudItem xs="12" sm="12" md="6">
                        <MudPaper Elevation="2" Class="pa-3" Style="height: 340px; overflow: hidden;">
                            <MudStack Spacing="0" Class="mb-2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.subtitle2">Throughput Trend</MudText>
                                    <TrendSlopeBadge StartValue="@_throughputStart"
                                                     EndValue="@_throughputEnd"
                                                     LowerIsBetter="false"
                                                     PositiveLabel="Rising"
                                                     NegativeLabel="Falling"
                                                     MetricLabel="throughput" />
                                </MudStack>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Effort completed per sprint (pts) — delivery capacity; higher is better
                                </MudText>
                            </MudStack>
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_throughputSeries"
                                      XAxisLabels="@_xAxisLabels"
                                      Width="100%"
                                      Height="240px"
                                      ChartOptions="@_chartOptions" />
                        </MudPaper>
                    </MudItem>

                </MudGrid>
            }
            else if (!_trendsLoading)
            {
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    No sprint projection data available for the selected range.
                    Sprint projections are computed when Sprint Trend is loaded with recompute enabled.
                    @if (_selectedProductId.HasValue)
                    {
                        var product = _products.FirstOrDefault(p => p.Id == _selectedProductId.Value);
                        <text> Showing data for product: @(product?.Name ?? _selectedProductId.ToString()).</text>
                    }
                </MudAlert>
            }
        }
        else if (!_trendsLoading)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                @if (!_selectedTeamId.HasValue)
                {
                    <text>Select a team to enable sprint range selection, then data will load automatically.</text>
                }
                else
                {
                    <text>Select a sprint range to view portfolio progress data.</text>
                }
            </MudAlert>
        }
    }
</MudContainer>

<style>
    .trend-slope-badge {
        font-size: 0.7rem;
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _trendsLoading = false;
    private bool _filtersExpanded = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Selectors
    private int? _selectedProductId;
    private int? _selectedTeamId;
    private int? _fromSprintId;
    private int? _toSprintId;
    private int? _defaultFromSprintId;
    private int? _defaultToSprintId;
    private List<ProductDto> _products = new();
    private List<TeamDto> _teams = new();
    private List<SprintDto> _sprints = new();

    // Context chip labels — computed from current selection
    private string ContextProductLabel => _selectedProductId.HasValue
        ? _products.FirstOrDefault(p => p.Id == _selectedProductId.Value)?.Name ?? "Unknown Product"
        : "All Products";

    private string ContextTeamLabel => _selectedTeamId.HasValue
        ? _teams.FirstOrDefault(t => t.Id == _selectedTeamId.Value)?.Name ?? "Unknown Team"
        : "All Teams";

    private string ContextSprintRangeLabel
    {
        get
        {
            if (!_sprints.Any()) return "No sprints";
            var from = _fromSprintId.HasValue ? _sprints.FirstOrDefault(s => s.Id == _fromSprintId.Value)?.Name ?? "?" : "?";
            var to = _toSprintId.HasValue ? _sprints.FirstOrDefault(s => s.Id == _toSprintId.Value)?.Name ?? "?" : "?";
            return $"{ShortSprintLabel(from)} → {ShortSprintLabel(to)}";
        }
    }

    // True when filters differ from the auto-applied defaults
    private bool IsCustomScope =>
        _selectedProductId.HasValue ||
        (_defaultFromSprintId.HasValue && _fromSprintId != _defaultFromSprintId) ||
        (_defaultToSprintId.HasValue && _toSprintId != _defaultToSprintId);

    // Trend data
    private PortfolioProgressTrendDto? _trendData;

    // Net focus toggle — default ON (show Net only in Combined Flow)
    private bool _netFocusOnly = true;

    // Chart data
    private string[] _xAxisLabels = Array.Empty<string>();
    private List<ChartSeries> _flowSeries = new();
    private List<ChartSeries> _scopeSeries = new();
    private List<ChartSeries> _remainingSeries = new();
    private List<ChartSeries> _throughputSeries = new();

    // TrendSlopeBadge start/end values (first and last non-null data point)
    private double? _netFlowStart, _netFlowEnd;
    private double? _scopeStart, _scopeEnd;
    private double? _remainingRatioStart, _remainingRatioEnd;  // ratio values (%)
    private double? _throughputStart, _throughputEnd;

    // Palette: Net only = primary blue; all series = Net first (blue), Completed (muted green), Added (muted orange)
    private ChartOptions _flowChartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true,
        ChartPalette = new[] { "#1976d2" }
    };

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true
    };

    // Ratio chart options for Remaining Effort % chart
    private ChartOptions _ratioChartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true
    };

    // Computed label for Net cumulative in Combined Flow header
    private string CumulativeNetFlowLabel
    {
        get
        {
            if (_trendData?.Summary.CumulativeNetFlow == null) return "N/A";
            var net = _trendData.Summary.CumulativeNetFlow.Value;
            var sign = net >= 0 ? "+" : "";
            return $"{sign}{net:F0} pts";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }

            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);

            _teams   = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();

            ParseQueryParameters();
            UpdateBreadcrumbs();

            // Default: auto-select first available team and load the default 5-sprint window.
            // This ensures the page loads with data without requiring manual filter selection.
            if (!_selectedTeamId.HasValue && _teams.Count > 0)
            {
                _selectedTeamId = _teams[0].Id;
            }

            if (_selectedTeamId.HasValue)
            {
                await LoadSprintsAsync(_selectedTeamId.Value);

                // Apply default 5-sprint window (current + past 4) if no sprint range was
                // specified via query parameters.
                if (!_fromSprintId.HasValue && !_toSprintId.HasValue)
                {
                    ApplyDefaultSprintWindow();
                }

                // Auto-load trend data with defaults
                await LoadTrendDataAsync();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading portfolio progress: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    /// <summary>
    /// Selects the default sprint window: current sprint + the 4 most recently completed sprints
    /// (5 sprints total), ordered chronologically.
    ///
    /// Selection logic:
    ///   1. Identify the "current" sprint (TimeFrame == "current", or the sprint whose date range
    ///      contains today if TimeFrame is absent).
    ///   2. Take up to 4 past sprints ending before or at the current sprint.
    ///   3. Set _fromSprintId to the earliest and _toSprintId to the current (latest).
    /// </summary>
    private void ApplyDefaultSprintWindow()
    {
        if (_sprints.Count == 0) return;

        var ordered = _sprints.OrderBy(s => s.StartUtc ?? DateTimeOffset.MaxValue).ToList();
        var now     = DateTimeOffset.UtcNow;

        // Find current sprint: prefer TimeFrame == "current", fallback to date range
        var current = ordered.FirstOrDefault(s => s.TimeFrame == "current")
            ?? ordered.FirstOrDefault(s => s.StartUtc <= now && (s.EndUtc == null || s.EndUtc >= now))
            ?? ordered.LastOrDefault(s => s.EndUtc <= now);  // fallback: most recent past sprint

        if (current == null) return;

        var currentIdx = ordered.IndexOf(current);

        // Take up to 4 sprints before current (inclusive = 5 total)
        var fromIdx = Math.Max(0, currentIdx - 4);

        _fromSprintId = ordered[fromIdx].Id;
        _toSprintId   = current.Id;

        // Remember the default window for "Custom Scope" detection
        _defaultFromSprintId = _fromSprintId;
        _defaultToSprintId   = _toSprintId;
    }

    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);

        if (int.TryParse(queryParams["productId"], out var productId))
        {
            _selectedProductId = productId;
        }

        if (int.TryParse(queryParams["teamId"], out var teamId))
        {
            _selectedTeamId = teamId;
        }
    }

    private async Task OnProductChangedAsync(int? productId)
    {
        _selectedProductId = productId;
        await LoadTrendDataAsync();
    }

    private async Task OnTeamChangedAsync(int? teamId)
    {
        _selectedTeamId = teamId;
        _fromSprintId   = null;
        _toSprintId     = null;
        _sprints.Clear();
        _trendData = null;

        if (teamId.HasValue)
        {
            await LoadSprintsAsync(teamId.Value);
            ApplyDefaultSprintWindow();
            await LoadTrendDataAsync();
        }
    }

    private async Task OnFromSprintChangedAsync(int? sprintId)
    {
        _fromSprintId = sprintId;
        await LoadTrendDataAsync();
    }

    private async Task OnToSprintChangedAsync(int? sprintId)
    {
        _toSprintId = sprintId;
        await LoadTrendDataAsync();
    }

    private async Task LoadSprintsAsync(int teamId)
    {
        try
        {
            _sprints = (await SprintService.GetSprintsForTeamAsync(teamId))
                .OrderBy(s => s.StartUtc)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load sprints: {ex.Message}", Severity.Warning);
        }
    }

    private async Task LoadTrendDataAsync()
    {
        if (!_profileId.HasValue) return;

        var sprintIds = GetSelectedSprintIds();
        if (sprintIds.Count == 0)
        {
            _trendData = null;
            return;
        }

        _trendsLoading = true;
        StateHasChanged();

        try
        {
            int[]? productFilter = _selectedProductId.HasValue
                ? new[] { _selectedProductId.Value }
                : null;

            _trendData = await MetricsClient.GetPortfolioProgressTrendAsync(
                _profileId.Value,
                sprintIds,
                productFilter,
                CancellationToken.None);

            if (_trendData != null)
            {
                BuildChartData(_trendData);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load portfolio progress: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _trendsLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Returns the IDs of sprints in the selected range (From..To inclusive).
    /// </summary>
    private List<int> GetSelectedSprintIds()
    {
        if (!_fromSprintId.HasValue && !_toSprintId.HasValue)
            return new List<int>();

        var orderedSprints = _sprints.OrderBy(s => s.StartUtc).ToList();

        var fromIdx = _fromSprintId.HasValue
            ? orderedSprints.FindIndex(s => s.Id == _fromSprintId.Value)
            : 0;
        var toIdx = _toSprintId.HasValue
            ? orderedSprints.FindIndex(s => s.Id == _toSprintId.Value)
            : orderedSprints.Count - 1;

        if (fromIdx < 0) fromIdx = 0;
        if (toIdx   < 0) toIdx   = orderedSprints.Count - 1;
        fromIdx = Math.Clamp(fromIdx, 0, orderedSprints.Count - 1);
        toIdx   = Math.Clamp(toIdx,   0, orderedSprints.Count - 1);
        if (fromIdx > toIdx) (fromIdx, toIdx) = (toIdx, fromIdx);

        return orderedSprints
            .Skip(fromIdx)
            .Take(toIdx - fromIdx + 1)
            .Select(s => s.Id)
            .ToList();
    }

    /// <summary>
    /// Builds chart series and axis labels from the trend DTO.
    /// Only sprints with actual data are included to avoid misleading zero values.
    /// </summary>
    private void BuildChartData(PortfolioProgressTrendDto data)
    {
        var dataPoints = data.Sprints.Where(s => s.HasData).ToList();

        _xAxisLabels = dataPoints.Select(s => ShortSprintLabel(s.SprintName)).ToArray();

        // Graph 2 — Total Scope (Stock)
        _scopeSeries = new List<ChartSeries>
        {
            new() { Name = "Total Scope (pts)", Data = dataPoints.Select(s => s.TotalScopeEffort ?? 0.0).ToArray() }
        };

        // Graph 3 — Remaining Effort Ratio (% of Total Scope)
        // Reuses ComputeRemainingRatio for consistent divide-by-zero handling.
        _remainingSeries = new List<ChartSeries>
        {
            new()
            {
                Name = "Remaining %",
                Data = dataPoints.Select(s => ComputeRemainingRatio(s) ?? 0.0).ToArray()
            }
        };

        // Graph 4 — Throughput (Flow Capacity)
        _throughputSeries = new List<ChartSeries>
        {
            new() { Name = "Throughput (pts)", Data = dataPoints.Select(s => s.ThroughputEffort ?? 0.0).ToArray() }
        };

        // Slope badge values — first and last sprints with actual data
        _netFlowStart    = dataPoints.FirstOrDefault()?.NetFlow;
        _netFlowEnd      = dataPoints.LastOrDefault()?.NetFlow;
        _scopeStart      = dataPoints.FirstOrDefault()?.TotalScopeEffort;
        _scopeEnd        = dataPoints.LastOrDefault()?.TotalScopeEffort;
        _throughputStart = dataPoints.FirstOrDefault()?.ThroughputEffort;
        _throughputEnd   = dataPoints.LastOrDefault()?.ThroughputEffort;

        // Remaining slope badge uses ratio values (%)
        _remainingRatioStart = ComputeRemainingRatio(dataPoints.FirstOrDefault());
        _remainingRatioEnd   = ComputeRemainingRatio(dataPoints.LastOrDefault());

        // Graph 1 — Combined Flow (built from _netFocusOnly state)
        RebuildFlowSeries(dataPoints);
    }

    /// <summary>Computes remaining ratio (%) for a single sprint data point.</summary>
    private static double? ComputeRemainingRatio(PortfolioSprintProgressDto? sprint)
    {
        if (sprint == null) return null;
        if (!sprint.RemainingEffort.HasValue || !sprint.TotalScopeEffort.HasValue || sprint.TotalScopeEffort.Value == 0)
            return null;
        return Math.Round((sprint.RemainingEffort.Value / sprint.TotalScopeEffort.Value) * 100.0, 1);
    }

    /// <summary>
    /// Rebuilds the Combined Flow series based on <see cref="_netFocusOnly"/>.
    /// When focus is ON: only Net Flow (primary blue).
    /// When focus is OFF: Net Flow first (blue), then Completed (muted green), Added (muted orange).
    /// </summary>
    private void RebuildFlowSeries(IList<PortfolioSprintProgressDto>? dataPoints = null)
    {
        dataPoints ??= _trendData?.Sprints.Where(s => s.HasData).ToList() ?? new List<PortfolioSprintProgressDto>();

        if (_netFocusOnly)
        {
            _flowSeries = new List<ChartSeries>
            {
                new() { Name = "Net Flow", Data = dataPoints.Select(s => s.NetFlow ?? 0.0).ToArray() }
            };
            _flowChartOptions = CreateFlowChartOptions(new[] { "#1976d2" });
        }
        else
        {
            _flowSeries = new List<ChartSeries>
            {
                new() { Name = "Net Flow",  Data = dataPoints.Select(s => s.NetFlow           ?? 0.0).ToArray() },
                new() { Name = "Completed", Data = dataPoints.Select(s => s.ThroughputEffort  ?? 0.0).ToArray() },
                new() { Name = "Added",     Data = dataPoints.Select(s => s.AddedEffort       ?? 0.0).ToArray() }
            };
            _flowChartOptions = CreateFlowChartOptions(new[] { "#1976d2", "#81c784", "#ffcc80" });
        }
    }

    /// <summary>Creates flow chart options with the given palette; all other settings are fixed.</summary>
    private static ChartOptions CreateFlowChartOptions(string[] palette) => new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true,
        ChartPalette = palette
    };

    /// <summary>Handles the Net Focus toggle in Combined Flow card.</summary>
    private void OnNetFocusToggled(bool value)
    {
        _netFocusOnly = value;
        RebuildFlowSeries();
        StateHasChanged();
    }

    /// <summary>Returns a short sprint label for the chart x-axis (max ~10 chars).</summary>
    private static string ShortSprintLabel(string name)
    {
        if (name.Length <= 10) return name;
        var lower = name.ToLowerInvariant();
        var idx   = lower.IndexOf("sprint ", StringComparison.Ordinal);
        if (idx >= 0)
        {
            var remainder = name[(idx + 7)..].Trim();
            return remainder.Length <= 5 ? $"S{remainder}" : name[..10];
        }
        return name[..10];
    }

    private async Task LoadInitialDataAsync()
    {
        _errorMessage = null;
        _isLoading    = true;
        StateHasChanged();
        await OnInitializedAsync();
    }

