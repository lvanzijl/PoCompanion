@page "/home/pipelines"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Shared.Pipelines
@using System.Web
@inject IProfileService ProfileService
@inject PipelineService PipelineService
@inject PipelineSprintTrendsService PipelineSprintTrendsService
@inject ProductService ProductService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pipeline Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Pipeline Insights
                    </MudText>
                </MudStack>

                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Sprint Navigation *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                        Sprint Navigation
                    </MudText>

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudText Typo="Typo.body2" Color="@(_advancedMode ? Color.Primary : Color.Default)">
                            @(_advancedMode ? "Trend (Multi-sprint)" : "Zoom (Single sprint)")
                        </MudText>
                        <MudTooltip Text="@(_advancedMode ? "Click to switch to Zoom (Single sprint)" : "Click to switch to Trend (Multi-sprint)")">
                            <MudToggleIconButton Toggled="@_advancedMode"
                                                 ToggledChanged="OnAdvancedModeToggled"
                                                 Icon="@Icons.Material.Filled.BarChart"
                                                 ToggledIcon="@Icons.Material.Filled.BarChart"
                                                 Color="Color.Default"
                                                 ToggledColor="Color.Primary"
                                                 Variant="Variant.Outlined"
                                                 Size="Size.Medium"
                                                 ToggledSize="Size.Medium" />
                        </MudTooltip>
                    </MudStack>
                </MudStack>

                @if (!_advancedMode)
                {
                    @* Single sprint navigation *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="3">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigatePrevious())"
                                       OnClick="NavigateToPreviousSprint"
                                       aria-label="Previous Sprint" />

                        <MudStack AlignItems="AlignItems.Center" Spacing="0">
                            <MudText Typo="Typo.h5" Align="Align.Center">
                                @(_currentSprint?.Name ?? "No sprint selected")
                            </MudText>
                            @if (_currentSprint?.StartUtc != null && _currentSprint?.EndUtc != null)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_currentSprint.StartUtc.Value.ToString("MMM d") — @_currentSprint.EndUtc.Value.ToString("MMM d, yyyy")
                                </MudText>
                            }
                        </MudStack>

                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                       Color="Color.Primary"
                                       Variant="Variant.Outlined"
                                       Disabled="@(!CanNavigateNext())"
                                       OnClick="NavigateToNextSprint"
                                       aria-label="Next Sprint" />
                    </MudStack>
                }
                else
                {
                    @* Advanced mode: multi-sprint trend *@
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                        Showing pipeline trends for the previous @_trendSprintCount sprints ending at the selected sprint.
                    </MudAlert>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="int" Label="Last sprint to show"
                                       Value="@(_currentSprint?.Id ?? 0)"
                                       ValueChanged="OnTrendLastSprintChanged"
                                       Variant="Variant.Outlined"
                                       Dense="true"
                                       FullWidth="true">
                                @foreach (var sprint in _filteredSprints)
                                {
                                    <MudSelectItem Value="@sprint.Id">@sprint.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField T="int" Label="Number of sprints to show"
                                             Value="@_trendSprintCount"
                                             ValueChanged="OnTrendSprintCountChanged"
                                             Min="1"
                                             Max="@MaxAvailableSprints"
                                             Variant="Variant.Outlined"
                                             FullWidth="true" />
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">@GetTrendRangeLabel()</MudText>
                        </MudItem>
                    </MudGrid>
                }

                @* Filter row *@
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnProductChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @if (_metricsLoading)
        {
            <LoadingIndicator IsLoading="true" />
        }
        else if (_filteredSprints.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                No sprints found. Ensure sprint data has been synced.
            </MudAlert>
        }
        else if (_currentSprint == null)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                No sprint selected.
            </MudAlert>
        }
        else
        {
            @* Sprint coverage diagnostics (only shown when there are unmapped runs) *@
            @if (_sprintTrendsResponse != null && _sprintTrendsResponse.Success && _sprintTrendsResponse.UnmappedRunCount > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Sprint coverage: @_sprintTrendsResponse.SprintCoveragePercent.ToString("F0")% of runs mapped
                    · @_sprintTrendsResponse.UnmappedRunCount unmapped run(s) (finished outside sprint boundaries)
                </MudAlert>
            }

            @* Single-sprint: KPI snapshot *@
            @if (!_advancedMode)
            {
                var sprintData = _sprintTrendsResponse?.Sprints.FirstOrDefault(s => s.SprintId == _currentSprint.Id);

                <MudGrid Spacing="3" Class="mb-4">
                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Build Success Rate</MudText>
                            <MudText Typo="Typo.h5" Color="Color.Success">
                                @(sprintData?.SuccessRate.HasValue == true ? $"{sprintData.SuccessRate.Value:F1}%" : "—")
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(sprintData?.CompletedRuns ?? 0) completed runs</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Build Failure Rate</MudText>
                            <MudText Typo="Typo.h5" Color="@(sprintData?.FailureRate > 20 ? Color.Error : Color.Default)">
                                @(sprintData?.FailureRate.HasValue == true ? $"{sprintData.FailureRate.Value:F1}%" : "—")
                            </MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">MTTR (Median)</MudText>
                            <MudText Typo="Typo.h5">
                                @FormatHours(sprintData?.MedianMttrHours)
                            </MudText>
                            @if (sprintData?.P75MttrHours.HasValue == true)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">P75: @FormatHours(sprintData.P75MttrHours)</MudText>
                            }
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pipeline Duration (Median)</MudText>
                            <MudText Typo="Typo.h5">
                                @FormatHours(sprintData?.MedianDurationHours)
                            </MudText>
                            @if (sprintData?.P75DurationHours.HasValue == true)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">P75: @FormatHours(sprintData.P75DurationHours)</MudText>
                            }
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Time to First Failure</MudText>
                            <MudText Typo="Typo.h5">
                                @FormatHours(sprintData?.MedianTimeToFirstFailureHours)
                            </MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="12" sm="6" md="4">
                        <MudPaper Elevation="2" Class="pa-4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Flakiness Rate</MudText>
                            <MudText Typo="Typo.h5" Color="@(sprintData?.FlakinessRate > 30 ? Color.Warning : Color.Default)">
                                @(sprintData?.FlakinessRate.HasValue == true ? $"{sprintData.FlakinessRate.Value:F1}%" : "—")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                @if (sprintData == null || sprintData.TotalRuns == 0)
                {
                    <MudAlert Severity="Severity.Info">No pipeline runs found for this sprint.</MudAlert>
                }
            }

            @* Multi-sprint trend charts *@
            @if (_advancedMode && _trendSprints.Count > 0)
            {
                @* Build Success & Failure Rate Trend *@
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" />
                        Build Success / Failure Rate per Sprint
                    </MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_successFailureChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* MTTR Trend *@
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Build" Class="mr-2" />
                        MTTR per Sprint (hours)
                    </MudText>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_mttrChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Duration Trend *@
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Class="mr-2" />
                        Pipeline Duration per Sprint (hours)
                    </MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_durationChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Flakiness Trend *@
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                        Flakiness Rate per Sprint (%)
                    </MudText>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_flakinessChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>

                @* Time to First Failure Trend *@
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-3">
                        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Class="mr-2" />
                        Time to First Failure Detection per Sprint (hours)
                    </MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_ttffChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="300px"
                              ChartOptions="@_chartOptions" />
                </MudPaper>
            }
            else if (_advancedMode && _trendSprints.Count == 0 && !_metricsLoading)
            {
                <MudAlert Severity="Severity.Info">No pipeline data available for the selected sprint range.</MudAlert>
            }
        }
    }
</MudContainer>

@code {
    private const int TrendSprintCount = 10;

    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Selectors
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private bool _advancedMode = true;
    private int _trendSprintCount = TrendSprintCount;
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;

    // Trend data
    private GetPipelineSprintTrendsResponse? _sprintTrendsResponse;
    private List<PipelineSprintMetricsDto> _trendSprints = new();
    private string[] _trendXAxisLabels = Array.Empty<string>();
    private List<ChartSeries> _successFailureChartSeries = new();
    private List<ChartSeries> _mttrChartSeries = new();
    private List<ChartSeries> _durationChartSeries = new();
    private List<ChartSeries> _flakinessChartSeries = new();
    private List<ChartSeries> _ttffChartSeries = new();

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        YAxisLines = true,
        XAxisLines = true
    };

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;

            if (_profileId == null)
            {
                _errorMessage = "No active profile selected.";
                return;
            }

            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value)).ToList();

            // Load all sprints for all teams
            _allSprints.Clear();
            foreach (var team in _teams)
            {
                try
                {
                    var teamSprints = (await SprintService.GetSprintsForTeamAsync(team.Id)).ToList();
                    _allSprints.AddRange(teamSprints);
                }
                catch { /* skip teams without sprints */ }
            }

            ApplySprintFilters();
            FindCurrentSprint();

            await LoadMetricsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplySprintFilters()
    {
        var sprints = _allSprints.AsEnumerable();
        if (_selectedTeamId.HasValue)
        {
            sprints = sprints.Where(s => s.TeamId == _selectedTeamId.Value);
        }

        _filteredSprints = sprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .ToList();
    }

    private void FindCurrentSprint()
    {
        var now = DateTimeOffset.UtcNow;
        _currentSprintIndex = _filteredSprints.FindIndex(s => s.StartUtc <= now && s.EndUtc >= now);

        if (_currentSprintIndex < 0 && _filteredSprints.Count > 0)
        {
            _currentSprintIndex = _filteredSprints.FindLastIndex(s => s.EndUtc <= now);
            if (_currentSprintIndex < 0)
                _currentSprintIndex = _filteredSprints.Count - 1;
        }

        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadMetricsAsync()
    {
        _metricsLoading = true;
        _sprintTrendsResponse = null;
        _trendSprints.Clear();
        _trendXAxisLabels = Array.Empty<string>();
        StateHasChanged();

        try
        {
            if (!_profileId.HasValue || _currentSprint == null)
                return;

            List<int> sprintIds;
            if (_advancedMode)
            {
                var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
                sprintIds = _filteredSprints
                    .Skip(startIndex)
                    .Take(_currentSprintIndex - startIndex + 1)
                    .Select(s => s.Id)
                    .ToList();
            }
            else
            {
                sprintIds = new List<int> { _currentSprint.Id };
            }

            if (sprintIds.Count == 0)
                return;

            IEnumerable<int>? productFilter = _selectedProductId.HasValue
                ? new[] { _selectedProductId.Value }
                : null;

            _sprintTrendsResponse = await PipelineSprintTrendsService.GetSprintTrendsAsync(
                _profileId.Value,
                sprintIds,
                productFilter);

            if (_sprintTrendsResponse?.Success == true)
            {
                _trendSprints = _sprintTrendsResponse.Sprints
                    .OrderBy(s => s.StartUtc ?? DateTimeOffset.MaxValue)
                    .ToList();

                if (_advancedMode)
                {
                    BuildTrendCharts();
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading pipeline metrics: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }

    private void BuildTrendCharts()
    {
        if (_trendSprints.Count == 0) return;

        _trendXAxisLabels = _trendSprints.Select(s => s.SprintName).ToArray();

        _successFailureChartSeries = new List<ChartSeries>
        {
            new() { Name = "Success %", Data = _trendSprints.Select(s => s.SuccessRate ?? 0).ToArray() },
            new() { Name = "Failure %", Data = _trendSprints.Select(s => s.FailureRate ?? 0).ToArray() }
        };

        _mttrChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median MTTR (h)", Data = _trendSprints.Select(s => s.MedianMttrHours ?? 0).ToArray() },
            new() { Name = "P75 MTTR (h)", Data = _trendSprints.Select(s => s.P75MttrHours ?? 0).ToArray() }
        };

        _durationChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median Duration (h)", Data = _trendSprints.Select(s => s.MedianDurationHours ?? 0).ToArray() },
            new() { Name = "P75 Duration (h)", Data = _trendSprints.Select(s => s.P75DurationHours ?? 0).ToArray() }
        };

        _flakinessChartSeries = new List<ChartSeries>
        {
            new() { Name = "Flakiness %", Data = _trendSprints.Select(s => s.FlakinessRate ?? 0).ToArray() }
        };

        _ttffChartSeries = new List<ChartSeries>
        {
            new() { Name = "Median TTFF (h)", Data = _trendSprints.Select(s => s.MedianTimeToFirstFailureHours ?? 0).ToArray() }
        };
    }

    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);

        var teamIdStr = queryParams["teamId"];
        if (!string.IsNullOrEmpty(teamIdStr) && int.TryParse(teamIdStr, out var teamId))
            _selectedTeamId = teamId;

        var productIdStr = queryParams["productId"];
        if (!string.IsNullOrEmpty(productIdStr) && int.TryParse(productIdStr, out var productId))
            _selectedProductId = productId;
    }

    private void UpdateUrlParameters()
    {
        var queryParams = new List<string>();
        if (_selectedTeamId.HasValue) queryParams.Add($"teamId={_selectedTeamId.Value}");
        if (_selectedProductId.HasValue) queryParams.Add($"productId={_selectedProductId.Value}");

        var qs = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : string.Empty;
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PipelineOverview}{qs}", forceLoad: false);
    }

    private bool CanNavigatePrevious() => _currentSprintIndex > 0;
    private bool CanNavigateNext() => _currentSprintIndex >= 0 && _currentSprintIndex < _filteredSprints.Count - 1;
    private int MaxAvailableSprints => _filteredSprints.Count > 0 ? _filteredSprints.Count : 1;

    private string GetTrendRangeLabel()
    {
        if (_filteredSprints.Count == 0 || _currentSprintIndex < 0) return string.Empty;
        var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
        return $"{_filteredSprints[startIndex].Name} – {_currentSprint!.Name}";
    }

    private static string FormatHours(double? hours)
    {
        if (!hours.HasValue) return "—";
        if (hours.Value < 1) return $"{hours.Value * 60:F0} min";
        return $"{hours.Value:F1} h";
    }

    private async Task NavigateToPreviousSprint()
    {
        if (CanNavigatePrevious())
        {
            _currentSprintIndex--;
            _currentSprint = _filteredSprints[_currentSprintIndex];
            await LoadMetricsAsync();
        }
    }

    private async Task NavigateToNextSprint()
    {
        if (CanNavigateNext())
        {
            _currentSprintIndex++;
            _currentSprint = _filteredSprints[_currentSprintIndex];
            await LoadMetricsAsync();
        }
    }

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        UpdateUrlParameters();
        ApplySprintFilters();
        FindCurrentSprint();
        await LoadMetricsAsync();
    }

    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        UpdateUrlParameters();
        await LoadMetricsAsync();
    }

    private async Task OnAdvancedModeToggled(bool toggled)
    {
        _advancedMode = toggled;
        await LoadMetricsAsync();
    }

    private async Task OnTrendLastSprintChanged(int sprintId)
    {
        var index = _filteredSprints.FindIndex(s => s.Id == sprintId);
        if (index >= 0)
        {
            _currentSprintIndex = index;
            _currentSprint = _filteredSprints[index];
            await LoadMetricsAsync();
        }
    }

    private async Task OnTrendSprintCountChanged(int count)
    {
        _trendSprintCount = Math.Max(1, count);
        await LoadMetricsAsync();
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
