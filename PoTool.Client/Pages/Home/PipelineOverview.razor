@page "/home/pipelines"
@using PoTool.Client.Components.Analytical
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Shared.Pipelines
@using System.Web
@inject IProfileService ProfileService
@inject IPipelinesClient PipelinesClient
@inject ProductService ProductService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pipeline Trend - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.ShowChart" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Pipeline Trend</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadDataAsync" Class="ml-2">Retry</MudButton>
        </MudAlert>
    }
    else
    {
        @* Sprint range + filter controls *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                    Sprint Range
                </MudText>

                <MudGrid Spacing="2">
                    @* Team selector (drives sprint list) *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Product filter *@
                    <MudItem xs="12" sm="6" md="3">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnProductChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    @* Last sprint to show *@
                    @if (_filteredSprints.Count > 0)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="int"
                                       Label="End sprint"
                                       Value="@(_currentSprint?.Id ?? 0)"
                                       ValueChanged="OnEndSprintChanged"
                                       Variant="Variant.Outlined"
                                       FullWidth="true">
                                @foreach (var sprint in _filteredSprints)
                                {
                                    <MudSelectItem Value="@sprint.Id">@sprint.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        @* Sprint count *@
                        <MudItem xs="12" sm="6" md="3">
                            <MudNumericField T="int"
                                             Label="Sprints to show"
                                             Value="@_trendSprintCount"
                                             ValueChanged="OnTrendSprintCountChanged"
                                             Min="2"
                                             Max="@MaxAvailableSprints"
                                             Variant="Variant.Outlined"
                                             FullWidth="true" />
                        </MudItem>
                    }
                </MudGrid>

                @if (_filteredSprints.Count > 0 && _currentSprint != null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Showing @GetTrendRangeLabel()
                    </MudText>
                }
            </MudStack>
        </MudPaper>

        @if (_metricsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Info" Class="mb-2" />
        }

        @if (_filteredSprints.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No sprints found. Ensure sprint data has been synced.</MudAlert>
        }
        else if (_currentSprint == null)
        {
            <MudAlert Severity="Severity.Info">No sprint selected.</MudAlert>
        }
        else if (_trendSprints.Count > 0)
        {
            @* Coverage notice (only when unmapped runs exist) *@
            @if (_sprintTrendsResponse?.UnmappedRunCount > 0)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Sprint coverage: @_sprintTrendsResponse.SprintCoveragePercent.ToString("F0")% of runs mapped
                    · @_sprintTrendsResponse.UnmappedRunCount unmapped run(s) finished outside sprint boundaries.
                </MudAlert>
            }

            @* Chart Layout (Primary Visualization Pattern) *@
            <AnalyticalPageLayout>

                @* Row 1 — Primary Visualization: Reliability Trend (full width, dominant) *@
                <PrimaryVisualizationSection>
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">Reliability Trend</MudText>
                            <TrendSlopeBadge StartValue="@_reliabilityStart"
                                             EndValue="@_reliabilityEnd"
                                             LowerIsBetter="false"
                                             MetricLabel="success rate" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Success rate % per sprint (successful / completed runs; cancelled excluded)
                        </MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_reliabilityChartSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="340px"
                              ChartOptions="@_chartOptions" />
                </PrimaryVisualizationSection>

                @* Row 2 — Secondary Visualizations: 3 equal columns *@
                <SecondaryVisualizationGrid Columns="3">

                    @* Cell 1 — Time-to-Green Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Time-to-Green Trend</MudText>
                                <TrendSlopeBadge StartValue="@_ttgStart"
                                                 EndValue="@_ttgEnd"
                                                 LowerIsBetter="true"
                                                 MetricLabel="time to green" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @if (_hasMainBranchData)
                                {
                                    <text>Median duration (h) of main/master branch runs per sprint</text>
                                }
                                else
                                {
                                    <text>Median pipeline duration (h) per sprint — all branches (no main-branch runs detected)</text>
                                }
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_ttgChartSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                    @* Cell 2 — Tail Risk Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Tail Risk Trend</MudText>
                                <TrendSlopeBadge StartValue="@_tailRiskStart"
                                                 EndValue="@_tailRiskEnd"
                                                 LowerIsBetter="true"
                                                 MetricLabel="P90 duration" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                P90 pipeline duration (h) per sprint — gaps shown when fewer than 3 runs
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_tailRiskChartSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                    @* Cell 3 — Flakiness Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Flakiness / Instability Trend</MudText>
                                <TrendSlopeBadge StartValue="@_flakinessStart"
                                                 EndValue="@_flakinessEnd"
                                                 LowerIsBetter="true"
                                                 MetricLabel="flakiness rate" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                % of distinct pipelines with both successes and failures in the same sprint
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_flakinessChartSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                </SecondaryVisualizationGrid>

            </AnalyticalPageLayout>

            @* Advanced drill-down (secondary; collapsed by default) *@
            <MudExpansionPanels>
                <MudExpansionPanel Text="Advanced / Drill-down" Icon="@Icons.Material.Filled.ExpandMore">
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                        Detailed sprint metrics table. Sprint coverage:
                        @_sprintTrendsResponse?.SprintCoveragePercent.ToString("F0")%
                        (@_sprintTrendsResponse?.UnmappedRunCount unmapped runs)
                    </MudText>
                    <MudSimpleTable Dense="true" Hover="true" Bordered="false">
                        <thead>
                            <tr>
                                <th>Sprint</th>
                                <th>Runs</th>
                                <th>Success&nbsp;%</th>
                                <th>Median&nbsp;Duration&nbsp;(h)</th>
                                <th>P75&nbsp;Duration&nbsp;(h)</th>
                                <th>P90&nbsp;Duration&nbsp;(h)</th>
                                <th>Main-Branch&nbsp;Runs</th>
                                <th>Flakiness&nbsp;%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _trendSprints)
                            {
                                <tr>
                                    <td>@s.SprintName</td>
                                    <td>@s.TotalRuns</td>
                                    <td>@(s.SuccessRate.HasValue ? $"{s.SuccessRate.Value:F1}" : "—")</td>
                                    <td>@FormatHours(s.MedianDurationHours)</td>
                                    <td>@FormatHours(s.P75DurationHours)</td>
                                    <td>@FormatHours(s.P90DurationHours)</td>
                                    <td>@(s.MainBranchRunCount > 0 ? $"{s.MainBranchRunCount} ({FormatHours(s.MedianMainBranchDurationHours)})" : "—")</td>
                                    <td>@(s.FlakinessRate.HasValue ? $"{s.FlakinessRate.Value:F1}" : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
        else if (!_metricsLoading)
        {
            <MudAlert Severity="Severity.Info">No pipeline data available for the selected sprint range.</MudAlert>
        }
    }
</MudContainer>

<style>
    .trend-slope-badge {
        font-size: 0.7rem;
    }
</style>

@code {
    private const int DefaultTrendSprintCount = 6;

    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Selectors
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private int _trendSprintCount = DefaultTrendSprintCount;
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;

    // Trend data
    private GetPipelineSprintTrendsResponse? _sprintTrendsResponse;
    private List<PipelineSprintMetricsDto> _trendSprints = new();
    private string[] _trendXAxisLabels = Array.Empty<string>();

    // 2×2 chart series
    private List<ChartSeries> _reliabilityChartSeries = new();
    private List<ChartSeries> _ttgChartSeries = new();
    private List<ChartSeries> _tailRiskChartSeries = new();
    private List<ChartSeries> _flakinessChartSeries = new();

    // Whether this response has main-branch data (affects Time-to-Green subtitle)
    private bool _hasMainBranchData = false;

    // Slope badge endpoints (first/last non-null point in the sprint range)
    private double? _reliabilityStart, _reliabilityEnd;
    private double? _ttgStart, _ttgEnd;
    private double? _tailRiskStart, _tailRiskEnd;
    private double? _flakinessStart, _flakinessEnd;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true
    };

    protected override async Task OnInitializedAsync()
    {
        ParseQueryParameters();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;

            if (_profileId == null)
            {
                _errorMessage = "No active profile selected.";
                return;
            }

            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value)).ToList();

            _allSprints.Clear();
            foreach (var team in _teams)
            {
                try
                {
                    var teamSprints = (await SprintService.GetSprintsForTeamAsync(team.Id)).ToList();
                    _allSprints.AddRange(teamSprints);
                }
                catch { /* skip teams without sprints */ }
            }

            ApplySprintFilters();
            FindCurrentSprint();
            await LoadMetricsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplySprintFilters()
    {
        var sprints = _allSprints.AsEnumerable();
        if (_selectedTeamId.HasValue)
            sprints = sprints.Where(s => s.TeamId == _selectedTeamId.Value);

        _filteredSprints = sprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .DistinctBy(s => s.Id)
            .ToList();
    }

    private void FindCurrentSprint()
    {
        var now = DateTimeOffset.UtcNow;
        _currentSprintIndex = _filteredSprints.FindIndex(s => s.StartUtc <= now && s.EndUtc >= now);

        if (_currentSprintIndex < 0 && _filteredSprints.Count > 0)
        {
            _currentSprintIndex = _filteredSprints.FindLastIndex(s => s.EndUtc <= now);
            if (_currentSprintIndex < 0)
                _currentSprintIndex = _filteredSprints.Count - 1;
        }

        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadMetricsAsync()
    {
        _metricsLoading = true;
        _sprintTrendsResponse = null;
        _trendSprints.Clear();
        _trendXAxisLabels = Array.Empty<string>();
        StateHasChanged();

        try
        {
            if (!_profileId.HasValue || _currentSprint == null)
                return;

            var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
            var sprintIds = _filteredSprints
                .Skip(startIndex)
                .Take(_currentSprintIndex - startIndex + 1)
                .Select(s => s.Id)
                .ToList();

            if (sprintIds.Count == 0)
                return;

            var productIdsString = _selectedProductId.HasValue
                ? _selectedProductId.Value.ToString()
                : null;

            _sprintTrendsResponse = await PipelinesClient.GetSprintTrendsAsync(
                _profileId.Value,
                sprintIds,
                productIds: productIdsString,
                teamId: !_selectedProductId.HasValue ? _selectedTeamId : null,
                CancellationToken.None);

            if (_sprintTrendsResponse?.Success == true)
            {
                _trendSprints = _sprintTrendsResponse.Sprints
                    .OrderBy(s => s.StartUtc ?? DateTimeOffset.MaxValue)
                    .ToList();

                _hasMainBranchData = _sprintTrendsResponse.HasMainBranchData;
                BuildTrendCharts();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading pipeline metrics: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }

    private void BuildTrendCharts()
    {
        if (_trendSprints.Count == 0) return;

        _trendXAxisLabels = _trendSprints.Select(s => s.SprintName).ToArray();

        // Chart 1: Reliability — null → 0 gap representation
        _reliabilityChartSeries = new List<ChartSeries>
        {
            new() { Name = "Success %", Data = _trendSprints.Select(s => s.SuccessRate ?? 0).ToArray() }
        };
        (_reliabilityStart, _reliabilityEnd) = FirstLastNonNull(_trendSprints.Select(s => s.SuccessRate));

        // Chart 2: Time-to-Green — prefer main-branch median; fall back to all-branch median
        if (_hasMainBranchData)
        {
            _ttgChartSeries = new List<ChartSeries>
            {
                new() { Name = "Median Main-Branch Duration (h)", Data = _trendSprints.Select(s => s.MedianMainBranchDurationHours ?? 0).ToArray() }
            };
            (_ttgStart, _ttgEnd) = FirstLastNonNull(_trendSprints.Select(s => s.MedianMainBranchDurationHours));
        }
        else
        {
            _ttgChartSeries = new List<ChartSeries>
            {
                new() { Name = "Median Duration (h)", Data = _trendSprints.Select(s => s.MedianDurationHours ?? 0).ToArray() }
            };
            (_ttgStart, _ttgEnd) = FirstLastNonNull(_trendSprints.Select(s => s.MedianDurationHours));
        }

        // Chart 3: Tail Risk (P90 duration; null shown as 0 in chart)
        _tailRiskChartSeries = new List<ChartSeries>
        {
            new() { Name = "P90 Duration (h)", Data = _trendSprints.Select(s => s.P90DurationHours ?? 0).ToArray() }
        };
        (_tailRiskStart, _tailRiskEnd) = FirstLastNonNull(_trendSprints.Select(s => s.P90DurationHours));

        // Chart 4: Flakiness
        _flakinessChartSeries = new List<ChartSeries>
        {
            new() { Name = "Flakiness %", Data = _trendSprints.Select(s => s.FlakinessRate ?? 0).ToArray() }
        };
        (_flakinessStart, _flakinessEnd) = FirstLastNonNull(_trendSprints.Select(s => s.FlakinessRate));
    }

    /// <summary>Returns the first and last non-null values in a series for slope badge computation.</summary>
    private static (double? first, double? last) FirstLastNonNull(IEnumerable<double?> values)
    {
        var nonNull = values.Where(v => v.HasValue).Select(v => v!.Value).ToList();
        if (nonNull.Count < 2) return (null, null);
        return (nonNull.First(), nonNull.Last());
    }

    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);

        var teamIdStr = queryParams["teamId"];
        if (!string.IsNullOrEmpty(teamIdStr) && int.TryParse(teamIdStr, out var teamId))
            _selectedTeamId = teamId;

        var productIdStr = queryParams["productId"];
        if (!string.IsNullOrEmpty(productIdStr) && int.TryParse(productIdStr, out var productId))
            _selectedProductId = productId;
    }

    private void UpdateUrlParameters()
    {
        var queryParams = new List<string>();
        if (_selectedTeamId.HasValue) queryParams.Add($"teamId={_selectedTeamId.Value}");
        if (_selectedProductId.HasValue) queryParams.Add($"productId={_selectedProductId.Value}");
        var qs = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : string.Empty;
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PipelineOverview}{qs}", forceLoad: false);
    }

    private int MaxAvailableSprints => _filteredSprints.Count > 0 ? _filteredSprints.Count : 1;

    private string GetTrendRangeLabel()
    {
        if (_filteredSprints.Count == 0 || _currentSprintIndex < 0) return string.Empty;
        var startIndex = Math.Max(0, _currentSprintIndex - _trendSprintCount + 1);
        return $"{_filteredSprints[startIndex].Name} – {_currentSprint!.Name}";
    }

    private static string FormatHours(double? hours)
    {
        if (!hours.HasValue) return "—";
        if (hours.Value < 1) return $"{hours.Value * 60:F0} min";
        return $"{hours.Value:F1} h";
    }

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        UpdateUrlParameters();
        ApplySprintFilters();
        FindCurrentSprint();
        await LoadMetricsAsync();
    }

    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        UpdateUrlParameters();
        await LoadMetricsAsync();
    }

    private async Task OnEndSprintChanged(int sprintId)
    {
        var index = _filteredSprints.FindIndex(s => s.Id == sprintId);
        if (index >= 0)
        {
            _currentSprintIndex = index;
            _currentSprint = _filteredSprints[index];
            await LoadMetricsAsync();
        }
    }

    private async Task OnTrendSprintCountChanged(int count)
    {
        _trendSprintCount = Math.Max(2, count);
        await LoadMetricsAsync();
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pipeline Trend", null, disabled: true, icon: Icons.Material.Filled.ShowChart)
        };
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
}

