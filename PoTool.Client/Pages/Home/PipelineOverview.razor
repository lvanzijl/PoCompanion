@page "/home/pipelines"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using System.Web
@inject IProfileService ProfileService
@inject PipelineService PipelineService
@inject ProductService ProductService
@inject TeamService TeamService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pipeline Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Pipeline Insights
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadPipelineDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Team & Product Selectors *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
                    Filters
                </MudText>
                
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnProductChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @* Metrics Grid *@
        <MudGrid Spacing="3">
            @* Build Success Rate *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Build Success Rate"
                           Result="_buildSuccessRate"
                           ValueFormat="MetricValueFormat.Percentage"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Build Failure Rate *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Build Failure Rate"
                           Result="_buildFailureRate"
                           ValueFormat="MetricValueFormat.Percentage"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Mean Time To Repair (MTTR) *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Mean Time To Repair (MTTR)"
                           Result="_mttr"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Pipeline Duration *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Pipeline Duration"
                           Result="_pipelineDuration"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Time to First Failure Detection *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Time to First Failure Detection"
                           Result="_timeToFirstFailure"
                           ValueFormat="MetricValueFormat.Hours"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Flakiness Rate *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Flakiness Rate"
                           Result="_flakinessRate"
                           ValueFormat="MetricValueFormat.Percentage"
                           ItemLabel="builds"
                           IsLoading="_metricsLoading" />
            </MudItem>
        </MudGrid>

        @if (_pipelineRuns.Count == 0 && !_metricsLoading)
        {
            <MudPaper Elevation="2" Class="pa-6 mt-4">
                <MudAlert Severity="Severity.Info">
                    No pipeline data found for the selected team/product and time range.
                </MudAlert>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Selectors
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    
    // Pipeline Data
    private List<PipelineRunDto> _pipelineRuns = new();
    
    // Calculated Metrics
    private MetricResult? _buildSuccessRate;
    private MetricResult? _buildFailureRate;
    private MetricResult? _mttr;
    private MetricResult? _pipelineDuration;
    private MetricResult? _timeToFirstFailure;
    private MetricResult? _flakinessRate;
    
    // Calculator
    private readonly PipelineInsightsCalculator _calculator = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Load teams and products
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            // Parse URL parameters
            ParseQueryParameters();
            
            // Load pipeline data and calculate metrics
            await LoadPipelineDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading pipeline insights: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        // Parse teamId
        var teamIdStr = queryParams["teamId"];
        if (!string.IsNullOrEmpty(teamIdStr) && int.TryParse(teamIdStr, out var teamId))
        {
            _selectedTeamId = teamId;
        }
        
        // Parse productId
        var productIdStr = queryParams["productId"];
        if (!string.IsNullOrEmpty(productIdStr) && int.TryParse(productIdStr, out var productId))
        {
            _selectedProductId = productId;
        }
    }
    
    private async Task LoadPipelineDataAsync()
    {
        _metricsLoading = true;
        _errorMessage = null;
        StateHasChanged();
        
        try
        {
            // Determine product IDs to filter by
            List<int>? productIds = null;
            
            if (_selectedProductId.HasValue)
            {
                productIds = new List<int> { _selectedProductId.Value };
            }
            else if (_selectedTeamId.HasValue)
            {
                // TODO: Implement proper team-to-product relationship filtering
                // Currently loads all products when a team is selected
                // This requires querying ProductTeamLink entities to get products for selected team
                var teamProducts = _products.Select(p => p.Id).ToList();
                
                if (teamProducts.Any())
                {
                    productIds = teamProducts;
                }
            }
            
            // Build product IDs string
            var productIdsStr = productIds != null ? string.Join(",", productIds) : null;
            
            // Load pipeline runs (will be empty until API client is regenerated)
            // For now, we'll use metrics to simulate the data
            _pipelineRuns = (await PipelineService.GetRunsForProductsAsync(productIdsStr)).ToList();
            
            // If we don't have runs yet (API not ready), use metrics as fallback
            if (_pipelineRuns.Count == 0)
            {
                var metrics = (await PipelineService.GetMetricsAsync(productIdsStr)).ToList();
                
                // Calculate metrics from aggregated data
                CalculateMetricsFromAggregates(metrics);
            }
            else
            {
                // Calculate metrics from individual runs
                CalculateMetrics();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load pipeline data: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }
    
    private void CalculateMetrics()
    {
        _buildSuccessRate = _calculator.CalculateBuildSuccessRate(_pipelineRuns);
        _buildFailureRate = _calculator.CalculateBuildFailureRate(_pipelineRuns);
        _mttr = _calculator.CalculateMTTR(_pipelineRuns);
        _pipelineDuration = _calculator.CalculatePipelineDuration(_pipelineRuns);
        _timeToFirstFailure = _calculator.CalculateTimeToFirstFailureDetection(_pipelineRuns);
        _flakinessRate = _calculator.CalculateFlakinessRate(_pipelineRuns);
    }
    
    private void CalculateMetricsFromAggregates(List<PipelineMetricsDto> metrics)
    {
        // Calculate success and failure rates from aggregated metrics
        var totalRuns = metrics.Sum(m => m.TotalRuns);
        var totalSuccessful = metrics.Sum(m => m.SuccessfulRuns);
        var totalFailed = metrics.Sum(m => m.FailedRuns + m.PartiallySucceededRuns);
        
        if (totalRuns > 0)
        {
            var successRate = (double)totalSuccessful / totalRuns * 100;
            _buildSuccessRate = new MetricResult(successRate, null, totalRuns, null);
            
            var failureRate = (double)totalFailed / totalRuns * 100;
            _buildFailureRate = new MetricResult(failureRate, null, totalRuns, null);
        }
        else
        {
            _buildSuccessRate = new MetricResult(null, null, 0, null);
            _buildFailureRate = new MetricResult(null, null, 0, null);
        }
        
        // Calculate duration from average durations
        var durationsInHours = metrics
            .Where(m => m.AverageDuration.HasValue)
            .Select(m => m.AverageDuration!.Value.TotalHours)
            .OrderBy(x => x)
            .ToList();
        
        if (durationsInHours.Count > 0)
        {
            var medianDuration = CalculateMedian(durationsInHours);
            var p75Duration = CalculatePercentile(durationsInHours, 75);
            _pipelineDuration = new MetricResult(medianDuration, p75Duration, durationsInHours.Count, null);
        }
        else
        {
            _pipelineDuration = new MetricResult(null, null, 0, null);
        }
        
        // MTTR, time to first failure, and flakiness require individual run data
        // These will be null until we have access to detailed runs
        _mttr = new MetricResult(null, null, 0, null);
        _timeToFirstFailure = new MetricResult(null, null, 0, null);
        _flakinessRate = new MetricResult(null, null, 0, null);
    }
    
    private double? CalculateMedian(List<double> sortedValues)
    {
        if (sortedValues.Count == 0)
            return null;

        int mid = sortedValues.Count / 2;
        if (sortedValues.Count % 2 == 0)
        {
            return (sortedValues[mid - 1] + sortedValues[mid]) / 2.0;
        }
        return sortedValues[mid];
    }
    
    private double? CalculatePercentile(List<double> sortedValues, int percentile)
    {
        if (sortedValues.Count == 0)
            return null;

        double rank = (percentile / 100.0) * (sortedValues.Count - 1);
        int lowerIndex = (int)Math.Floor(rank);
        int upperIndex = (int)Math.Ceiling(rank);

        if (lowerIndex == upperIndex)
        {
            return sortedValues[lowerIndex];
        }

        double lowerValue = sortedValues[lowerIndex];
        double upperValue = sortedValues[upperIndex];
        double fraction = rank - lowerIndex;

        return lowerValue + (upperValue - lowerValue) * fraction;
    }
    
    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        UpdateUrlParameters();
        await LoadPipelineDataAsync();
    }
    
    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        UpdateUrlParameters();
        await LoadPipelineDataAsync();
    }
    
    private void UpdateUrlParameters()
    {
        var queryParams = new List<string>();
        
        if (_selectedTeamId.HasValue)
        {
            queryParams.Add($"teamId={_selectedTeamId.Value}");
        }
        
        if (_selectedProductId.HasValue)
        {
            queryParams.Add($"productId={_selectedProductId.Value}");
        }
        
        var queryString = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : "";
        var newUrl = $"{WorkspaceRoutes.PipelineOverview}{queryString}";
        
        NavigationManager.NavigateTo(newUrl, forceLoad: false);
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pipeline Insights", null, disabled: true, icon: Icons.Material.Filled.Insights)
        };
    }
    
    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
}
