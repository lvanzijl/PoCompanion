    }

    private async Task NavigateToPlanning()
    {
        NavigationManager.NavigateTo(await GlobalFilterRouteService.BuildPlanningPageUriAsync(
            "PlanningWorkspace",
            _selectedProjectRouteKey,
            additionalParams: WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri)));
    }

    private async Task NavigateToHealth()
    {
        var currentContext = WorkspaceQueryContextHelper.Parse(NavigationManager.Uri);
        var selectedProjectId = currentContext.ProjectId
            ?? _projects.FirstOrDefault(project => string.Equals(project.Alias, _selectedProjectRouteKey, StringComparison.OrdinalIgnoreCase))?.Id;
        NavigationManager.NavigateTo(await GlobalFilterRouteService.BuildUriAsync(
            WorkspaceRoutes.HealthWorkspace,
            new FilterState(
                currentContext.ProductId.HasValue ? [currentContext.ProductId.Value] : Array.Empty<int>(),
                string.IsNullOrWhiteSpace(selectedProjectId) ? Array.Empty<string>() : [selectedProjectId],
                currentContext.TeamId,
                new FilterTimeSelection(
                    currentContext.TimeMode ?? FilterTimeMode.Snapshot,
                    currentContext.SprintId,
                    currentContext.FromSprintId,
                    currentContext.ToSprintId,
                    currentContext.RollingWindow,
                    currentContext.RollingUnit)),
            WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri)));
    }

    private async Task NavigateToRoadmapEditor(int productId)
    {
        NavigationManager.NavigateTo(await GlobalFilterRouteService.BuildUriAsync(
            WorkspaceRoutes.GetProductRoadmapEditor(productId),
            new FilterState(
                [productId],
                string.IsNullOrWhiteSpace(_selectedProjectRouteKey)
                    ? Array.Empty<string>()
                    : [_projects.FirstOrDefault(project => string.Equals(project.Alias, _selectedProjectRouteKey, StringComparison.OrdinalIgnoreCase))?.Id ?? string.Empty],
                null,
                FilterTimeSelection.Snapshot),
