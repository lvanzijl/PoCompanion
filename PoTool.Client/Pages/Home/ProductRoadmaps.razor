@page "/planning/product-roadmaps"
@page "/planning/{RouteProjectAlias}/product-roadmaps"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Shared.Contracts
@using PoTool.Shared.DataState
@using PoTool.Shared.Planning
@using PoTool.Shared.Settings
@using PoTool.Shared.WorkItems
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject ProjectService ProjectService
@inject GlobalFilterRouteService GlobalFilterRouteService
@inject WorkItemService WorkItemService
@inject SprintService SprintService
@inject TfsConfigService TfsConfigService
@inject RoadmapReportingService RoadmapReporting
@inject RoadmapSnapshotService SnapshotService
@inject IRoadmapSnapshotsClient SnapshotClient
@inject RoadmapAnalyticsService AnalyticsService
@inject IClipboardService ClipboardService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILogger<ProductRoadmaps> Logger

<PageTitle>Product Roadmaps - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Product Roadmaps
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.VisibilityOff">Read-only</MudChip>
                </MudStack>

                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudMenu StartIcon="@Icons.Material.Filled.Assessment"
                         Label="Reporting"
                         Variant="Variant.Outlined"
                         Color="Color.Primary"
                         AnchorOrigin="Origin.BottomLeft"
                         Dense="true"
                         Disabled="@(_isLoading || _productLanes.Count == 0)">
                    <MudMenuItem OnClick="GenerateVisualRoadmap">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Slideshow" Size="Size.Small" />
                            <span>Generate Visual Roadmap</span>
                        </div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="ExportStructuredData">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" />
                            <span>Export Structured Data (JSON)</span>
                        </div>
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Disabled="true">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">AI Prompt Templates</MudText>
                    </MudMenuItem>
                    @foreach (var template in _promptTemplates)
                    {
                        var t = template;
                        <MudMenuItem OnClick="@(() => GenerateAiPrompt(t.Template))">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Size="Size.Small" />
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@t.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@t.Description</MudText>
                                </MudStack>
                            </div>
                        </MudMenuItem>
                    }
                </MudMenu>
                <MudMenu StartIcon="@Icons.Material.Filled.CameraAlt"
                         Label="Snapshots"
                         Variant="Variant.Outlined"
                         Color="Color.Secondary"
                         AnchorOrigin="Origin.BottomLeft"
                         Dense="true"
                         Disabled="@(_isLoading)">
                    <MudMenuItem OnClick="OpenCreateSnapshotDialog"
                                 Disabled="@(_productLanes.Count == 0)">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.AddAPhoto" Size="Size.Small" />
                            <span>Create Snapshot</span>
                        </div>
                    </MudMenuItem>
                    <MudMenuItem OnClick="OpenSnapshotListDialog">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" />
                            <span>View Snapshots</span>
                        </div>
                    </MudMenuItem>
                </MudMenu>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
                @if (!string.IsNullOrWhiteSpace(_selectedProjectRouteKey))
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.FolderSpecial"
                               OnClick="NavigateToOverview">
                        Overview
                    </MudButton>
                }
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @if (_projectPlanningSummary is not null)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Spacing="2">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.overline" Color="Color.Secondary">Project roadmap summary</MudText>
                            <MudText Typo="Typo.h6">@_projectPlanningSummary.ProjectAlias</MudText>
                        </MudStack>
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info">
                                @_projectPlanningSummary.TotalEpics roadmap epics
                            </MudChip>
                            <MudChip T="string" Variant="Variant.Outlined" Color="@GetRoadmapRiskColor(HasRoadmapDominance())">
                                @GetRoadmapDominanceLabel()
                            </MudChip>
                        </MudStack>
                    </MudStack>

                    <MudGrid Spacing="2">
                        @foreach (var productSummary in _projectPlanningSummary.Products.OrderByDescending(product => product.EpicCount).ThenBy(product => product.ProductName))
                        {
                            var epicShare = _projectPlanningSummary.TotalEpics == 0
                                ? 0
                                : productSummary.EpicCount / (double)_projectPlanningSummary.TotalEpics * 100d;

                            <MudItem xs="12" sm="6" md="4">
                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudText Typo="Typo.subtitle2">@productSummary.ProductName</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @productSummary.EpicCount epic@(productSummary.EpicCount == 1 ? "" : "s") · @(epicShare.ToString("F0"))% of project roadmap
                                    </MudText>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudStack>
            </MudPaper>
        }
        else if (_projectPlanningSummaryState?.State == CacheBackedClientState.NotReady)
        {
            <DataStatePanel State="DataStateDto.NotReady"
                            Subject="Project roadmap summary"
                            Reason="@_projectPlanningSummaryState.Reason"
                            ProductOwnerId="@_profileId"
                            OnRecovery="@LoadProjectPlanningSummaryAsync" />
        }
        else if (_projectPlanningSummaryState?.State is CacheBackedClientState.Failed or CacheBackedClientState.Unavailable)
        {
            <DataStatePanel State="DataStateDto.Failed"
                            Subject="Project roadmap summary"
                            Reason="@(_projectPlanningSummaryState?.Reason)"
                            OnRecovery="@LoadProjectPlanningSummaryAsync" />
        }

        @* Horizontal Scrollable Product Lanes *@
        <div style="overflow-x: auto; padding-bottom: 16px;">
            <div style="display: flex; gap: 16px; min-width: max-content;">
                @foreach (var lane in _productLanes)
                {
                    var laneIndex = _productLanes.IndexOf(lane);
                    <MudPaper Elevation="2" Style="min-width: 320px; max-width: 360px; flex-shrink: 0;">
                        @* Sticky Product Lane Header *@
                        <div style="position: sticky; top: 0; z-index: 1; background: var(--mud-palette-surface); border-bottom: 2px solid var(--mud-palette-primary);">
                            <MudStack Class="pa-3" Spacing="1">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudText Typo="Typo.h6" Style="font-weight: 600;">@lane.ProductName</MudText>
                                    <MudStack Row="true" Spacing="0">
                                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Disabled="@(laneIndex == 0 || _isReordering)"
                                                       OnClick="@(() => MoveProductEarlier(laneIndex))"
                                                       aria-label="Move Earlier" />
                                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       Disabled="@(laneIndex == _productLanes.Count - 1 || _isReordering)"
                                                       OnClick="@(() => MoveProductLater(laneIndex))"
                                                       aria-label="Move Later" />
                                    </MudStack>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @lane.Epics.Count roadmap epic@(lane.Epics.Count == 1 ? "" : "s")
                                    </MudText>
                                    <MudButton Variant="Variant.Outlined"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               StartIcon="@Icons.Material.Filled.Edit"
                                               OnClick="@(() => NavigateToRoadmapEditor(lane.ProductId))">
                                        Edit roadmap
                                    </MudButton>
                                </MudStack>
                            </MudStack>
                        </div>

                        @* Epic Cards *@
                        <MudStack Class="pa-3" Spacing="2">
                            @if (lane.Epics.Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                    No roadmap epics found for this product.
                                </MudAlert>
                            }
                            else
                            {
                                var timeline = BuildTimeline(lane);

                                <MudPaper Outlined="true" Class="pa-3">
                                    <MudText Typo="Typo.subtitle2">Projected timeline</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        Shared time axis with independent forecast ranges in roadmap order.
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @lane.SprintCadence.TooltipText
                                    </MudText>
                                    @if (!lane.SprintCadence.IsResolved)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="mt-2">
                                            Sprint cadence unavailable
                                        </MudChip>
                                    }

                                    @if (timeline.AxisStart.HasValue && timeline.AxisEnd.HasValue)
                                    {
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-2">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @timeline.AxisStart.Value.LocalDateTime.ToString("dd MMM yyyy")
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @timeline.AxisEnd.Value.LocalDateTime.ToString("dd MMM yyyy")
                                            </MudText>
                                        </MudStack>
                                    }

                                    <MudStack Spacing="1" Class="mt-2">
                                        @foreach (var row in timeline.Rows)
                                        {
                                            <MudStack Spacing="0">
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                    <MudText Typo="Typo.caption" Style="font-weight: 500;">
                                                        #@row.RoadmapOrder · @row.Title
                                                    </MudText>
                                                    @if (row.EndDate.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="@(row.IsDelayed ? Color.Error : Color.Secondary)">
                                                            @row.EndDate.Value.LocalDateTime.ToString("dd MMM yyyy")
                                                        </MudText>
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                                                            Forecast unavailable
                                                        </MudChip>
                                                    }
                                                </MudStack>
                                                <div class="projection-timeline-track">
                                                    @if (row.HasTimelineBar)
                                                    {
                                                        <MudTooltip Placement="Placement.Top" Arrow="true">
                                                            <ChildContent>
                                                                <div class="@GetTimelineBarClass(row, lane.SprintCadence)"
                                                                     style="@GetTimelineBarStyle(row)">
                                                                    <div class="@GetTimelineEndMarkerClass(row)"></div>
                                                                </div>
                                                            </ChildContent>
                                                            <TooltipContent>
                                                                <MudStack Spacing="1" Style="font-size: 0.75rem; max-width: 220px;">
                                                                    <MudText Typo="Typo.caption" Style="font-weight: 600;">@row.EndDate!.Value.LocalDateTime.ToString("dd MMM yyyy")</MudText>
                                                                    <MudText Typo="Typo.caption">Projected completion (authoritative)</MudText>
                                                                    @if (row.IsLowConfidence)
                                                                    {
                                                                        <MudText Typo="Typo.caption" Color="Color.Warning">Low confidence forecast</MudText>
                                                                    }
                                                                    <MudText Typo="Typo.caption">@lane.SprintCadence.TooltipText</MudText>
                                                                    @if (!lane.SprintCadence.IsResolved)
                                                                    {
                                                                        <MudText Typo="Typo.caption" Color="Color.Warning">Timeline hidden until explicit sprint cadence is available.</MudText>
                                                                    }
                                                                    @if (row.IsDelayed)
                                                                    {
                                                                        <MudText Typo="Typo.caption" Color="Color.Error">Overdue — completion not yet recorded</MudText>
                                                                    }
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-style: italic;">
                                                                        Start is estimated from forecast, not actual data.
                                                                    </MudText>
                                                                </MudStack>
                                                            </TooltipContent>
                                                        </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                        <div class="projection-timeline-missing">
                                                            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Small" Class="mr-1" />
                                                            Missing forecast
                                                        </div>
                                                    }
                                                </div>
                                            </MudStack>
                                        }
                                    </MudStack>
                                </MudPaper>

                                @foreach (var epic in lane.Epics)
                                {
                                    <MudCard Elevation="1" Class="@GetEpicCardClass(epic)">
                                        <MudCardContent Class="pa-3">
                                            <MudStack Spacing="1">
                                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Style="font-weight: 700;">
                                                        #@epic.OrderNumber
                                                    </MudChip>
                                                    @if (!string.IsNullOrEmpty(epic.TfsUrl))
                                                    {
                                                        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                                                                       Size="Size.Small"
                                                                       Color="Color.Info"
                                                                       Href="@epic.TfsUrl"
                                                                       Target="_blank"
                                                                       aria-label="Open in TFS" />
                                                    }
                                                </MudStack>
                                                <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                                    @epic.Title
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    TFS ID: @epic.TfsId
                                                </MudText>

                                                @* Progress and effort signals *@
                                                @if (epic.TotalStoryPoints > 0)
                                                {
                                                    <MudStack Spacing="0" Class="mt-1">
                                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                Delivered Story Points: @epic.DeliveredStoryPoints / @epic.TotalStoryPoints (@epic.ProgressPercent%)
                                                            </MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                Remaining Story Points: @epic.RemainingStoryPoints
                                                            </MudText>
                                                        </MudStack>
                                                        <MudProgressLinear Value="@epic.ProgressPercent"
                                                                           Color="@GetProgressColor(epic.ProgressPercent)"
                                                                           Size="Size.Small"
                                                                           Rounded="true"
                                                                           Class="mt-1" />
                                                    </MudStack>
                                                }
                                                else
                                                {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                                            No story points estimated
                                                        </MudText>
                                                }

                                                @* Analytics indicators *@
                                                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap" Class="mt-1">
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                                        PBIs: @epic.PbiCount
                                                    </MudChip>
                                                    @if (epic.HasForecast && epic.EstimatedCompletionDate.HasValue)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetForecastDateChipColor(epic)">
                                                            @epic.EstimatedCompletionDate.Value.LocalDateTime.ToString("dd MMM yyyy")
                                                        </MudChip>
                                                        @if (epic.SprintsRemaining.HasValue)
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetSprintChipColor(epic.SprintsRemaining.Value)">
                                                                ~@epic.SprintsRemaining sprints
                                                            </MudChip>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                                            Forecast unavailable
                                                        </MudChip>
                                                    }
                                                </MudStack>

                                                @* Warning signals *@
                                                @if (epic.HasDependencies)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Info">
                                                        <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Small" Class="mr-1" />Has dependencies
                                                    </MudText>
                                                }
                                                @if (epic.HasRefinementBlockers)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Warning">
                                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />Refinement blockers
                                                    </MudText>
                                                }
                                                @if (epic.HasValidationIssues)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Warning">
                                                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1" />Validation issues
                                                    </MudText>
                                                }
                                                @if (epic.IsDelayed)
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />Delayed by @FormatDelayDuration(epic.DelayDuration)
                                                    </MudText>
                                                }

                                                @* Derived signals *@
                                                <MudStack Row="true" Spacing="2" Class="mt-1">
                                                    @if (epic.EpicAgeDays.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Age: @epic.EpicAgeDays days
                                                        </MudText>
                                                    }
                                                    @if (epic.LastActivityDays.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="@GetLastActivityColor(epic.LastActivityDays.Value)">
                                                            Last activity: @epic.LastActivityDays days ago
                                                        </MudText>
                                                    }
                                                    @if (epic.Confidence.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="@GetConfidenceColor(epic.Confidence.Value)">
                                                            @epic.Confidence.Value confidence
                                                        </MudText>
                                                    }
                                                    @if (epic.HasForecast && epic.LastUpdated.HasValue)
                                                    {
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                            Forecast updated @epic.LastUpdated.Value.LocalDateTime.ToString("dd MMM yyyy")
                                                        </MudText>
                                                    }
                                                </MudStack>
                                            </MudStack>
                                        </MudCardContent>
                                    </MudCard>
                                }
                            }
                        </MudStack>
                    </MudPaper>
                }

                @if (_productLanes.Count == 0)
                {
                    <MudPaper Elevation="2" Class="pa-6" Style="min-width: 400px;">
                        <MudAlert Severity="Severity.Info">
                            No products found. Configure products in Settings to see roadmap lanes.
                        </MudAlert>
                    </MudPaper>
                }
            </div>
        </div>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4 mt-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@* --- Create Snapshot Dialog --- *@
<MudDialog @bind-Visible="_showCreateSnapshotDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddAPhoto" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Create Roadmap Snapshot</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Capture the current roadmap state. Snapshots are stored locally and never modify TFS.
        </MudText>
        <MudTextField @bind-Value="_snapshotDescription"
                      Label="Description (optional)"
                      Placeholder="e.g. Q1 planning session, Sprint 12 grooming"
                      Variant="Variant.Outlined"
                      Lines="2" />
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
            @_productLanes.Count product@(_productLanes.Count == 1 ? "" : "s"),
            @_productLanes.Sum(l => l.Epics.Count) roadmap epic@(_productLanes.Sum(l => l.Epics.Count) == 1 ? "" : "s")
            will be captured.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseCreateSnapshotDialog" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="CreateSnapshot" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CameraAlt">
            Create Snapshot
        </MudButton>
    </DialogActions>
</MudDialog>

@* --- Snapshot List Dialog --- *@
<MudDialog @bind-Visible="_showSnapshotListDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Roadmap Snapshots</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_snapshots.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No snapshots yet. Create one to capture the current roadmap state.
            </MudAlert>
        }
        else
        {
            <MudTable Items="@_snapshots" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Products</MudTh>
                    <MudTh>Epics</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.CreatedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd>@(context.Description ?? "—")</MudTd>
                    <MudTd>@context.ProductCount</MudTd>
                    <MudTd>@context.EpicCount</MudTd>
                    <MudTd Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.CompareArrows"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => CompareSnapshot(context))"
                                       Disabled="@(_productLanes.Count == 0)"
                                       aria-label="Compare with current" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteSnapshot(context.Id))"
                                       aria-label="Delete snapshot" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseSnapshotListDialog" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@* --- Drift Comparison Dialog --- *@
<MudDialog @bind-Visible="_showDriftDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true })">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.CompareArrows" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Drift Detection</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        @if (_driftReport != null)
        {
            <MudStack Spacing="2" Class="mb-3">
                <MudText Typo="Typo.body2">
                    Comparing snapshot from <strong>@_driftReport.SnapshotCreatedAtUtc.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</strong>
                    with the current roadmap.
                </MudText>

                @if (!_driftReport.HasDrift)
                {
                    <MudAlert Severity="Severity.Success" Dense="true">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-1" Size="Size.Small" />
                        No drift detected. The roadmap matches the snapshot.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Warning" Dense="true">
                        Drift detected — the roadmap has changed since this snapshot was taken.
                    </MudAlert>
                }
            </MudStack>

            @foreach (var product in _driftReport.Products)
            {
                <MudPaper Elevation="1" Class="pa-3 mb-3">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@product.ProductName</MudText>
                        @if (product.HasDrift)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Changed</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">No changes</MudChip>
                        }
                    </MudStack>

                    @if (product.Epics.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No epics to compare.</MudText>
                    }
                    else
                    {
                        <MudTable Items="@product.Epics" Dense="true" Hover="true" Elevation="0">
                            <HeaderContent>
                                <MudTh>TFS ID</MudTh>
                                <MudTh>Epic</MudTh>
                                <MudTh>Snapshot #</MudTh>
                                <MudTh>Current #</MudTh>
                                <MudTh>Change</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.TfsId</MudTd>
                                <MudTd>@context.Title</MudTd>
                                <MudTd>@(context.SnapshotOrder?.ToString() ?? "—")</MudTd>
                                <MudTd>@(context.CurrentOrder?.ToString() ?? "—")</MudTd>
                                <MudTd>
                                    @switch (context.ChangeType)
                                    {
                                        case DriftChangeType.Unchanged:
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text">Unchanged</MudChip>
                                            break;
                                        case DriftChangeType.MovedEarlier:
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                                <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Class="mr-1" /> Earlier
                                            </MudChip>
                                            break;
                                        case DriftChangeType.MovedLater:
                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">
                                                <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Class="mr-1" /> Later
                                            </MudChip>
                                            break;
                                        case DriftChangeType.Added:
                                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">
                                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Class="mr-1" /> Added
                                            </MudChip>
                                            break;
                                        case DriftChangeType.Removed:
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">
                                                <MudIcon Icon="@Icons.Material.Filled.Remove" Size="Size.Small" Class="mr-1" /> Removed
                                            </MudChip>
                                            break;
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDriftDialog" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
