    // --- Snapshot methods ---

    private void OpenCreateSnapshotDialog()
    {
        _snapshotDescription = null;
        _showCreateSnapshotDialog = true;
    }

    private void CloseCreateSnapshotDialog()
    {
        _showCreateSnapshotDialog = false;
    }

    private async Task CreateSnapshot()
    {
        try
        {
            var entries = BuildReportEntries();
            var request = new CreateRoadmapSnapshotRequest(
                _snapshotDescription,
                entries.Select(p => new CreateRoadmapSnapshotProductRequest(
                    p.ProductName,
                    p.Epics.Select(e => new CreateRoadmapSnapshotEpicRequest(
                        e.TfsId,
                        e.Title,
                        e.Order
                    )).ToList()
                )).ToList()
            );
            await SnapshotClient.CreateSnapshotAsync(request);
            _showCreateSnapshotDialog = false;
            Snackbar.Add("Roadmap snapshot created.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create snapshot: {ex.Message}", Severity.Error);
        }
    }

    private async Task OpenSnapshotListDialog()
    {
        try
        {
            _snapshots = (await SnapshotClient.ListSnapshotsAsync()).ToList();
        }
        catch
        {
            _snapshots = new();
        }
        _showSnapshotListDialog = true;
    }

    private void CloseSnapshotListDialog()
    {
        _showSnapshotListDialog = false;
    }

    private async Task CompareSnapshot(RoadmapSnapshotDto snapshotSummary)
    {
        try
        {
            var detail = await SnapshotClient.GetSnapshotAsync(snapshotSummary.Id);
            var snapshot = new RoadmapSnapshot
            {
                Id = detail.Id.ToString(),
                CreatedAtUtc = detail.CreatedAtUtc,
                Description = detail.Description,
                Products = detail.Products.Select(p => new SnapshotProductEntry
                {
                    ProductName = p.ProductName,
                    Epics = p.Epics.Select(e => new SnapshotEpicEntry
                    {
                        Order = e.EpicOrder,
                        Title = e.EpicTitle,
                        TfsId = e.EpicTfsId
                    }).ToList()
                }).ToList()
            };
            var currentEntries = BuildReportEntries();
            _driftReport = SnapshotService.Compare(snapshot, currentEntries);
            _showSnapshotListDialog = false;
            _showDriftDialog = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load snapshot for comparison: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSnapshot(int id)
    {
        try
        {
            await SnapshotClient.DeleteSnapshotAsync(id);
            _snapshots = (await SnapshotClient.ListSnapshotsAsync()).ToList();
            Snackbar.Add("Snapshot deleted.", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete snapshot: {ex.Message}", Severity.Error);
        }
    }

    private void CloseDriftDialog()
    {
        _showDriftDialog = false;
        _driftReport = null;
    }

    /// <summary>
    /// Represents a single product lane with its roadmap epics.
    /// </summary>
    private sealed class ProductLane
    {
        public int ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public int ObjectiveTfsId { get; set; }
        public double? ObjectiveBacklogPriority { get; set; }
        public List<RoadmapEpic> Epics { get; set; } = new();
        public SprintCadenceInfo SprintCadence { get; set; } = SprintCadenceResolver.Resolve([]);
    }

    /// <summary>
    /// Represents a single roadmap epic card.
    /// </summary>
    private sealed class RoadmapEpic
    {
        public int TfsId { get; set; }
        public string Title { get; set; } = string.Empty;
        public int OrderNumber { get; set; }
        public string? TfsUrl { get; set; }

        // Analytics signals — populated from RoadmapAnalyticsService
        public int TotalStoryPoints { get; set; }
        public int DeliveredStoryPoints { get; set; }
        public int RemainingStoryPoints { get; set; }
        public string State { get; set; } = string.Empty;
        public int ProgressPercent { get; set; }
        public bool HasDependencies { get; set; }
        public int PbiCount { get; set; }
        public bool HasForecast { get; set; }
        public int? SprintsRemaining { get; set; }
        public DateTimeOffset? EstimatedCompletionDate { get; set; }
        public ForecastConfidence? Confidence { get; set; }
        public DateTimeOffset? LastUpdated { get; set; }
        public int? EpicAgeDays { get; set; }
        public int? LastActivityDays { get; set; }
        public bool HasRefinementBlockers { get; set; }
        public bool HasValidationIssues { get; set; }
        public bool IsDone =>
            State.Equals("Closed", StringComparison.OrdinalIgnoreCase)
            || State.Equals("Done", StringComparison.OrdinalIgnoreCase)
            || State.Equals("Removed", StringComparison.OrdinalIgnoreCase);
        public bool IsDelayed =>
            !IsDone
            && EstimatedCompletionDate.HasValue
            && DateTimeOffset.UtcNow.Date > EstimatedCompletionDate.Value.Date;
        public TimeSpan? DelayDuration =>
            IsDelayed && EstimatedCompletionDate.HasValue
                ? DateTimeOffset.UtcNow.Date - EstimatedCompletionDate.Value.Date
                : null;
    }

    private static Color GetSprintChipColor(int sprintsRemaining)
    {
        if (sprintsRemaining <= 3) return Color.Success;
        if (sprintsRemaining <= 6) return Color.Warning;
        return Color.Error;
    }

    private static Color GetForecastDateChipColor(RoadmapEpic epic)
        => epic.IsDelayed ? Color.Error : Color.Primary;

    private static Color GetProgressColor(int progressPercent)
    {
        if (progressPercent >= 75) return Color.Success;
        if (progressPercent >= 25) return Color.Info;
        return Color.Warning;
    }

    private static Color GetLastActivityColor(int days)
    {
        if (days <= 14) return Color.Secondary;
        if (days <= 30) return Color.Warning;
        return Color.Error;
    }

    private static Color GetConfidenceColor(ForecastConfidence confidence) => confidence switch
    {
        ForecastConfidence.High => Color.Success,
        ForecastConfidence.Medium => Color.Warning,
        ForecastConfidence.Low => Color.Error,
        _ => Color.Default
    };

    private static string GetEpicCardClass(RoadmapEpic epic)
        => epic.IsDelayed ? "roadmap-epic-card roadmap-epic-card-delayed" : "roadmap-epic-card";

    private static RoadmapTimelineModel BuildTimeline(ProductLane lane)
    {
        if (!lane.SprintCadence.IsResolved)
        {
            return new RoadmapTimelineModel(null, null, []);
        }

        return RoadmapTimelineLayout.Build(
            lane.Epics
                .Select(epic => new RoadmapTimelineEpicInput(
                    epic.TfsId,
                    epic.Title,
                    epic.OrderNumber,
                    epic.EstimatedCompletionDate,
                    epic.SprintsRemaining,
                    epic.Confidence,
                    epic.HasForecast,
                    epic.IsDelayed))
                .ToList(),
            new RoadmapTimelineBuildOptions(lane.SprintCadence.DurationDays!.Value));
    }

    private static string GetTimelineBarClass(RoadmapTimelineRow row, SprintCadenceInfo sprintCadence)
    {
        var classes = new List<string> { "projection-timeline-bar" };
        if (row.IsDelayed)
        {
            classes.Add("projection-timeline-bar-delayed");
        }

        if (row.IsLowConfidence)
        {
            classes.Add("projection-timeline-bar-low-confidence");
        }

        return string.Join(" ", classes);
    }

    private static string GetTimelineBarStyle(RoadmapTimelineRow row)
        => $"left: {row.LeftPercent.GetValueOrDefault():F2}%; width: {Math.Max(row.WidthPercent.GetValueOrDefault(), 2d):F2}%;";

    private static string GetTimelineEndMarkerClass(RoadmapTimelineRow row)
        => row.IsDelayed
            ? "projection-timeline-end-marker projection-timeline-end-marker-delayed"
            : "projection-timeline-end-marker";

    private static string FormatDelayDuration(TimeSpan? delay)
    {
        if (!delay.HasValue)
        {
            return "0 days";
        }

        var days = Math.Max(1, (int)Math.Ceiling(delay.Value.TotalDays));
        return days == 1 ? "1 day" : $"{days} days";
    }

    private static SprintCadenceInfo ResolveSprintCadence()
    {
        return SprintCadenceResolver.Resolve([]);
    }
