    private async Task<List<ProjectDto>> LoadAvailableProjectsAsync(IReadOnlyCollection<ProductDto> products)
    {
        var productIds = products.Select(product => product.Id).ToHashSet();
        var projects = await ProjectService.GetAllProjectsAsync();

        return projects
            .Where(project => project.ProductIds.Any(productIds.Contains))
            .OrderBy(project => project.Name)
            .ToList();
    }

    private void ResolveInitialProjectSelection()
    {
        var context = WorkspaceQueryContextHelper.Parse(NavigationManager.Uri);
        var requestedProjectKey = string.IsNullOrWhiteSpace(RouteProjectAlias)
            ? context.ProjectAlias
            : RouteProjectAlias;

        var selectedProject = ResolveProject(requestedProjectKey);
        if (selectedProject == null && context.ProductId.HasValue)
        {
            selectedProject = _projects.FirstOrDefault(project => project.ProductIds.Contains(context.ProductId.Value));
        }

        _selectedProjectRouteKey = selectedProject?.Alias;
    }

    private void ApplyProjectFilter()
    {
        var selectedProject = ResolveProject(_selectedProjectRouteKey);
        _products = selectedProject == null
            ? _allProducts
            : _allProducts.Where(product => selectedProject.ProductIds.Contains(product.Id)).ToList();
    }

    private async Task LoadProjectPlanningSummaryAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedProjectRouteKey))
        {
            _projectPlanningSummaryState = CacheBackedClientResult<ProjectPlanningSummaryDto>.Empty();
            _projectPlanningSummary = null;
            return;
        }

        _projectPlanningSummaryState = await ProjectService.GetPlanningSummaryAsync(_selectedProjectRouteKey);
        _projectPlanningSummary = _projectPlanningSummaryState.State == CacheBackedClientState.Success
            ? _projectPlanningSummaryState.Data
            : null;
    }

    private async Task OnProjectChanged(string? projectRouteKey)
    {
        _selectedProjectRouteKey = string.IsNullOrWhiteSpace(projectRouteKey) ? null : projectRouteKey;
        ApplyProjectFilter();
        await LoadProjectPlanningSummaryAsync();
        await BuildProductLanesAsync();

        NavigationManager.NavigateTo(
            await GlobalFilterRouteService.BuildPlanningPageUriAsync(
                "ProductRoadmaps",
                _selectedProjectRouteKey,
                additionalParams: WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri)),
            forceLoad: false);
    }

    private ProjectDto? ResolveProject(string? projectRouteKey)
    {
        if (string.IsNullOrWhiteSpace(projectRouteKey))
        {
            return null;
        }

        return _projects.FirstOrDefault(project =>
            string.Equals(project.Alias, projectRouteKey, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(project.Id, projectRouteKey, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatProjectLabel(ProjectDto project)
        => string.Equals(project.Name, project.Alias, StringComparison.OrdinalIgnoreCase)
            ? project.Name
            : $"{project.Name} ({project.Alias})";

    private bool HasRoadmapDominance()
    {
        if (_projectPlanningSummary is null || _projectPlanningSummary.TotalEpics <= 0 || _projectPlanningSummary.Products.Count == 0)
        {
            return false;
        }

        var leadingEpicCount = _projectPlanningSummary.Products.Max(static product => product.EpicCount);
        return leadingEpicCount / (double)_projectPlanningSummary.TotalEpics > 0.6d;
    }

    private string GetRoadmapDominanceLabel()
    {
        if (_projectPlanningSummary is null || _projectPlanningSummary.Products.Count == 0 || _projectPlanningSummary.TotalEpics <= 0)
        {
            return "Roadmap balance unavailable";
        }

        var leadingProduct = _projectPlanningSummary.Products.MaxBy(static product => product.EpicCount);
        if (leadingProduct == null)
        {
            return "Roadmap balance unavailable";
        }

        var share = leadingProduct.EpicCount / (double)_projectPlanningSummary.TotalEpics * 100d;
        return HasRoadmapDominance()
            ? $"{leadingProduct.ProductName} dominates with {share:F0}% of roadmap epics"
            : "Roadmap epics are distributed across products";
    }

    private static Color GetRoadmapRiskColor(bool isRisk) => isRisk ? Color.Warning : Color.Success;

    private IReadOnlyList<RoadmapProductEntry> BuildReportEntries()
    {
        return _productLanes.Select(lane => new RoadmapProductEntry
        {
            ProductName = lane.ProductName,
            Epics = lane.Epics.Select(e => new RoadmapEpicEntry
            {
                Order = e.OrderNumber,
                Title = e.Title,
                TfsId = e.TfsId
            }).ToList()
        }).ToList();
    }

    private async Task GenerateVisualRoadmap()
    {
        try
        {
            var entries = BuildReportEntries();
