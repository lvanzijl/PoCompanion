@code {
    [Parameter]
    public string? RouteProjectAlias { get; set; }

    private bool _isLoading = true;
    private bool _isReordering = false;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private List<ProductLane> _productLanes = new();
    private List<ProductDto> _allProducts = new();
    private List<ProductDto> _products = new();
    private List<ProjectDto> _projects = new();
    private string? _selectedProjectRouteKey;
    private ProjectPlanningSummaryDto? _projectPlanningSummary;
    private CacheBackedClientResult<ProjectPlanningSummaryDto>? _projectPlanningSummaryState;
    private TfsConfigDto? _tfsConfig;
    private readonly IReadOnlyList<PromptTemplateOption> _promptTemplates = RoadmapReportingService.GetAvailableTemplates();

    // Snapshot state
    private bool _showCreateSnapshotDialog;
    private bool _showSnapshotListDialog;
    private bool _showDriftDialog;
    private string? _snapshotDescription;
    private List<RoadmapSnapshotDto> _snapshots = new();
    private DriftReport? _driftReport;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }

            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);

            _tfsConfig = await TfsConfigService.GetConfigAsync();

            _allProducts = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            _projects = await LoadAvailableProjectsAsync(_allProducts);
            ResolveInitialProjectSelection();
            ApplyProjectFilter();
            await LoadProjectPlanningSummaryAsync();

            // Build lanes with roadmap epics, ordered by Objective BacklogPriority
            await BuildProductLanesAsync();

            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading roadmap data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task BuildProductLanesAsync()
    {
        _productLanes.Clear();

        foreach (var product in _products)
        {
            var lane = new ProductLane
            {
                ProductId = product.Id,
                ProductName = product.Name,
                Epics = new List<RoadmapEpic>()
            };

            if (product.BacklogRootWorkItemIds.Count > 0)
            {
                try
                {
                     var workItems = await WorkItemService.GetByRootIdsAsync(product.BacklogRootWorkItemIds.ToArray());
                     var workItemList = workItems.ToList();
                     var discovery = RoadmapEpicDiscoveryAnalysis.Analyze(product.BacklogRootWorkItemIds, workItemList);

                      // Find the root Objective work item to get its BacklogPriority for lane ordering
                     var objectiveWorkItem = discovery.RawItems
                        .FirstOrDefault(wi => RoadmapWorkItemRules.IsObjective(wi.Type) && product.BacklogRootWorkItemIds.Contains(wi.TfsId));
                      lane.ObjectiveTfsId = objectiveWorkItem?.TfsId ?? 0;
                      lane.ObjectiveBacklogPriority = objectiveWorkItem?.BacklogPriority;

                      // Filter to epics with "roadmap" tag, ordered by BacklogPriority (TfsId as tie-breaker)
                      var roadmapEpics = discovery.RoadmapEpicItems;

                     if (discovery.RoadmapEpicItems.Count == 0)
                     {
                         Logger.LogWarning(
                             "Roadmap overview product {ProductId} '{ProductName}' found no roadmap epics. Only epics with the lowercase 'roadmap' tag are shown; verify that the expected epics carry that tag under the configured roots. Epic-like count {EpicLikeCount}; configured roots [{ConfiguredRootIds}]; missing roots [{MissingRootIds}]",
                             product.Id,
                             product.Name,
                             discovery.EpicLikeItems.Count,
                             string.Join(", ", discovery.ConfiguredRootIds),
                             string.Join(", ", discovery.MissingRootIds));
                     }

                    // Load backlog health signals for all epics in one call
                     var healthLookup = await AnalyticsService.LoadBacklogHealthAsync(product.Id);

                    var orderNumber = 1;
                    foreach (var epic in roadmapEpics)
                    {
                        // Compute local analytics from already-loaded work items
                        var localAnalytics = RoadmapAnalyticsService.ComputeLocalAnalytics(epic.TfsId, workItemList);

                        // Map health signals
                        healthLookup.TryGetValue(epic.TfsId, out var healthAnalytics);

                        lane.Epics.Add(new RoadmapEpic
                        {
                            TfsId = epic.TfsId,
                            Title = epic.Title,
                            OrderNumber = orderNumber++,
                            TfsUrl = BuildTfsUrl(epic.TfsId),
                            State = epic.State,
                            TotalStoryPoints = localAnalytics.TotalStoryPoints,
                            DeliveredStoryPoints = localAnalytics.DeliveredStoryPoints,
                            RemainingStoryPoints = localAnalytics.RemainingStoryPoints,
                            ProgressPercent = localAnalytics.TotalStoryPoints > 0
                                ? (int)Math.Round(100.0 * localAnalytics.DeliveredStoryPoints / localAnalytics.TotalStoryPoints)
                                : 0,
                            PbiCount = localAnalytics.PbiCount,
                            EpicAgeDays = localAnalytics.EpicAgeDays,
                            LastActivityDays = localAnalytics.LastActivityDays,
                            HasRefinementBlockers = healthAnalytics?.HasRefinementBlockers ?? false,
                            HasValidationIssues = healthAnalytics?.HasValidationIssues ?? false
                        });
                    }

                    // Load persisted planning projections and dependency signals in parallel for all roadmap epics
                    var epicTfsIds = lane.Epics.Select(e => e.TfsId).ToList();
                     var dependencyTask = AnalyticsService.LoadDependencySignalsAsync(epicTfsIds);
                     var projectionTask = ProductService.GetPlanningProjectionsAsync(product.Id);
                     var sprintCadence = ResolveSprintCadence();
                     await Task.WhenAll(dependencyTask, projectionTask);

                     var epicIdsWithDependencies = await dependencyTask;
                     var projections = await projectionTask;
                     lane.SprintCadence = sprintCadence;
                     var projectionsByEpicId = projections.ToDictionary(projection => projection.EpicId);
                     foreach (var epic in lane.Epics)
                     {
                        epic.HasDependencies = epicIdsWithDependencies.Contains(epic.TfsId);

                        if (projectionsByEpicId.TryGetValue(epic.TfsId, out var projection))
                        {
                            epic.OrderNumber = projection.RoadmapOrder;
                            epic.HasForecast = projection.HasForecast;
                            epic.SprintsRemaining = projection.SprintsRemaining;
                            epic.EstimatedCompletionDate = projection.EstimatedCompletionDate;
                            epic.Confidence = projection.Confidence;
                            epic.LastUpdated = projection.LastUpdated;
                        }
                    }

                    lane.Epics = lane.Epics
                        .OrderBy(epic => epic.OrderNumber)
                        .ToList();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error loading epics for {product.Name}: {ex.Message}", Severity.Warning);
                }
            }

            _productLanes.Add(lane);
        }

        // Sort product lanes by Objective BacklogPriority (null = last, TfsId as tie-breaker)
        _productLanes = _productLanes
            .OrderBy(l => l.ObjectiveBacklogPriority ?? double.MaxValue)
            .ThenBy(l => l.ObjectiveTfsId)
            .ToList();
    }

    private string? BuildTfsUrl(int workItemId)
    {
        if (_tfsConfig?.Url == null || _tfsConfig.Project == null)
            return null;

        return TfsUrlBuilder.BuildWorkItemUrl(_tfsConfig.Url, _tfsConfig.Project, workItemId);
    }

    private async Task MoveProductEarlier(int laneIndex)
    {
        if (laneIndex <= 0 || _profileId == null || _isReordering) return;
        await SwapProductOrder(laneIndex, laneIndex - 1);
    }

    private async Task MoveProductLater(int laneIndex)
    {
        if (laneIndex >= _productLanes.Count - 1 || _profileId == null || _isReordering) return;
        await SwapProductOrder(laneIndex, laneIndex + 1);
    }

    private async Task SwapProductOrder(int indexA, int indexB)
    {
        _isReordering = true;
        try
        {
            var laneA = _productLanes[indexA];
            var laneB = _productLanes[indexB];

            if (laneA.ObjectiveTfsId == 0 || laneB.ObjectiveTfsId == 0)
            {
                Snackbar.Add("Cannot reorder: one or both products have no Objective work item.", Severity.Warning);
                return;
            }

            if (!ProductLanePrioritySwapPlanner.TryCreateExactNeighborSwap(
                    laneA.ObjectiveTfsId,
                    laneA.ObjectiveBacklogPriority,
                    laneB.ObjectiveTfsId,
                    laneB.ObjectiveBacklogPriority,
                    out var swapPlan,
                    out var failureReason))
            {
                Logger.LogWarning(
                    "Product lane reorder requires priority recovery. Selected objective {SelectedObjectiveId} priority {SelectedPriority}; neighbor objective {NeighborObjectiveId} priority {NeighborPriority}; reason {FailureReason}.",
                    laneA.ObjectiveTfsId,
                    laneA.ObjectiveBacklogPriority,
                    laneB.ObjectiveTfsId,
                    laneB.ObjectiveBacklogPriority,
                    failureReason);
                Snackbar.Add("Cannot reorder because one or both neighbouring Objectives do not have distinct usable TFS backlog priorities. Recover the priorities first.", Severity.Warning);
                return;
            }

            var swapPlanToApply = swapPlan!;

            Logger.LogDebug(
                "Swapping product lane priorities. Selected objective {SelectedObjectiveId} old priority {SelectedOldPriority}; neighbor objective {NeighborObjectiveId} old priority {NeighborOldPriority}; writing {SelectedWrittenPriority} to selected and {NeighborWrittenPriority} to neighbor.",
                swapPlanToApply.SelectedObjectiveTfsId,
                swapPlanToApply.SelectedOriginalPriority,
                swapPlanToApply.NeighborObjectiveTfsId,
                swapPlanToApply.NeighborOriginalPriority,
                swapPlanToApply.SelectedWrittenPriority,
                swapPlanToApply.NeighborWrittenPriority);

            // Write swapped priorities to TFS using the exact current values read from cache.
            var successA = await WorkItemService.UpdateBacklogPriorityAsync(swapPlanToApply.SelectedObjectiveTfsId, swapPlanToApply.SelectedWrittenPriority);
            if (!successA)
            {
                Snackbar.Add($"Failed to update priority for {laneA.ProductName} in TFS.", Severity.Error);
                return;
            }

            var successB = await WorkItemService.UpdateBacklogPriorityAsync(swapPlanToApply.NeighborObjectiveTfsId, swapPlanToApply.NeighborWrittenPriority);
            if (!successB)
            {
                // Attempt to revert A
                await WorkItemService.UpdateBacklogPriorityAsync(swapPlanToApply.SelectedObjectiveTfsId, swapPlanToApply.SelectedOriginalPriority);
                Snackbar.Add($"Failed to update priority for {laneB.ProductName} in TFS. Reverted.", Severity.Error);
                return;
            }

            // Rebuild lanes from cache (which was refreshed by the API calls)
            _allProducts = (await ProductService.GetProductsByOwnerAsync(_profileId!.Value)).ToList();
            _projects = await LoadAvailableProjectsAsync(_allProducts);
            ApplyProjectFilter();
            await LoadProjectPlanningSummaryAsync();
            await BuildProductLanesAsync();

            Snackbar.Add("Product order updated in TFS.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error reordering products: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isReordering = false;
        }
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Planning (Future)", WorkspaceRoutes.PlanningWorkspace, icon: Icons.Material.Filled.CalendarMonth),
            new("Product Roadmaps", null, disabled: true, icon: Icons.Material.Filled.Map)
        };
    }

    private async Task NavigateToHome()
    {
        var currentContext = WorkspaceQueryContextHelper.Parse(NavigationManager.Uri);
