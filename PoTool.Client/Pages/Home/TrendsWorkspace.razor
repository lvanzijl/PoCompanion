@page "/home/trends"
@using PoTool.Client.Components.Common
@using PoTool.Client.Pages.Home.Components
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Shared.Settings
@using System.Web
@using PoTool.Client.ApiClient
@inherits WorkspaceBase
@implements IDisposable
@inject WorkItemService WorkItemService
@inject StateClassificationService StateClassificationService
@inject TeamService TeamService
@inject SprintService SprintService
@inject PullRequestStateService PullRequestStateService
@inject IBuildQualityService BuildQualityService
@inject PageFilterExecutionGate PageFilterExecutionGate

@* 
    Decision #3: Time Horizon Default - Configurable sprint range (defaults to last 6 months if no sprints selected)
    Decision #12: Trend Chart Interaction - Hover highlight, click to filter (Option D)
*@

<PageTitle>Trends (Past) - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Trends (Past)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <CompactButton ButtonRole="ButtonRole.Utility"
                               Icon="@Icons.Material.Filled.Home"
                               OnClick="NavigateToHome">
                    Home
                </CompactButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @* Trend Signals Grid *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h5" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
            Trend Signals
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Structural behavior over time — click to explore details
        </MudText>
        
        <MudGrid>
            @* Bug Trend Signal *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="Bug Trend"
                                    Subtitle="Bug patterns over time"
                                    Icon="@Icons.Material.Filled.BugReport"
                                    IconColor="Color.Error"
                                    AriaLabel="Bug Trend — Bug patterns over time"
                                    OnClick="NavigateToBugTrend">
                    @if (_bugTrendSignal?.HasTrendValues == true)
                    {
                        <TrendSlopeBadge StartValue="@_bugTrendSignal.StartValue"
                                         EndValue="@_bugTrendSignal.EndValue"
                                         LowerIsBetter="true"
                                         MetricLabel="bug creation rate"
                                         PositiveLabel="Decreasing"
                                         NegativeLabel="Increasing"
                                         NeutralLabel="Stable" />
                    }
                    else if (_bugTrendSignal?.FallbackSignal is not null)
                    {
                        <WorkspaceTileBadge Signal="@_bugTrendSignal.FallbackSignal"
                                           AriaLabel="Bug Trend signal status"
                                           Class="mt-1" />
                    }
                </NavigationTileCard>
            </MudItem>

            @* PR Trend Signal (Read-Only) *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="PR Trend"
                                    Subtitle="Pull request insights"
                                    Icon="@Icons.Material.Filled.MergeType"
                                    IconColor="Color.Info"
                                    AriaLabel="PR Trend — Pull request insights"
                                    OnClick="NavigateToPrOverview">
                    @* Slope badge: summarises median time-to-merge over the selected horizon.
                       Median TTM is chosen as the primary signal because it captures end-to-end
                       flow efficiency and is the most actionable metric for a PO. *@
                    @if (_prTrendSignal?.HasTrendValues == true)
                    {
                        <TrendSlopeBadge StartValue="@_prTrendSignal.StartValue"
                                         EndValue="@_prTrendSignal.EndValue"
                                         LowerIsBetter="true"
                                         MetricLabel="median time to merge" />
                    }
                    else if (_prTrendSignal?.FallbackSignal is not null)
                    {
                        <WorkspaceTileBadge Signal="@_prTrendSignal.FallbackSignal"
                                           AriaLabel="PR Trend signal status"
                                           Class="mt-1" />
                    }
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                </NavigationTileCard>
            </MudItem>

            @* Pipeline Insights Signal (Read-Only) *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="Pipeline Insights"
                                    Subtitle="PO-first sprint stability per product"
                                    Icon="@Icons.Material.Filled.HealthAndSafety"
                                    IconColor="Color.Warning"
                                    AriaLabel="Pipeline Insights — PO-first sprint stability per product"
                                    OnClick="NavigateToPipelineInsights">
                    @if (_pipelineSignal is not null)
                    {
                        <WorkspaceTileBadge Signal="@_pipelineSignal"
                                           AriaLabel="Pipeline Insights signal status"
                                           Class="mt-1" />
                    }
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                </NavigationTileCard>
            </MudItem>

            @* PR Delivery Insights Signal (Read-Only) *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="PR Delivery Insights"
                                    Subtitle="PR classification by Epic/Feature hierarchy"
                                    Icon="@Icons.Material.Filled.LocalShipping"
                                    IconColor="Color.Success"
                                    AriaLabel="PR Delivery Insights — PR classification by Epic/Feature hierarchy"
                                    OnClick="NavigateToPrDeliveryInsights">
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                </NavigationTileCard>
            </MudItem>

            @* Portfolio Progress Trend Signal *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="Portfolio Progress"
                                    Subtitle="Strategic progress over sprint range"
                                    Icon="@Icons.Material.Filled.Insights"
                                    IconColor="Color.Warning"
                                    AriaLabel="Portfolio Progress — Strategic progress over sprint range"
                                    OnClick="NavigateToPortfolioProgress" />
            </MudItem>

            @* Delivery Trends Signal *@
            <MudItem xs="12" sm="6" md="4">
                <NavigationTileCard Title="Delivery Trends"
                                    Subtitle="PBI & effort throughput over time"
                                    Icon="@Icons.Material.Filled.LocalShipping"
                                    IconColor="Color.Success"
                                    AriaLabel="Delivery Trends — PBI & effort throughput over time"
                                    OnClick="NavigateToDeliveryTrends" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!CurrentGateEvaluation.CanExecuteQueries)
    {
        <CanonicalDataStateView TData="object"
                                State="@InvalidWorkspaceState"
                                Subject="Trend workspace"
                                InvalidMessage="Adjust the selected filter to load trend data.">
            <ChildContent Context="_">
            </ChildContent>
        </CanonicalDataStateView>
    }
    else
    {
        @* Information Notice *@
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Note:</strong> Bug trend chart shows last 6 months (Decision #3: 6 month time horizon). 
                PRs and Pipelines are insight-only. Bugs may navigate to editable detail.
                <br/>
                <strong>Interaction:</strong> Hover to highlight, click to filter by that period (Decision #12).
            </MudText>
        </MudAlert>

        @* Bug Trend Chart with Interactive Click-to-Filter - 3 Series *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <TrendMultiSeriesChart 
                Title="Bug Trend (Last 6 Months)"
                Icon="@Icons.Material.Filled.BugReport"
                SeriesTotal="@_bugTrendTotal"
                SeriesFixed="@_bugTrendFixed"
                SeriesAdded="@_bugTrendAdded"
                OnPeriodClick="OnBugTrendPeriodClick"
                MaxPeriods="6" />
        </MudPaper>
    }

    @* Cross-Workspace Navigation *@
    <MudPaper Elevation="2" Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
            Navigate to Other Workspaces
        </MudText>
        
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <CompactButton ButtonRole="ButtonRole.Action"
                           Icon="@Icons.Material.Filled.Inventory2"
                           OnClick="NavigateToBacklogOverview">
                Backlog Health
            </CompactButton>
            <CompactButton ButtonRole="ButtonRole.Action"
                           Icon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                Health
            </CompactButton>
            <CompactButton ButtonRole="ButtonRole.Action"
                           Icon="@Icons.Material.Filled.CheckCircle"
                           OnClick="NavigateToDelivery">
                Delivery
            </CompactButton>
            <CompactButton ButtonRole="ButtonRole.Action"
                           Icon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                Planning (Future)
            </CompactButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Sprint range selector state
    private List<TeamDto> _teams = new();
    private List<SprintDto> _sprints = new();
    private DateTimeOffset _fromDate;
    private DateTimeOffset _toDate;
    
    // Decision #12: Interactive trend chart data - 3 series
    private Dictionary<string, int> _bugTrendTotal = new();   // Bugs existing/active in that month
    private Dictionary<string, int> _bugTrendFixed = new();   // Bugs moved to Done in that month
    private Dictionary<string, int> _bugTrendAdded = new();   // Bugs created in that month

    private TrendTileSignal? _bugTrendSignal;
    private TrendTileSignal? _prTrendSignal;
    private StatusTileSignal? _pipelineSignal;
    private CanonicalFilterMetadata? _prTrendFilterMetadata;
    private CanonicalFilterMetadata? _pipelineSignalFilterMetadata;
    private CancellationTokenSource? _tileSignalLoadCts;
    private DataStateViewModel<IReadOnlyList<WorkItemWithValidationDto>> _bugTrendState = DataStateViewModel<IReadOnlyList<WorkItemWithValidationDto>>.NotRequested();
    private DataStateViewModel<PullRequestQueryResponseDto<GetPrSprintTrendsResponse>> _prTrendState = DataStateViewModel<PullRequestQueryResponseDto<GetPrSprintTrendsResponse>>.NotRequested();
    private IDisposable? _filterSubscription;
    private int? _selectedTeamId => GlobalFilterStore.GetState().TeamId;
    private int? _selectedFromSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.StartSprintId : null;
    private int? _selectedToSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.EndSprintId : null;
    private FilterExecutionGateResult CurrentGateEvaluation => PageFilterExecutionGate.Evaluate(GlobalFilterStore.CurrentUsage);
    private DataStateViewModel<object> InvalidWorkspaceState
        => DataStateViewModel<object>.Invalid(
            reason: TrendUiStateFactory.GetBlockingReason(CurrentGateEvaluation, "Adjust the selected filter to load trend data."),
            data: default,
            invalidFields: CurrentGateEvaluation.BlockingFields,
            validationMessages: []);
    
    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        try
        {
            // Parse context from query string (inherited from base class)
            ParseContextQueryParameters();
            
            if (!await EnsureProfileAsync())
            {
                return;
            }
            
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            
            // Load teams for sprint selector
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            
            // Load sprints if team is selected
            if (_selectedTeamId.HasValue)
            {
                await LoadSprintsForTeamAsync(_selectedTeamId.Value);
            }
            
            // Calculate date range (default to 6 months if no sprints selected)
            CalculateDateRange();
            
            // Load bug trend data with calculated date range
            await LoadBugTrendDataAsync();
             
            UpdateBreadcrumbs();
            StartDynamicTileSignalLoad();
        }
        catch (Exception)
        {
            Snackbar.Add("Trends could not be loaded right now.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void StartDynamicTileSignalLoad()
    {
        CancelTileSignalLoad();
        _prTrendSignal = null;
        _pipelineSignal = null;

        if (!_profileId.HasValue)
        {
            return;
        }

        var cancellationTokenSource = new CancellationTokenSource();
        _tileSignalLoadCts = cancellationTokenSource;
        _ = LoadDynamicTileSignalsAsync(cancellationTokenSource.Token);
    }

    private async Task LoadDynamicTileSignalsAsync(CancellationToken cancellationToken)
    {
        try
        {
            var prTrendTask = LoadPrTrendSignalAsync(cancellationToken);
            var pipelineTask = LoadPipelineSignalAsync(cancellationToken);

            await Task.WhenAll(prTrendTask, pipelineTask);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (!cancellationToken.IsCancellationRequested)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    
    /// <summary>
    /// Loads bug trend data with configurable date range (sprint-based or default 6 months).
    /// Decision #3: Time horizon is configurable via sprint selection (defaults to 6 months).
    /// 
    /// Series 1 (Total): Bugs open at month-end (approximate using current state).
    /// Series 2 (Fixed): Bugs in "Done" state (approximate - no state transition history).
    /// Series 3 (Added): Bugs created in that month (accurate using System.CreatedDate).
    /// 
    /// Uses CreatedDate from TFS (System.CreatedDate) for accurate bug creation timing.
    /// Bugs without CreatedDate are excluded from trend calculations (DateTimeOffset.MinValue).
    /// </summary>
    private async Task LoadBugTrendDataAsync()
    {
        if (!CurrentGateEvaluation.CanExecuteQueries)
        {
            _bugTrendTotal = new Dictionary<string, int>();
            _bugTrendFixed = new Dictionary<string, int>();
            _bugTrendAdded = new Dictionary<string, int>();
            _bugTrendSignal = TrendTileSignal.WithFallback(
                StatusTileSignal.InvalidFilter(
                    TrendUiStateFactory.GetBlockingReason(CurrentGateEvaluation, "Adjust the selected filter to load bug trends.")));
            return;
        }

        _bugTrendState = DataStateViewModel<IReadOnlyList<WorkItemWithValidationDto>>.Loading();
        var response = await WorkItemService.GetAllWithValidationStateAsync(cancellationToken: CancellationToken.None);
        _bugTrendState = DataStateViewModel<IReadOnlyList<WorkItemWithValidationDto>>.FromResponse(
            response,
            "Bug trend data is unavailable right now.");

        if (_bugTrendState.UiState is UiDataState.Invalid)
        {
            _bugTrendTotal = new Dictionary<string, int>();
            _bugTrendFixed = new Dictionary<string, int>();
            _bugTrendAdded = new Dictionary<string, int>();
            _bugTrendSignal = TrendTileSignal.WithFallback(
                StatusTileSignal.InvalidFilter(_bugTrendState.Reason ?? "Adjust the selected filter to load bug trends."));
            return;
        }

        if (_bugTrendState.State != DataStateDto.Available || _bugTrendState.Data is null)
        {
            _bugTrendTotal = new Dictionary<string, int>();
            _bugTrendFixed = new Dictionary<string, int>();
            _bugTrendAdded = new Dictionary<string, int>();
            _bugTrendSignal = TrendTileSignal.WithFallback(
                _bugTrendState.State == DataStateDto.NotReady
                    ? StatusTileSignal.Loading(_bugTrendState.Reason ?? "Bug trend data is still loading from the cache.")
                    : StatusTileSignal.Failed(_bugTrendState.Reason ?? "Bug trend data could not be loaded right now."));
            return;
        }

        var bugs = _bugTrendState.Data.Where(wi => wi.Type?.Equals("Bug", StringComparison.OrdinalIgnoreCase) == true).ToList();
        var classifications = await StateClassificationService.GetClassificationsAsync();
        var classificationLookup = classifications.Classifications
            .Where(c => c.WorkItemType.Equals("Bug", StringComparison.OrdinalIgnoreCase))
            .ToDictionary(
                c => c.StateName,
                c => c.Classification,
                StringComparer.OrdinalIgnoreCase);

        _bugTrendTotal = new Dictionary<string, int>();
        _bugTrendFixed = new Dictionary<string, int>();
        _bugTrendAdded = new Dictionary<string, int>();

        var monthsCount = CalculateMonthsBetween(_fromDate.DateTime, _toDate.DateTime);
        for (var i = monthsCount - 1; i >= 0; i--)
        {
            var monthDate = _toDate.DateTime.AddMonths(-i);
            var periodKey = monthDate.ToString("yyyy-MM");
            var monthStart = new DateTime(monthDate.Year, monthDate.Month, 1);
            var nextMonthStart = monthStart.AddMonths(1);

            var addedCount = bugs.Count(b =>
            {
                var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                return effectiveDate >= monthStart && effectiveDate < nextMonthStart;
            });
            _bugTrendAdded[periodKey] = addedCount;

            var fixedCount = bugs.Count(b =>
            {
                var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                var createdBeforeOrDuringMonth = effectiveDate < nextMonthStart && effectiveDate > DateTimeOffset.MinValue;
                if (!createdBeforeOrDuringMonth)
                    return false;

                classificationLookup.TryGetValue(b.State, out var classification);
                return classification == PoTool.Shared.Settings.StateClassification.Done;
            });
            _bugTrendFixed[periodKey] = fixedCount;

            var totalCount = bugs.Count(b =>
            {
                var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                var createdBeforeOrDuringMonth = effectiveDate < nextMonthStart && effectiveDate > DateTimeOffset.MinValue;
                if (!createdBeforeOrDuringMonth)
                    return false;

                classificationLookup.TryGetValue(b.State, out var classification);
                return classification != PoTool.Shared.Settings.StateClassification.Done &&
                       classification != PoTool.Shared.Settings.StateClassification.Removed;
            });
            _bugTrendTotal[periodKey] = totalCount;
        }

        _bugTrendSignal = TrendsWorkspaceTileSignalService.GetBugTrendSignal(_bugTrendAdded);
    }
    
    /// <summary>
    /// Handles click on a trend chart bar.
    /// Decision #12: Click = filter to that period.
    /// </summary>
    private void OnBugTrendPeriodClick(string period)
    {
        // Navigate to bug overview filtered by the selected period
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BugOverview}{BuildContextQuery($"period={period}")}");
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", null, disabled: true, icon: Icons.Material.Filled.Timeline)
        };
    }

    private void NavigateToBugTrend()
    {
        // Navigate to bug overview with period scoped
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BugOverview}{BuildContextQuery()}");
    }
    
    private void NavigateToPrOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PrOverview}{BuildContextQuery("insightOnly=true")}");
    }
    
    private void NavigateToPipelineInsights()
    {
        NavigationManager.NavigateTo(
            WorkspaceQueryContextHelper.BuildRoute(
                WorkspaceRoutes.PipelineInsights,
                new WorkspaceQueryContext(ProductId: ProductId, TeamId: _selectedTeamId)));
    }
    
    private void NavigateToPrDeliveryInsights()
    {
        NavigationManager.NavigateTo(
            WorkspaceQueryContextHelper.BuildRoute(
                WorkspaceRoutes.PrDeliveryInsights,
                new WorkspaceQueryContext(ProductId: ProductId, TeamId: _selectedTeamId)));
    }
    
    private void NavigateToPortfolioProgress()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PortfolioProgress}{BuildContextQuery()}");
    }

    private void NavigateToDeliveryTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.DeliveryTrends}{BuildContextQuery()}");
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo(
            WorkspaceQueryContextHelper.BuildRoute(
                WorkspaceRoutes.DeliveryWorkspace,
                new WorkspaceQueryContext(ProductId: ProductId, TeamId: _selectedTeamId)));
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }
    
    private void ClearProductFilter()
    {
        var targetUri = WorkspaceQueryContextHelper.BuildRoute(
            WorkspaceRoutes.TrendsWorkspace,
            new WorkspaceQueryContext(TeamId: _selectedTeamId, FromSprintId: _selectedFromSprintId, ToSprintId: _selectedToSprintId));
        if (GlobalFilterStore.TryPrepareNavigation(NavigationManager.Uri, targetUri))
        {
            NavigationManager.NavigateTo(targetUri);
        }
    }
    
    /// <summary>
    /// Loads sprints for the selected team.
    /// </summary>
    private async Task LoadSprintsForTeamAsync(int teamId)
    {
        try
        {
            _sprints = (await SprintService.GetSprintsForTeamAsync(teamId)).ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Sprints could not be loaded right now.", Severity.Warning);
            _sprints = new List<SprintDto>();
        }
    }

    /// <summary>
    /// Loads median time-to-merge data for the selected sprint range to populate the PR Trend tile signal.
    /// Only called when both from/to sprints are selected.
    /// </summary>
    private async Task LoadPrTrendSignalAsync(CancellationToken cancellationToken)
    {
        if (!CurrentGateEvaluation.CanExecuteQueries)
        {
            _prTrendSignal = TrendTileSignal.WithFallback(
                StatusTileSignal.InvalidFilter(
                    TrendUiStateFactory.GetBlockingReason(CurrentGateEvaluation, "Adjust the selected filter to load PR trend data.")));
            return;
        }

        if (!_selectedFromSprintId.HasValue || !_selectedToSprintId.HasValue || _sprints.Count == 0)
        {
            _prTrendSignal = TrendTileSignal.WithFallback(
                StatusTileSignal.InvalidFilter("Select a valid sprint range to load PR trend data."));
            return;
        }

        try
        {
            var timeRange = GlobalFilterTrendRequestMapper.ResolveRange(GlobalFilterStore.GetState(), _sprints);
            if (!timeRange.IsResolved || timeRange.SprintIds.Count == 0)
            {
                _prTrendSignal = TrendTileSignal.WithFallback(
                    StatusTileSignal.InvalidFilter(timeRange.FailureReason ?? "Adjust the selected sprint range to load PR trend data."));
                return;
            }

            _prTrendState = DataStateViewModel<PullRequestQueryResponseDto<GetPrSprintTrendsResponse>>.Loading();
            var response = await PullRequestStateService.GetSprintTrendsStateAsync(
                timeRange,
                productIds: null,
                teamId: _selectedTeamId,
                cancellationToken);
            _prTrendState = DataStateViewModel<PullRequestQueryResponseDto<GetPrSprintTrendsResponse>>.FromResponse(
                response,
                "PR trend data is unavailable right now.");
            if (_prTrendState.UiState == UiDataState.Invalid)
            {
                _prTrendFilterMetadata = _prTrendState.Data is null
                    ? null
                    : CanonicalClientResponseFactory.Create(_prTrendState.Data).FilterMetadata;
                _prTrendSignal = TrendTileSignal.WithFallback(
                    StatusTileSignal.InvalidFilter(_prTrendState.Reason ?? "Adjust the selected filter to load PR trend data."));
                return;
            }

            if (_prTrendState.State != DataStateDto.Available || _prTrendState.Data is null)
            {
                _prTrendFilterMetadata = null;
                _prTrendSignal = TrendTileSignal.WithFallback(
                    _prTrendState.State == DataStateDto.NotReady
                        ? StatusTileSignal.Loading(_prTrendState.Reason ?? "PR trend data is still loading from the cache.")
                        : StatusTileSignal.Failed(_prTrendState.Reason ?? "PR trend data could not be loaded right now."));
                return;
            }

            _prTrendFilterMetadata = CanonicalClientResponseFactory.Create(_prTrendState.Data).FilterMetadata;
            _prTrendSignal = TrendsWorkspaceTileSignalService.GetPrTrendSignal(
                _prTrendState.Data.Data?.Success == true ? _prTrendState.Data.Data.Sprints : null);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadPipelineSignalAsync(CancellationToken cancellationToken)
    {
        if (!CurrentGateEvaluation.CanExecuteQueries)
        {
            _pipelineSignal = StatusTileSignal.InvalidFilter(
                TrendUiStateFactory.GetBlockingReason(CurrentGateEvaluation, "Adjust the selected filter to load pipeline signal data."));
            return;
        }

        if (!_profileId.HasValue)
        {
            _pipelineSignal = null;
            return;
        }

        try
        {
            var buildQualityResponse = await BuildQualityService.GetRollingWindowAsync(
                _profileId.Value,
                _fromDate,
                _toDate,
                cancellationToken);
            if (buildQualityResponse.State == CacheBackedClientState.Success && buildQualityResponse.Data is not null)
            {
                _pipelineSignalFilterMetadata = buildQualityResponse.Data.FilterMetadata;
                _pipelineSignal = TrendsWorkspaceTileSignalService.GetPipelineSignal(buildQualityResponse.Data.Data, ProductId);
                return;
            }

            _pipelineSignalFilterMetadata = null;
            _pipelineSignal = buildQualityResponse.State == CacheBackedClientState.NotReady
                ? StatusTileSignal.Loading(buildQualityResponse.Reason ?? "Pipeline signal data is still loading from the cache.")
                : StatusTileSignal.Failed(buildQualityResponse.Reason ?? "Pipeline signal data could not be loaded right now.");
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception)
        {
            _pipelineSignalFilterMetadata = null;
            _pipelineSignal = StatusTileSignal.Failed("Pipeline signal data could not be loaded right now.");
        }
    }
    
    /// <summary>
    /// Calculates the date range based on sprint selection or defaults to 6 months.
    /// </summary>
    private void CalculateDateRange()
    {
        // If both sprints are selected, use their date range
        if (_selectedFromSprintId.HasValue && _selectedToSprintId.HasValue)
        {
            var fromSprint = _sprints.FirstOrDefault(s => s.Id == _selectedFromSprintId.Value);
            var toSprint = _sprints.FirstOrDefault(s => s.Id == _selectedToSprintId.Value);
            
            if (fromSprint?.StartUtc.HasValue == true && toSprint?.EndUtc.HasValue == true)
            {
                _fromDate = fromSprint.StartUtc.Value;
                _toDate = toSprint.EndUtc.Value;
                return;
            }
        }
        
        // Default to last 6 months
        _toDate = DateTimeOffset.UtcNow;
        _fromDate = _toDate.AddMonths(-6);
    }
    
    /// <summary>
    /// Updates URL parameters with sprint selection.
    /// </summary>
    private void UpdateSprintUrlParameters()
    {
        var queryParams = new List<string>();
        
        if (_selectedTeamId.HasValue)
        {
            queryParams.Add($"teamId={_selectedTeamId.Value}");
        }

        if (ProductId.HasValue)
        {
            queryParams.Add($"productId={ProductId.Value}");
        }
        
        if (_selectedFromSprintId.HasValue)
        {
            queryParams.Add($"fromSprintId={_selectedFromSprintId.Value}");
        }
        
        if (_selectedToSprintId.HasValue)
        {
            queryParams.Add($"toSprintId={_selectedToSprintId.Value}");
        }
        
        var queryString = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : "";
        var newUrl = $"{WorkspaceRoutes.TrendsWorkspace}{queryString}";
        
        NavigationManager.NavigateTo(newUrl, forceLoad: false);
    }

    
    /// <summary>
    /// Handles team selection change.
    /// </summary>
    private async Task OnTeamSelectionChanged(int? teamId)
    {
        _sprints.Clear();
        _prTrendSignal = null;
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { TeamId = teamId, FromSprintId = null, ToSprintId = null });
         
        if (teamId.HasValue)
        {
            await LoadSprintsForTeamAsync(teamId.Value);
        }
        
        CalculateDateRange();
        UpdateSprintUrlParameters();
        await LoadBugTrendDataAsync();
        StartDynamicTileSignalLoad();
        StateHasChanged();
    }
    
    /// <summary>
    /// Handles from sprint selection change.
    /// </summary>
    private async Task OnFromSprintChanged(int? sprintId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { FromSprintId = sprintId });
        CalculateDateRange();
        UpdateSprintUrlParameters();
        await LoadBugTrendDataAsync();
        StartDynamicTileSignalLoad();
        StateHasChanged();
    }
    
    /// <summary>
    /// Handles to sprint selection change.
    /// </summary>
    private async Task OnToSprintChanged(int? sprintId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { ToSprintId = sprintId });
        CalculateDateRange();
        UpdateSprintUrlParameters();
        await LoadBugTrendDataAsync();
        StartDynamicTileSignalLoad();
        StateHasChanged();
    }
    
    /// <summary>
    /// Calculates the number of months between two dates.
    /// </summary>
    private int CalculateMonthsBetween(DateTime fromDate, DateTime toDate)
    {
        var months = ((toDate.Year - fromDate.Year) * 12) + toDate.Month - fromDate.Month + 1;
        return Math.Max(1, Math.Min(months, 12)); // Cap at 12 months for performance
    }

    private void CancelTileSignalLoad()
    {
        _tileSignalLoadCts?.Cancel();
        _tileSignalLoadCts?.Dispose();
        _tileSignalLoadCts = null;
    }

    public void Dispose()
    {
        _filterSubscription?.Dispose();
        CancelTileSignalLoad();
    }

    private FilterLocalBridgeState BuildCurrentLocalBridgeState()
        => FilterLocalBridgeState.FromState(GlobalFilterStore.GetState()) with { ProductId = ProductId };

    private async Task UpdateFilterStateAsync(FilterLocalBridgeState localState)
        => await GlobalFilterStore.SetStateAsync(
            NavigationManager.Uri,
            _profileId,
            localState,
            FilterUpdateSource.Ui);

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(StateHasChanged);
}
