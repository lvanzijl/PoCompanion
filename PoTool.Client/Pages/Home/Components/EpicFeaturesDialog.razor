@using PoTool.Shared.Metrics
@using PoTool.Shared.WorkItems

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.subtitle1" Class="mb-3">
            <strong>Features for Epic: @EpicTitle</strong>
        </MudText>

        @if (GetVisibleFeatures().Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No features with sprint activity found for this epic.
            </MudAlert>
        }
        else
        {
            <MudSimpleTable Dense="true" Striped="true" Hover="true">
                <thead>
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Feature</th>
                        <th style="width: 180px;">Progress</th>
                        <th style="width: 110px; text-align: right;">Delivered (pts)</th>
                        <th style="width: 110px; text-align: right;">Δ Effort (pts)</th>
                        <th style="width: 70px; text-align: right;">PBIs ✓</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var feature in GetVisibleFeatures())
                    {
                        <tr>
                            <td style="padding-top: 4px; padding-bottom: 4px;">
                                @if (!string.IsNullOrEmpty(TfsUrl) && !string.IsNullOrEmpty(TfsProject))
                                {
                                    <MudLink Href="@TfsUrlBuilder.BuildWorkItemUrl(TfsUrl, TfsProject, feature.FeatureId)"
                                             Target="_blank"
                                             Typo="Typo.body2">#@feature.FeatureId</MudLink>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2">#@feature.FeatureId</MudText>
                                }
                            </td>
                            <td style="padding-top: 4px; padding-bottom: 4px;">
                                <MudText Typo="Typo.body2"><strong>@feature.FeatureTitle</strong></MudText>
                            </td>
                            <td style="padding-top: 4px; padding-bottom: 4px;">
                                <MudProgressLinear Color="@GetFeatureProgressColor(feature.ProgressPercent)"
                                                   Value="@feature.ProgressPercent"
                                                   Max="100"
                                                   Size="Size.Small"
                                                   Style="opacity: 0.75;" />
                            </td>
                            <td style="text-align: right; padding-top: 4px; padding-bottom: 4px;">
                                <MudText Typo="Typo.body2">@feature.SprintCompletedEffort</MudText>
                            </td>
                            <td style="text-align: right; padding-top: 4px; padding-bottom: 4px;">
                                <MudText Typo="Typo.body2"
                                         Color="@(feature.SprintEffortDelta > 0 ? Color.Warning : feature.SprintEffortDelta < 0 ? Color.Info : Color.Default)">
                                    @FormatSignedInt(feature.SprintEffortDelta)
                                </MudText>
                            </td>
                            <td style="text-align: right; padding-top: 4px; padding-bottom: 4px;">
                                <MudText Typo="Typo.body2">@feature.SprintCompletedPbiCount</MudText>
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Default">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance? MudDialog { get; set; }

    [Parameter]
    public string EpicTitle { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<FeatureProgressDto>? Features { get; set; }

    [Parameter]
    public string? TfsUrl { get; set; }

    [Parameter]
    public string? TfsProject { get; set; }

    private void Close()
    {
        MudDialog?.Cancel();
    }

    /// <summary>
    /// Returns features with any delivery signal in the sprint.
    /// Hides features where Delivered = 0, Δ Effort = 0, and no PBIs completed.
    /// </summary>
    private List<FeatureProgressDto> GetVisibleFeatures()
    {
        return Features?
            .Where(f => f.SprintCompletedEffort > 0 || f.SprintEffortDelta != 0 || f.SprintCompletedPbiCount > 0)
            .ToList()
            ?? new List<FeatureProgressDto>();
    }

    private static string FormatSignedInt(int value) => value >= 0 ? $"+{value}" : $"{value}";

    private static Color GetFeatureProgressColor(int progress) =>
        SprintProgressColorHelper.GetProgressColor(progress);
}
