@using PoTool.Client.Services

@* Metric Card Component - Displays a single insight metric (e.g., PRs, bugs, builds) *@
<MudCard Elevation="2" Class="metric-card">
    <MudCardContent>
        <MudStack Spacing="2">
            @* Metric Title *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">
                @Title
            </MudText>

            @if (IsLoading)
            {
                @* Loading State *@
                <MudSkeleton SkeletonType="SkeletonType.Text" Height="48px" />
                <MudSkeleton SkeletonType="SkeletonType.Text" Height="32px" />
            }
            else if (Result == null || Result.Count == 0)
            {
                @* Empty State *@
                <MudText Typo="Typo.h4" Color="Color.Default">
                    —
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    No data
                </MudText>
            }
            else
            {
                @* Primary Value (Median) *@
                <MudText Typo="Typo.h4" Style="font-weight: 600;">
                    @FormatValue(Result.Median, ValueFormat)
                </MudText>

                @* Secondary Value (P75) *@
                <MudTooltip Text="75th percentile: 75% of values are at or below this value">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        75th percentile: @FormatValue(Result.P75, ValueFormat)
                    </MudText>
                </MudTooltip>

                @* Footer (Count or Coverage) *@
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.caption" Color="Color.Default">
                    @if (Result.Coverage.HasValue)
                    {
                        @:@Result.Count @ItemLabel (@($"{Result.Coverage.Value:F1}") % coverage)
                    }
                    else
                    {
                        <text>@Result.Count @ItemLabel</text>
                    }
                </MudText>
            }
        </MudStack>
    </MudCardContent>
</MudCard>

@code {
    /// <summary>
    /// Metric title displayed at top of card.
    /// </summary>
    [Parameter]
    [EditorRequired]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// Metric result containing Median, P75, Count, and Coverage.
    /// </summary>
    [Parameter]
    public MetricResult? Result { get; set; }

    /// <summary>
    /// Format type for displaying values (Hours, Days, Count).
    /// </summary>
    [Parameter]
    public MetricValueFormat ValueFormat { get; set; } = MetricValueFormat.Hours;

    /// <summary>
    /// Whether the metric is currently loading.
    /// </summary>
    [Parameter]
    public bool IsLoading { get; set; }

    /// <summary>
    /// Label for the items being counted (e.g., "PRs", "Bugs"). Defaults to "items".
    /// </summary>
    [Parameter]
    public string ItemLabel { get; set; } = "items";

    /// <summary>
    /// Formats a nullable double value based on the specified format.
    /// </summary>
    private string FormatValue(double? value, MetricValueFormat format)
    {
        if (!value.HasValue)
            return "—";

        return format switch
        {
            MetricValueFormat.Hours => FormatHours(value.Value),
            MetricValueFormat.Days => FormatDays(value.Value),
            MetricValueFormat.Count => value.Value.ToString("F1"),
            MetricValueFormat.Percentage => $"{value.Value:F1}%",
            _ => value.Value.ToString("F1")
        };
    }

    /// <summary>
    /// Formats hours into human-readable format (days, hours, or minutes).
    /// </summary>
    private string FormatHours(double hours)
    {
        if (hours >= 24)
        {
            var days = hours / 24;
            return $"{days:F1}d";
        }
        else if (hours >= 1)
        {
            return $"{hours:F1}h";
        }
        else
        {
            var minutes = hours * 60;
            return $"{minutes:F0}m";
        }
    }

    /// <summary>
    /// Formats days into human-readable format.
    /// </summary>
    private string FormatDays(double days)
    {
        return $"{days:F1}d";
    }
}

@* Add hover effect for metric cards *@
<style>
    .metric-card {
        transition: transform 0.2s ease;
    }

    .metric-card:hover {
        transform: translateY(-2px);
    }
</style>
