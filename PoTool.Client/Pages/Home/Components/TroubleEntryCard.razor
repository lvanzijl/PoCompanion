@*
    TroubleEntryCard — Compact card showing pipeline failure/warning metrics for a single pipeline.
    Used in the "Top Pipelines In Trouble" lists on the Pipeline Insights page.

    Parameters:
      Entry           — the PipelineTroubleEntryDto to display
      ShowProductName — when true (default), shows the product name below the pipeline name
*@
@using PoTool.Client.ApiClient

<MudPaper Elevation="2" Class="pa-3" Style="border-left: 4px solid var(--mud-palette-error);">
    <MudStack Spacing="1">

        @* Rank badge + pipeline name *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudChip T="string" Size="Size.Small" Color="Color.Error" Style="min-width:28px; justify-content:center;">
                #@Entry.Rank
            </MudChip>
            <MudText Typo="Typo.subtitle2" Style="word-break:break-word;">
                @Entry.PipelineName
            </MudText>
        </MudStack>

        @* Optional product name *@
        @if (ShowProductName && !string.IsNullOrEmpty(Entry.ProductName))
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Entry.ProductName</MudText>
        }

        <MudDivider Class="my-1" />

        @* Failure rate row *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6" Color="Color.Error">
                    @Entry.FailureRate.ToString("F1")%
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Failure rate (@Entry.FailedBuilds / @Entry.CompletedBuilds)
                </MudText>
            </MudStack>
            @if (Entry.DeltaFailureRate.HasValue)
            {
                <MudChip T="string"
                         Size="Size.Small"
                         Color="@DeltaColor(Entry.DeltaFailureRate, lowerIsBetter: true)"
                         Icon="@DeltaIcon(Entry.DeltaFailureRate, lowerIsBetter: true)">
                    @FormatDelta(Entry.DeltaFailureRate)
                </MudChip>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Default">Δ n/a</MudText>
            }
        </MudStack>

        @* Warning rate row (only shown when there are warnings) *@
        @if (Entry.WarningBuilds > 0 || Entry.WarningRate > 0)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.body2" Color="Color.Warning">
                        @Entry.WarningRate.ToString("F1")%
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Warning rate (@Entry.WarningBuilds partial)
                    </MudText>
                </MudStack>
                @if (Entry.DeltaWarningRate.HasValue)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="@DeltaColor(Entry.DeltaWarningRate, lowerIsBetter: true)"
                             Icon="@DeltaIcon(Entry.DeltaWarningRate, lowerIsBetter: true)">
                        @FormatDelta(Entry.DeltaWarningRate)
                    </MudChip>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Default">Δ n/a</MudText>
                }
            </MudStack>
        }

    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public PipelineTroubleEntryDto Entry { get; set; } = null!;

    [Parameter]
    public bool ShowProductName { get; set; } = true;

    private static string FormatDelta(double? delta)
    {
        if (!delta.HasValue) return "n/a";
        if (delta.Value > 0) return $"+{delta.Value:F1} pp";
        if (delta.Value < 0) return $"{delta.Value:F1} pp";
        return "±0 pp";
    }

    private static Color DeltaColor(double? delta, bool lowerIsBetter)
    {
        if (!delta.HasValue || delta.Value == 0) return Color.Default;
        bool isImprovement = lowerIsBetter ? delta.Value < 0 : delta.Value > 0;
        return isImprovement ? Color.Success : Color.Error;
    }

    private static string DeltaIcon(double? delta, bool lowerIsBetter)
    {
        if (!delta.HasValue || delta.Value == 0) return Icons.Material.Filled.TrendingFlat;
        bool isImprovement = lowerIsBetter ? delta.Value < 0 : delta.Value > 0;
        if (isImprovement)
            return lowerIsBetter ? Icons.Material.Filled.TrendingDown : Icons.Material.Filled.TrendingUp;
        return lowerIsBetter ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown;
    }
}
