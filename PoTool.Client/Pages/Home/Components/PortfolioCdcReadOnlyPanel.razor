@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Shared.Metrics
@inject IMetricsClient MetricsClient
@inject IProfileService ProfileService
@inject ProductService ProductService

<MudPaper Elevation="2" Class="pa-4 mt-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-2" />
                CDC Portfolio History View
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Read-only progress, history, lifecycle, and decision signals from persisted CDC snapshots.
            </MudText>
        </MudStack>

        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAsync">
            Refresh
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@_errorMessage</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-3">
            <MudItem xs="12" md="3">
                <MudSelect T="int?"
                           Label="Product"
                           Value="_productId"
                           ValueChanged="OnProductChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField T="string"
                              Label="Project"
                              Value="_projectNumber"
                              ValueChanged="OnProjectChangedAsync"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField T="string"
                              Label="Work Package"
                              Value="_workPackage"
                              ValueChanged="OnWorkPackageChangedAsync"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="PortfolioLifecycleState?"
                           Label="Lifecycle"
                           Value="_lifecycleState"
                           ValueChanged="OnLifecycleChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@((PortfolioLifecycleState?)null)">All</MudSelectItem>
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@PortfolioLifecycleState.Active">Active</MudSelectItem>
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@PortfolioLifecycleState.Retired">Retired</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="1">
                <MudSelect T="PortfolioReadSortBy"
                           Label="Sort"
                           Value="_sortBy"
                           ValueChanged="OnSortChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Default">Default</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Progress">Progress</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Weight">Weight</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Delta">Delta</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="1">
                <MudSelect T="PortfolioReadGroupBy"
                           Label="Group"
                           Value="_groupBy"
                           ValueChanged="OnGroupChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.None">None</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.Product">Product</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.Project">Project</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.WorkPackage">Package</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int"
                           Label="History"
                           Value="_snapshotCount"
                           ValueChanged="OnSnapshotCountChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="int" Value="3">Last 3</MudSelectItem>
                    <MudSelectItem T="int" Value="6">Last 6</MudSelectItem>
                    <MudSelectItem T="int" Value="10">Last 10</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="long?"
                           Label="Compare to"
                           Value="_compareToSnapshotId"
                           ValueChanged="OnCompareToSnapshotChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="long?" Value="@((long?)null)">Previous snapshot</MudSelectItem>
                    @if (_trend?.Snapshots is not null)
                    {
                        foreach (var historicalSnapshot in _trend.Snapshots.Skip(1))
                        {
                            <MudSelectItem T="long?" Value="@historicalSnapshot.SnapshotId">
                                @($"{historicalSnapshot.SnapshotLabel} ({historicalSnapshot.Timestamp:yyyy-MM-dd})")
                            </MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudCheckBox T="bool"
                             Label="Include archived history"
                             Value="_includeArchivedSnapshots"
                             ValueChanged="OnIncludeArchivedChangedAsync"
                             Dense="true"
                             Color="Color.Primary" />
            </MudItem>
        </MudGrid>

        @if (_progress?.HasData == true)
        {
            <MudGrid Class="mb-4" Spacing="2">
                <MudItem xs="12" md="3">
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Portfolio progress</MudText>
                        <MudText Typo="Typo.h5">@FormatPercent(_progress.PortfolioProgress)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@($"{_progress.FilteredItemCount} visible of {_progress.TotalItemCount}")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Delta vs previous</MudText>
                        @if (GetPortfolioProgressDelta() is double portfolioDelta)
                        {
                            <MudText Typo="Typo.h5" Color="@GetTrendColorFromValue(portfolioDelta)">@FormatSignedRatio(portfolioDelta)</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@GetPortfolioDeltaContext()</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h6">—</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No previous snapshot in the selected history.</MudText>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Snapshot</MudText>
                        <MudText Typo="Typo.h6">@_progress.SnapshotLabel</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_progress.SnapshotTimestamp.ToString("yyyy-MM-dd")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="3">
                    <MudPaper Outlined="true" Class="pa-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Portfolio weight</MudText>
                        <MudText Typo="Typo.h5">@FormatNumber(_progress.TotalWeight)</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Current scope weight</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        @if (_trend?.ArchivedSnapshotsExcludedNotice == true && !_includeArchivedSnapshots)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Archived snapshots exist in the selected history window and remain excluded until you enable archived history.
            </MudAlert>
        }
        else if (_trend?.IncludesArchivedSnapshots == true)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Historical trends and signals currently include archived persisted snapshots.
            </MudAlert>
        }

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Trend history</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Snapshot state stays visible while archived status moves into the snapshot label.
            </MudText>
        </MudStack>
        @if (_trend?.HasData == true)
        {
            <MudTable T="PortfolioHistoricalSnapshotDto" Items="_trend.Snapshots" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Snapshot</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Portfolio progress</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Snapshot">
                        <MudText Typo="Typo.body2">@context.SnapshotLabel</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.IncludesArchivedSnapshot ? "Includes archived" : "Active-only")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Date">@context.Timestamp.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Portfolio progress">@FormatRatio(FindPointValue(_trend.PortfolioProgressTrend.Points, context.SnapshotId))</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2">No persisted history is available for the selected scope.</MudText>
        }

        <MudDivider Class="my-4" />

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Decision signals</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Signals are grouped to emphasize movement, regression, and repeated stability.
            </MudText>
        </MudStack>
        @if (_signals.Count > 0)
        {
            <MudStack Spacing="2" Class="mb-4">
                @foreach (var signalGroup in GetSignalGroups())
                {
                    <MudAlert Severity="@signalGroup.Severity" Dense="true" Variant="Variant.Outlined">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.subtitle2">@signalGroup.Title</MudText>
                            <MudText Typo="Typo.body2">@signalGroup.Summary</MudText>
                            @foreach (var detail in signalGroup.Details)
                            {
                                <MudText Typo="Typo.body2">• @detail</MudText>
                            }
                        </MudStack>
                    </MudAlert>
                }
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-4">No decision signals are available for the selected persisted history.</MudText>
        }

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Project trends</MudText>
        @if (GetVisibleProjectTrends() is { Count: > 0 } projectTrends)
        {
            <MudTable T="PortfolioScopedTrendDto" Items="projectTrends" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Product</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Lifecycle</MudTh>
                    <MudTh>Current progress</MudTh>
                    <MudTh>Previous progress</MudTh>
                    <MudTh>Δ Progress</MudTh>
                    <MudTh>Direction</MudTh>
                    <MudTh>Current weight</MudTh>
                    <MudTh>Previous weight</MudTh>
                    <MudTh>Δ Weight</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Product">@context.ProductName</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                    <MudTd DataLabel="Lifecycle">@FormatLifecycle(context.CurrentLifecycleState)</MudTd>
                    <MudTd DataLabel="Current progress">@FormatRatio(context.ProgressTrend.CurrentValue)</MudTd>
                    <MudTd DataLabel="Previous progress">@FormatRatio(context.ProgressTrend.PreviousValue)</MudTd>
                    <MudTd DataLabel="Δ Progress">@FormatSignedRatio(context.ProgressTrend.Delta)</MudTd>
                    <MudTd DataLabel="Direction">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(context.ProgressTrend.Direction)">
                            @($"{GetTrendGlyph(context.ProgressTrend.Direction)} {FormatDirection(context.ProgressTrend.Direction)}")
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Current weight">@FormatNumber(context.WeightTrend.CurrentValue)</MudTd>
                    <MudTd DataLabel="Previous weight">@FormatNumber(context.WeightTrend.PreviousValue)</MudTd>
                    <MudTd DataLabel="Δ Weight">@FormatSignedNumber(context.WeightTrend.Delta)</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2">No project-level changes detected in selected history.</MudText>
        }

        <MudDivider Class="my-4" />

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Work package trends</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Grouped by lifecycle so active and retired items scan separately.
            </MudText>
        </MudStack>
        @if (_trend?.WorkPackages.Count > 0)
        {
            @foreach (var section in GetWorkPackageTrendSections())
            {
                <MudText Typo="Typo.subtitle2" Class="mt-3 mb-2">@(section.Title)</MudText>

                @if (section.Items.Count > 0)
                {
                    <MudTable T="PortfolioScopedTrendDto" Items="section.Items" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Product</MudTh>
                            <MudTh>Project</MudTh>
                            <MudTh>Work Package</MudTh>
                            <MudTh>Current progress</MudTh>
                            <MudTh>Previous progress</MudTh>
                            <MudTh>Δ Progress</MudTh>
                            <MudTh>Change</MudTh>
                            <MudTh>Current weight</MudTh>
                            <MudTh>Previous weight</MudTh>
                            <MudTh>Δ Weight</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Product">@context.ProductName</MudTd>
                            <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                            <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                            <MudTd DataLabel="Current progress">@FormatRatio(context.ProgressTrend.CurrentValue)</MudTd>
                            <MudTd DataLabel="Previous progress">@FormatRatio(context.ProgressTrend.PreviousValue)</MudTd>
                            <MudTd DataLabel="Δ Progress">@FormatSignedRatio(context.ProgressTrend.Delta)</MudTd>
                            <MudTd DataLabel="Change">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(context.ProgressTrend.Direction)">
                                    @($"{GetTrendGlyph(context.ProgressTrend.Direction)} {FormatDirection(context.ProgressTrend.Direction)}")
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Current weight">@FormatNumber(context.WeightTrend.CurrentValue)</MudTd>
                            <MudTd DataLabel="Previous weight">@FormatNumber(context.WeightTrend.PreviousValue)</MudTd>
                            <MudTd DataLabel="Δ Weight">@FormatSignedNumber(context.WeightTrend.Delta)</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@(section.EmptyState)</MudText>
                }
            }
        }
        else
        {
            <MudText Typo="Typo.body2">No work package trends available.</MudText>
        }

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Current snapshot</MudText>
        @if (_snapshot?.HasData == true)
        {
            <MudTable T="PortfolioSnapshotItemDto" Items="_snapshot.Items" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Product</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Work Package</MudTh>
                    <MudTh>Lifecycle</MudTh>
                    <MudTh>Progress</MudTh>
                    <MudTh>Weight</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var comparisonItem = FindComparisonItem(context);
                    }
                    <MudTd DataLabel="Product">@context.ProductName</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                    <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                    <MudTd DataLabel="Lifecycle">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2">@context.LifecycleState</MudText>
                            @if (HasLifecycleChanged(comparisonItem))
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">
                                    @GetLifecycleChangeText(comparisonItem!)
                                </MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Progress">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">@FormatRatio(context.Progress)</MudText>
                            @if (comparisonItem is not null)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetProgressChangeColor(comparisonItem)">
                                    @GetProgressChangeText(comparisonItem)
                                </MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Weight">@($"{context.Weight:F1}")</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2">No snapshot rows available.</MudText>
        }

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle1" Class="mb-2">Snapshot comparison</MudText>
        @if (_comparison?.HasData == true)
        {
            <MudTable T="PortfolioComparisonItemDto" Items="_comparison.Items" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Product</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Work Package</MudTh>
                    <MudTh>Previous</MudTh>
                    <MudTh>Current</MudTh>
                    <MudTh>Δ Progress</MudTh>
                    <MudTh>Δ Weight</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Product">@context.ProductName</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                    <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                    <MudTd DataLabel="Previous">@($"{FormatLifecycle(context.PreviousLifecycleState)} / {FormatRatio(context.PreviousProgress)}")</MudTd>
                    <MudTd DataLabel="Current">@($"{FormatLifecycle(context.CurrentLifecycleState)} / {FormatRatio(context.CurrentProgress)}")</MudTd>
                    <MudTd DataLabel="Δ Progress">@FormatSignedRatio(context.ProgressDelta)</MudTd>
                    <MudTd DataLabel="Δ Weight">@FormatSignedNumber(context.WeightDelta)</MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2">No comparison rows available.</MudText>
        }
    }
</MudPaper>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private int? _profileId;
    private int? _productId;
    private string? _projectNumber;
    private string? _workPackage;
    private PortfolioLifecycleState? _lifecycleState;
    private PortfolioReadSortBy _sortBy = PortfolioReadSortBy.Default;
    private PortfolioReadGroupBy _groupBy = PortfolioReadGroupBy.None;
    private readonly PortfolioReadSortDirection _sortDirection = PortfolioReadSortDirection.Desc;
    private int _snapshotCount = 6;
    private bool _includeArchivedSnapshots;
    private long? _compareToSnapshotId;
    private IReadOnlyList<ProductDto> _products = Array.Empty<ProductDto>();
    private PortfolioProgressDto? _progress;
    private PortfolioSnapshotDto? _snapshot;
    private PortfolioComparisonDto? _comparison;
    private PortfolioTrendDto? _trend;
    private IReadOnlyList<PortfolioDecisionSignalDto> _signals = Array.Empty<PortfolioDecisionSignalDto>();

    private sealed record SignalGroupDisplay(
        string Title,
        Severity Severity,
        string Summary,
        IReadOnlyList<string> Details);

    private sealed record WorkPackageTrendSection(
        string Title,
        string EmptyState,
        IReadOnlyList<PortfolioScopedTrendDto> Items);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile is null)
            {
                _errorMessage = "Select an active profile to load portfolio snapshot data.";
                return;
            }

            _profileId = activeProfile.Id;
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();

            _progress = await MetricsClient.GetPortfolioProgressAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy);
            _snapshot = await MetricsClient.GetPortfolioSnapshotsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy);
            _comparison = await MetricsClient.GetPortfolioComparisonAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots,
                _compareToSnapshotId);
            _trend = await MetricsClient.GetPortfolioTrendsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                _snapshotCount,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots);
            _signals = await MetricsClient.GetPortfolioSignalsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                _snapshotCount,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots,
                _compareToSnapshotId);

            if (_compareToSnapshotId.HasValue
                && _trend?.Snapshots.All(snapshot => snapshot.SnapshotId != _compareToSnapshotId.Value) == true)
            {
                _compareToSnapshotId = null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load CDC portfolio data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnProductChangedAsync(int? value)
    {
        _productId = value;
        await LoadAsync();
    }

    private async Task OnProjectChangedAsync(string? value)
    {
        _projectNumber = value;
        await LoadAsync();
    }

    private async Task OnWorkPackageChangedAsync(string? value)
    {
        _workPackage = value;
        await LoadAsync();
    }

    private async Task OnLifecycleChangedAsync(PortfolioLifecycleState? value)
    {
        _lifecycleState = value;
        await LoadAsync();
    }

    private async Task OnSortChangedAsync(PortfolioReadSortBy value)
    {
        _sortBy = value;
        await LoadAsync();
    }

    private async Task OnGroupChangedAsync(PortfolioReadGroupBy value)
    {
        _groupBy = value;
        await LoadAsync();
    }

    private async Task OnSnapshotCountChangedAsync(int value)
    {
        _snapshotCount = value;
        await LoadAsync();
    }

    private async Task OnCompareToSnapshotChangedAsync(long? value)
    {
        _compareToSnapshotId = value;
        await LoadAsync();
    }

    private async Task OnIncludeArchivedChangedAsync(bool value)
    {
        _includeArchivedSnapshots = value;
        await LoadAsync();
    }

    private static string FormatPercent(double? value)
        => value.HasValue ? $"{value.Value:F0}%" : "—";

    private static string FormatRatio(double? value)
        => value.HasValue ? $"{value.Value:P0}" : "—";

    private static string FormatNumber(double? value)
        => value.HasValue ? $"{value.Value:F1}" : "—";

    private static string FormatSignedRatio(double? value)
        => value.HasValue ? $"{value.Value:+0%;-0%;0%}" : "—";

    private static string FormatSignedNumber(double? value)
        => value.HasValue ? $"{value.Value:+0.0;-0.0;0.0}" : "—";

    private static string FormatDirection(PortfolioTrendDirection? value)
        => value?.ToString() ?? "—";

    private static string FormatLifecycle(PortfolioLifecycleState? value)
        => value?.ToString() ?? "—";

    private static string FormatDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "—";

    private double? GetPortfolioProgressDelta()
        => _comparison?.PreviousTimestamp is null ? null : _trend?.PortfolioProgressTrend.Delta;

    private string GetPortfolioDeltaContext()
        => _comparison?.PreviousSnapshotLabel is null
            ? "Previous snapshot"
            : $"{_comparison.PreviousSnapshotLabel} · {FormatDate(_comparison.PreviousTimestamp)}";

    private IReadOnlyList<SignalGroupDisplay> GetSignalGroups()
    {
        if (_signals.Count == 0)
        {
            return Array.Empty<SignalGroupDisplay>();
        }

        var groups = new List<SignalGroupDisplay>();

        AddSignalGroup(
            groups,
            "Improving",
            Severity.Success,
            "Positive movement detected in the latest persisted comparison.",
            _signals.Where(signal => signal.Tone == PortfolioDecisionSignalTone.Positive));

        AddSignalGroup(
            groups,
            "Regression",
            Severity.Warning,
            "Warning signals detected in the latest persisted comparison.",
            _signals.Where(signal => signal.Tone == PortfolioDecisionSignalTone.Warning));

        AddRepeatedNoChangeGroup(groups);

        AddSignalGroup(
            groups,
            "Lifecycle updates",
            Severity.Info,
            "Lifecycle transitions remain visible without repeating one alert per row.",
            _signals.Where(signal => signal.Type is PortfolioDecisionSignalType.NewWorkPackage or PortfolioDecisionSignalType.RetiredWorkPackage));

        AddSignalGroup(
            groups,
            "History notices",
            Severity.Info,
            "Context notices for the selected persisted history window.",
            _signals.Where(signal => signal.Type == PortfolioDecisionSignalType.ArchivedSnapshotExcludedNotice));

        return groups;
    }

    private IReadOnlyList<WorkPackageTrendSection> GetWorkPackageTrendSections()
    {
        var workPackageTrends = _trend?.WorkPackages ?? Array.Empty<PortfolioScopedTrendDto>();

        return
        [
            new WorkPackageTrendSection(
                "Active Work Packages",
                "No active work package changes detected in selected history.",
                workPackageTrends
                    .Where(item => item.CurrentLifecycleState != PortfolioLifecycleState.Retired)
                    .ToArray()),
            new WorkPackageTrendSection(
                "Retired Work Packages",
                "No retired work package changes detected in selected history.",
                workPackageTrends
                    .Where(item => item.CurrentLifecycleState == PortfolioLifecycleState.Retired)
                    .ToArray())
        ];
    }

    private IReadOnlyList<PortfolioScopedTrendDto> GetVisibleProjectTrends()
        => (_trend?.Projects ?? Array.Empty<PortfolioScopedTrendDto>())
            .Where(HasScopedTrendData)
            .ToArray();

    private static double? FindPointValue(IReadOnlyList<PortfolioTrendPointDto> points, long snapshotId)
        => points.FirstOrDefault(point => point.SnapshotId == snapshotId)?.Value;

    private PortfolioComparisonItemDto? FindComparisonItem(PortfolioSnapshotItemDto item)
        => _comparison?.Items.FirstOrDefault(comparisonItem =>
            comparisonItem.ProductId == item.ProductId
            && string.Equals(comparisonItem.ProjectNumber, item.ProjectNumber, StringComparison.Ordinal)
            && string.Equals(comparisonItem.WorkPackage ?? string.Empty, item.WorkPackage ?? string.Empty, StringComparison.Ordinal));

    private static Severity GetSignalSeverity(PortfolioDecisionSignalTone tone)
        => tone switch
        {
            PortfolioDecisionSignalTone.Positive => Severity.Success,
            PortfolioDecisionSignalTone.Warning => Severity.Warning,
            _ => Severity.Info
        };

    private static void AddSignalGroup(
        ICollection<SignalGroupDisplay> groups,
        string title,
        Severity severity,
        string summary,
        IEnumerable<PortfolioDecisionSignalDto> signals)
    {
        var details = signals
            .Select(FormatSignalDetail)
            .ToArray();

        if (details.Length == 0)
        {
            return;
        }

        groups.Add(new SignalGroupDisplay(title, severity, summary, details));
    }

    private void AddRepeatedNoChangeGroup(ICollection<SignalGroupDisplay> groups)
    {
        var repeatedSignals = _signals
            .Where(signal => signal.Type == PortfolioDecisionSignalType.RepeatedNoChange)
            .ToArray();

        if (repeatedSignals.Length == 0)
        {
            return;
        }

        var projects = new List<string>();
        var workPackages = new List<string>();

        foreach (var signal in repeatedSignals)
        {
            if (string.IsNullOrWhiteSpace(signal.WorkPackage))
            {
                projects.Add(signal.ProjectNumber ?? signal.ProductName ?? "Unknown project");
            }
            else
            {
                workPackages.Add(signal.WorkPackage);
            }
        }

        var summaryParts = new List<string>();
        if (workPackages.Count > 0)
        {
            summaryParts.Add($"{workPackages.Count} work package{(workPackages.Count == 1 ? string.Empty : "s")}");
        }

        if (projects.Count > 0)
        {
            summaryParts.Add($"{projects.Count} project{(projects.Count == 1 ? string.Empty : "s")}");
        }

        var details = new List<string>();
        if (projects.Count > 0)
        {
            details.Add($"Projects: {string.Join(", ", projects)}");
        }

        if (workPackages.Count > 0)
        {
            details.Add($"Work packages: {string.Join(", ", workPackages)}");
        }

        groups.Add(new SignalGroupDisplay(
            "No change",
            Severity.Info,
            $"No change detected ({string.Join(", ", summaryParts)})",
            details));
    }

    private static string FormatSignalDetail(PortfolioDecisionSignalDto signal)
        => signal.Type switch
        {
            PortfolioDecisionSignalType.NewWorkPackage => $"Work package {signal.WorkPackage} appeared in the latest snapshot.",
            PortfolioDecisionSignalType.RetiredWorkPackage => $"Work package {signal.WorkPackage} moved to retired lifecycle.",
            _ => signal.Description
        };

    private static bool HasScopedTrendData(PortfolioScopedTrendDto trend)
        => trend.CurrentLifecycleState is not null
           || trend.PreviousLifecycleState is not null
           || trend.ProgressTrend.CurrentValue.HasValue
           || trend.ProgressTrend.PreviousValue.HasValue
           || trend.ProgressTrend.Delta.HasValue
           || trend.ProgressTrend.Direction.HasValue
           || trend.WeightTrend.CurrentValue.HasValue
           || trend.WeightTrend.PreviousValue.HasValue
           || trend.WeightTrend.Delta.HasValue
           || trend.WeightTrend.Direction.HasValue;

    private static string GetTrendGlyph(PortfolioTrendDirection? direction)
        => direction switch
        {
            PortfolioTrendDirection.Increasing => "↑",
            PortfolioTrendDirection.Decreasing => "↓",
            PortfolioTrendDirection.Stable => "→",
            _ => "—"
        };

    private static Color GetTrendColorFromDirection(PortfolioTrendDirection? direction)
        => direction switch
        {
            PortfolioTrendDirection.Increasing => Color.Success,
            PortfolioTrendDirection.Decreasing => Color.Warning,
            PortfolioTrendDirection.Stable => Color.Info,
            _ => Color.Default
        };

    private static Color GetTrendColorFromValue(double value)
        => value switch
        {
            > 0 => Color.Success,
            < 0 => Color.Warning,
            _ => Color.Info
        };

    private static PortfolioTrendDirection? GetTrendDirection(double? value)
        => value switch
        {
            > 0 => PortfolioTrendDirection.Increasing,
            < 0 => PortfolioTrendDirection.Decreasing,
            0 => PortfolioTrendDirection.Stable,
            _ => null
        };

    private static bool HasLifecycleChanged(PortfolioComparisonItemDto? comparisonItem)
        => comparisonItem?.PreviousLifecycleState.HasValue == true
            && comparisonItem.PreviousLifecycleState != comparisonItem.CurrentLifecycleState;

    private static string GetLifecycleChangeText(PortfolioComparisonItemDto comparisonItem)
        => comparisonItem.PreviousLifecycleState is null
            ? "New in snapshot"
            : $"Was {FormatLifecycle(comparisonItem.PreviousLifecycleState)}";

    private static Color GetProgressChangeColor(PortfolioComparisonItemDto comparisonItem)
    {
        if (comparisonItem.ProgressDelta.HasValue)
        {
            return GetTrendColorFromDirection(GetTrendDirection(comparisonItem.ProgressDelta));
        }

        return comparisonItem.PreviousProgress is null ? Color.Info : Color.Default;
    }

    private static string GetProgressChangeText(PortfolioComparisonItemDto comparisonItem)
    {
        if (!comparisonItem.ProgressDelta.HasValue)
        {
            return comparisonItem.PreviousProgress is null ? "New" : "—";
        }

        var direction = GetTrendDirection(comparisonItem.ProgressDelta);
        return comparisonItem.ProgressDelta.Value == 0
            ? "→ stable"
            : $"{GetTrendGlyph(direction)} {FormatSignedRatio(comparisonItem.ProgressDelta)}";
    }

    private static string? NullIfWhiteSpace(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
}
