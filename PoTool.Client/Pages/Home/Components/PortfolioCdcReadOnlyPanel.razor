@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Shared.Metrics
@inject IMetricsClient MetricsClient
@inject IProfileService ProfileService
@inject ProductService ProductService

<MudPaper Elevation="2" Class="pa-4 mt-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h6">
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Class="mr-2" />
                CDC Portfolio History View
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Read-only progress, history, lifecycle, and decision signals from persisted CDC snapshots.
            </MudText>
        </MudStack>

        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAsync">
            Refresh
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-3">@_errorMessage</MudAlert>
    }
    else
    {
        <MudGrid Class="mb-3">
            <MudItem xs="12" md="3">
                <MudSelect T="int?"
                           Label="Product"
                           Value="_productId"
                           ValueChanged="OnProductChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField T="string"
                              Label="Project"
                              Value="_projectNumber"
                              ValueChanged="OnProjectChangedAsync"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudTextField T="string"
                              Label="Work Package"
                              Value="_workPackage"
                              ValueChanged="OnWorkPackageChangedAsync"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="PortfolioLifecycleState?"
                           Label="Lifecycle"
                           Value="_lifecycleState"
                           ValueChanged="OnLifecycleChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@((PortfolioLifecycleState?)null)">All</MudSelectItem>
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@PortfolioLifecycleState.Active">Active</MudSelectItem>
                    <MudSelectItem T="PortfolioLifecycleState?" Value="@PortfolioLifecycleState.Retired">Retired</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="1">
                <MudSelect T="PortfolioReadSortBy"
                           Label="Sort"
                           Value="_sortBy"
                           ValueChanged="OnSortChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Default">Default</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Progress">Progress</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Weight">Weight</MudSelectItem>
                    <MudSelectItem T="PortfolioReadSortBy" Value="@PortfolioReadSortBy.Delta">Delta</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="1">
                <MudSelect T="PortfolioReadGroupBy"
                           Label="Group"
                           Value="_groupBy"
                           ValueChanged="OnGroupChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.None">None</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.Product">Product</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.Project">Project</MudSelectItem>
                    <MudSelectItem T="PortfolioReadGroupBy" Value="@PortfolioReadGroupBy.WorkPackage">Package</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int"
                           Label="History"
                           Value="_snapshotCount"
                           ValueChanged="OnSnapshotCountChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true">
                    <MudSelectItem T="int" Value="3">Last 3</MudSelectItem>
                    <MudSelectItem T="int" Value="6">Last 6</MudSelectItem>
                    <MudSelectItem T="int" Value="10">Last 10</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="long?"
                           Label="Compare to"
                           Value="_compareToSnapshotId"
                           ValueChanged="OnCompareToSnapshotChangedAsync"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Clearable="true">
                    <MudSelectItem T="long?" Value="@((long?)null)">Previous snapshot</MudSelectItem>
                    @if (_trend?.Snapshots is not null)
                    {
                        foreach (var historicalSnapshot in _trend.Snapshots.Skip(1))
                        {
                            <MudSelectItem T="long?" Value="@historicalSnapshot.SnapshotId">
                                @($"{historicalSnapshot.SnapshotLabel} ({historicalSnapshot.Timestamp:yyyy-MM-dd})")
                            </MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2" Class="d-flex align-center">
                <MudCheckBox T="bool"
                             Label="Include archived history"
                             Value="_includeArchivedSnapshots"
                             ValueChanged="OnIncludeArchivedChangedAsync"
                             Dense="true"
                             Color="Color.Primary" />
            </MudItem>
        </MudGrid>

        @if (_progress?.HasData == true)
        {
            <MudPaper Outlined="true" Class="pa-4 mb-4">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Portfolio summary</MudText>
                    <MudText Typo="Typo.h6">@_progress.SnapshotLabel</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.h4">Progress: @FormatPercent(_progress.PortfolioProgress)</MudText>
                        @if (GetPortfolioProgressDelta() is double portfolioDelta)
                        {
                            <MudChip T="string" Size="Size.Small" Color="@GetTrendColorFromValue(portfolioDelta)" Variant="Variant.Text">
                                @FormatDeltaWithDirection(portfolioDelta)
                            </MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total weight: @FormatNumber(_progress.TotalWeight)</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@GetPortfolioDeltaContext()</MudText>
                    @if (!string.IsNullOrWhiteSpace(GetArchivedHistorySummary()))
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@GetArchivedHistorySummary()</MudText>
                    }
                </MudStack>
            </MudPaper>
        }

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Decision signal</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                One dominant signal first, with the rest collapsed into a single summary line.
            </MudText>
        </MudStack>
        @if (GetPrimarySignalDisplay() is { } primarySignal)
        {
            <MudAlert Severity="@primarySignal.Severity" Variant="Variant.Filled" Class="mb-2">
                <MudText Typo="Typo.h6">@primarySignal.Title</MudText>
                <MudText Typo="Typo.body1">@primarySignal.Summary</MudText>
            </MudAlert>

            @if (!string.IsNullOrWhiteSpace(GetSecondarySignalSummary()))
            {
                <MudPaper Outlined="true" Class="pa-2 mb-4">
                    <MudText Typo="Typo.body2">
                        <strong>Secondary signals:</strong> @GetSecondarySignalSummary()
                    </MudText>
                </MudPaper>
            }
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                <MudText Typo="Typo.subtitle2">No dominant signal in the selected history.</MudText>
                <MudText Typo="Typo.body2">Persisted CDC history is available, but no priority signal stands out for immediate action.</MudText>
            </MudAlert>
        }

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Trend Overview</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Snapshot trend, delta, and direction are aligned for quick scanning.
            </MudText>
        </MudStack>
        @if (GetTrendOverviewRows() is { Count: > 0 } trendOverviewRows)
        {
            <MudTable T="TrendOverviewRow" Items="trendOverviewRows" Dense="true" Hover="true" Class="mb-4">
                <HeaderContent>
                    <MudTh>Snapshot</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Progress</MudTh>
                    <MudTh>Δ</MudTh>
                    <MudTh>Direction</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Snapshot">
                        <MudText Typo="Typo.body2">@context.SnapshotLabel</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.IncludesArchivedSnapshot ? "Includes archived" : "Active-only")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Date">@context.Timestamp.ToString("yyyy-MM-dd")</MudTd>
                    <MudTd DataLabel="Progress">@FormatRatio(context.Progress)</MudTd>
                    <MudTd DataLabel="Δ">@FormatSignedRatio(context.Delta)</MudTd>
                    <MudTd DataLabel="Direction">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(context.Direction)">
                            @GetTrendGlyph(context.Direction)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-4">No persisted history is available for the selected scope.</MudText>
        }

        <MudStack Spacing="0" Class="mb-2">
            <MudText Typo="Typo.subtitle1">Changed Work Packages</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Rows with progress, lifecycle, or weight changes are shown first.
            </MudText>
        </MudStack>
        @if (GetChangedWorkPackageItems() is { Count: > 0 } changedWorkPackages)
        {
            <MudTable T="PortfolioComparisonItemDto" Items="changedWorkPackages" Dense="true" Hover="true" Class="mb-4">
                <HeaderContent>
                    <MudTh>Product</MudTh>
                    <MudTh>Project</MudTh>
                    <MudTh>Work Package</MudTh>
                    <MudTh>Progress</MudTh>
                    <MudTh>Lifecycle</MudTh>
                    <MudTh>Weight Δ</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Product">@context.ProductName</MudTd>
                    <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                    <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                    <MudTd DataLabel="Progress">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2">@FormatRatio(context.CurrentProgress)</MudText>
                            @if (context.ProgressDelta.HasValue)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(GetTrendDirection(context.ProgressDelta))">
                                    @FormatDeltaWithDirection(context.ProgressDelta)
                                </MudChip>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Lifecycle">
                        <MudStack Spacing="1">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetLifecycleBadgeColor(context.CurrentLifecycleState)">
                                @FormatLifecycle(context.CurrentLifecycleState)
                            </MudChip>
                            @if (HasLifecycleDelta(context))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@GetLifecycleTransitionText(context)</MudText>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Weight Δ">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(GetTrendDirection(context.WeightDelta))">
                            @FormatSignedNumber(context.WeightDelta)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudText Typo="Typo.body2" Class="mb-4">No changed work packages detected for the selected comparison baseline.</MudText>
        }

        <MudExpansionPanels MultiExpansion="true" Elevation="0" Class="mb-4">
            <MudExpansionPanel Dense="true">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.subtitle2">Stable Work Packages</MudText>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                            @GetStableWorkPackageItems().Count
                        </MudChip>
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    @if (GetStableWorkPackageItems() is { Count: > 0 } stableWorkPackages)
                    {
                        <MudTable T="PortfolioSnapshotItemDto" Items="stableWorkPackages" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Product</MudTh>
                                <MudTh>Project</MudTh>
                                <MudTh>Work Package</MudTh>
                                <MudTh>Progress</MudTh>
                                <MudTh>Lifecycle</MudTh>
                                <MudTh>Weight</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Product">@context.ProductName</MudTd>
                                <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                                <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                                <MudTd DataLabel="Progress">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2">@FormatRatio(context.Progress)</MudText>
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">@GetStableIndicatorText()</MudChip>
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Lifecycle">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetLifecycleBadgeColor(context.LifecycleState)">
                                        @context.LifecycleState
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Weight">@($"{context.Weight:F1}")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No stable work packages are available for the selected comparison baseline.</MudText>
                    }
                </ChildContent>
            </MudExpansionPanel>

            <MudExpansionPanel Dense="true">
                <TitleContent>
                    <MudText Typo="Typo.subtitle2">Project trends</MudText>
                </TitleContent>
                <ChildContent>
                    @if (GetVisibleProjectTrends() is { Count: > 0 } projectTrends)
                    {
                        <MudTable T="PortfolioScopedTrendDto" Items="projectTrends" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Product</MudTh>
                                <MudTh>Project</MudTh>
                                <MudTh>Progress</MudTh>
                                <MudTh>Δ</MudTh>
                                <MudTh>Direction</MudTh>
                                <MudTh>Weight Δ</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Product">@context.ProductName</MudTd>
                                <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                                <MudTd DataLabel="Progress">@FormatRatio(context.ProgressTrend.CurrentValue)</MudTd>
                                <MudTd DataLabel="Δ">@FormatSignedRatio(context.ProgressTrend.Delta)</MudTd>
                                <MudTd DataLabel="Direction">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetTrendColorFromDirection(context.ProgressTrend.Direction)">
                                        @GetTrendGlyph(context.ProgressTrend.Direction)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="Weight Δ">@FormatSignedNumber(context.WeightTrend.Delta)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No project-level changes detected in selected history.</MudText>
                    }
                </ChildContent>
            </MudExpansionPanel>

            <MudExpansionPanel Dense="true">
                <TitleContent>
                    <MudText Typo="Typo.subtitle2">Current snapshot</MudText>
                </TitleContent>
                <ChildContent>
                    @if (_snapshot?.HasData == true)
                    {
                        <MudTable T="PortfolioSnapshotItemDto" Items="_snapshot.Items" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Product</MudTh>
                                <MudTh>Project</MudTh>
                                <MudTh>Work Package</MudTh>
                                <MudTh>Progress</MudTh>
                                <MudTh>Lifecycle</MudTh>
                                <MudTh>Weight</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                @{
                                    var comparisonItem = FindComparisonItem(context);
                                }
                                <MudTd DataLabel="Product">@context.ProductName</MudTd>
                                <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                                <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                                <MudTd DataLabel="Progress">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudText Typo="Typo.body2">@FormatRatio(context.Progress)</MudText>
                                        @if (comparisonItem is not null && HasProgressOrWeightChange(comparisonItem))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="@GetProgressChangeColor(comparisonItem)">
                                                @GetProgressChangeText(comparisonItem)
                                            </MudChip>
                                        }
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Lifecycle">
                                    <MudStack Spacing="1">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetLifecycleBadgeColor(context.LifecycleState)">
                                            @context.LifecycleState
                                        </MudChip>
                                        @if (comparisonItem is not null && HasLifecycleDelta(comparisonItem))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetLifecycleTransitionText(comparisonItem)</MudText>
                                        }
                                    </MudStack>
                                </MudTd>
                                <MudTd DataLabel="Weight">@($"{context.Weight:F1}")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No snapshot rows available.</MudText>
                    }
                </ChildContent>
            </MudExpansionPanel>

            <MudExpansionPanel Dense="true">
                <TitleContent>
                    <MudText Typo="Typo.subtitle2">Snapshot comparison</MudText>
                </TitleContent>
                <ChildContent>
                    @if (GetChangedComparisonItems() is { Count: > 0 } changedComparisonItems)
                    {
                        <MudTable T="PortfolioComparisonItemDto" Items="changedComparisonItems" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Product</MudTh>
                                <MudTh>Project</MudTh>
                                <MudTh>Work Package</MudTh>
                                <MudTh>Previous</MudTh>
                                <MudTh>Current</MudTh>
                                <MudTh>Δ Progress</MudTh>
                                <MudTh>Δ Weight</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="Product">@context.ProductName</MudTd>
                                <MudTd DataLabel="Project">@context.ProjectNumber</MudTd>
                                <MudTd DataLabel="Work Package">@(context.WorkPackage ?? "—")</MudTd>
                                <MudTd DataLabel="Previous">@($"{FormatLifecycle(context.PreviousLifecycleState)} / {FormatRatio(context.PreviousProgress)}")</MudTd>
                                <MudTd DataLabel="Current">@($"{FormatLifecycle(context.CurrentLifecycleState)} / {FormatRatio(context.CurrentProgress)}")</MudTd>
                                <MudTd DataLabel="Δ Progress">@FormatSignedRatio(context.ProgressDelta)</MudTd>
                                <MudTd DataLabel="Δ Weight">@FormatSignedNumber(context.WeightDelta)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2">No changed comparison rows available.</MudText>
                    }
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>
    }
</MudPaper>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private int? _profileId;
    private int? _productId;
    private string? _projectNumber;
    private string? _workPackage;
    private PortfolioLifecycleState? _lifecycleState;
    private PortfolioReadSortBy _sortBy = PortfolioReadSortBy.Default;
    private PortfolioReadGroupBy _groupBy = PortfolioReadGroupBy.None;
    private readonly PortfolioReadSortDirection _sortDirection = PortfolioReadSortDirection.Desc;
    private int _snapshotCount = 6;
    private bool _includeArchivedSnapshots;
    private long? _compareToSnapshotId;
    private IReadOnlyList<ProductDto> _products = Array.Empty<ProductDto>();
    private PortfolioProgressDto? _progress;
    private PortfolioSnapshotDto? _snapshot;
    private PortfolioComparisonDto? _comparison;
    private PortfolioTrendDto? _trend;
    private IReadOnlyList<PortfolioDecisionSignalDto> _signals = Array.Empty<PortfolioDecisionSignalDto>();

    private sealed record PrimarySignalDisplay(
        string Title,
        string Summary,
        Severity Severity);

    private sealed record TrendOverviewRow(
        string SnapshotLabel,
        DateTimeOffset Timestamp,
        double? Progress,
        double? Delta,
        PortfolioTrendDirection? Direction,
        bool IncludesArchivedSnapshot);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile is null)
            {
                _errorMessage = "Select an active profile to load portfolio snapshot data.";
                return;
            }

            _profileId = activeProfile.Id;
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();

            _progress = await MetricsClient.GetPortfolioProgressAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy);
            _snapshot = await MetricsClient.GetPortfolioSnapshotsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy);
            _comparison = await MetricsClient.GetPortfolioComparisonAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots,
                _compareToSnapshotId);
            _trend = await MetricsClient.GetPortfolioTrendsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                _snapshotCount,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots);
            _signals = await MetricsClient.GetPortfolioSignalsAsync(
                activeProfile.Id,
                _productId,
                NullIfWhiteSpace(_projectNumber),
                NullIfWhiteSpace(_workPackage),
                _lifecycleState,
                _sortBy,
                _sortDirection,
                _groupBy,
                _snapshotCount,
                rangeStartUtc: null,
                rangeEndUtc: null,
                _includeArchivedSnapshots,
                _compareToSnapshotId);

            if (_compareToSnapshotId.HasValue
                && _trend?.Snapshots.All(snapshot => snapshot.SnapshotId != _compareToSnapshotId.Value) == true)
            {
                _compareToSnapshotId = null;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Unable to load CDC portfolio data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

