    private static string FormatPercent(double? value)
        => value.HasValue ? $"{value.Value:F0}%" : "—";

    private static string FormatRatio(double? value)
        => value.HasValue ? $"{value.Value:P0}" : "—";

    private static string FormatNumber(double? value)
        => value.HasValue ? $"{value.Value:F1}" : "—";

    private static string FormatSignedRatio(double? value)
        => value.HasValue ? $"{value.Value:+0%;-0%;0%}" : "—";

    private static string FormatSignedNumber(double? value)
        => value.HasValue ? $"{value.Value:+0.0;-0.0;0.0}" : "—";

    private static string FormatDirection(PortfolioTrendDirection? value)
        => value?.ToString() ?? "—";

    private static string FormatLifecycle(PortfolioLifecycleState? value)
        => value?.ToString() ?? "—";

    private static string FormatDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToString("yyyy-MM-dd") : "—";

    private double? GetPortfolioProgressDelta()
        => _comparison?.PreviousTimestamp is null ? null : _trend?.PortfolioProgressTrend.Delta;

    private string GetPortfolioDeltaContext()
        => _comparison?.PreviousSnapshotLabel is null
            ? $"Snapshot date: {_progress?.SnapshotTimestamp:yyyy-MM-dd}"
            : $"Vs {_comparison.PreviousSnapshotLabel} · {FormatDate(_comparison.PreviousTimestamp)}";

    private string? GetArchivedHistorySummary()
    {
        if (_trend?.ArchivedSnapshotsExcludedNotice == true && !_includeArchivedSnapshots)
        {
            return "Archived snapshots exist in the selected history window and remain excluded.";
        }

        if (_trend?.IncludesArchivedSnapshots == true)
        {
            return "Historical trends currently include archived persisted snapshots.";
        }

        return null;
    }

    private PrimarySignalDisplay? GetPrimarySignalDisplay()
    {
        var primarySignal = _signals
            .OrderBy(GetSignalPriority)
            .ThenBy(signal => signal.Title, StringComparer.Ordinal)
            .FirstOrDefault();

        return primarySignal is null
            ? null
            : new PrimarySignalDisplay(primarySignal.Title, primarySignal.Description, GetSignalSeverity(primarySignal.Tone));
    }

    private string GetSecondarySignalSummary()
    {
        var primarySignal = _signals
            .OrderBy(GetSignalPriority)
            .ThenBy(signal => signal.Title, StringComparer.Ordinal)
            .FirstOrDefault();

        var secondarySignals = _signals
            .Where(signal => !ReferenceEquals(signal, primarySignal))
            .ToArray();

        var summaryParts = new List<string>();

        var repeatedNoChangeSummary = BuildRepeatedNoChangeSummary(secondarySignals);
        if (!string.IsNullOrWhiteSpace(repeatedNoChangeSummary))
        {
            summaryParts.Add(repeatedNoChangeSummary);
        }

        var lifecycleCount = secondarySignals.Count(signal => signal.Type is PortfolioDecisionSignalType.NewWorkPackage or PortfolioDecisionSignalType.RetiredWorkPackage);
        if (lifecycleCount > 0)
        {
            summaryParts.Add($"{lifecycleCount} lifecycle update{(lifecycleCount == 1 ? string.Empty : "s")}");
        }

        var improvingCount = secondarySignals.Count(signal => signal.Tone == PortfolioDecisionSignalTone.Positive);
        if (improvingCount > 0)
        {
            summaryParts.Add($"{improvingCount} improving signal{(improvingCount == 1 ? string.Empty : "s")}");
        }

        var regressionCount = secondarySignals.Count(signal => signal.Tone == PortfolioDecisionSignalTone.Warning);
        if (regressionCount > 0)
        {
            summaryParts.Add($"{regressionCount} regression signal{(regressionCount == 1 ? string.Empty : "s")}");
        }

        var noticeCount = secondarySignals.Count(signal => signal.Type == PortfolioDecisionSignalType.ArchivedSnapshotExcludedNotice);
        if (noticeCount > 0)
        {
            summaryParts.Add($"{noticeCount} history notice{(noticeCount == 1 ? string.Empty : "s")}");
        }

        return string.Join(" · ", summaryParts);
    }

    private IReadOnlyList<TrendOverviewRow> GetTrendOverviewRows()
    {
        var snapshots = _trend?.Snapshots ?? Array.Empty<PortfolioHistoricalSnapshotDto>();
        if (snapshots.Count == 0)
        {
            return Array.Empty<TrendOverviewRow>();
        }

        var rows = new List<TrendOverviewRow>(snapshots.Count);
        for (var index = 0; index < snapshots.Count; index++)
        {
            var snapshot = snapshots[index];
            var progress = FindPointValue(_trend!.PortfolioProgressTrend.Points, snapshot.SnapshotId);
            var nextSnapshot = index + 1 < snapshots.Count ? snapshots[index + 1] : null;
            var nextProgress = nextSnapshot is null
                ? null
                : FindPointValue(_trend.PortfolioProgressTrend.Points, nextSnapshot.SnapshotId);
            double? delta = progress.HasValue && nextProgress.HasValue ? progress.Value - nextProgress.Value : null;

            rows.Add(new TrendOverviewRow(
                snapshot.SnapshotLabel,
                snapshot.Timestamp,
                progress,
                delta,
                GetTrendDirection(delta),
                snapshot.IncludesArchivedSnapshot));
        }

        return rows;
    }

    private IReadOnlyList<PortfolioScopedTrendDto> GetVisibleProjectTrends()
        => (_trend?.Projects ?? Array.Empty<PortfolioScopedTrendDto>())
            .Where(HasScopedTrendData)
            .ToArray();

    private IReadOnlyList<PortfolioComparisonItemDto> GetChangedWorkPackageItems()
        => (_comparison?.Items ?? Array.Empty<PortfolioComparisonItemDto>())
            .Where(item => item.WorkPackage is not null && IsComparisonItemChanged(item))
            .ToArray();

    private IReadOnlyList<PortfolioSnapshotItemDto> GetStableWorkPackageItems()
        => (_snapshot?.Items ?? Array.Empty<PortfolioSnapshotItemDto>())
            .Where(item => item.WorkPackage is not null)
            .Where(item =>
            {
                var comparisonItem = FindComparisonItem(item);
                return comparisonItem is not null && !IsComparisonItemChanged(comparisonItem);
            })
            .ToArray();

    private IReadOnlyList<PortfolioComparisonItemDto> GetChangedComparisonItems()
        => (_comparison?.Items ?? Array.Empty<PortfolioComparisonItemDto>())
            .Where(IsComparisonItemChanged)
            .ToArray();

    private static double? FindPointValue(IReadOnlyList<PortfolioTrendPointDto> points, long snapshotId)
        => points.FirstOrDefault(point => point.SnapshotId == snapshotId)?.Value;

    private PortfolioComparisonItemDto? FindComparisonItem(PortfolioSnapshotItemDto item)
        => _comparison?.Items.FirstOrDefault(comparisonItem =>
            comparisonItem.ProductId == item.ProductId
            && string.Equals(comparisonItem.ProjectNumber, item.ProjectNumber, StringComparison.Ordinal)
            && string.Equals(comparisonItem.WorkPackage ?? string.Empty, item.WorkPackage ?? string.Empty, StringComparison.Ordinal));

    private static Severity GetSignalSeverity(PortfolioDecisionSignalTone tone)
        => tone switch
        {
            PortfolioDecisionSignalTone.Positive => Severity.Success,
            PortfolioDecisionSignalTone.Warning => Severity.Warning,
            _ => Severity.Info
        };

    private static int GetSignalPriority(PortfolioDecisionSignalDto signal)
        => signal.Type switch
        {
            PortfolioDecisionSignalType.ProgressDeclining => 0,
            PortfolioDecisionSignalType.WeightIncreasing => 1,
            PortfolioDecisionSignalType.ProgressImproving => 2,
            PortfolioDecisionSignalType.WeightDecreasing => 3,
            PortfolioDecisionSignalType.NewWorkPackage => 4,
            PortfolioDecisionSignalType.RetiredWorkPackage => 5,
            PortfolioDecisionSignalType.RepeatedNoChange => 6,
            PortfolioDecisionSignalType.ArchivedSnapshotExcludedNotice => 7,
            _ => 8
        };

    private static string BuildRepeatedNoChangeSummary(IEnumerable<PortfolioDecisionSignalDto> signals)
    {
        var repeatedSignals = signals
            .Where(signal => signal.Type == PortfolioDecisionSignalType.RepeatedNoChange)
            .ToArray();

        if (repeatedSignals.Length == 0)
        {
            return string.Empty;
        }

        var workPackageCount = repeatedSignals.Count(signal => !string.IsNullOrWhiteSpace(signal.WorkPackage));
        var projectCount = repeatedSignals.Length - workPackageCount;
        var summaryParts = new List<string>();

        if (workPackageCount > 0)
        {
            summaryParts.Add($"{workPackageCount} work package{(workPackageCount == 1 ? string.Empty : "s")}");
        }

        if (projectCount > 0)
        {
            summaryParts.Add($"{projectCount} project{(projectCount == 1 ? string.Empty : "s")}");
        }

        return $"No change ({string.Join(", ", summaryParts)})";
    }

    private static bool HasScopedTrendData(PortfolioScopedTrendDto trend)
        => trend.CurrentLifecycleState is not null
           || trend.PreviousLifecycleState is not null
           || trend.ProgressTrend.CurrentValue.HasValue
           || trend.ProgressTrend.PreviousValue.HasValue
           || trend.ProgressTrend.Delta.HasValue
           || trend.ProgressTrend.Direction.HasValue
           || trend.WeightTrend.CurrentValue.HasValue
           || trend.WeightTrend.PreviousValue.HasValue
           || trend.WeightTrend.Delta.HasValue
           || trend.WeightTrend.Direction.HasValue;

    private static string GetTrendGlyph(PortfolioTrendDirection? direction)
        => direction switch
        {
            PortfolioTrendDirection.Increasing => "↑",
            PortfolioTrendDirection.Decreasing => "↓",
            PortfolioTrendDirection.Stable => "→",
            _ => "—"
        };

    private static string FormatDeltaWithDirection(double? value)
        => value.HasValue
            ? $"{FormatSignedRatio(value)} {GetTrendGlyph(GetTrendDirection(value))}"
            : "—";

    private static Color GetTrendColorFromDirection(PortfolioTrendDirection? direction)
        => direction switch
        {
            PortfolioTrendDirection.Increasing => Color.Success,
            PortfolioTrendDirection.Decreasing => Color.Warning,
            PortfolioTrendDirection.Stable => Color.Info,
            _ => Color.Default
        };

    private static Color GetTrendColorFromValue(double value)
        => value switch
        {
            > 0 => Color.Success,
            < 0 => Color.Warning,
            _ => Color.Info
        };

    private static PortfolioTrendDirection? GetTrendDirection(double? value)
        => value switch
        {
            > 0 => PortfolioTrendDirection.Increasing,
            < 0 => PortfolioTrendDirection.Decreasing,
            0 => PortfolioTrendDirection.Stable,
            _ => null
        };

    private static bool IsComparisonItemChanged(PortfolioComparisonItemDto comparisonItem)
        => HasProgressOrWeightChange(comparisonItem)
           || HasLifecycleDelta(comparisonItem);

    private static bool HasProgressOrWeightChange(PortfolioComparisonItemDto comparisonItem)
        => HasNonZeroValue(comparisonItem.ProgressDelta)
           || HasNonZeroValue(comparisonItem.WeightDelta);

    private static bool HasLifecycleDelta(PortfolioComparisonItemDto comparisonItem)
        => comparisonItem.PreviousLifecycleState != comparisonItem.CurrentLifecycleState;

    private static bool HasNonZeroValue(double? value)
        => value.HasValue && Math.Abs(value.Value) > double.Epsilon;

    private static string GetLifecycleTransitionText(PortfolioComparisonItemDto comparisonItem)
        => comparisonItem.PreviousLifecycleState is null
            ? "Changed in latest snapshot"
            : $"Was {FormatLifecycle(comparisonItem.PreviousLifecycleState)}";

    private static Color GetLifecycleBadgeColor(PortfolioLifecycleState? lifecycleState)
        => lifecycleState == PortfolioLifecycleState.Retired
            ? Color.Warning
            : Color.Success;

    private static Color GetProgressChangeColor(PortfolioComparisonItemDto comparisonItem)
    {
        if (comparisonItem.ProgressDelta.HasValue)
        {
            return GetTrendColorFromDirection(GetTrendDirection(comparisonItem.ProgressDelta));
        }

        if (comparisonItem.WeightDelta.HasValue)
        {
            return GetTrendColorFromDirection(GetTrendDirection(comparisonItem.WeightDelta));
        }

        return HasLifecycleDelta(comparisonItem) ? Color.Warning : Color.Default;
    }

    private static string GetProgressChangeText(PortfolioComparisonItemDto comparisonItem)
    {
        if (comparisonItem.ProgressDelta.HasValue)
        {
            return FormatDeltaWithDirection(comparisonItem.ProgressDelta);
        }

        if (comparisonItem.WeightDelta.HasValue)
        {
            return $"{FormatSignedNumber(comparisonItem.WeightDelta)} {GetTrendGlyph(GetTrendDirection(comparisonItem.WeightDelta))}";
        }

        return "Changed";
    }

    private static string GetStableIndicatorText()
        => "0% →";

    private static string? NullIfWhiteSpace(string? value)
        => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
}
