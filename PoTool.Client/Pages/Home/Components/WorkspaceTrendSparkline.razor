@using PoTool.Shared.Metrics
@namespace PoTool.Client.Pages.Home.Components

@if (Trend is { Points.Count: >= 2 })
{
    <svg class="workspace-trend-sparkline"
         viewBox="0 0 80 14"
         preserveAspectRatio="none"
         aria-hidden="true">
        <polyline points="@GetSparklinePoints(Trend)"
                  class="@GetSparklineClass(Trend)"
                  fill="none"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
    </svg>
}

@code {
    [Parameter]
    public WorkspaceTrend? Trend { get; set; }

    private static string GetSparklineClass(WorkspaceTrend trendInfo)
    {
        return trendInfo.IsDeteriorating
            ? "workspace-trend-sparkline__line workspace-trend-sparkline__line--warn"
            : "workspace-trend-sparkline__line";
    }

    private static string GetSparklinePoints(WorkspaceTrend trendInfo)
    {
        const int width = 80;
        const int height = 14;
        const int padding = 1;

        var data = trendInfo.Points;
        var min = data.Min();
        var max = data.Max();
        var range = max - min;

        var sb = new System.Text.StringBuilder();
        for (var i = 0; i < data.Count; i++)
        {
            var x = (double)i / (data.Count - 1) * width;
            var y = range == 0
                ? height / 2.0
                : (height - padding) - (data[i] - min) / range * (height - padding * 2);

            if (i > 0)
            {
                sb.Append(' ');
            }

            sb.Append(FormattableString.Invariant($"{x:F1},{y:F1}"));
        }

        return sb.ToString();
    }
}
