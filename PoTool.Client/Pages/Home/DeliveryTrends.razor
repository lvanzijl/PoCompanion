@page "/home/trends/delivery"
@using PoTool.Client.Components.Analytical
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Shared.Metrics
@using System.Web
@inject IProfileService ProfileService
@inject MetricsStateService MetricsStateService
@inject ProductService ProductService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject GlobalFilterStore GlobalFilterStore
@inject PageFilterExecutionGate PageFilterExecutionGate
@inject GlobalFilterRouteService GlobalFilterRouteService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Delivery Trends - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Delivery Trends</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Back to Trends
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <TrendDataStateView TData="SprintQueryResponseDto<GetSprintTrendMetricsResponse>"
                        State="@_dataState"
                        IsLoading="@_isLoading"
                        FilterNotice="@_filterNotice"
                        ProductOwnerId="@_profileId"
                        Subject="Delivery trends"
                        InvalidMessage="Adjust the selected team or sprint range to load delivery trends."
                        FailedMessage="The delivery trends request failed."
                        NotReadyMessage="Delivery trends will load once the cache is ready."
                        OnRecovery="@LoadDataAsync">
        <NotRequestedContent>
            @if (_filteredSprints.Count == 0)
            {
                <MudAlert Severity="Severity.Info">No sprints found. Ensure sprint data has been synced.</MudAlert>
            }
            else if (_currentSprint == null)
            {
                <MudAlert Severity="Severity.Info">No sprint selected.</MudAlert>
            }
        </NotRequestedContent>
        <ChildContent Context="_">
        @* Canonical range projection *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                    Trend window
                </MudText>

                <MudGrid Spacing="2">
                    @if (_filteredSprints.Count > 0)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudSelect T="int"
                                       Label="End sprint"
                                       Value="@(_currentSprint?.Id ?? 0)"
                                       ValueChanged="OnEndSprintChanged"
                                       Variant="Variant.Outlined"
                                       FullWidth="true">
                                @foreach (var sprint in _filteredSprints)
                                {
                                    <MudSelectItem Value="@sprint.Id">@sprint.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>

                        <MudItem xs="12" sm="6" md="3">
                            <MudNumericField T="int"
                                             Label="Sprints to show"
                                             Value="@CurrentTrendSprintCount"
                                             ValueChanged="OnTrendSprintCountChanged"
                                             Min="2"
                                             Max="@MaxAvailableSprints"
                                             Variant="Variant.Outlined"
                                             FullWidth="true" />
                        </MudItem>
                    }
                </MudGrid>

                @if (_filteredSprints.Count > 0 && _currentSprint != null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Projection over canonical inclusive range: @GetTrendRangeLabel()
                    </MudText>
                }
            </MudStack>
        </MudPaper>

        @if (_metricsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Success" Class="mb-2" />
        }

        @if (_trendMetrics.Count > 0)
        {
            @* Chart Layout (Primary Visualization Pattern) *@
            <AnalyticalPageLayout>

                @* Row 1 — Primary Visualization: PBI Throughput Trend (full width, dominant) *@
                <PrimaryVisualizationSection>
                    <MudStack Spacing="0" Class="mb-2">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.subtitle2">PBI Throughput Trend</MudText>
                            <TrendSlopeBadge StartValue="@_pbiThroughputStart"
                                             EndValue="@_pbiThroughputEnd"
                                             LowerIsBetter="false"
                                             MetricLabel="completed PBIs" />
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Completed PBIs per sprint — delivery capacity; higher is better
                        </MudText>
                    </MudStack>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_pbiThroughputSeries"
                              XAxisLabels="@_trendXAxisLabels"
                              Width="100%"
                              Height="340px"
                              ChartOptions="@_chartOptions" />
                </PrimaryVisualizationSection>

                @* Row 2 — Secondary Visualizations: 3 equal columns *@
                <SecondaryVisualizationGrid Columns="3">

                    @* Cell 1 — Story Point Delivery Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Story Point Delivery Trend</MudText>
                                <TrendSlopeBadge StartValue="@_effortThroughputStart"
                                                 EndValue="@_effortThroughputEnd"
                                                 LowerIsBetter="false"
                                                 MetricLabel="story points" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Story points delivered per sprint; higher is better
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_effortThroughputSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                    @* Cell 2 — Progress Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Progress Trend</MudText>
                                <TrendSlopeBadge StartValue="@_progressStart"
                                                 EndValue="@_progressEnd"
                                                 LowerIsBetter="false"
                                                 MetricLabel="completion rate" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Completed effort as % of planned effort per sprint; higher is better
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_progressSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                    @* Cell 3 — Bug Trend *@
                    <MudPaper Elevation="2" Class="pa-3 analytical-secondary-cell">
                        <MudStack Spacing="0" Class="mb-2">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.subtitle2">Bug Trend</MudText>
                                <TrendSlopeBadge StartValue="@_bugsCreatedStart"
                                                 EndValue="@_bugsCreatedEnd"
                                                 LowerIsBetter="true"
                                                 MetricLabel="bugs created" />
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Bugs created vs closed per sprint; fewer created is better
                            </MudText>
                        </MudStack>
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_bugTrendSeries"
                                  XAxisLabels="@_trendXAxisLabels"
                                  Width="100%"
                                  Height="260px"
                                  ChartOptions="@_chartOptions" />
                    </MudPaper>

                </SecondaryVisualizationGrid>

            </AnalyticalPageLayout>

            @* Drill-down table *@
            <MudExpansionPanels Class="mt-4">
                <MudExpansionPanel Text="Drill-down — per sprint data" Icon="@Icons.Material.Filled.ExpandMore">
                    <MudSimpleTable Dense="true" Hover="true" Bordered="false">
                        <thead>
                            <tr>
                                <th>Sprint</th>
                                <th>Completed PBIs</th>
                                <th>Completed Effort (hours)</th>
                                <th>Planned Effort (hours)</th>
                                <th>Completion %</th>
                                <th>Bugs Created</th>
                                <th>Bugs Closed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in _trendMetrics)
                            {
                                var completedPbis = GetMetricValue(m, pm => (double)pm.CompletedPbiCount, m.TotalCompletedPbiCount);
                                var completedEffort = GetMetricValue(m, pm => (double)pm.CompletedPbiEffort, m.TotalCompletedPbiEffort);
                                var plannedEffort = (double)m.TotalPlannedEffort;
                                var completionPct = plannedEffort > 0 ? completedEffort / plannedEffort * 100.0 : 0.0;
                                var bugsCreated = GetMetricValue(m, pm => (double)pm.BugsCreatedCount, m.TotalBugsCreatedCount);
                                var bugsClosed = GetMetricValue(m, pm => (double)pm.BugsClosedCount, m.TotalBugsClosedCount);
                                <tr>
                                    <td>@m.SprintName</td>
                                    <td>@((int)completedPbis)</td>
                                    <td>@((int)completedEffort)</td>
                                    <td>@((int)plannedEffort)</td>
                                    <td>@(plannedEffort > 0 ? $"{completionPct:F1}%" : "—")</td>
                                    <td>@((int)bugsCreated)</td>
                                    <td>@((int)bugsClosed)</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
        </ChildContent>
    </TrendDataStateView>
</MudContainer>

@code {
    private const int DefaultTrendSprintCount = 6;

    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Selectors
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    private List<SprintDto> _allSprints = new();
    private List<SprintDto> _filteredSprints = new();
    private SprintDto? _currentSprint;
    private int _currentSprintIndex = -1;

    // Trend data
    private List<SprintTrendMetricsDto> _trendMetrics = new();
    private DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>> _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.NotRequested();
    private CanonicalFilterNoticeModel? _filterNotice;
    private string[] _trendXAxisLabels = Array.Empty<string>();

    // Chart series
    private List<ChartSeries> _pbiThroughputSeries = new();
    private List<ChartSeries> _effortThroughputSeries = new();
    private List<ChartSeries> _progressSeries = new();
    private List<ChartSeries> _bugTrendSeries = new();

    // Slope badge endpoints
    private double? _pbiThroughputStart, _pbiThroughputEnd;
    private double? _effortThroughputStart, _effortThroughputEnd;
    private double? _progressStart, _progressEnd;
    private double? _bugsCreatedStart, _bugsCreatedEnd;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 8,
        YAxisLines = true,
        XAxisLines = true
    };
    private IDisposable? _filterSubscription;
    private int? _selectedTeamId => GlobalFilterStore.GetState().TeamId;
    private int? _selectedProductId => GlobalFilterStore.GetState().PrimaryProductId;
    private int? _selectedFromSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.StartSprintId : null;
    private int? _selectedToSprintId => GlobalFilterStore.GetState().Time.Mode == FilterTimeMode.Range ? GlobalFilterStore.GetState().Time.EndSprintId : null;

    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        await SyncStoreFromCurrentRouteAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _isLoading = true;
            _errorMessage = null;
            _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.NotRequested();
            _filterNotice = null;

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;

            if (_profileId == null)
            {
                _errorMessage = "No active profile selected.";
                return;
            }

            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(_profileId.Value)).ToList();

            _allSprints.Clear();
            foreach (var team in _teams)
            {
                try
                {
                    var teamSprints = (await SprintService.GetSprintsForTeamAsync(team.Id)).ToList();
                    _allSprints.AddRange(teamSprints);
                }
                catch { /* skip teams without sprints */ }
            }

            ApplySprintFilters();
            await LoadMetricsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplySprintFilters()
    {
        var sprints = _allSprints.AsEnumerable();
        if (_selectedTeamId.HasValue)
            sprints = sprints.Where(s => s.TeamId == _selectedTeamId.Value);

        _filteredSprints = sprints
            .Where(s => s.StartUtc.HasValue && s.EndUtc.HasValue)
            .OrderBy(s => s.StartUtc)
            .DistinctBy(s => s.Id)
            .ToList();
    }

    private void SelectDeterministicEndSprint()
    {
        var selectedEndSprintId = _selectedToSprintId ?? _filteredSprints.LastOrDefault()?.Id;
        _currentSprintIndex = selectedEndSprintId.HasValue
            ? _filteredSprints.FindIndex(s => s.Id == selectedEndSprintId.Value)
            : _filteredSprints.Count - 1;
        if (_currentSprintIndex < 0)
        {
            _currentSprintIndex = _filteredSprints.Count - 1;
        }
        _currentSprint = _currentSprintIndex >= 0 ? _filteredSprints[_currentSprintIndex] : null;
    }

    private async Task LoadMetricsAsync()
    {
        _metricsLoading = true;
        _trendMetrics.Clear();
        _trendXAxisLabels = Array.Empty<string>();
        _filterNotice = null;
        StateHasChanged();

        try
        {
            var evaluation = PageFilterExecutionGate.Evaluate(GlobalFilterStore.CurrentUsage);
            if (!evaluation.CanExecuteQueries)
            {
                _dataState = TrendUiStateFactory.InvalidFilter<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>(
                    evaluation,
                    "Select a valid team and sprint range to load delivery trends.");
                return;
            }

            if (!_profileId.HasValue || _currentSprint == null)
            {
                _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.NotRequested();
                return;
            }

            var timeRange = GlobalFilterTrendRequestMapper.ResolveRange(GlobalFilterStore.GetState(), _filteredSprints);
            if (!timeRange.IsResolved || timeRange.SprintIds.Count == 0)
            {
                _dataState = TrendUiStateFactory.InvalidFilter<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>(
                    timeRange.FailureReason ?? "The selected sprint range could not be resolved.",
                    [GlobalFilterValidationMapper.Time]);
                return;
            }

            _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.Loading();
            var response = await MetricsStateService.GetSprintTrendMetricsStateAsync(_profileId.Value, timeRange, _selectedProductId, _selectedTeamId, CancellationToken.None);
            _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.FromResponse(response, "Delivery trends could not be loaded right now.");
            _filterNotice = _dataState.Data is null
                ? null
                : CanonicalClientResponseFactory.CreateNotice(CanonicalClientResponseFactory.Create(_dataState.Data).FilterMetadata);
            if (_dataState.State is DataStateDto.NotReady or DataStateDto.Failed || _dataState.UiState == UiDataState.Invalid)
            {
                _trendMetrics.Clear();
                return;
            }

            if (_dataState.Data?.Data?.Metrics is not null)
            {
                _trendMetrics = _dataState.Data.Data.Metrics
                    .OrderBy(m => m.StartUtc ?? DateTimeOffset.MaxValue)
                    .ToList();

                if (_trendMetrics.Count == 0)
                {
                    _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.Empty("No data for selected period.");
                    return;
                }

                BuildTrendCharts();
            }
        }
        catch (Exception)
        {
            _dataState = DataStateViewModel<SprintQueryResponseDto<GetSprintTrendMetricsResponse>>.Failed("The delivery trends request failed.");
            Snackbar.Add(_dataState.Reason!, Severity.Warning);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }

    private void BuildTrendCharts()
    {
        if (_trendMetrics.Count == 0) return;

        _trendXAxisLabels = _trendMetrics.Select(m => m.SprintName).ToArray();

        // Chart 1: PBI Throughput
        var pbiData = _trendMetrics
            .Select(m => GetMetricValue(m, pm => (double)pm.CompletedPbiCount, m.TotalCompletedPbiCount))
            .ToArray();
        _pbiThroughputSeries = new List<ChartSeries>
        {
            new() { Name = "Completed PBIs", Data = pbiData }
        };
        (_pbiThroughputStart, _pbiThroughputEnd) = FirstLastNonZero(pbiData);

        // Chart 2: Effort Throughput
        var effortData = _trendMetrics
            .Select(m => GetMetricValue(m, pm => pm.CompletedPbiStoryPoints, m.TotalCompletedPbiStoryPoints))
            .ToArray();
        _effortThroughputSeries = new List<ChartSeries>
        {
            new() { Name = "Delivered Story Points", Data = effortData }
        };
        (_effortThroughputStart, _effortThroughputEnd) = FirstLastNonZero(effortData);

        // Chart 3: Progress Trend — completion rate (%)
        var progressData = _trendMetrics
            .Select(m =>
            {
                var completed = GetMetricValue(m, pm => (double)pm.CompletedPbiEffort, m.TotalCompletedPbiEffort);
                var planned = (double)m.TotalPlannedEffort;
                return planned > 0 ? completed / planned * 100.0 : 0.0;
            })
            .ToArray();
        _progressSeries = new List<ChartSeries>
        {
            new() { Name = "Completion Rate (%)", Data = progressData }
        };
        (_progressStart, _progressEnd) = FirstLastNonZero(progressData);

        // Chart 4: Bug Trend — Created vs Closed
        var bugsCreatedData = _trendMetrics
            .Select(m => GetMetricValue(m, pm => (double)pm.BugsCreatedCount, m.TotalBugsCreatedCount))
            .ToArray();
        var bugsClosedData = _trendMetrics
            .Select(m => GetMetricValue(m, pm => (double)pm.BugsClosedCount, m.TotalBugsClosedCount))
            .ToArray();
        _bugTrendSeries = new List<ChartSeries>
        {
            new() { Name = "Created", Data = bugsCreatedData },
            new() { Name = "Closed", Data = bugsClosedData }
        };
        (_bugsCreatedStart, _bugsCreatedEnd) = FirstLastNonZero(bugsCreatedData);
    }

    /// <summary>
    /// Returns the metric value for the selected product (if any), or the total aggregated value.
    /// </summary>
    private double GetMetricValue(
        SprintTrendMetricsDto metric,
        Func<ProductSprintMetricsDto, double> productSelector,
        double totalFallback)
    {
        if (_selectedProductId.HasValue)
        {
            var pm = metric.ProductMetrics.FirstOrDefault(p => p.ProductId == _selectedProductId.Value);
            return pm != null ? productSelector(pm) : 0.0;
        }
        return totalFallback;
    }

    /// <summary>Returns the first and last non-zero values in an array for slope badge computation.</summary>
    private static (double? first, double? last) FirstLastNonZero(double[] values)
    {
        var nonZero = values.Where(v => v > 0).ToList();
        if (nonZero.Count < 2) return (null, null);
        return (nonZero.First(), nonZero.Last());
    }

    private int MaxAvailableSprints => _filteredSprints.Count > 0 ? _filteredSprints.Count : 1;

    private int CurrentTrendSprintCount
    {
        get
        {
            if (!_selectedFromSprintId.HasValue || !_selectedToSprintId.HasValue || _filteredSprints.Count == 0)
            {
                return Math.Min(DefaultTrendSprintCount, MaxAvailableSprints);
            }

            var startIndex = _filteredSprints.FindIndex(s => s.Id == _selectedFromSprintId.Value);
            var endIndex = _filteredSprints.FindIndex(s => s.Id == _selectedToSprintId.Value);
            if (startIndex < 0 || endIndex < 0)
            {
                return Math.Min(DefaultTrendSprintCount, MaxAvailableSprints);
            }

            if (startIndex > endIndex)
            {
                (startIndex, endIndex) = (endIndex, startIndex);
            }

            return endIndex - startIndex + 1;
        }
    }

    private string GetTrendRangeLabel()
    {
        if (_filteredSprints.Count == 0 || _currentSprintIndex < 0) return string.Empty;
        var startIndex = Math.Max(0, _currentSprintIndex - CurrentTrendSprintCount + 1);
        return $"{_filteredSprints[startIndex].Name} – {_currentSprint!.Name}";
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Delivery Trends", null, disabled: true, icon: Icons.Material.Filled.LocalShipping)
        };
    }

    private async Task OnTeamChanged(int? teamId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { TeamId = teamId, FromSprintId = null, ToSprintId = null });
        await NavigateToResolvedFilterStateAsync();
        ApplySprintFilters();
        await LoadMetricsAsync();
    }

    private async Task OnProductChanged(int? productId)
    {
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with { ProductId = productId });
        await NavigateToResolvedFilterStateAsync();
        if (_trendMetrics.Count > 0)
            BuildTrendCharts();
        StateHasChanged();
    }

    private async Task OnEndSprintChanged(int sprintId)
    {
        var endIndex = _filteredSprints.FindIndex(s => s.Id == sprintId);
        if (endIndex < 0)
        {
            return;
        }

        var startIndex = Math.Max(0, endIndex - CurrentTrendSprintCount + 1);
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with
        {
            FromSprintId = _filteredSprints[startIndex].Id,
            ToSprintId = _filteredSprints[endIndex].Id
        });
        await NavigateToResolvedFilterStateAsync();
        SelectDeterministicEndSprint();
        await LoadMetricsAsync();
    }

    private async Task OnTrendSprintCountChanged(int count)
    {
        if (_filteredSprints.Count == 0)
        {
            return;
        }

        SelectDeterministicEndSprint();
        var endIndex = Math.Max(0, _currentSprintIndex);
        var startIndex = Math.Max(0, endIndex - count + 1);
        await UpdateFilterStateAsync(BuildCurrentLocalBridgeState() with
        {
            FromSprintId = _filteredSprints[startIndex].Id,
            ToSprintId = _filteredSprints[endIndex].Id
        });
        await NavigateToResolvedFilterStateAsync();
        await LoadMetricsAsync();
    }

    private void NavigateToTrends() => NavigationManager.NavigateTo(WorkspaceRoutes.TrendsWorkspace);
    private void NavigateToHome() => NavigationManager.NavigateTo(WorkspaceRoutes.Home);

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId);

    private FilterLocalBridgeState BuildCurrentLocalBridgeState()
        => FilterLocalBridgeState.FromState(GlobalFilterStore.GetState());

    private async Task UpdateFilterStateAsync(FilterLocalBridgeState localState)
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId, localState, FilterUpdateSource.Ui);

    private async Task NavigateToResolvedFilterStateAsync()
    {
        var targetUri = await GlobalFilterRouteService.BuildCurrentPageUriAsync(NavigationManager.Uri, GlobalFilterStore.GetState());
        if (GlobalFilterStore.TryPrepareNavigation(NavigationManager.Uri, targetUri))
        {
            NavigationManager.NavigateTo(targetUri, forceLoad: false);
        }
    }

    private List<int> GetSelectedSprintIds()
    {
        if (!_selectedFromSprintId.HasValue || !_selectedToSprintId.HasValue)
        {
            return new List<int>();
        }

        var startIndex = _filteredSprints.FindIndex(s => s.Id == _selectedFromSprintId.Value);
        var endIndex = _filteredSprints.FindIndex(s => s.Id == _selectedToSprintId.Value);
        if (startIndex < 0 || endIndex < 0)
        {
            return new List<int>();
        }

        if (startIndex > endIndex)
        {
            (startIndex, endIndex) = (endIndex, startIndex);
        }

        return _filteredSprints
            .Skip(startIndex)
            .Take(endIndex - startIndex + 1)
            .Select(s => s.Id)
            .ToList();
    }

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _filterSubscription?.Dispose();
    }
}
