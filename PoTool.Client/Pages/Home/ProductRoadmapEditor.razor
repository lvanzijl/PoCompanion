    // --- Add / Remove roadmap membership (button-based) ---

    private async Task AddToRoadmap(ApiWorkItemDto epic)
    {
        _isBusy = true;
        SetSavingStatus();
        try
        {
            var tagList = RoadmapWorkItemRules.GetTagList(epic.Tags);
            if (!tagList.Any(t => t.Equals("roadmap", StringComparison.OrdinalIgnoreCase)))
            {
                tagList.Add("roadmap");
            }

            var updated = await WorkItemService.UpdateTagsAsync(epic.TfsId, tagList);
            if (updated == null)
            {
                Snackbar.Add($"Failed to add epic {epic.TfsId} to roadmap.", Severity.Error);
                await SetFailedStatus();
                return;
            }

            // Append to end: give it a priority higher than all current roadmap epics
            double newPriority;
            if (_roadmapEpics.Count > 0)
            {
                var maxPriority = _roadmapEpics.Max(e => e.BacklogPriority ?? 0);
                newPriority = maxPriority + 1000.0;
            }
            else
            {
                newPriority = 1000.0;
            }

            await WorkItemService.UpdateBacklogPriorityAsync(epic.TfsId, newPriority);

            await ReloadEpicsAsync();
            _ = HighlightEpic(epic.TfsId);
            Snackbar.Add($"Epic \"{epic.Title}\" added to roadmap.", Severity.Success);
            await SetSavedStatus();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error adding epic to roadmap: {ex.Message}", Severity.Error);
            await SetFailedStatus();
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RemoveFromRoadmap(ApiWorkItemDto epic)
    {
        _isBusy = true;
        SetSavingStatus();
        try
        {
            var tagList = RoadmapWorkItemRules.GetTagList(epic.Tags);
            tagList.RemoveAll(t => t.Equals("roadmap", StringComparison.OrdinalIgnoreCase));

            var updated = await WorkItemService.UpdateTagsAsync(epic.TfsId, tagList);
            if (updated == null)
            {
                Snackbar.Add($"Failed to remove epic {epic.TfsId} from roadmap.", Severity.Error);
                await SetFailedStatus();
                return;
            }

            // Close drawer if the removed epic was being edited
            if (_drawerEpic?.TfsId == epic.TfsId)
            {
                CloseDrawer();
            }

            await ReloadEpicsAsync();
            Snackbar.Add($"Epic \"{epic.Title}\" removed from roadmap.", Severity.Success);
            await SetSavedStatus();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error removing epic from roadmap: {ex.Message}", Severity.Error);
            await SetFailedStatus();
        }
        finally
        {
            _isBusy = false;
        }
    }

    // --- Reordering (button-based) ---

    private async Task MoveEarlier(int index)
    {
        if (index <= 0 || _isBusy) return;
        await SwapEpicOrder(index, index - 1);
    }

    private async Task MoveLater(int index)
    {
        if (index >= _roadmapEpics.Count - 1 || _isBusy) return;
        await SwapEpicOrder(index, index + 1);
    }

    private async Task SwapEpicOrder(int indexA, int indexB)
    {
        _isBusy = true;
        SetSavingStatus();
        try
        {
            var epicA = _roadmapEpics[indexA];
            var epicB = _roadmapEpics[indexB];

            Logger.LogDebug(
                "Roadmap button reorder requested for product {ProductId}: epic {EpicATfsId} at index {IndexA} with priority {PriorityA}, neighbor epic {EpicBTfsId} at index {IndexB} with priority {PriorityB}.",
                ProductId,
                epicA.TfsId,
                indexA,
                epicA.BacklogPriority,
                epicB.TfsId,
                indexB,
                epicB.BacklogPriority);

            var applied = await ApplyRoadmapReorderAsync(indexA, indexB);
            if (!applied)
                return;

            await ReloadEpicsAsync();
            Snackbar.Add("Roadmap order updated.", Severity.Success);
            await SetSavedStatus();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error reordering epics: {ex.Message}", Severity.Error);
            await SetFailedStatus();
        }
        finally
        {
            _isBusy = false;
        }
    }

    /// <summary>
    /// Normalizes roadmap epic priorities when they become inconsistent or have duplicates.
    /// Assigns deterministic priorities based on current position using 1000.0 spacing.
    /// Persists the corrected priorities to TFS.
    /// </summary>
    private async Task NormalizeRoadmapPrioritiesAsync()
    {
        for (var i = 0; i < _roadmapEpics.Count; i++)
        {
            var newPriority = (i + 1) * 1000.0;
            _roadmapEpics[i].BacklogPriority = newPriority;
            var success = await WorkItemService.UpdateBacklogPriorityAsync(_roadmapEpics[i].TfsId, newPriority);
            if (!success)
            {
                Snackbar.Add($"Failed to normalize priority for epic {_roadmapEpics[i].TfsId}.", Severity.Warning);
            }
        }
    }

