    private void OpenDrawer(ApiWorkItemDto epic)
    {
        _drawerEpic = epic;
        _drawerTitle = epic.Title;
        _drawerDescription = epic.Description ?? string.Empty;
        _drawerOpen = true;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _drawerEpic = null;
        _drawerTitle = string.Empty;
        _drawerDescription = string.Empty;
    }

    private async Task SaveDrawerChanges()
    {
        if (_drawerEpic == null) return;

        _isSaving = true;
        SetSavingStatus();
        try
        {
            var updated = await WorkItemService.UpdateTitleDescriptionAsync(
                _drawerEpic.TfsId,
                _drawerTitle,
                _drawerDescription);

            if (updated == null)
            {
                Snackbar.Add($"Failed to save changes for epic {_drawerEpic.TfsId}.", Severity.Error);
                await SetFailedStatus();
                return;
            }

            await ReloadEpicsAsync();

            // Update drawer with refreshed data
            var refreshed = _roadmapEpics.FirstOrDefault(e => e.TfsId == _drawerEpic.TfsId)
                         ?? _availableEpics.FirstOrDefault(e => e.TfsId == _drawerEpic.TfsId);
            if (refreshed != null)
            {
                _drawerEpic = refreshed;
                _drawerTitle = refreshed.Title;
                _drawerDescription = refreshed.Description ?? string.Empty;
            }

            Snackbar.Add("Epic updated successfully.", Severity.Success);
            await SetSavedStatus();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving epic changes: {ex.Message}", Severity.Error);
            await SetFailedStatus();
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task<bool> ApplyRoadmapReorderAsync(int currentIndex, int targetIndex)
    {
        if (!TryCreateRoadmapReorderPlan(currentIndex, targetIndex, out var writes, out var failureReason))
        {
            Logger.LogWarning(
                "Roadmap reorder requires priority recovery for product {ProductId}. CurrentIndex {CurrentIndex}, TargetIndex {TargetIndex}, reason {FailureReason}.",
                ProductId,
                currentIndex,
                targetIndex,
                failureReason);

            await NormalizeRoadmapPrioritiesAsync();

            if (!TryCreateRoadmapReorderPlan(currentIndex, targetIndex, out writes, out var retryFailureReason))
            {
                Logger.LogWarning(
                    "Roadmap reorder still unavailable after normalization for product {ProductId}. CurrentIndex {CurrentIndex}, TargetIndex {TargetIndex}, reason {FailureReason}.",
                    ProductId,
                    currentIndex,
                    targetIndex,
                    retryFailureReason);
                Snackbar.Add("Cannot reorder because roadmap priorities could not be recovered.", Severity.Warning);
                await SetFailedStatus();
                await ReloadEpicsAsync();
                return false;
            }
        }

        Logger.LogDebug(
            "Applying roadmap reorder for product {ProductId}. CurrentIndex {CurrentIndex}, TargetIndex {TargetIndex}, writes [{PriorityWrites}]",
            ProductId,
            currentIndex,
            targetIndex,
            string.Join(", ", writes!.Select(write => $"{write.TfsId}:{write.OriginalPriority}->{write.NewPriority}")));

        var appliedWrites = new List<RoadmapEpicPriorityWrite>();
        foreach (var write in writes!)
        {
            var success = await WorkItemService.UpdateBacklogPriorityAsync(write.TfsId, write.NewPriority);
            if (!success)
            {
                foreach (var appliedWrite in Enumerable.Reverse(appliedWrites))
                {
                    await WorkItemService.UpdateBacklogPriorityAsync(appliedWrite.TfsId, appliedWrite.OriginalPriority);
                }

                Snackbar.Add($"Failed to update priority for epic {write.TfsId}. Reloading state.", Severity.Error);
                await SetFailedStatus();
                await ReloadEpicsAsync();
                return false;
            }

            appliedWrites.Add(write);
        }

        return true;
    }

    private bool TryCreateRoadmapReorderPlan(
        int currentIndex,
        int targetIndex,
        out IReadOnlyList<RoadmapEpicPriorityWrite>? writes,
        out RoadmapEpicPriorityReorderFailureReason? failureReason)
    {
        return RoadmapEpicPriorityReorderPlanner.TryCreatePriorityPreservingPlan(
            _roadmapEpics
                .Select(epic => new RoadmapEpicPriorityItem(epic.TfsId, epic.BacklogPriority))
                .ToList(),
            currentIndex,
            targetIndex,
            out writes,
            out failureReason);
    }

