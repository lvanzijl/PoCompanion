    private async Task HighlightEpic(int tfsId)
    {
        try
        {
            _highlightedEpicIds.Add(tfsId);
            StateHasChanged();

            await Task.Delay(HighlightDurationMs);
            _highlightedEpicIds.Remove(tfsId);
            StateHasChanged();
        }
        catch
        {
            _highlightedEpicIds.Remove(tfsId);
        }
    }

