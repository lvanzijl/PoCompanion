    // --- Phase 1: Save status feedback ---

    private async Task ShowSaveStatus(string status, Color color, string icon)
    {
        _saveStatusCts?.Cancel();
        _saveStatusCts = new CancellationTokenSource();
        var token = _saveStatusCts.Token;

        _saveStatus = status;
        _saveStatusColor = color;
        _saveStatusIcon = icon;
        StateHasChanged();

        try
        {
            await Task.Delay(SaveStatusDisplayDurationMs, token);
            _saveStatus = string.Empty;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Cancelled by next status update — expected
        }
    }

    private void SetSavingStatus()
    {
        _saveStatusCts?.Cancel();
        _saveStatus = "Saving…";
        _saveStatusColor = Color.Warning;
        _saveStatusIcon = Icons.Material.Filled.Sync;
    }

    private async Task SetSavedStatus()
    {
        await ShowSaveStatus("Saved to TFS", Color.Success, Icons.Material.Filled.CheckCircle);
    }

    private async Task SetFailedStatus()
    {
        await ShowSaveStatus("Failed to update TFS", Color.Error, Icons.Material.Filled.Error);
    }

