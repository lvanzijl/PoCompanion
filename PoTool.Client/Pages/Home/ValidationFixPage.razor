@page "/home/validation-fix"
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Shared.WorkItems
@using System.Web
@inherits WorkspaceBase
@inject WorkItemService WorkItemService
@inject ProductService ProductService

<PageTitle>Fix Session - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Fix Session</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (ProductId.HasValue && _productName != null)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Size="Size.Small"
                             Color="Color.Primary"
                             OnClose="ClearProductFilter">
                        @_productName
                    </MudChip>
                }
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NavigateToQueue">
                    Back to Queue
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_recoveryMessage != null)
    {
        <GuidedRecoveryPanel Title="@_recoveryTitle"
                             Message="@_recoveryMessage"
                             PrimaryActionLabel="@_recoveryPrimaryActionLabel"
                             PrimaryAction="@_recoveryPrimaryAction"
                             SecondaryActionLabel="Home"
                             SecondaryAction="NavigateToHome" />
    }
    else if (_dataState.State == DataStateDto.NotReady)
    {
        <DataStatePanel State="@_dataState.State"
                        Title="Validation fix session is syncing"
                        Message="@(_dataState.Reason ?? "Validation fix data will load automatically after cache warming completes.")"
                        ProductOwnerId="@_profileId" />
    }
    else if (_dataState.State == DataStateDto.Failed)
    {
        <DataStatePanel State="@_dataState.State"
                        Title="Validation fix session failed to load"
                        Message="@(_dataState.Reason ?? "Validation fix data could not be loaded right now.")" />
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (_session != null)
    {
        @* Rule context banner *@
        <MudPaper Elevation="1" Class="pa-3 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                <MudIcon Icon="@ValidationCategoryMeta.GetIcon(_session.CategoryKey)"
                         Color="@ValidationCategoryMeta.GetColor(_session.CategoryKey)"
                         Size="Size.Medium" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                        @_session.RuleTitle
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_session.CategoryLabel
                    </MudText>
                </MudStack>
                <MudSpacer />
                @if (_session.Items.Count > 0)
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Medium">
                        @_dismissedCount dismissed · @_activeItems.Count remaining of @_session.Items.Count
                    </MudChip>
                }
            </MudStack>
        </MudPaper>

        @if (_session.Items.Count == 0)
        {
            <MudAlert Severity="Severity.Success">
                No work items need attention for this rule right now.
            </MudAlert>
        }
        else if (_activeItems.Count == 0)
        {
            @* All dismissed state *@
            <MudPaper Elevation="1" Class="pa-8">
                <MudStack AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Style="font-size: 4rem;" />
                    <MudText Typo="Typo.h5">Session complete!</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary">
                        All @_session.Items.Count item@(_session.Items.Count == 1 ? "" : "s") in this session @(_session.Items.Count == 1 ? "has" : "have") been reviewed.
                    </MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   StartIcon="@Icons.Material.Filled.Replay"
                                   OnClick="RestartSession">
                            Restart session
                        </MudButton>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="NavigateToQueue">
                            Back to Queue
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
        else
        {
            @* Navigation bar *@
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ChevronLeft"
                           Disabled="@(_currentIndex == 0)"
                           OnClick="Previous">
                    Previous
                </MudButton>

                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Item @(_currentIndex + 1) of @_activeItems.Count remaining
                </MudText>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           EndIcon="@Icons.Material.Filled.ChevronRight"
                           Disabled="@(_currentIndex >= _activeItems.Count - 1)"
                           OnClick="Next">
                    Next
                </MudButton>
            </MudStack>

            @* Current item card *@
            @if (CurrentItem != null)
            {
            <MudCard Elevation="3" Class="validation-fix-card mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                    @CurrentItem.Type
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                    @CurrentItem.State
                                </MudChip>
                                @if (CurrentItem.Effort.HasValue)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                        @CurrentItem.Effort SP
                                    </MudChip>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                <WorkItemLink WorkItemId="@CurrentItem.TfsId" Text="@($"TFS #{CurrentItem.TfsId}")" />
                            </MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3">@CurrentItem.Title</MudText>

                    @* Violation alert *@
                    <MudAlert Severity="@ValidationCategoryMeta.GetAlertSeverity(_session.CategoryKey)"
                              Class="mb-3"
                              Dense="true">
                        <MudText Typo="Typo.body2">
                            @CurrentItem.ViolationMessage
                        </MudText>
                    </MudAlert>

                    @* Item metadata *@
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Area Path</MudText>
                                <MudText Typo="Typo.body2">@CurrentItem.AreaPath</MudText>
                            </MudStack>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Iteration</MudText>
                                <MudText Typo="Typo.body2">@CurrentItem.IterationPath</MudText>
                            </MudStack>
                        </MudItem>
                        @if (CurrentItem.ParentTfsId.HasValue)
                        {
                            <MudItem xs="12" sm="6">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Parent TFS ID</MudText>
                                    <MudText Typo="Typo.body2">
                                        <WorkItemLink WorkItemId="@CurrentItem.ParentTfsId.Value" />
                                    </MudText>
                                </MudStack>
                            </MudItem>
                        }
                    </MudGrid>

                    @if (!string.IsNullOrWhiteSpace(CurrentItem.Description))
                    {
                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Description</MudText>
                        <MudText Typo="Typo.body2" Style="white-space: pre-wrap; max-height: 160px; overflow-y: auto;">
                            @CurrentItem.Description
                        </MudText>
                    }
                </MudCardContent>

                @if (_refreshError != null)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mx-4 mb-2">@_refreshError</MudAlert>
                }

                <MudCardActions>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="DismissCurrent">
                        Done for now
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               Disabled="@_isRefreshing"
                               OnClick="RefreshCurrentFromTfs">
                        @(_isRefreshing ? "Refreshing…" : "Refresh from TFS")
                    </MudButton>
                    <MudSpacer />
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.SkipNext"
                               OnClick="Next"
                               Disabled="@(_currentIndex >= _activeItems.Count - 1)">
                        Skip
                    </MudButton>
                </MudCardActions>
            </MudCard>
            }
        }
    }
</MudContainer>

<style>
    .validation-fix-card {
        border-left: 4px solid var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private int? _profileId;
    private string? _productName;
    private string _categoryKey = string.Empty;
    private string _ruleId = string.Empty;
    private ValidationFixSessionDto? _session;
    private List<ValidationFixItemDto> _activeItems = new();
    private HashSet<int> _dismissedIds = new();
    private int _currentIndex;
    private int _dismissedCount;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private bool _isRefreshing;
    private string? _refreshError;
    private int[]? _productIds;
    private string? _recoveryTitle;
    private string? _recoveryMessage;
    private string? _recoveryPrimaryActionLabel;
    private EventCallback _recoveryPrimaryAction;
    private DataStateViewModel<ValidationFixSessionDto> _dataState = DataStateViewModel<ValidationFixSessionDto>.NotRequested();

    /// <summary>The current work item being reviewed in the session.</summary>
    private ValidationFixItemDto? CurrentItem =>
        _activeItems.Count > 0 ? _activeItems[_currentIndex] : null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ParseContextQueryParameters();

            var uri = new Uri(NavigationManager.Uri);
            var queryParams = HttpUtility.ParseQueryString(uri.Query);
            var rawCategory = queryParams["category"];
            var rawRuleId = queryParams["ruleId"];
            if (!ValidationRouteContextHelper.TryNormalizeCategory(rawCategory, out _categoryKey))
            {
                SetFixRecoveryForCategory(rawCategory);
                UpdateBreadcrumbs();
                return;
            }
            if (!ValidationRouteContextHelper.TryNormalizeRuleForCategory(rawRuleId, _categoryKey, out _ruleId))
            {
                SetFixRecoveryForRule(rawRuleId);
                UpdateBreadcrumbs();
                return;
            }

            if (!await EnsureProfileAsync())
                return;

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            var profileProducts = activeProfile != null
                ? (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList()
                : new List<ProductDto>();

            if (ProductId.HasValue)
                _productName = profileProducts.FirstOrDefault(p => p.Id == ProductId.Value)?.Name;

            int[]? productIds = ProductId.HasValue
                ? new[] { ProductId.Value }
                : profileProducts.Select(p => p.Id).ToArray();

            if (productIds.Length == 0)
                productIds = null;

            _productIds = productIds;
            _dataState = DataStateViewModel<ValidationFixSessionDto>.Loading();
            var response = await WorkItemService.GetValidationFixSessionStateAsync(_ruleId, _categoryKey, productIds);
            _dataState = DataStateViewModel<ValidationFixSessionDto>.FromResponse(response, "Validation fix data could not be loaded right now.");
            _session = _dataState.Data;
            _activeItems = _session?.Items.ToList() ?? new();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _loadError = "Validation fix data could not be loaded right now. Try again later.";
            Console.WriteLine($"[ValidationFix] {ex}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void UpdateBreadcrumbs()
    {
        var categoryLabel = _session?.CategoryLabel ?? _categoryKey;
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Health", WorkspaceRoutes.HealthWorkspace, icon: Icons.Material.Filled.HealthAndSafety),
            new("Validation Triage", WorkspaceRoutes.ValidationTriage, icon: Icons.Material.Filled.FactCheck),
            // Recovery states can render breadcrumbs before category validation succeeds.
            new(string.IsNullOrWhiteSpace(categoryLabel) ? "Queue" : $"{categoryLabel} Queue",
                string.IsNullOrWhiteSpace(_categoryKey)
                    ? null
                    : $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery($"category={Uri.EscapeDataString(_categoryKey)}")}",
                disabled: string.IsNullOrWhiteSpace(_categoryKey),
                icon: Icons.Material.Filled.Queue),
            new("Fix Session", null, disabled: true, icon: Icons.Material.Filled.Build)
        };
    }

    private void DismissCurrent()
    {
        if (CurrentItem == null) return;
        _dismissedIds.Add(CurrentItem.TfsId);
        _dismissedCount++;
        _activeItems.RemoveAt(_currentIndex);
        // Keep index in bounds after removal
        if (_currentIndex >= _activeItems.Count && _currentIndex > 0)
            _currentIndex = _activeItems.Count - 1;
    }

    private void Next()
    {
        if (_currentIndex < _activeItems.Count - 1)
            _currentIndex++;
    }

    private void Previous()
    {
        if (_currentIndex > 0)
            _currentIndex--;
    }

    private void RestartSession()
    {
        _dismissedIds.Clear();
        _dismissedCount = 0;
        _activeItems = _session?.Items.ToList() ?? new();
        _currentIndex = 0;
    }

    private async Task RefreshCurrentFromTfs()
    {
        if (CurrentItem == null || _isRefreshing) return;
        _refreshError = null;
        _isRefreshing = true;
        try
        {
            var found = await WorkItemService.RefreshWorkItemFromTfsAsync(CurrentItem.TfsId);
            if (!found)
            {
                _refreshError = $"Work item #{CurrentItem.TfsId} was not found in TFS.";
                return;
            }

            // Reload the fix session to reflect the updated state
            var updatedResponse = await WorkItemService.GetValidationFixSessionStateAsync(_ruleId, _categoryKey, _productIds);
            var updated = updatedResponse?.Data;
            if (updated != null)
            {
                _session = updated;
                // Rebuild active items, preserving dismissed set
                _activeItems = _session.Items
                    .Where(i => !_dismissedIds.Contains(i.TfsId))
                    .ToList();
                // Keep index in bounds
                if (_currentIndex >= _activeItems.Count)
                    _currentIndex = Math.Max(0, _activeItems.Count - 1);
            }
        }
        catch (Exception ex)
        {
            _refreshError = $"Refresh failed: {ex.Message}";
            Console.WriteLine($"[ValidationFix] {_refreshError}");
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private void NavigateToQueue()
    {
        if (string.IsNullOrWhiteSpace(_categoryKey))
        {
            NavigateToTriage();
            return;
        }

        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery($"category={Uri.EscapeDataString(_categoryKey)}")}");
    }

    private void NavigateToTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void ClearProductFilter()
    {
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationFix}?category={Uri.EscapeDataString(_categoryKey)}&ruleId={Uri.EscapeDataString(_ruleId)}");
    }

    private void SetFixRecoveryForCategory(string? rawCategory)
    {
        if (string.IsNullOrWhiteSpace(rawCategory))
        {
            SetRecovery(
                "Validation category missing",
                "This fix session needs a validation category. Open Validation Triage to choose a category first.",
                "Go to Validation Triage",
                NavigateToTriage);
            return;
        }

        SetRecovery(
            "Unknown validation category",
            "The category in the URL is not recognised. Open Validation Triage to choose a valid category.",
            "Go to Validation Triage",
            NavigateToTriage);
    }

    private void SetFixRecoveryForRule(string? rawRuleId)
    {
        if (string.IsNullOrWhiteSpace(rawRuleId))
        {
            SetRecovery(
                "Validation rule missing",
                "This fix session needs a rule ID. Open the queue for this category and start a fix session from there.",
                "Back to Queue",
                NavigateToQueue);
            return;
        }

        SetRecovery(
            "Unknown validation rule",
            "The rule in the URL is invalid for this category. Open the queue and start a valid fix session.",
            "Back to Queue",
            NavigateToQueue);
    }

    private void SetRecovery(string title, string message, string primaryActionLabel, Action primaryAction)
    {
        _recoveryTitle = title;
        _recoveryMessage = message;
        _recoveryPrimaryActionLabel = primaryActionLabel;
        _recoveryPrimaryAction = EventCallback.Factory.Create(this, primaryAction);
    }
}
