@page "/home/bugs"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Client.Pages.Home.Components
@using System.Web
@inject IProfileService ProfileService
@inject WorkItemService WorkItemService
@inject ProductService ProductService
@inject TeamService TeamService
@inject NavigationManager NavigationManager
@inject GlobalFilterStore GlobalFilterStore
@inject PageFilterExecutionGate PageFilterExecutionGate
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Bug Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Bug Insights
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="NavigateToBugTriage">
                    Bug Triage
                </MudButton>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <CanonicalDataStateView TData="IReadOnlyList<WorkItemDto>"
                            State="@_bugState"
                            ProductOwnerId="@_profileId"
                            Subject="Bug insights"
                            EmptyTitle="No bug data available"
                            EmptyMessage="No bug data found for the selected team/product and time range."
                            FailedTitle="Bug insights failed to load">
        <NotRequestedContent>
            <MudAlert Severity="Severity.Info">Select a valid team or product scope to load bug insights.</MudAlert>
        </NotRequestedContent>
        <ChildContent Context="bugs">
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6" md="4">
                        <MetricCard Title="Total Open Bugs"
                                   Result="_totalOpenBugs"
                                   ValueFormat="MetricValueFormat.Count"
                                   ItemLabel="bugs"
                                   IsLoading="_metricsLoading" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MetricCard Title="Bugs Created (Last 6 Months)"
                                   Result="_bugsCreated"
                                   ValueFormat="MetricValueFormat.Count"
                                   ItemLabel="bugs"
                                   IsLoading="_metricsLoading" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MetricCard Title="Bugs Resolved (Last 6 Months)"
                                   Result="_bugsResolved"
                                   ValueFormat="MetricValueFormat.Count"
                                   ItemLabel="bugs"
                                   IsLoading="_metricsLoading" />
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MetricCard Title="Bug Resolution Time"
                                   Result="_resolutionTime"
                                   ValueFormat="MetricValueFormat.Hours"
                                   ItemLabel="bugs"
                                   IsLoading="_metricsLoading" />
                    </MudItem>
                </MudGrid>

                <MudPaper Elevation="2" Class="pa-4 mt-3">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-2" />
                            Bugs by Severity Distribution
                        </MudText>

                        @if (_severityDistribution.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info">
                                No severity data available.
                            </MudAlert>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                @foreach (var (severity, data) in _severityDistribution)
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@GetSeverityColor(severity)"
                                                 Style="min-width: 120px;">
                                            @severity
                                        </MudChip>
                                        <MudProgressLinear Color="@GetSeverityColor(severity)"
                                                           Value="@data.Percentage"
                                                           Size="Size.Large"
                                                           Class="flex-grow-1" />
                                        <MudText Typo="Typo.body2" Style="min-width: 100px;">
                                            @data.Count (@($"{data.Percentage:F1}") %)
                                        </MudText>
                                    </MudStack>
                                }
                            </MudStack>
                        }
                    </MudStack>
                </MudPaper>
        </ChildContent>
    </CanonicalDataStateView>

        @* Suggestion 6: Prominent "Go to Triage" contextual action panel *@
        <MudPaper Elevation="2" Class="pa-4 mt-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" Color="Color.Error" />
                        Ready to triage?
                    </MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @if (_totalOpenBugs?.Count > 0)
                        {
                            <span>@_totalOpenBugs.Count open bugs need triage attention</span>
                        }
                        else
                        {
                            <span>Go to Bug Triage to manage triage tags and prioritise bugs</span>
                        }
                    </MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="NavigateToBugTriage"
                           Size="Size.Large">
                    Go to Triage
                </MudButton>
            </MudStack>
        </MudPaper>
</MudContainer>

@code {
    private bool _metricsLoading = false;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Selectors
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    
    // Bug Data
    private List<WorkItemDto> _allBugs = new();
    
    // Calculated Metrics
    private MetricResult? _totalOpenBugs;
    private MetricResult? _bugsCreated;
    private MetricResult? _bugsResolved;
    private MetricResult? _resolutionTime;
    private Dictionary<string, (int Count, double Percentage)> _severityDistribution = new();
    
    // Calculator
    private readonly BugInsightsCalculator _calculator = new();
    
    // Time window (6 months by default)
    private readonly DateTimeOffset _fromDate = DateTimeOffset.UtcNow.AddMonths(-6);
    private DataStateViewModel<IReadOnlyList<WorkItemDto>> _bugState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.NotRequested();
    private IDisposable? _filterSubscription;
    private int? _selectedTeamId => GlobalFilterStore.GetState().TeamId;
    private int? _selectedProductId => GlobalFilterStore.GetState().PrimaryProductId;
    
    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Load teams and products
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            await SyncStoreFromCurrentRouteAsync();
            
            // Load bug data and calculate metrics
            await LoadBugDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception)
        {
            _bugState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.Failed("Bug insights could not be loaded right now. Try again later.");
            Snackbar.Add(_bugState.Reason!, Severity.Error);
        }
    }
    
    private async Task LoadBugDataAsync()
    {
        if (!PageFilterExecutionGate.CanExecuteQueries(GlobalFilterStore.CurrentUsage))
        {
            _allBugs = [];
            _severityDistribution = new();
            _totalOpenBugs = null;
            _bugsCreated = null;
            _bugsResolved = null;
            _resolutionTime = null;
            _bugState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.NotRequested();
            StateHasChanged();
            return;
        }

        _metricsLoading = true;
        _bugState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.Loading();
        StateHasChanged();

        var response = await WorkItemService.GetAllStateAsync();
        var bugState = DataStateViewModel<IReadOnlyList<WorkItemDto>>.FromResponse(
            response,
            "Bug data could not be loaded right now.");

        if (bugState.State == PoTool.Shared.DataState.DataStateDto.Available && bugState.Data is not null)
        {
            var bugs = bugState.Data.Where(wi => wi.Type.Equals("Bug", StringComparison.OrdinalIgnoreCase)).ToList();

            if (_selectedProductId.HasValue)
            {
                var selectedProduct = _products.FirstOrDefault(p => p.Id == _selectedProductId.Value);
                if (selectedProduct != null && selectedProduct.TeamIds.Any())
                {
                    var linkedTeams = _teams.Where(t => selectedProduct.TeamIds.Contains(t.Id)).ToList();
                    var teamAreaPaths = linkedTeams.Select(t => t.TeamAreaPath).ToHashSet(StringComparer.OrdinalIgnoreCase);
                    bugs = bugs.Where(b => teamAreaPaths.Any(path => b.AreaPath?.StartsWith(path, StringComparison.OrdinalIgnoreCase) == true)).ToList();
                }
                else
                {
                    bugs = [];
                }
            }

            if (_selectedTeamId.HasValue)
            {
                var selectedTeam = _teams.FirstOrDefault(t => t.Id == _selectedTeamId.Value);
                bugs = selectedTeam is null
                    ? []
                    : bugs.Where(b => b.AreaPath?.StartsWith(selectedTeam.TeamAreaPath, StringComparison.OrdinalIgnoreCase) == true).ToList();
            }

            _allBugs = bugs;
            CalculateMetrics();
            _bugState = bugState with { Data = bugs };
        }
        else
        {
            _allBugs = [];
            _severityDistribution = new();
            _totalOpenBugs = null;
            _bugsCreated = null;
            _bugsResolved = null;
            _resolutionTime = null;
            _bugState = bugState;
        }

        _metricsLoading = false;
        StateHasChanged();
    }
    
    private void CalculateMetrics()
    {
        _totalOpenBugs = _calculator.CalculateTotalOpenBugs(_allBugs);
        _bugsCreated = _calculator.CalculateBugsCreatedPerPeriod(_allBugs, _fromDate);
        _bugsResolved = _calculator.CalculateBugsResolvedPerPeriod(_allBugs, _fromDate);
        _resolutionTime = _calculator.CalculateBugResolutionTime(_allBugs, _fromDate);
        _severityDistribution = _calculator.CalculateBugsBySeverityDistribution(_allBugs);
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Bug Insights", null, disabled: true, icon: Icons.Material.Filled.Insights)
        };
    }
    
    private Color GetSeverityColor(string severity)
    {
        // ExtractSeverity returns "1 - Critical", "2 - High", etc., or "Unknown"
        if (severity.StartsWith("1"))
        {
            return Color.Error;
        }
        if (severity.StartsWith("2"))
        {
            return Color.Warning;
        }
        if (severity.StartsWith("3"))
        {
            return Color.Info;
        }
        if (severity.StartsWith("4"))
        {
            return Color.Default;
        }
        return Color.Default; // Unknown
    }
    
    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
    
    private void NavigateToBugTriage()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage);
    }

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId);

    private FilterLocalBridgeState BuildCurrentLocalBridgeState()
        => FilterLocalBridgeState.FromState(GlobalFilterStore.GetState());

    private async Task UpdateFilterStateAsync(FilterLocalBridgeState localState)
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _profileId, localState, FilterUpdateSource.Ui);

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        _filterSubscription?.Dispose();
    }
}
