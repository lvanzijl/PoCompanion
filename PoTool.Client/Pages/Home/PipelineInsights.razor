@page "/home/pipeline-insights"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Charts
@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Shared.DataState
@using PoTool.Client.Pages.Home.Components
@using SharedPipelineBuildQualityDto = PoTool.Shared.BuildQuality.PipelineBuildQualityDto
@inject IProfileService ProfileService
@inject PipelineStateService PipelineStateService
@inject IBuildQualityService BuildQualityService
@inject TeamService TeamService
@inject SprintService SprintService
@inject NavigationManager NavigationManager
@inject GlobalFilterStore GlobalFilterStore
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Pipeline Insights - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* ── Workspace Header ────────────────────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Pipeline Insights</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @* ── Context / Filters (collapsible) ───────────────────────────────── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                  Style="cursor:pointer;" @onclick="() => _filterExpanded = !_filterExpanded">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.FilterAlt" />
                <MudText Typo="Typo.h6">Filters</MudText>
                @if (!_filterExpanded && (_selectedTeamId.HasValue || _selectedSprintId.HasValue))
                {
                    @* Summary chips shown when collapsed *@
                    @if (_selectedTeamId.HasValue)
                    {
                        var teamName = _teams.FirstOrDefault(t => t.Id == _selectedTeamId)?.Name;
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Group">@teamName</MudChip>
                    }
                    @if (_selectedSprintId.HasValue)
                    {
                        var sprintName = _sprints.FirstOrDefault(s => s.Id == _selectedSprintId)?.Name;
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Icon="@Icons.Material.Filled.CalendarMonth">@sprintName</MudChip>
                    }
                }
            </MudStack>
            <MudIconButton Icon="@(_filterExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                           Size="Size.Small"
                           Color="Color.Default"
                           OnClick="() => _filterExpanded = !_filterExpanded" />
        </MudStack>

        <MudCollapse Expanded="_filterExpanded">
            <MudDivider Class="my-3" />
            <MudGrid Spacing="2">
                @* Team selector — drives sprint list *@
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="int?"
                               Value="_selectedTeamId"
                               Label="Team"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               ValueChanged="OnTeamChanged">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select team…</MudSelectItem>
                        @foreach (var team in _teams)
                        {
                            <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* Sprint selector *@
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="int?"
                               Value="_selectedSprintId"
                               Label="Sprint"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               Disabled="@(!_sprints.Any())"
                               ValueChanged="OnSprintChanged">
                        <MudSelectItem T="int?" Value="@((int?)null)">Select sprint…</MudSelectItem>
                        @foreach (var sprint in _sprints)
                        {
                            <MudSelectItem T="int?" Value="@sprint.Id">
                                @sprint.Name
                                @if (sprint.StartUtc.HasValue)
                                {
                                    <text> (@sprint.StartUtc.Value.ToString("MMM yyyy"))</text>
                                }
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                @* Include partiallySucceeded toggle *@
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                    <MudTooltip Text="When enabled, partially succeeded builds are included in calculations and shown as warnings.">
                        <MudSwitch T="bool"
                                   @bind-Value="_includePartiallySucceeded"
                                   Label="Include partial success"
                                   Color="Color.Warning" />
                    </MudTooltip>
                </MudItem>

                @* Include canceled toggle *@
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                    <MudTooltip Text="When enabled, canceled builds are counted in the total.">
                        <MudSwitch T="bool"
                                   @bind-Value="_includeCanceled"
                                   Label="Include canceled"
                                   Color="Color.Default" />
                    </MudTooltip>
                </MudItem>

                @* SLO input *@
                <MudItem xs="12" sm="6" md="3">
                    <MudNumericField T="double?"
                                     @bind-Value="_sloDurationMinutes"
                                     Label="SLO duration (min)"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     HelperText="Optional horizontal SLO line on scatter" />
                </MudItem>
            </MudGrid>

            @* Reload button shown when toggles change after initial load *@
            @if (_insightsData is not null && _togglesDirty)
            {
                <MudStack Row="true" Class="mt-3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="LoadInsightsAsync">
                        Apply filters
                    </MudButton>
                </MudStack>
            }
        </MudCollapse>
    </MudPaper>

    <CanonicalFilterMetadataNotice Metadata="_filterNotice" />

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_dataState.State == DataStateDto.NotReady)
    {
        <DataStatePanel State="@_dataState.State" Title="Pipeline insights are syncing" Message="@(_dataState.Reason ?? "Pipeline insights will load once the cache is ready.")" ProductOwnerId="@_activeProfileId" />
    }
    else if (_dataState.State == DataStateDto.Failed)
    {
        <DataStatePanel State="@_dataState.State" Title="Pipeline insights failed to load" Message="@(_dataState.Reason ?? "Pipeline insights could not be loaded right now.")" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="LoadInsightsAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else if (_insightsData is null)
    {
        @* No sprint selected yet *@
        <MudPaper Elevation="1" Class="pa-6 mb-4 d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Large" Color="Color.Default" Class="mb-2" />
            <MudText Typo="Typo.h6">Select a team and sprint to view pipeline health</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Data is read from the local cache — no live TFS calls.
            </MudText>
        </MudPaper>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_pipelineQualityErrorMessage))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-4">
                @_pipelineQualityErrorMessage
            </MudAlert>
        }

        @* ── Global summary chips ────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-2" />
                Global Summary (All Products)
            </MudText>

            <MudGrid Spacing="2">
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="0" Class="pa-3 mud-theme-default" Style="text-align:center;">
                        <MudText Typo="Typo.h5">@_insightsData.TotalBuilds</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total builds</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="0" Class="pa-3 pipeline-stat-error" Style="text-align:center;">
                        <MudText Typo="Typo.h5" Color="Color.Error">@_insightsData.FailureRate.ToString("F1")%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Failure rate (@_insightsData.FailedBuilds failed)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="0" Class="pa-3 pipeline-stat-warning" Style="text-align:center;">
                        <MudText Typo="Typo.h5" Color="Color.Warning">@_insightsData.WarningRate.ToString("F1")%</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Warning rate (@_insightsData.WarningBuilds partial)</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Elevation="0" Class="pa-3 mud-theme-default" Style="text-align:center;">
                        @if (_insightsData.P90DurationMinutes.HasValue)
                        {
                            <MudText Typo="Typo.h5">@FormatMinutes(_insightsData.P90DurationMinutes.Value)</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.h5" Color="Color.Default">—</MudText>
                        }
                        <MudText Typo="Typo.caption" Color="Color.Secondary">P90 duration</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── Global Top 3 In Trouble ─────────────────────────────────── *@
        @if (_insightsData.GlobalTop3InTrouble.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Class="mr-2" />
                    Top Pipelines In Trouble (Global)
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Ranked by failure rate — highest failure rate first. Click a card to scroll to the product section.
                </MudText>

                <MudGrid Spacing="2">
                    @foreach (var entry in _insightsData.GlobalTop3InTrouble)
                    {
                        var capturedEntry = entry;
                        <MudItem xs="12" md="4">
                            <MudTooltip Text="Click to scroll to product section" Placement="Placement.Top" Arrow="true">
                                <div @onclick="() => ScrollToProductAsync(capturedEntry.ProductId)"
                                     style="cursor:pointer;">
                                    <TroubleEntryCard Entry="@capturedEntry" />
                                </div>
                            </MudTooltip>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        }

        @* ── Per-product sections ────────────────────────────────────── *@
        @foreach (var product in _insightsData.Products)
        {
            var productPoints = _scatterPointsByProduct.TryGetValue(product.ProductId, out var pts) ? pts : Array.Empty<TimeScatterPoint>();
            var highlightSet  = _highlightByProduct.TryGetValue(product.ProductId, out var hs) ? hs : null;

            <MudPaper Elevation="2" Class="pa-4 mb-4" id="@($"product-{product.ProductId}")">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Info" />
                    <MudText Typo="Typo.h5">@product.ProductName</MudText>
                </MudStack>

                @if (!product.HasData)
                {
                    <MudAlert Severity="Severity.Info" Class="mb-0">
                        No cached pipeline runs for this product in the selected sprint.
                    </MudAlert>
                }
                else
                {
                    @* Product Top 3 In Trouble *@
                    @if (product.Top3InTrouble.Any())
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                            Pipelines in trouble
                            @if (highlightSet != null)
                            {
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Default" Class="ml-2"
                                           OnClick="() => ClearHighlight(product.ProductId)">
                                    Clear highlight
                                </MudButton>
                            }
                        </MudText>
                        <MudGrid Spacing="2" Class="mb-4">
                            @foreach (var entry in product.Top3InTrouble)
                            {
                                bool isHighlighted = highlightSet?.Contains(entry.PipelineDefinitionId) == true;
                                <MudItem xs="12" sm="4">
                                    <div @onclick="() => ToggleHighlight(product.ProductId, entry.PipelineDefinitionId)"
                                         style="cursor: pointer;">
                                        <MudPaper Elevation="@(isHighlighted ? 4 : 1)"
                                                  Style="@(isHighlighted ? "outline: 2px solid var(--mud-palette-primary);" : "")">
                                            <TroubleEntryCard Entry="@entry" ShowProductName="false" />
                                        </MudPaper>
                                    </div>
                                </MudItem>
                            }
                        </MudGrid>
                    }

                    @* ── Pipeline Stability Scatter ──────────────────── *@
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        <MudIcon Icon="@Icons.Material.Filled.ScatterPlot" Size="Size.Small" Class="mr-1" />
                        Pipeline Stability Scatter
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                        Each dot is one build — X: start time, Y: duration.
                        Click a dot to see build details.
                        Click a pipeline in trouble to highlight it.
                    </MudText>
                    <MudPaper Elevation="1" Class="pa-2 mb-4">
                        @if (_insightsData.SprintStart.HasValue && _insightsData.SprintEnd.HasValue)
                        {
                            <TimeScatterSvg Points="@productPoints"
                                            SprintStart="@_insightsData.SprintStart.Value"
                                            SprintEnd="@_insightsData.SprintEnd.Value"
                                            MedianDurationMinutes="@product.MedianDurationMinutes"
                                            P90DurationMinutes="@product.P90DurationMinutes"
                                            SloDurationMinutes="@_sloDurationMinutes"
                                            HighlightedPipelineIds="@highlightSet"
                                            OnPointClick="@(pt => OpenBuildDrawerAsync(pt, product.ProductId))" />
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Warning" Dense="true">
                                Sprint boundaries are unavailable — scatter chart cannot be displayed.
                            </MudAlert>
                        }
                    </MudPaper>

                    @* Product Summary Chips *@
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Summary — @product.CompletedBuilds completed builds</MudText>
                    <MudGrid Spacing="2">
                        <MudItem xs="6" sm="2">
                            <MudPaper Elevation="0" Class="pa-2 pipeline-stat-error" Style="text-align:center;">
                                <MudText Typo="Typo.subtitle1" Color="Color.Error"><strong>@product.FailureRate.ToString("F1")%</strong></MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Failed (@product.FailedBuilds)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudPaper Elevation="0" Class="pa-2 pipeline-stat-warning" Style="text-align:center;">
                                <MudText Typo="Typo.subtitle1" Color="Color.Warning"><strong>@product.WarningRate.ToString("F1")%</strong></MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Warning (@product.WarningBuilds)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudPaper Elevation="0" Class="pa-2 pipeline-stat-success" Style="text-align:center;">
                                <MudText Typo="Typo.subtitle1" Color="Color.Success"><strong>@product.SuccessRate.ToString("F1")%</strong></MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Success (@product.SucceededBuilds)</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudPaper Elevation="0" Class="pa-2 mud-theme-default" Style="text-align:center;">
                                @if (product.MedianDurationMinutes.HasValue)
                                {
                                    <MudText Typo="Typo.subtitle1"><strong>@FormatMinutes(product.MedianDurationMinutes.Value)</strong></MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle1" Color="Color.Default">—</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Median duration</MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6" sm="2">
                            <MudPaper Elevation="0" Class="pa-2 mud-theme-default" Style="text-align:center;">
                                @if (product.P90DurationMinutes.HasValue)
                                {
                                    <MudText Typo="Typo.subtitle1"><strong>@FormatMinutes(product.P90DurationMinutes.Value)</strong></MudText>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle1" Color="Color.Default">—</MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">P90 duration</MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    @* ── Per-Pipeline Breakdown ──────────────────────── *@
                    <PipelineBreakdownTable Entries="@product.PipelineBreakdown" />
                }
            </MudPaper>
        }
    }

</MudContainer>

@* ── Build Summary Drawer ─────────────────────────────────────────────── *@
<MudDrawer @bind-Open="_drawerOpen"
           Anchor="Anchor.End"
           Elevation="4"
           Width="360px"
           Variant="DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
            <MudText Typo="Typo.h6">Build Summary</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           OnClick="() => _drawerOpen = false"
                           Size="Size.Small" />
        </MudStack>
    </MudDrawerHeader>

    @if (_drawerPoint is not null)
    {
        <MudContainer Class="px-4 py-2">

            @* Result badge *@
            <MudChip T="string"
                     Color="@GetResultColor(_drawerPoint.Category)"
                     Size="Size.Medium"
                     Class="mb-3">
                @FormatResultLabel(_drawerPoint.Category)
            </MudChip>

            @* Build number *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Build</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                <strong>#@_drawerPoint.Label</strong>
            </MudText>

            @* Pipeline *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Pipeline</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">@_drawerPoint.PipelineName</MudText>

            @* Start time *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Start time</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                @_drawerPoint.X.ToLocalTime().ToString("ddd MMM d, HH:mm:ss")
            </MudText>

            @* Finish time *@
            @if (!string.IsNullOrEmpty(_drawerPoint.FinishTimeString)
                 && DateTimeOffset.TryParse(_drawerPoint.FinishTimeString, out var finishDto))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Finish time</MudText>
                <MudText Typo="Typo.body1" Class="mb-3">
                    @finishDto.ToLocalTime().ToString("ddd MMM d, HH:mm:ss")
                </MudText>
            }

            @* Duration *@
            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Duration</MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                @(FormatMinutes(_drawerPoint.Y))
            </MudText>

            @* Branch *@
            @if (!string.IsNullOrEmpty(_drawerPoint.Branch))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Branch</MudText>
                <MudText Typo="Typo.body1" Class="mb-3"
                         Style="word-break:break-all;">
                    @_drawerPoint.Branch
                </MudText>
            }

            <MudDivider Class="my-3" />

            <MudText Typo="Typo.subtitle1" Class="mb-2">Build Quality</MudText>

            @if (_isDrawerBuildQualityLoading)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="140px" Class="mb-3" />
            }
            else if (!string.IsNullOrWhiteSpace(_drawerBuildQualityErrorMessage))
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                    @_drawerBuildQualityErrorMessage
                </MudAlert>
            }
            else if (_drawerBuildQuality?.Result is not null)
            {
                <BuildQualityCompactComponent Result="@_drawerBuildQuality.Result"
                                              Title="@GetDrawerBuildQualityTitle()"
                                              Elevation="0" />

                <MudGrid Spacing="2" Class="mt-2">
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Builds</MudText>
                            <MudText Typo="Typo.body2">
                                Total @_drawerBuildQuality.Result.Evidence.EligibleBuilds · Succeeded @_drawerBuildQuality.Result.Evidence.SucceededBuilds · Failed @_drawerBuildQuality.Result.Evidence.FailedBuilds · Partial @_drawerBuildQuality.Result.Evidence.PartiallySucceededBuilds
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Tests</MudText>
                            <MudText Typo="Typo.body2">
                                Total @_drawerBuildQuality.Result.Evidence.TotalTests · Passed @_drawerBuildQuality.Result.Evidence.PassedTests · N/A @_drawerBuildQuality.Result.Evidence.NotApplicableTests
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Pass rate: @BuildQualityPresentation.FormatPercent(_drawerBuildQuality.Result.Metrics.TestPassRate, _drawerBuildQuality.Result.Evidence.TestPassRateUnknown)
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Coverage</MudText>
                            <MudText Typo="Typo.body2">
                                Covered @_drawerBuildQuality.Result.Evidence.CoveredLines · Total @_drawerBuildQuality.Result.Evidence.TotalLines
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Coverage: @BuildQualityPresentation.FormatPercent(_drawerBuildQuality.Result.Metrics.Coverage, _drawerBuildQuality.Result.Evidence.CoverageUnknown)
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                    Build Quality has not been loaded for this pipeline yet.
                </MudText>
            }

            <MudDivider Class="my-3" />

            @* Azure DevOps link *@
            @if (!string.IsNullOrEmpty(_drawerPoint.Url))
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.OpenInNew"
                           Href="@_drawerPoint.Url"
                           Target="_blank"
                           FullWidth="true">
                    Open in Azure DevOps
                </MudButton>
            }
            else
            {
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    No Azure DevOps link available.
                </MudText>
            }
        </MudContainer>
    }
</MudDrawer>

@* ── Inline reusable component: TroubleEntryCard ────────────────────── *@
@* Note: placed here as a private razor component pattern via code-behind *@

@code {
    // ── State ────────────────────────────────────────────────────────────

    private bool   _isLoading;
    private string? _errorMessage;

    private int? _activeProfileId;
    private int? _selectedTeamId;
    private int? _selectedSprintId;

    private bool _includePartiallySucceeded = true;
    private bool _includeCanceled = false;
    private bool _prevIncludePartial = true;
    private bool _prevIncludeCanceled = false;

    private bool _togglesDirty =>
        _includePartiallySucceeded != _prevIncludePartial ||
        _includeCanceled           != _prevIncludeCanceled;

    private double? _sloDurationMinutes;

    // ── Filter panel state ───────────────────────────────────────────────
    private bool _filterExpanded = true;

    private List<TeamDto>   _teams   = new();
    private List<SprintDto> _sprints = new();

    private PipelineInsightsDto? _insightsData;
    private CanonicalFilterNoticeModel? _filterNotice;
    private DataStateViewModel<PipelineQueryResponseDto<PipelineInsightsDto>> _dataState = DataStateViewModel<PipelineQueryResponseDto<PipelineInsightsDto>>.NotRequested();
    private string? _pipelineQualityErrorMessage;
    private bool _isDrawerBuildQualityLoading;
    private string? _drawerBuildQualityErrorMessage;
    private SharedPipelineBuildQualityDto? _drawerBuildQuality;
    private Dictionary<int, SharedPipelineBuildQualityDto> _pipelineBuildQualityByDefinition = new();
    private CancellationTokenSource? _pipelineQualityLoadCts;

    // ── Scatter state (per product) ──────────────────────────────────────

    /// <summary>Maps ProductId → list of TimeScatterPoint (computed after data load).</summary>
    private Dictionary<int, IReadOnlyList<TimeScatterPoint>> _scatterPointsByProduct = new();

    /// <summary>Maps ProductId → set of highlighted PipelineDefinitionId. Null = no highlight.</summary>
    private Dictionary<int, IReadOnlySet<int>> _highlightByProduct = new();

    // ── Build Summary Drawer state ───────────────────────────────────────

    private bool _drawerOpen;
    private TimeScatterPoint? _drawerPoint;

    // ── Breadcrumbs ──────────────────────────────────────────────────────

    private List<BreadcrumbItem> _breadcrumbs = new();
    private IDisposable? _filterSubscription;

    // ── Lifecycle ────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        _filterSubscription = GlobalFilterStore.Subscribe(HandleGlobalFilterChanged);
        UpdateBreadcrumbs();

        _isLoading = true;
        try
        {
            var profile = await ProfileService.GetActiveProfileAsync();
            _activeProfileId = profile?.Id;

            var teams = await TeamService.GetAllTeamsAsync();
            _teams = teams.OrderBy(t => t.Name).ToList();

            await SyncStoreFromCurrentRouteAsync();
            ApplyStoreState();

            if (_selectedTeamId.HasValue)
            {
                await LoadSprintsForTeamAsync(_selectedTeamId.Value);
            }

            if (_selectedSprintId.HasValue && (!_selectedTeamId.HasValue || !_sprints.Any(s => s.Id == _selectedSprintId.Value)))
            {
                _selectedSprintId = null;
            }

            if (_selectedTeamId.HasValue && _selectedSprintId.HasValue)
            {
                await LoadInsightsAsync();
                return;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to initialize: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Event handlers ───────────────────────────────────────────────────

    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId  = teamId;
        _selectedSprintId = null;
        _insightsData    = null;
        _sprints.Clear();
        await SyncStoreFromLocalStateAsync();

        if (teamId.HasValue)
        {
            try
            {
                var sprints = await SprintService.GetSprintsForTeamAsync(teamId.Value);
                _sprints = sprints
                    .Where(s => s.StartUtc.HasValue)
                    .OrderByDescending(s => s.StartUtc)
                    .ToList();

                if (_selectedSprintId.HasValue && !_sprints.Any(s => s.Id == _selectedSprintId.Value))
                {
                    _selectedSprintId = null;
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Could not load sprints: {ex.Message}", Severity.Warning);
            }

            if (_selectedSprintId.HasValue)
            {
                UpdateContextUrl();
                StateHasChanged();
                await LoadInsightsAsync();
                return;
            }
        }

        UpdateContextUrl();
        StateHasChanged();
    }

    private async Task OnSprintChanged(int? sprintId)
    {
        _selectedSprintId = sprintId;
        _insightsData = null;
        _filterNotice = null;
        await SyncStoreFromLocalStateAsync();
        UpdateContextUrl();

        if (sprintId.HasValue)
        {
            await LoadInsightsAsync();
        }
        else
        {
            StateHasChanged();
        }
    }

    private async Task LoadInsightsAsync()
    {
        if (!_activeProfileId.HasValue || !_selectedTeamId.HasValue || !_selectedSprintId.HasValue)
            return;

        _isLoading    = true;
        _errorMessage = null;
        _scatterPointsByProduct.Clear();
        _highlightByProduct.Clear();
        _pipelineBuildQualityByDefinition.Clear();
        _pipelineQualityErrorMessage = null;
        _drawerBuildQuality = null;
        _drawerBuildQualityErrorMessage = null;
        _isDrawerBuildQualityLoading = false;
        _drawerOpen = false;
        CancelPipelineQualityLoad();
        StateHasChanged();

        try
        {
            _dataState = DataStateViewModel<PipelineQueryResponseDto<PipelineInsightsDto>>.Loading();
            var response = await PipelineStateService.GetInsightsStateAsync(
                _activeProfileId.Value,
                _selectedSprintId.Value,
                _includePartiallySucceeded,
                _includeCanceled,
                CancellationToken.None);
            _dataState = DataStateViewModel<PipelineQueryResponseDto<PipelineInsightsDto>>.FromResponse(response, "Pipeline insights could not be loaded right now.");
            if (_dataState.State is DataStateDto.NotReady or DataStateDto.Failed)
            {
                _filterNotice = null;
                _insightsData = null;
                return;
            }

            var envelope = _dataState.Data;
            _filterNotice = envelope is null ? null : CanonicalClientResponseFactory.CreateNotice(CanonicalClientResponseFactory.Create(envelope).FilterMetadata);
            _insightsData = envelope?.Data;

            _prevIncludePartial   = _includePartiallySucceeded;
            _prevIncludeCanceled  = _includeCanceled;

            // Build scatter point maps for all products
            if (_insightsData != null)
            {
                BuildScatterMaps(_insightsData);
                // Collapse filter panel once data is loaded successfully
                _filterExpanded = false;

                _ = LoadPipelineBuildQualityAsync(_selectedSprintId.Value, _insightsData);
            }
        }
        catch (Exception)
        {
            _errorMessage = "Pipeline insights could not be loaded right now. Try again later.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ── Scatter map builder ──────────────────────────────────────────────

    private void BuildScatterMaps(PipelineInsightsDto data)
    {
        _scatterPointsByProduct = new Dictionary<int, IReadOnlyList<TimeScatterPoint>>();

        foreach (var product in data.Products)
        {
            if (!product.HasData || product.ScatterPoints == null || !product.ScatterPoints.Any())
            {
                _scatterPointsByProduct[product.ProductId] = Array.Empty<TimeScatterPoint>();
                continue;
            }

            var points = product.ScatterPoints
                .Where(sp => sp.StartTime.HasValue)
                .Select(sp =>
                {
                    return new TimeScatterPoint
                    {
                        Id = sp.Id,
                        X = sp.StartTime!.Value,
                        Y = sp.DurationMinutes ?? 0,
                        Category = sp.Result ?? "Unknown",
                        Label = sp.BuildNumber ?? $"Build #{sp.TfsRunId}",
                        Metadata = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
                        {
                            ["PipelineName"] = sp.PipelineName,
                            ["PipelineDefinitionId"] = sp.PipelineDefinitionId.ToString(),
                            ["FinishTime"] = sp.FinishTime?.ToString("O") ?? string.Empty,
                            ["Branch"] = sp.Branch ?? string.Empty,
                            ["Url"] = sp.Url ?? string.Empty
                        }
                    };
                })
                .ToList();

            _scatterPointsByProduct[product.ProductId] = points;
        }
    }

    // ── Highlight interactions ────────────────────────────────────────────

    private void ToggleHighlight(int productId, int pipelineDefinitionId)
    {
        if (_highlightByProduct.TryGetValue(productId, out var existing)
            && existing.Contains(pipelineDefinitionId))
        {
            // Same pipeline clicked again — clear highlight
            _highlightByProduct.Remove(productId);
        }
        else
        {
            _highlightByProduct[productId] = new HashSet<int> { pipelineDefinitionId };
        }
        StateHasChanged();
    }

    private void ClearHighlight(int productId)
    {
        _highlightByProduct.Remove(productId);
        StateHasChanged();
    }

    // ── Navigation / Scroll ───────────────────────────────────────────────

    private async Task ScrollToProductAsync(int productId)
    {
        try
        {
            await JS.InvokeVoidAsync("PoTool.Navigation.scrollToElement", $"product-{productId}");
        }
        catch
        {
            // JS interop failures (e.g. during pre-render) are non-critical
        }
    }

    private async Task OpenBuildDrawerAsync(TimeScatterPoint point, int productId)
    {
        _drawerPoint = point;
        _drawerOpen  = true;
        _drawerBuildQuality = null;
        _drawerBuildQualityErrorMessage = null;
        _isDrawerBuildQualityLoading = true;
        StateHasChanged();

        await LoadDrawerBuildQualityAsync(point.PipelineDefinitionId);

        // Scroll the product section into view so the drawer opens next to the scatter chart
        await ScrollToProductAsync(productId);
    }

    // ── Formatting helpers ───────────────────────────────────────────────

    private static string FormatMinutes(double minutes)
    {
        if (minutes >= 60)
        {
            int h = (int)(minutes / 60);
            int m = (int)(minutes % 60);
            return m > 0 ? $"{h}h {m}m" : $"{h}h";
        }
        return $"{minutes:F0}m";
    }

    private static string FormatResultLabel(string category) =>
        category.ToUpperInvariant() switch
        {
            "SUCCEEDED"           => "Succeeded",
            "FAILED"              => "Failed",
            "PARTIALLYSUCCEEDED"  => "Partial success",
            "CANCELED"            => "Canceled",
            _                     => category
        };

    private static Color GetResultColor(string category) =>
        category.ToUpperInvariant() switch
        {
            "SUCCEEDED"           => Color.Success,
            "FAILED"              => Color.Error,
            "PARTIALLYSUCCEEDED"  => Color.Warning,
            "CANCELED"            => Color.Default,
            _                     => Color.Default
        };

    private static string FormatDelta(double? delta)
    {
        if (!delta.HasValue) return "n/a";
        if (delta.Value > 0)  return $"+{delta.Value:F1} pp";
        if (delta.Value < 0)  return $"{delta.Value:F1} pp";
        return "±0 pp";
    }

    private static Color DeltaColor(double? delta, bool lowerIsBetter = true)
    {
        if (!delta.HasValue) return Color.Default;
        if (delta.Value == 0) return Color.Default;
        bool isImprovement = lowerIsBetter ? delta.Value < 0 : delta.Value > 0;
        return isImprovement ? Color.Success : Color.Error;
    }

    // ── Navigation / Breadcrumbs ─────────────────────────────────────────

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home",         WorkspaceRoutes.Home,            icon: Icons.Material.Filled.Home),
            new("Trends (Past)",WorkspaceRoutes.TrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pipeline Insights", null, disabled: true,       icon: Icons.Material.Filled.HealthAndSafety)
        };
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }

    private async Task LoadSprintsForTeamAsync(int teamId)
    {
        var sprints = await SprintService.GetSprintsForTeamAsync(teamId);
        _sprints = sprints
            .Where(s => s.StartUtc.HasValue)
            .OrderByDescending(s => s.StartUtc)
            .ToList();
    }

    private void UpdateContextUrl()
    {
        NavigationManager.NavigateTo(
            WorkspaceQueryContextHelper.BuildRoute(
                WorkspaceRoutes.PipelineInsights,
                new WorkspaceQueryContext(TeamId: _selectedTeamId, SprintId: _selectedSprintId)),
            forceLoad: false);
    }

    private async Task LoadPipelineBuildQualityAsync(int sprintId, PipelineInsightsDto data)
    {
        if (!_activeProfileId.HasValue)
        {
            return;
        }

        CancelPipelineQualityLoad();
        var cancellationTokenSource = new CancellationTokenSource();
        _pipelineQualityLoadCts = cancellationTokenSource;
        try
        {
            var pipelineIds = data.Products
                .SelectMany(product => product.ScatterPoints ?? Array.Empty<PipelineScatterPointDto>())
                .Select(point => point.PipelineDefinitionId)
                .Where(id => id > 0)
                .Distinct()
                .ToArray();

            var loadTasks = pipelineIds.Select(async pipelineId => new
            {
                PipelineId = pipelineId,
                Detail = await BuildQualityService.GetPipelineAsync(
                    _activeProfileId.Value,
                    sprintId,
                    pipelineDefinitionId: pipelineId,
                    cancellationToken: cancellationTokenSource.Token)
            });

            var pipelineDetails = await Task.WhenAll(loadTasks);
            _pipelineBuildQualityByDefinition = pipelineDetails.ToDictionary(
                detail => detail.PipelineId,
                detail => detail.Detail);

            if (_insightsData is not null)
            {
                BuildScatterMaps(_insightsData);
            }

            if (_drawerPoint is not null)
            {
                await LoadDrawerBuildQualityAsync(_drawerPoint.PipelineDefinitionId);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _pipelineQualityErrorMessage = $"Build Quality overlay unavailable right now: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadDrawerBuildQualityAsync(int pipelineDefinitionId)
    {
        if (!_activeProfileId.HasValue || !_selectedSprintId.HasValue || pipelineDefinitionId <= 0)
        {
            _isDrawerBuildQualityLoading = false;
            return;
        }

        try
        {
            if (_pipelineBuildQualityByDefinition.TryGetValue(pipelineDefinitionId, out var cachedDetail))
            {
                _drawerBuildQuality = cachedDetail;
                return;
            }

            _drawerBuildQuality = await BuildQualityService.GetPipelineAsync(
                _activeProfileId.Value,
                _selectedSprintId.Value,
                pipelineDefinitionId: pipelineDefinitionId,
                cancellationToken: CancellationToken.None);

            _pipelineBuildQualityByDefinition[pipelineDefinitionId] = _drawerBuildQuality;
        }
        catch (Exception ex)
        {
            _drawerBuildQualityErrorMessage = $"Build Quality detail unavailable right now: {ex.Message}";
        }
        finally
        {
            _isDrawerBuildQualityLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetDrawerBuildQualityTitle()
    {
        if (_drawerBuildQuality is null)
        {
            return "Pipeline scope";
        }

        return !string.IsNullOrWhiteSpace(_drawerBuildQuality.PipelineName)
            ? _drawerBuildQuality.PipelineName!
            : "Pipeline scope";
    }

    private void CancelPipelineQualityLoad()
    {
        _pipelineQualityLoadCts?.Cancel();
        _pipelineQualityLoadCts?.Dispose();
        _pipelineQualityLoadCts = null;
    }

    private async Task SyncStoreFromCurrentRouteAsync()
        => await GlobalFilterStore.SetStateAsync(NavigationManager.Uri, _activeProfileId);

    private async Task SyncStoreFromLocalStateAsync()
        => await GlobalFilterStore.SetStateAsync(
            NavigationManager.Uri,
            _activeProfileId,
            new FilterLocalBridgeState(TeamId: _selectedTeamId, SprintId: _selectedSprintId),
            FilterUpdateSource.Ui);

    private void ApplyStoreState()
    {
        var state = GlobalFilterStore.GetState();
        _selectedTeamId = state.TeamId;
        _selectedSprintId = state.Time.Mode == FilterTimeMode.Sprint
            ? state.Time.SprintId
            : null;
    }

    private void HandleGlobalFilterChanged()
        => _ = InvokeAsync(() =>
        {
            ApplyStoreState();
            StateHasChanged();
        });

    public void Dispose()
    {
        _filterSubscription?.Dispose();
        CancelPipelineQualityLoad();
    }
}

