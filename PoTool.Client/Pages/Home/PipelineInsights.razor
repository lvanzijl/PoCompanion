    private async Task ScrollToProductAsync(int productId)
    {
        try
        {
            await JS.InvokeVoidAsync("PoTool.Navigation.scrollToElement", $"product-{productId}");
        }
        catch
        {
            // JS interop failures (e.g. during pre-render) are non-critical
        }
    }

    private async Task OpenBuildDrawerAsync(TimeScatterPoint point, int productId)
    {
        _drawerPoint = point;
        _drawerOpen  = true;
        _drawerBuildQuality = null;
        _drawerBuildQualityErrorMessage = null;
        _isDrawerBuildQualityLoading = true;
        StateHasChanged();

        await LoadDrawerBuildQualityAsync(point.PipelineDefinitionId);

        // Scroll the product section into view so the drawer opens next to the scatter chart
        await ScrollToProductAsync(productId);
    }

    // ── Formatting helpers ───────────────────────────────────────────────

    private static string FormatMinutes(double minutes)
    {
        if (minutes >= 60)
        {
            int h = (int)(minutes / 60);
            int m = (int)(minutes % 60);
            return m > 0 ? $"{h}h {m}m" : $"{h}h";
        }
        return $"{minutes:F0}m";
    }

    private static string FormatResultLabel(string category) =>
        category.ToUpperInvariant() switch
        {
            "SUCCEEDED"           => "Succeeded",
            "FAILED"              => "Failed",
            "PARTIALLYSUCCEEDED"  => "Partial success",
            "CANCELED"            => "Canceled",
            _                     => category
        };

    private static Color GetResultColor(string category) =>
        category.ToUpperInvariant() switch
        {
            "SUCCEEDED"           => Color.Success,
            "FAILED"              => Color.Error,
            "PARTIALLYSUCCEEDED"  => Color.Warning,
            "CANCELED"            => Color.Default,
            _                     => Color.Default
        };

    private static string FormatDelta(double? delta)
    {
        if (!delta.HasValue) return "n/a";
        if (delta.Value > 0)  return $"+{delta.Value:F1} pp";
        if (delta.Value < 0)  return $"{delta.Value:F1} pp";
        return "±0 pp";
    }

    private static Color DeltaColor(double? delta, bool lowerIsBetter = true)
    {
        if (!delta.HasValue) return Color.Default;
        if (delta.Value == 0) return Color.Default;
        bool isImprovement = lowerIsBetter ? delta.Value < 0 : delta.Value > 0;
        return isImprovement ? Color.Success : Color.Error;
    }

