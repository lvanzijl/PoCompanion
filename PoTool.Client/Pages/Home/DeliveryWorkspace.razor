@page "/home/delivery"
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@inherits WorkspaceBase

<PageTitle>Delivery - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4 workspace-hub">
    <MudStack Spacing="3">
        @* Workspace Header *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="workspace-hub__header">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary" Size="Size.Large" />
                        <MudText Typo="Typo.h4">
                            Delivery
                        </MudText>
                    </MudStack>

                    <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
                </MudStack>

                <CompactButton ButtonRole="ButtonRole.Utility"
                               Icon="@Icons.Material.Filled.Home"
                               OnClick="NavigateToHome">
                    Home
                </CompactButton>
            </MudStack>
        </MudPaper>

        @* Delivery Navigation *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Delivery hub</MudText>
                <MudText Typo="Typo.h5">
                    Choose a delivery view
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="workspace-hub__section-copy">
                    Open the view that best explains what landed, where it landed, or what shifted during the sprint.
                </MudText>
            </MudStack>

            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Sprint Delivery"
                                        Subtitle="Check what landed in the latest sprint"
                                        Icon="@Icons.Material.Filled.RunCircle"
                                        IconColor="Color.Success"
                                        AriaLabel="Sprint Delivery — Check what landed in the latest sprint"
                                        OnClick="NavigateToSprintDelivery" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Portfolio Delivery"
                                        Subtitle="Compare delivered work across products"
                                        Icon="@Icons.Material.Filled.Inventory2"
                                        IconColor="Color.Warning"
                                        AriaLabel="Portfolio Delivery — Compare delivered work across products"
                                        OnClick="NavigateToPortfolioDelivery" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Sprint Execution"
                                        Subtitle="Investigate churn inside the sprint"
                                        Icon="@Icons.Material.Filled.Analytics"
                                        IconColor="Color.Info"
                                        AriaLabel="Sprint Execution — Investigate churn inside the sprint"
                                        OnClick="NavigateToSprintExecution" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section workspace-hub__secondary-nav">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Other workspaces</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Need a different lens? Jump to the adjacent workspace without leaving the hub.
                </MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-2">
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Inventory2"
                               OnClick="NavigateToBacklogOverview">
                    Backlog Health
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.HealthAndSafety"
                               OnClick="NavigateToHealth">
                    Health
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Timeline"
                               OnClick="NavigateToTrends">
                    Trends (Past)
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.CalendarMonth"
                               OnClick="NavigateToPlanning">
                    Planning (Future)
                </CompactButton>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        ParseContextQueryParameters();
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Delivery", null, disabled: true, icon: Icons.Material.Filled.CheckCircle)
        };
    }

    private void NavigateToSprintDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.SprintDelivery}{BuildContextQuery()}");
    }

    private void NavigateToPortfolioDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PortfolioDelivery}{BuildContextQuery()}");
    }

    private void NavigateToSprintExecution()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.SprintExecution}{BuildContextQuery()}");
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }
}
