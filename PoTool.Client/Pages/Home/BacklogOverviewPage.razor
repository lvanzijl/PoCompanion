@page "/home/backlog-overview"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Shared.Health
@using PoTool.Shared.WorkItems
@inherits WorkspaceBase
@inject BacklogStateService BacklogStateService
@inject WorkItemService WorkItemService
@inject ProductService ProductService

<PageTitle>Backlog Overview - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Backlog Overview</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (_products.Count > 1)
                {
                    <MudSelect T="int?"
                               Value="@_selectedProductId"
                               ValueChanged="OnProductSelectedAsync"
                               Label="Product"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="false"
                               Style="min-width: 200px;">
                        @foreach (var p in _products)
                        {
                            <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Name</MudSelectItem>
                        }
                    </MudSelect>
                }
                else if (_products.Count == 1)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.Inventory2"
                             Size="Size.Small"
                             Color="Color.Primary">
                        @_products[0].Name
                    </MudChip>
                }

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (_selectedProductId == null)
    {
        <MudAlert Severity="Severity.Info">Select a product to view its backlog overview.</MudAlert>
    }
    else if (_state != null)
    {
        @* ── SECTION 1: READY FOR IMPLEMENTATION ────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">Ready for Implementation</MudText>
                <MudChip T="string" Color="Color.Success" Size="Size.Small">
                    @_readyEpics.Count epic@(_readyEpics.Count == 1 ? "" : "s")
                </MudChip>
            </MudStack>

            @if (_readyEpics.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    No epics are fully refined yet. Work through the refinement queue below.
                </MudText>
            }
            else
            {
                <MudGrid>
                    @foreach (var epic in _readyEpics)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Elevation="1"
                                     Style="cursor: pointer; border: 2px solid transparent; transition: all 0.2s;"
                                     Class="backlog-overview-card"
                                     @onclick="() => NavigateToExplorer(epic.TfsId)">
                                <MudCardContent>
                                    <MudStack Spacing="1">
                                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@epic.Title</MudText>
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small">100%</MudChip>
                                        </MudStack>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @epic.Features.Count feature@(epic.Features.Count == 1 ? "" : "s") · all ready
                                        </MudText>
                                    </MudStack>
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudPaper>

        @* ── SECTION 2: NEEDS REFINEMENT ────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">Needs Refinement</MudText>
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">
                    @_refinementEpics.Count epic@(_refinementEpics.Count == 1 ? "" : "s")
                </MudChip>
            </MudStack>

            @if (_refinementEpics.Count == 0)
            {
                <MudAlert Severity="Severity.Success">
                    All epics are fully refined — nothing needs attention here.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                    Epics sorted by refinement progress — highest first.
                    Expand an epic to review its features, then expand a feature to see individual PBI readiness.
                </MudText>

                @foreach (var epic in _refinementEpics)
                {
                    <MudExpansionPanel Class="mb-2" @key="epic.TfsId">
                        <TitleContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Style="width: 100%;">
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600; flex: 1;">
                                    @epic.Title
                                </MudText>
                                <MudProgressLinear Value="@epic.Score"
                                                   Color="@GetProgressColor(epic.Score)"
                                                   Style="width: 120px; height: 8px;"
                                                   Rounded="true" />
                                <MudTooltip Text="Percentage of features ready for implementation (average feature readiness score)">
                                    <MudText Typo="Typo.body2" Style="min-width: 40px; text-align: right;">
                                        @epic.Score%
                                    </MudText>
                                </MudTooltip>
                            </MudStack>
                        </TitleContent>
                        <ChildContent>
                            @if (epic.Features.Count == 0)
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-2">
                                    No features found under this epic.
                                </MudText>
                            }
                            else
                            {
                                @foreach (var feature in epic.Features.OrderBy(f => f.Score))
                                {
                                    <MudExpansionPanel Class="mb-1 ml-2" @key="feature.TfsId" Dense="true">
                                        <TitleContent>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
                                                <MudText Typo="Typo.body1" Style="flex: 1;">@feature.Title</MudText>
                                                <MudChip T="string"
                                                         Color="@GetOwnerColor(feature.OwnerState)"
                                                         Size="Size.Small">
                                                    @feature.OwnerState.ToString()
                                                </MudChip>
                                                <MudProgressLinear Value="@feature.Score"
                                                                   Color="@GetProgressColor(feature.Score)"
                                                                   Style="width: 80px; height: 6px;"
                                                                   Rounded="true" />
                                                <MudTooltip Text="@GetFeatureScoreTooltip(feature)">
                                                    <MudText Typo="Typo.body2" Style="min-width: 36px; text-align: right; cursor: help;">
                                                        @feature.Score%
                                                    </MudText>
                                                </MudTooltip>
                                            </MudStack>
                                        </TitleContent>
                                        <ChildContent>
                                            @if (feature.Pbis.Count == 0)
                                            {
                                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-2">
                                                    No PBIs found. Team must create and refine PBIs under this feature.
                                                </MudText>
                                            }
                                            else
                                            {
                                                <MudSimpleTable Dense="true" Hover="true" Style="margin: 0 8px 4px 8px;">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 55%;">PBI</th>
                                                            <th style="width: 35%;">Status</th>
                                                            <th style="width: 10%; text-align: right;">Ready %</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var pbi in feature.Pbis.OrderBy(p => p.Score))
                                                        {
                                                            <tr @key="pbi.TfsId">
                                                                <td>
                                                                    <MudText Typo="Typo.body2">
                                                                        @GetPbiDisplayTitle(pbi)
                                                                    </MudText>
                                                                </td>
                                                                <td>
                                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                                        @GetPbiStatusText(pbi.Score)
                                                                    </MudText>
                                                                </td>
                                                                <td style="text-align: right;">
                                                                    <MudChip T="string"
                                                                             Color="@GetProgressColor(pbi.Score)"
                                                                             Size="Size.Small">
                                                                        @pbi.Score%
                                                                    </MudChip>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </MudSimpleTable>
                                            }
                                        </ChildContent>
                                    </MudExpansionPanel>
                                }
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                }
            }
        </MudPaper>

        @* ── SECTION 3: INTEGRITY MAINTENANCE ───────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Default" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">Integrity Maintenance</MudText>
            </MudStack>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Structural integrity findings are maintenance items. They do not affect refinement scores.
            </MudText>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                @if (_siIssueCount == 0)
                {
                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Medium">
                        No structural issues
                    </MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Error" Icon="@Icons.Material.Filled.Error" Size="Size.Medium">
                        @_siIssueCount structural issue@(_siIssueCount == 1 ? "" : "s")
                    </MudChip>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.OpenInNew"
                               OnClick="NavigateToSiQueue">
                        Open Validation Queue
                    </MudButton>
                }
            </MudStack>
        </MudPaper>

        @* ── CROSS-WORKSPACE NAVIGATION ──────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .backlog-overview-card:hover {
        border-color: var(--mud-palette-success) !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.15) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private List<BreadcrumbItem> _breadcrumbs = new();

    // Products
    private List<ProductDto> _products = new();
    private int? _selectedProductId;

    // Loaded backlog state
    private ProductBacklogStateDto? _state;
    private List<EpicRefinementDto> _readyEpics = new();
    private List<EpicRefinementDto> _refinementEpics = new();

    // SI count (integrity maintenance)
    private int _siIssueCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ParseContextQueryParameters();

            if (!await EnsureProfileAsync(WorkspaceRoutes.BacklogOverview))
            {
                return;
            }

            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                return;
            }

            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();

            // Resolve initial product selection:
            //  1. Explicit query param
            //  2. Auto-select when only one product exists
            if (ProductId.HasValue && _products.Any(p => p.Id == ProductId.Value))
            {
                _selectedProductId = ProductId.Value;
            }
            else if (_products.Count == 1)
            {
                _selectedProductId = _products[0].Id;
            }

            if (_selectedProductId.HasValue)
            {
                await LoadDataAsync(_selectedProductId.Value);
            }

            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load backlog overview: {ex.Message}";
            Console.WriteLine($"[BacklogOverview] {_loadError}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnProductSelectedAsync(int? productId)
    {
        _selectedProductId = productId;
        if (productId.HasValue)
        {
            _isLoading = true;
            _loadError = null;
            StateHasChanged();
            try
            {
                await LoadDataAsync(productId.Value);
            }
            catch (Exception ex)
            {
                _loadError = $"Failed to load backlog overview: {ex.Message}";
                Console.WriteLine($"[BacklogOverview] {_loadError}");
            }
            finally
            {
                _isLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task LoadDataAsync(int productId)
    {
        _state = await BacklogStateService.GetBacklogStateAsync(productId);
        if (_state != null)
        {
            _readyEpics = _state.Epics.Where(e => e.Score == 100).ToList();
            _refinementEpics = _state.Epics
                .Where(e => e.Score < 100)
                .OrderByDescending(e => e.Score)
                .ToList();
        }

        // Load SI count from validation triage (product-scoped)
        var summary = await WorkItemService.GetValidationTriageSummaryAsync(new[] { productId });
        _siIssueCount = summary?.StructuralIntegrity.TotalItemCount ?? 0;
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Backlog Overview", null, disabled: true, icon: Icons.Material.Filled.Inventory2)
        };
    }

    private void NavigateToExplorer(int rootWorkItemId)
    {
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.WorkItems}?rootWorkItemId={rootWorkItemId}");
    }

    private void NavigateToSiQueue()
    {
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery("category=SI")}");
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace2}{BuildContextQuery()}");
    }

    private static string GetPbiDisplayTitle(PbiReadinessDto pbi) =>
        string.IsNullOrWhiteSpace(pbi.Title) ? $"PBI #{pbi.TfsId}" : pbi.Title;

    private static Color GetProgressColor(int score) => score switch
    {
        100 => Color.Success,
        >= 70 => Color.Info,
        >= 40 => Color.Warning,
        _ => Color.Error
    };

    private static Color GetOwnerColor(FeatureOwnerState state) => state switch
    {
        FeatureOwnerState.Ready => Color.Success,
        FeatureOwnerState.Team => Color.Info,
        FeatureOwnerState.PO => Color.Error,
        _ => Color.Default
    };

    private static string GetFeatureScoreTooltip(FeatureRefinementDto feature) => feature.Score switch
    {
        0  => "0% — Feature has no description. PO must write the description before refinement can begin.",
        25 => "25% — Feature has a description but no PBIs yet. Team must create and refine PBIs.",
        100 => "100% — All PBIs have description and story points. Feature is ready for implementation.",
        _  => $"{feature.Score}% — Average PBI readiness: {feature.Pbis.Count(p => p.Score == 100)} of {feature.Pbis.Count} PBIs fully ready."
    };

    private static string GetPbiStatusText(int score) => score switch
    {
        100 => "Ready — has description and story points",
        75  => "Needs story points — description present",
        0   => "Needs description",
        _   => $"Partial readiness"
    };
}
