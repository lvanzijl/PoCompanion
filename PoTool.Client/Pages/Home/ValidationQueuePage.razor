@page "/home/validation-queue"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Shared.WorkItems
@using System.Web
@inherits WorkspaceBase
@inject WorkItemService WorkItemService
@inject ProductService ProductService

<PageTitle>Validation Queue - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Queue" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">Validation Queue</MudText>
                </MudStack>
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (ProductId.HasValue && _productName != null)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Size="Size.Small"
                             Color="Color.Primary"
                             OnClose="ClearProductFilter">
                        @_productName
                    </MudChip>
                }
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="NavigateToTriage">
                    Validation Triage
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_loadError != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
    }
    else if (_queue != null)
    {
        @* Category summary header *@
        <MudPaper Elevation="1" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@ValidationCategoryMeta.GetIcon(_queue.CategoryKey)" Color="@ValidationCategoryMeta.GetColor(_queue.CategoryKey)" Size="Size.Large" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h5">@_queue.CategoryLabel</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @_queue.TotalItemCount work item@(_queue.TotalItemCount == 1 ? "" : "s") affected across @_queue.RuleGroups.Count rule@(_queue.RuleGroups.Count == 1 ? "" : "s")
                    </MudText>
                </MudStack>
                @if (_queue.TotalItemCount > 0)
                {
                    <MudChip T="string"
                             Color="@ValidationCategoryMeta.GetColor(_queue.CategoryKey)"
                             Size="Size.Medium">
                        @_queue.TotalItemCount items
                    </MudChip>
                }
            </MudStack>
        </MudPaper>

        @if (_queue.RuleGroups.Count == 0)
        {
            <MudAlert Severity="Severity.Success">
                No validation issues found for this category. 
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Click <strong>Start fix session</strong> to work through items for a specific rule.
                Items are sorted by number of affected work items (most impactful first).
            </MudText>

            <MudGrid>
                @foreach (var group in _queue.RuleGroups)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="2" Style="height: 100%;" Class="validation-queue-card">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudStack Spacing="0">
                                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@group.ShortTitle</MudText>
                                        </MudStack>
                                        <MudChip T="string"
                                                 Color="@ValidationCategoryMeta.GetColor(_queue.CategoryKey)"
                                                 Size="Size.Medium">
                                            @group.ItemCount
                                        </MudChip>
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>

                            <MudCardContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @group.ItemCount work item@(group.ItemCount == 1 ? "" : "s") @(group.ItemCount == 1 ? "needs" : "need") attention
                                </MudText>
                            </MudCardContent>

                            <MudCardActions>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.PlayArrow"
                                           FullWidth="true"
                                           OnClick="@(() => StartFixSession(group.RuleId))">
                                    Start fix session
                                </MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    }
</MudContainer>

<style>
    .validation-queue-card {
        border: 2px solid transparent;
        transition: all 0.2s;
    }
    .validation-queue-card:hover {
        border-color: var(--mud-palette-primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.15) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private string? _loadError;
    private string? _productName;
    private string _categoryKey = string.Empty;
    private ValidationQueueDto? _queue;
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ParseContextQueryParameters();

            // Read the required 'category' query parameter
            var uri = new Uri(NavigationManager.Uri);
            var queryParams = HttpUtility.ParseQueryString(uri.Query);
            _categoryKey = queryParams["category"] ?? string.Empty;

            if (string.IsNullOrWhiteSpace(_categoryKey))
            {
                _loadError = "Missing required query parameter: category";
                return;
            }

            if (!await EnsureProfileAsync())
            {
                return;
            }

            var activeProfile = await ProfileService.GetActiveProfileAsync();

            // Load products for the active profile
            var profileProducts = activeProfile != null
                ? (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList()
                : new List<PoTool.Client.ApiClient.ProductDto>();

            // Resolve product name for context chip
            if (ProductId.HasValue)
            {
                _productName = profileProducts.FirstOrDefault(p => p.Id == ProductId.Value)?.Name;
            }

            // Determine which product IDs to pass to the backend
            int[]? productIds = ProductId.HasValue
                ? new[] { ProductId.Value }
                : profileProducts.Select(p => p.Id).ToArray();

            if (productIds.Length == 0)
            {
                productIds = null;
            }

            _queue = await WorkItemService.GetValidationQueueAsync(_categoryKey, productIds);
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load validation queue: {ex.Message}";
            Console.WriteLine($"[ValidationQueue] {_loadError}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void UpdateBreadcrumbs()
    {
        var categoryLabel = _queue?.CategoryLabel ?? _categoryKey;
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Health", WorkspaceRoutes.HealthWorkspace, icon: Icons.Material.Filled.HealthAndSafety),
            new("Validation Triage", WorkspaceRoutes.ValidationTriage, icon: Icons.Material.Filled.FactCheck),
            new($"{categoryLabel} Queue", null, disabled: true, icon: Icons.Material.Filled.Queue)
        };
    }

    private void StartFixSession(string ruleId)
    {
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationFix}{BuildContextQuery($"category={Uri.EscapeDataString(_categoryKey)}&ruleId={Uri.EscapeDataString(ruleId)}")}");
    }

    private void NavigateToTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void ClearProductFilter()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationQueue}?category={Uri.EscapeDataString(_categoryKey)}");
    }
}
