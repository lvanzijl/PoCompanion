@page "/home/planning"
@using PoTool.Client.Components.Common
@using PoTool.Client.Models
@inject NavigationManager NavigationManager

<PageTitle>Planning - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Planning
                    </MudText>
                </MudStack>

                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToHome">
                Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @* Planning Tools *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h5" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
            Planning Tools
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Structure, sequence and validate upcoming work
        </MudText>

        <MudGrid>
            @* Product Roadmaps *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="1"
                         Style="cursor: pointer; transition: all 0.2s;"
                         Class="mud-card-hover"
                         @onclick="NavigateToProductRoadmaps">
                    <MudCardContent Class="d-flex flex-column align-center pa-4">
                        <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Info" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1" Class="mt-2">Product Roadmaps</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Strategic ordering of epics and product direction</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            @* Plan Board (placeholder) *@
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="1"
                         Style="transition: all 0.2s; opacity: 0.7;"
                         Class="mud-card-hover">
                    <MudCardContent Class="d-flex flex-column align-center pa-4">
                        <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Color="Color.Default" Size="Size.Large" />
                        <MudText Typo="Typo.subtitle1" Class="mt-2">Plan Board</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Iteration planning board for organizing upcoming sprint work</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="mt-2">Coming soon</MudChip>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Cross-Workspace Navigation *@
    <MudPaper Elevation="2" Class="pa-4">
        <MudText Typo="Typo.h6" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
            Navigate to Other Workspaces
        </MudText>

        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Inventory2"
                       OnClick="NavigateToBacklogOverview">
                Backlog Overview
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.HealthAndSafety"
                       OnClick="NavigateToHealth">
                Health (Now)
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Info"
                       StartIcon="@Icons.Material.Filled.Timeline"
                       OnClick="NavigateToTrends">
                Trends (Past)
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="NavigateToDelivery">
                Delivery
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Planning", null, disabled: true, icon: Icons.Material.Filled.CalendarMonth)
        };
    }

    private void NavigateToProductRoadmaps()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.ProductRoadmaps);
    }

    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.HealthWorkspace);
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.TrendsWorkspace);
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.DeliveryWorkspace);
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BacklogOverview);
    }
}
