@page "/home/planning"
@using PoTool.Client.Components.Common
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@inherits WorkspaceBase
@inject GlobalFilterRouteService GlobalFilterRouteService

<PageTitle>Planning - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4 workspace-hub">
    <MudStack Spacing="3">
        @* Workspace Header *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="workspace-hub__header">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" Size="Size.Large" />
                        <MudText Typo="Typo.h4">
                            Planning
                        </MudText>
                    </MudStack>

                    <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
                </MudStack>

                <CompactButton ButtonRole="ButtonRole.Utility"
                               Icon="@Icons.Material.Filled.Home"
                               OnClick="NavigateToHome">
                    Home
                </CompactButton>
            </MudStack>
        </MudPaper>

        @* Planning Navigation *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Planning hub</MudText>
                <MudText Typo="Typo.h5">
                    Choose a planning view
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="workspace-hub__section-copy">
                    Open the workspace that helps you sequence roadmap decisions or place work into upcoming sprints.
                </MudText>
            </MudStack>

            <MudGrid Spacing="2" Class="mt-1">
                @if (!string.IsNullOrWhiteSpace(ProjectAlias))
                {
                    <MudItem xs="12" sm="6" md="4">
                        <NavigationTileCard Title="Project Overview"
                                            Subtitle="Review project-wide planning signals before drilling in"
                                            Icon="@Icons.Material.Filled.FolderSpecial"
                                            IconColor="Color.Info"
                                            AriaLabel="Project Overview — Review project-wide planning signals before drilling in"
                                            OnClick="NavigateToProjectOverview" />
                    </MudItem>
                }
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Product Roadmaps"
                                        Subtitle="Review epic order before roadmap changes"
                                        Icon="@Icons.Material.Filled.Map"
                                        IconColor="Color.Info"
                                        AriaLabel="Product Roadmaps — Review epic order before roadmap changes"
                                        OnClick="NavigateToProductRoadmaps" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Plan Board"
                                        Subtitle="Place upcoming work into target sprints"
                                        Icon="@Icons.Material.Filled.ViewColumn"
                                        IconColor="Color.Info"
                                        AriaLabel="Plan Board — Place upcoming work into target sprints"
                                        OnClick="NavigateToPlanBoard" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Multi-Product Planning"
                                        Subtitle="Align timelines across all products on a shared axis"
                                        Icon="@Icons.Material.Filled.AccountTree"
                                        IconColor="Color.Info"
                                        AriaLabel="Multi-Product Planning — Align timelines across all products on a shared axis"
                                        OnClick="NavigateToMultiProductPlanning" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section workspace-hub__secondary-nav">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Other workspaces</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Switch to delivery, trends, or health when you need a different decision context.
                </MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-2">
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Inventory2"
                               OnClick="NavigateToBacklogOverview">
                    Backlog Health
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.HealthAndSafety"
                               OnClick="NavigateToHealth">
                    Health
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Timeline"
                               OnClick="NavigateToTrends">
                    Trends (Past)
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.CheckCircle"
                               OnClick="NavigateToDelivery">
                    Delivery
                </CompactButton>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        ParseContextQueryParameters();
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Planning", null, disabled: true, icon: Icons.Material.Filled.CalendarMonth)
        };
    }

    private async Task NavigateToProductRoadmaps()
    {
        var targetUri = await GlobalFilterRouteService.BuildPlanningPageUriAsync(
            "ProductRoadmaps",
            ProjectId ?? ProjectAlias,
            ProductId,
            WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri));
        NavigationManager.NavigateTo(targetUri);
    }

    private async Task NavigateToPlanBoard()
    {
        var targetUri = await GlobalFilterRouteService.BuildPlanningPageUriAsync(
            "PlanBoard",
            ProjectId ?? ProjectAlias,
            ProductId,
            WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri));
        NavigationManager.NavigateTo(targetUri);
    }

    private async Task NavigateToProjectOverview()
    {
        if (string.IsNullOrWhiteSpace(ProjectId) && string.IsNullOrWhiteSpace(ProjectAlias))
        {
            return;
        }

        var targetUri = await GlobalFilterRouteService.BuildPlanningPageUriAsync(
            "ProjectPlanningOverview",
            ProjectId ?? ProjectAlias,
            ProductId,
            WorkspaceQueryContextHelper.ExtractAdditionalParameters(NavigationManager.Uri));
        NavigationManager.NavigateTo(targetUri);
    }

    private void NavigateToMultiProductPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.MultiProductPlanning}{BuildContextQuery()}");
    }

    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.DeliveryWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }
}
