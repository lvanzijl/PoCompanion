@page "/home/health"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Shared.WorkItems
@using PoTool.Shared.Health
@inherits WorkspaceBase
@inject INavigationContextService NavigationContextService
@inject WorkItemService WorkItemService
@inject ProductService ProductService
@inject IWorkItemsClient WorkItemsClient

<PageTitle>Health (Now) - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Health (Now)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.AccessTime" 
                         Size="Size.Small"
                         Color="Color.Success">
                    Current State
                </MudChip>
                
                @* Suggestion 4: Product context chip with clear button *@
                @if (ProductId.HasValue && _productName != null)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Size="Size.Small"
                             Color="Color.Primary"
                             OnClose="ClearProductFilter">
                        @_productName
                    </MudChip>
                }
                
                @* Suggestion 3: Bug Triage as primary action in Health workspace *@
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.BugReport"
                               OnClick="NavigateToBugTriage">
                    Bug Triage
                </CompactButton>
                
                @* Phase 1: Validation Triage as primary entry point for validation work *@
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.FactCheck"
                               OnClick="NavigateToValidationTriage">
                    Validation Triage
                </CompactButton>
                
                    <CompactButton ButtonRole="ButtonRole.Utility"
                                   Icon="@Icons.Material.Filled.Home"
                                   OnClick="NavigateToHome">
                        Home
                    </CompactButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* ── COMPACT SIGNALS BAR ───────────────────────────────────────────────── *@
        <MudPaper Elevation="1" Class="pa-2 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight:600;">Refinement:</MudText>
                <MudChip T="string"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.Warning"
                         Color="@GetHealthColorBySeverity(_refinementReadinessCount, HealthSignalSeverity.Warning)"
                         OnClick='() => NavigateToValidationCategory(ValidationCategory.RefinementReadiness)'
                         Style="cursor:pointer;">
                    Blockers · @_refinementReadinessCount
                </MudChip>
                <MudChip T="string"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.EditNote"
                         Color="@GetHealthColorBySeverity(_refinementCompletenessCount, HealthSignalSeverity.Warning)"
                         OnClick='() => NavigateToValidationCategory(ValidationCategory.RefinementCompleteness)'
                         Style="cursor:pointer;">
                    Needed · @_refinementCompletenessCount
                </MudChip>
                <MudDivider Vertical="true" FlexItem="true" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-weight:600;">Integrity:</MudText>
                <MudChip T="string"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.Build"
                         Color="@GetHealthColorBySeverity(_structuralIntegrityCount, HealthSignalSeverity.Error)"
                         OnClick='() => NavigateToValidationCategory(ValidationCategory.StructuralIntegrity)'
                         Style="cursor:pointer;">
                    Errors · @_structuralIntegrityCount
                </MudChip>
            </MudStack>
        </MudPaper>

        @* ── PER-PRODUCT TILES ────────────────────────────────────────────────── *@
        @if (_profileProducts.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">No products configured for this profile.</MudAlert>
        }
        else
        {
            <MudGrid Class="mb-4">
                @foreach (var product in _profileProducts)
                {
                    var stats = GetProductStats(product.Id);
                    <MudItem xs="12" md="6" lg="4" @key="product.Id">
                        <MudCard Elevation="2" Class="health-product-card">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                        <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Size="Size.Small" />
                                        <MudText Typo="Typo.h6" Class="health-product-title">@product.Name</MudText>
                                    </MudStack>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent Class="pt-0">
                                @if (stats == null)
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">No backlog data available.</MudText>
                                }
                                else
                                {
                                    @* Ready-to-pick-up + features ready in pending *@
                                    <MudGrid Spacing="2" Class="mb-3">
                                        <MudItem xs="6">
                                            <MudPaper Elevation="0" Class="pa-2 health-tile-stat health-tile-stat--success">
                                                <MudText Typo="Typo.h5" Color="Color.Success" Class="health-tile-stat-value">@stats.ReadyEffort</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">ready story points</MudText>
                                            </MudPaper>
                                        </MudItem>
                                        <MudItem xs="6">
                                            <MudPaper Elevation="0" Class="pa-2 health-tile-stat health-tile-stat--info">
                                                <MudText Typo="Typo.h5" Color="Color.Info" Class="health-tile-stat-value">@stats.FeaturesReadyInPendingEpics</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">features ready in pending epics</MudText>
                                            </MudPaper>
                                        </MudItem>
                                    </MudGrid>

                                    @* Top 3 epics closest to ready *@
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="health-tile-section-label mb-1">
                                        Closest to ready
                                    </MudText>
                                    <MudSimpleTable Dense="true" Class="health-epic-table">
                                        <tbody>
                                            @for (int i = 0; i < 3; i++)
                                            {
                                                int idx = i;
                                                @if (idx < stats.TopEpics.Count)
                                                {
                                                    var epic = stats.TopEpics[idx];
                                                    <tr @key="epic.TfsId">
                                                        <td class="health-epic-title-cell">
                                                            <MudText Typo="Typo.body2" Class="health-epic-title-text">@epic.Title</MudText>
                                                        </td>
                                                        <td class="health-epic-score-cell">
                                                            <MudChip T="string" Size="Size.Small" Color="@GetEpicScoreColor(epic.Score)" Class="health-epic-score-chip">
                                                                @epic.Score%
                                                            </MudChip>
                                                        </td>
                                                        <td class="health-epic-effort-cell">
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@epic.Effort sp</MudText>
                                                        </td>
                                                    </tr>
                                                }
                                                else
                                                {
                                                    <tr @key="@($"empty-{idx}")">
                                                        <td colspan="3" class="health-epic-empty-cell">—</td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </MudSimpleTable>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                <CompactButton ButtonRole="ButtonRole.Action"
                                               Icon="@Icons.Material.Filled.OpenInNew"
                                               OnClick="() => NavigateToBacklogOverviewForProduct(product.Id)">
                                    Backlog Overview
                                </CompactButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Inventory2"
                               OnClick="NavigateToBacklogOverview">
                    Backlog Overview
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Timeline"
                               OnClick="NavigateToTrends">
                    Trends (Past)
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.CalendarMonth"
                               OnClick="NavigateToPlanning">
                    Planning (Future)
                </CompactButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }

    /* Per-product tile card */
    .health-product-card  { height: 100%; }
    .health-product-title { font-weight: 600; }

    /* Per-product tile stats */
    .health-tile-stat {
        border-radius: 8px;
        text-align: center;
    }
    .health-tile-stat--success { background: rgba(76, 175, 80, 0.1); border: 1px solid rgba(76, 175, 80, 0.3); }
    .health-tile-stat--info    { background: rgba(33, 150, 243, 0.1); border: 1px solid rgba(33, 150, 243, 0.3); }
    .health-tile-stat-value    { font-weight: 700; }

    /* Section label above top-3 table */
    .health-tile-section-label {
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: block;
    }

    /* Top-3 epics table */
    .health-epic-table         { font-size: 0.82rem; }
    .health-epic-title-cell    { max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .health-epic-title-text    { font-size: 0.82rem; }
    .health-epic-score-cell    { text-align: right; white-space: nowrap; padding-left: 8px; }
    .health-epic-score-chip    { font-size: 0.75rem; height: 20px; }
    .health-epic-effort-cell   { text-align: right; white-space: nowrap; padding-left: 4px; }
    .health-epic-empty-cell    { color: var(--mud-palette-text-disabled); font-style: italic; font-size: 0.8rem; }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private ProfileDto? _activeProfile;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string? _productName;

    // Products for the active profile
    private List<ProductDto> _profileProducts = new();

    // Per-product backlog state
    private Dictionary<int, ProductBacklogStateDto?> _productBacklogStates = new();

    // Validation issue counts by category
    private int _structuralIntegrityCount;
    private int _refinementReadinessCount;
    private int _refinementCompletenessCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Parse context from query string (inherited from base class)
            ParseContextQueryParameters();

            if (!await EnsureProfileAsync())
            {
                return;
            }

            _activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = _activeProfile?.Id;

            await LoadDataAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            // Reset counts before loading
            _structuralIntegrityCount = 0;
            _refinementReadinessCount = 0;
            _refinementCompletenessCount = 0;

            // Get products for the active profile
            if (_activeProfile != null)
            {
                _profileProducts = (await ProductService.GetProductsByOwnerAsync(_activeProfile.Id)).ToList();
            }
            else
            {
                _profileProducts = (await ProductService.GetAllProductsAsync()).ToList();
            }

            // Resolve product name for context chip
            if (ProductId.HasValue)
            {
                _productName = _profileProducts.FirstOrDefault(p => p.Id == ProductId.Value)?.Name;
            }

            var productIds = _profileProducts.Select(p => p.Id).ToArray();

            // Load validation counts and per-product backlog states in parallel
            var validationTask = LoadValidationCountsAsync(productIds);
            var backlogTask = LoadBacklogStatesAsync(_profileProducts);
            await Task.WhenAll(validationTask, backlogTask);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[HealthWorkspace] Failed to load data: {ex.Message}");
        }
    }

    private async Task LoadValidationCountsAsync(int[] productIds)
    {
        try
        {
            var workItemsWithValidation = await WorkItemService.GetAllWithValidationAsync(productIds);
            var workItemsList = workItemsWithValidation.ToList();

            var workItemsByCategory = new Dictionary<ValidationCategory, HashSet<int>>
            {
                { ValidationCategory.StructuralIntegrity, new HashSet<int>() },
                { ValidationCategory.RefinementReadiness, new HashSet<int>() },
                { ValidationCategory.RefinementCompleteness, new HashSet<int>() }
            };

            foreach (var wi in workItemsList)
            {
                if (wi.ValidationIssues != null)
                {
                    foreach (var issue in wi.ValidationIssues)
                    {
                        var category = GetCategoryFromRuleId(issue.RuleId);
                        if (category.HasValue)
                        {
                            workItemsByCategory[category.Value].Add(wi.TfsId);
                        }
                    }
                }
            }

            _structuralIntegrityCount = workItemsByCategory[ValidationCategory.StructuralIntegrity].Count;
            _refinementReadinessCount = workItemsByCategory[ValidationCategory.RefinementReadiness].Count;
            _refinementCompletenessCount = workItemsByCategory[ValidationCategory.RefinementCompleteness].Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[HealthWorkspace] Failed to load validation counts: {ex.Message}");
        }
    }

    private async Task LoadBacklogStatesAsync(List<ProductDto> products)
    {
        _productBacklogStates = new Dictionary<int, ProductBacklogStateDto?>();
        using var semaphore = new SemaphoreSlim(5, 5);
        var tasks = products.Select(async p =>
        {
            await semaphore.WaitAsync();
            try
            {
                var state = await WorkItemsClient.GetBacklogStateAsync(p.Id);
                return (p.Id, state);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[HealthWorkspace] Failed to load backlog state for product {p.Id}: {ex.Message}");
                return (p.Id, (ProductBacklogStateDto?)null);
            }
            finally
            {
                semaphore.Release();
            }
        });

        var results = await Task.WhenAll(tasks);
        foreach (var (id, state) in results)
        {
            _productBacklogStates[id] = state;
        }
    }

    // ── Per-product stats helpers ────────────────────────────────────────────

    private sealed record EpicSummary(int TfsId, string Title, int Score, int Effort);

    private sealed record ProductBacklogStats(
        int ReadyEffort,
        int FeaturesReadyInPendingEpics,
        IReadOnlyList<EpicSummary> TopEpics);

    private ProductBacklogStats? GetProductStats(int productId)
    {
        if (!_productBacklogStates.TryGetValue(productId, out var state) || state == null)
            return null;

        var readyEpics = state.Epics.Where(e => e.Score == 100).ToList();
        var pendingEpics = state.Epics.Where(e => e.Score < 100).ToList();

        int readyEffort = readyEpics
            .SelectMany(e => e.Features)
            .SelectMany(f => f.Pbis)
            .Sum(p => p.Effort ?? 0);

        int featuresReadyInPending = pendingEpics
            .SelectMany(e => e.Features)
            .Count(f => f.Score == 100);

        var topEpics = state.Epics
            .OrderByDescending(e => e.Score)
            .Take(3)
            .Select(e => new EpicSummary(
                e.TfsId,
                e.Title,
                e.Score,
                e.Features.SelectMany(f => f.Pbis).Sum(p => p.Effort ?? 0)))
            .ToList();

        return new ProductBacklogStats(readyEffort, featuresReadyInPending, topEpics);
    }

    // ── Navigation helpers ───────────────────────────────────────────────────

    /// <summary>
    /// Determines the validation category from a rule ID.
    /// Maps rule ID prefixes to ValidationCategory enum values.
    /// </summary>
    private ValidationCategory? GetCategoryFromRuleId(string? ruleId)
    {
        if (string.IsNullOrEmpty(ruleId))
        {
            return null;
        }

        // Rule IDs follow pattern: SI-1, RR-1, RC-1
        if (ruleId.StartsWith("SI-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.StructuralIntegrity;
        }
        else if (ruleId.StartsWith("RR-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.RefinementReadiness;
        }
        else if (ruleId.StartsWith("RC-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.RefinementCompleteness;
        }

        return null;
    }

    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Health (Now)", null, disabled: true, icon: Icons.Material.Filled.HealthAndSafety)
        };
    }

    private void NavigateToValidationCategory(ValidationCategory category)
    {
        var categoryKey = category switch
        {
            ValidationCategory.StructuralIntegrity    => "SI",
            ValidationCategory.RefinementReadiness    => "RR",
            ValidationCategory.RefinementCompleteness => "RC",
            _                                         => "SI"
        };
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery($"category={categoryKey}")}");
    }

    private void NavigateToBugOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BugOverview}{BuildContextQuery()}");
    }

    private void NavigateToValidationTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void NavigateToBugTriage()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage);
    }

    private void ClearProductFilter()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.HealthWorkspace);
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverviewForProduct(int productId)
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}?productId={productId}");
    }

    // ── Color helpers ────────────────────────────────────────────────────────

    /// <summary>
    /// Enum representing the severity level of a health signal.
    /// </summary>
    private enum HealthSignalSeverity
    {
        Error,
        Warning,
        Info
    }

    /// <summary>
    /// Gets the color based on severity and count.
    /// - Count == 0: Neutral (Default/Gray) - indicates no detected issues, not necessarily "good"
    /// - Count > 0 with Error severity: Error (Red) - critical issues requiring immediate attention
    /// - Count > 0 with Warning severity: Warning (Yellow/Orange) - important issues requiring attention
    /// - Count > 0 with Info severity: Info (Blue) - informational issues
    /// </summary>
    private Color GetHealthColorBySeverity(int count, HealthSignalSeverity severity)
    {
        if (count == 0)
        {
            return Color.Default;
        }

        return severity switch
        {
            HealthSignalSeverity.Error => Color.Error,
            HealthSignalSeverity.Warning => Color.Warning,
            HealthSignalSeverity.Info => Color.Info,
            _ => Color.Default
        };
    }

    private static Color GetEpicScoreColor(int score) => score switch
    {
        100 => Color.Success,
        >= 70 => Color.Info,
        >= 40 => Color.Warning,
        _ => Color.Error
    };
}
