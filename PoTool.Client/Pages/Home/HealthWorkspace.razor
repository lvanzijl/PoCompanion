@page "/home/health"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.BacklogHealth
@using PoTool.Client.ApiClient
@using PoTool.Shared.WorkItems
@inherits WorkspaceBase
@inject INavigationContextService NavigationContextService
@inject WorkItemService WorkItemService
@inject ProductService ProductService

<PageTitle>Health (Now) - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Health (Now)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.AccessTime" 
                         Size="Size.Small"
                         Color="Color.Success">
                    Current State
                </MudChip>
                
                @* Suggestion 4: Product context chip with clear button *@
                @if (ProductId.HasValue && _productName != null)
                {
                    <MudChip T="string"
                             Icon="@Icons.Material.Filled.FilterAlt"
                             Size="Size.Small"
                             Color="Color.Primary"
                             OnClose="ClearProductFilter">
                        @_productName
                    </MudChip>
                }
                
                @* Suggestion 3: Bug Triage as primary action in Health workspace *@
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           StartIcon="@Icons.Material.Filled.BugReport"
                           OnClick="NavigateToBugTriage">
                    Bug Triage
                </MudButton>
                
                @* Phase 1: Validation Triage as primary entry point for validation work *@
                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.FactCheck"
                           OnClick="NavigateToValidationTriage">
                    Validation Triage
                </MudButton>
                
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Default"
                               StartIcon="@Icons.Material.Filled.Home"
                               OnClick="NavigateToHome">
                        Home
                    </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* ── REFINEMENT SIGNALS ────────────────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Warning" />
                <MudText Typo="Typo.h5">Refinement Signals</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                These signals affect backlog readiness. Click a card to navigate to related work items.
            </MudText>

            @* 
                Decision #2: Health Signal Thresholds
                Decision #9: Single click = navigate immediately
                Decision #10: Show "0 items" badge (don't hide empty cards)
            *@
            <MudGrid>
                @* Refinement Readiness Validation Category *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToValidationCategory(ValidationCategory.RefinementReadiness)'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@GetHealthColorBySeverity(_refinementReadinessCount, HealthSignalSeverity.Warning)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Refinement blockers</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetHealthColorBySeverity(_refinementReadinessCount, HealthSignalSeverity.Warning)">
                                @_refinementReadinessCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Refinement Completeness Validation Category *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToValidationCategory(ValidationCategory.RefinementCompleteness)'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Warning" Color="@GetHealthColorBySeverity(_refinementCompletenessCount, HealthSignalSeverity.Warning)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Refinement needed</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetHealthColorBySeverity(_refinementCompletenessCount, HealthSignalSeverity.Warning)">
                                @_refinementCompletenessCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Bug Overview Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBugOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="@GetHealthColor(_bugCount)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bugs</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetHealthColor(_bugCount)">
                                @_bugCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* ── INTEGRITY (MAINTENANCE) ──────────────────────────────────────────── *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Default" />
                <MudText Typo="Typo.h5">Integrity (Maintenance)</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Structural integrity findings are maintenance items. They do <strong>not</strong> affect refinement scores or backlog readiness.
            </MudText>

            <MudGrid>
                @* Structural Integrity Validation Category *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToValidationCategory(ValidationCategory.StructuralIntegrity)'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Color="@GetHealthColorBySeverity(_structuralIntegrityCount, HealthSignalSeverity.Error)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Structural integrity errors</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetHealthColorBySeverity(_structuralIntegrityCount, HealthSignalSeverity.Error)">
                                @_structuralIntegrityCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Backlog Health Panel - Embedded iteration-level health analysis *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
                    Backlog Health Analysis
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           OnClick="NavigateToBacklogOverview">
                    Backlog Overview
                </MudButton>
            </MudStack>
            
            <BacklogHealthPanel MaxIterations="3" />
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.Inventory2"
                           OnClick="NavigateToBacklogOverview">
                    Backlog Overview
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private ProfileDto? _activeProfile;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string? _productName;
    
    // Validation issue counts by category
    private int _structuralIntegrityCount;
    private int _refinementReadinessCount;
    private int _refinementCompletenessCount;
    private int _bugCount;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Parse context from query string (inherited from base class)
            ParseContextQueryParameters();
            
            if (!await EnsureProfileAsync(WorkspaceRoutes.HealthWorkspace))
            {
                return;
            }
            
            _activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = _activeProfile?.Id;
            
            await LoadValidationCountsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task LoadValidationCountsAsync()
    {
        try
        {
            // Reset counts before loading
            _structuralIntegrityCount = 0;
            _refinementReadinessCount = 0;
            _refinementCompletenessCount = 0;
            _bugCount = 0;
            
            // Get products for the active profile (matching WorkItemExplorer approach)
            List<ProductDto> profileProducts;
            
            if (_activeProfile != null)
            {
                // Load products for the active profile (Product Owner)
                profileProducts = (await ProductService.GetProductsByOwnerAsync(_activeProfile.Id)).ToList();
                Console.WriteLine($"[HealthWorkspace] Loaded {profileProducts.Count} products for active profile '{_activeProfile.Name}' (ID: {_activeProfile.Id})");
            }
            else
            {
                // No active profile - load all products as fallback
                profileProducts = (await ProductService.GetAllProductsAsync()).ToList();
                Console.WriteLine($"[HealthWorkspace] No active profile, loaded all {profileProducts.Count} products");
            }
            
            // Resolve product name for context chip (Suggestion 4)
            if (ProductId.HasValue)
            {
                _productName = profileProducts.FirstOrDefault(p => p.Id == ProductId.Value)?.Name;
            }
            
            // Extract product IDs to pass to the backend for efficient filtering
            var productIds = profileProducts.Select(p => p.Id).ToArray();
            Console.WriteLine($"[HealthWorkspace] Loading work items for {productIds.Length} products: {string.Join(", ", productIds)}");
            
            // Load work items with validation, filtered by product IDs (matching WorkItemExplorer)
            var workItemsWithValidation = await WorkItemService.GetAllWithValidationAsync(productIds);
            var workItemsList = workItemsWithValidation.ToList();
            Console.WriteLine($"[HealthWorkspace] Loaded {workItemsList.Count} total work items from product hierarchies");
            
            // Track which work items have issues in each validation category
            var workItemsByCategory = new Dictionary<ValidationCategory, HashSet<int>>
            {
                { ValidationCategory.StructuralIntegrity, new HashSet<int>() },
                { ValidationCategory.RefinementReadiness, new HashSet<int>() },
                { ValidationCategory.RefinementCompleteness, new HashSet<int>() }
            };
            
            foreach (var wi in workItemsList)
            {
                if (wi.Type == "Bug")
                {
                    _bugCount++;
                }
                
                if (wi.ValidationIssues != null)
                {
                    foreach (var issue in wi.ValidationIssues)
                    {
                        // Determine category from rule ID prefix
                        var category = GetCategoryFromRuleId(issue.RuleId);
                        if (category.HasValue)
                        {
                            workItemsByCategory[category.Value].Add(wi.TfsId);
                        }
                    }
                }
            }
            
            _structuralIntegrityCount = workItemsByCategory[ValidationCategory.StructuralIntegrity].Count;
            _refinementReadinessCount = workItemsByCategory[ValidationCategory.RefinementReadiness].Count;
            _refinementCompletenessCount = workItemsByCategory[ValidationCategory.RefinementCompleteness].Count;
            
            Console.WriteLine($"[HealthWorkspace] Validation counts - SI: {_structuralIntegrityCount}, RR: {_refinementReadinessCount}, RC: {_refinementCompletenessCount}, Bugs: {_bugCount}");
        }
        catch (Exception ex)
        {
            // Log the error but keep counts at 0
            Console.WriteLine($"[HealthWorkspace] Failed to load validation counts: {ex.Message}");
        }
    }
    
    /// <summary>
    /// Determines the validation category from a rule ID.
    /// Maps rule ID prefixes to ValidationCategory enum values.
    /// </summary>
    private ValidationCategory? GetCategoryFromRuleId(string? ruleId)
    {
        if (string.IsNullOrEmpty(ruleId))
        {
            return null;
        }
        
        // Rule IDs follow pattern: SI-1, RR-1, RC-1
        if (ruleId.StartsWith("SI-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.StructuralIntegrity;
        }
        else if (ruleId.StartsWith("RR-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.RefinementReadiness;
        }
        else if (ruleId.StartsWith("RC-", StringComparison.OrdinalIgnoreCase))
        {
            return ValidationCategory.RefinementCompleteness;
        }
        
        return null;
    }
    
    private void UpdateBreadcrumbs()
    {
            _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Health (Now)", null, disabled: true, icon: Icons.Material.Filled.HealthAndSafety)
        };
    }
    
    private void NavigateToValidationCategory(ValidationCategory category)
    {
        // Phase 4: navigate to the Validation Queue for the selected category;
        // Explorer is now "advanced inspection" only and is no longer the primary entry.
        var categoryKey = category switch
        {
            ValidationCategory.StructuralIntegrity    => "SI",
            ValidationCategory.RefinementReadiness    => "RR",
            ValidationCategory.RefinementCompleteness => "RC",
            _                                         => "SI"
        };
        NavigationManager.NavigateTo(
            $"{WorkspaceRoutes.ValidationQueue}{BuildContextQuery($"category={categoryKey}")}");
    }
    
    private void NavigateToBugOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BugOverview}{BuildContextQuery()}");
    }
    
    private void NavigateToValidationTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void NavigateToBugTriage()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BugTriage);
    }
    
    private void ClearProductFilter()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.HealthWorkspace);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace2}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }

    
    /// <summary>
    /// Enum representing the severity level of a health signal.
    /// </summary>
    private enum HealthSignalSeverity
    {
        Error,
        Warning,
        Info
    }
    
    /// <summary>
    /// Gets the color based on severity and count.
    /// - Count == 0: Neutral (Default/Gray) - indicates no detected issues, not necessarily "good"
    /// - Count > 0 with Error severity: Error (Red) - critical issues requiring immediate attention
    /// - Count > 0 with Warning severity: Warning (Yellow/Orange) - important issues requiring attention
    /// - Count > 0 with Info severity: Info (Blue) - informational issues
    /// </summary>
    private Color GetHealthColorBySeverity(int count, HealthSignalSeverity severity)
    {
        if (count == 0)
        {
            // Zero count is neutral - absence of detected issues, not a positive indicator
            return Color.Default;
        }
        
        return severity switch
        {
            HealthSignalSeverity.Error => Color.Error,
            HealthSignalSeverity.Warning => Color.Warning,
            HealthSignalSeverity.Info => Color.Info,
            _ => Color.Default
        };
    }
    
    /// <summary>
    /// Legacy method for bug count - uses old threshold-based approach.
    /// Kept for backward compatibility with Bug Overview signal.
    /// </summary>
    private Color GetHealthColor(int count) => count switch
    {
        0 => Color.Success,
        < 10 => Color.Info,
        < 50 => Color.Warning,
        _ => Color.Error
    };
}
