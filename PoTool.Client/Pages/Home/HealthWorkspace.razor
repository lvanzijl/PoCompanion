@page "/home/health"
@using PoTool.Client.Components.Common
@inherits WorkspaceBase
@using PoTool.Client.Models

<PageTitle>Health - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-4 workspace-hub">
    <MudStack Spacing="3">
        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="workspace-hub__header">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" Size="Size.Large" />
                        <MudText Typo="Typo.h4">
                            Health
                        </MudText>
                    </MudStack>

                    <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
                </MudStack>

                <CompactButton ButtonRole="ButtonRole.Utility"
                               Icon="@Icons.Material.Filled.Home"
                               OnClick="NavigateToHome">
                    Home
                </CompactButton>
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Health hub</MudText>
                <MudText Typo="Typo.h5">
                    Choose a health view
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="workspace-hub__section-copy">
                    Start from the health hub, then open the Build Quality overview, validation triage, or backlog health detail you need.
                </MudText>
            </MudStack>

            <MudGrid Spacing="2" Class="mt-1">
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Overview"
                                        Subtitle="Review the current Build Quality summary"
                                        Icon="@Icons.Material.Filled.Assessment"
                                        IconColor="Color.Success"
                                        AriaLabel="Overview — Review the current Build Quality summary"
                                        OnClick="NavigateToOverview" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Validation Triage"
                                        Subtitle="Review structural and refinement issues"
                                        Icon="@Icons.Material.Filled.RuleFolder"
                                        IconColor="Color.Warning"
                                        AriaLabel="Validation Triage — Review structural and refinement issues"
                                        OnClick="NavigateToValidationTriage" />
                </MudItem>
                <MudItem xs="12" sm="6" md="4">
                    <NavigationTileCard Title="Backlog Health"
                                        Subtitle="Open backlog readiness and refinement detail"
                                        Icon="@Icons.Material.Filled.Inventory2"
                                        IconColor="Color.Info"
                                        AriaLabel="Backlog Health — Open backlog readiness and refinement detail"
                                        OnClick="NavigateToBacklogOverview" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-3 workspace-hub__section workspace-hub__secondary-nav">
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Other workspaces</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Need a different lens? Move to delivery, trends, or planning without loading health data first.
                </MudText>
            </MudStack>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mt-2">
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.CheckCircle"
                               OnClick="NavigateToDelivery">
                    Delivery
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.Timeline"
                               OnClick="NavigateToTrends">
                    Trends (Past)
                </CompactButton>
                <CompactButton ButtonRole="ButtonRole.Action"
                               Icon="@Icons.Material.Filled.CalendarMonth"
                               OnClick="NavigateToPlanning">
                    Planning (Future)
                </CompactButton>
            </MudStack>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private readonly List<BreadcrumbItem> _breadcrumbs = new();

    protected override void OnInitialized()
    {
        ParseContextQueryParameters();
        _breadcrumbs.Add(new BreadcrumbItem("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home));
        _breadcrumbs.Add(new BreadcrumbItem("Health", null, disabled: true, icon: Icons.Material.Filled.HealthAndSafety));
    }

    private void NavigateToOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.HealthOverview}{BuildContextQuery()}");
    }

    private void NavigateToValidationTriage()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.ValidationTriage}{BuildContextQuery()}");
    }

    private void NavigateToBacklogOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BacklogOverview}{BuildContextQuery()}");
    }

    private void NavigateToDelivery()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.DeliveryWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.TrendsWorkspace}{BuildContextQuery()}");
    }

    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.PlanningWorkspace}{BuildContextQuery()}");
    }
}
