@page "/settings/products"
@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Settings
@using PoTool.Client.ApiClient
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ErrorMessageService ErrorMessageService

<PageTitle>Manage Products</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudStack Spacing="4">
        @* Header *@
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h4">Manage Products</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Manage all products across all Product Owners
                </MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2">
                <MudSwitch @bind-Value="_showOnlyOrphans" 
                           Label="Show Only Orphans" 
                           Color="Color.Warning" />
                <CompactButton Variant="Variant.Filled" 
                               Color="Color.Primary"
                               OnClick="OpenAddProduct"
                               StartIcon="@Icons.Material.Filled.Add">
                    Add Product
                </CompactButton>
            </MudStack>
        </MudStack>

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        }
        else if (_errorResponse != null)
        {
            <ErrorDisplay ErrorResponse="@_errorResponse" OnDismiss="ClearError" />
        }
        else
        {
            @* Orphan Warning Banner *@
            @if (_orphanCount > 0 && !_showOnlyOrphans)
            {
                <MudAlert Severity="Severity.Warning" Dense="true">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.body2">
                            <strong>@_orphanCount orphaned product@(_orphanCount == 1 ? "" : "s")</strong> need assignment to a Product Owner
                        </MudText>
                        <CompactButton Variant="Variant.Text" 
                                       Color="Color.Default"
                                       OnClick="@(() => _showOnlyOrphans = true)"
                                       Size="Size.Small">
                            Show Orphans
                        </CompactButton>
                    </MudStack>
                </MudAlert>
            }

            @* Product List *@
            @if (_products != null && _products.Any())
            {
                <MudPaper Elevation="1" Class="pa-2">
                    <CompactList T="string">
                        @foreach (var product in GetFilteredProducts())
                        {
                            <MudListItem T="string">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                                        <MudAvatar Size="Size.Medium">
                                            <MudImage Src="@GetProductImagePath(product)" Alt="@product.Name" />
                                        </MudAvatar>
                                        <MudStack Spacing="0">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body1"><strong>@product.Name</strong></MudText>
                                                @if (product.ProductOwnerId == null)
                                                {
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Orphan</MudChip>
                                                }
                                            </MudStack>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                Work Item: @product.BacklogRootWorkItemId
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @if (product.ProductOwnerId.HasValue)
                                                {
                                                    <span>Owner: Product Owner #@product.ProductOwnerId | </span>
                                                }
                                                @product.TeamIds.Count team(s) linked
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                    <MudStack Row="true" Spacing="1">
                                        <CompactIconButton Icon="@Icons.Material.Filled.Edit" 
                                                       Color="Color.Primary" 
                                                       OnClick="@(() => EditProduct(product))" />
                                        <CompactIconButton Icon="@Icons.Material.Filled.Delete" 
                                                       Color="Color.Error" 
                                                       OnClick="@(() => DeleteProduct(product))" />
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                            <MudDivider />
                        }
                    </CompactList>
                </MudPaper>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Dense="true">
                    @if (_showOnlyOrphans)
                    {
                        <MudText Typo="Typo.body1">
                            No orphaned products. All products are assigned to Product Owners.
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.body1">
                            No products yet. Create your first product to get started.
                        </MudText>
                    }
                </MudAlert>
            }

            @* Editor Panel *@
            @if (_showEditor)
            {
                <ProductEditor ProductOwnerId="@_editingProductOwnerId" 
                               Product="@_editingProduct" 
                               OnSaved="OnProductSaved" 
                               OnCancelled="CloseEditor" />
            }
        }
    </MudStack>
</MudContainer>

@code {
    private IEnumerable<ProductDto>? _products;
    private bool _isLoading = true;
    private bool _showOnlyOrphans = false;
    private bool _showEditor = false;
    private int _orphanCount = 0;
    private ProductDto? _editingProduct;
    private int _editingProductOwnerId = 0;
    private ErrorResponse? _errorResponse;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            _isLoading = true;
            ClearError();
            
            _products = await ProductService.GetAllProductsAsync();
            _orphanCount = _products.Count(p => p.ProductOwnerId == null);
        }
        catch (Exception ex)
        {
            _errorResponse = ErrorMessageService.GetErrorResponse(ex, "Error loading products");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<ProductDto> GetFilteredProducts()
    {
        if (_products == null) return Enumerable.Empty<ProductDto>();
        
        return _showOnlyOrphans 
            ? _products.Where(p => p.ProductOwnerId == null)
            : _products;
    }

    private void OpenAddProduct()
    {
        _editingProduct = null;
        _editingProductOwnerId = 0; // Will create orphan product
        _showEditor = true;
    }

    private void EditProduct(ProductDto product)
    {
        _editingProduct = product;
        _editingProductOwnerId = product.ProductOwnerId ?? 0;
        _showEditor = true;
    }

    private async Task DeleteProduct(ProductDto product)
    {
        var orphanWarning = product.ProductOwnerId == null 
            ? " This orphaned product has no owner." 
            : "";
        
        var result = await DialogService.ShowMessageBox(
            "Delete Product",
            $"Are you sure you want to delete the product '{product.Name}'?{orphanWarning} This action cannot be undone.",
            yesText: "Delete",
            cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                var deleted = await ProductService.DeleteProductAsync(product.Id);
                if (deleted)
                {
                    Snackbar.Add($"Product '{product.Name}' deleted", Severity.Success);
                    await LoadProductsAsync();
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting product: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OnProductSaved()
    {
        _showEditor = false;
        _editingProduct = null;
        await LoadProductsAsync();
    }

    private void CloseEditor()
    {
        _showEditor = false;
        _editingProduct = null;
    }

    private string GetProductImagePath(ProductDto product)
    {
        return $"images/profiles/profile-{product.DefaultPictureId}.png";
    }

    private void ClearError()
    {
        _errorResponse = null;
    }
}
