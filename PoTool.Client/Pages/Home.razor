@page "/"
@using PoTool.Client.Components.Common
@using static PoTool.Client.Components.Common.PageHelp
@inject NavigationManager Navigation

<PageTitle>PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Welcome to PO Companion"
              Description="PO Companion is your comprehensive Azure DevOps work item management tool. This dashboard provides quick access to all major features for tracking work items, analyzing metrics, and managing your development process."
              Class="mb-6"
              BestPractices="@_homeBestPractices">
        <MudText Typo="Typo.body2" Paragraph="true">
            <strong>Getting Started:</strong>
        </MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Settings">
                <strong>Step 1:</strong> Configure your Azure DevOps connection in the Configuration page
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Sync">
                <strong>Step 2:</strong> Sync your work items to pull data from Azure DevOps
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.Explore">
                <strong>Step 3:</strong> Explore features like Work Items, PR Insights, and Velocity Dashboard
            </MudListItem>
        </MudList>
    </PageHelp>
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
        Welcome to PO Companion
    </MudText>
    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-8" Color="Color.Secondary">
        Your Azure DevOps work item management companion
    </MudText>

    <MudGrid Spacing="4" Justify="Justify.Center">
        <FeatureCard 
            Icon="@Icons.Material.Filled.List"
            IconColor="Color.Primary"
            Title="Work Items"
            Description="View and manage your work items in a hierarchical tree structure with real-time sync."
            ButtonText="Go to Work Items"
            ButtonColor="Color.Primary"
            Href="/workitems" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Insights"
            IconColor="Color.Tertiary"
            Title="PR Insight"
            Description="Analyze pull request metrics, track iteration patterns, and identify bottlenecks with visual dashboards."
            ButtonText="Go to PR Insights"
            ButtonColor="Color.Tertiary"
            Href="/pr-insights" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.TrendingUp"
            IconColor="Color.Success"
            Title="Velocity Dashboard"
            Description="Track team velocity and sprint metrics for data-driven sprint planning and forecasting."
            ButtonText="View Velocity"
            ButtonColor="Color.Success"
            Href="/velocity" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Settings"
            IconColor="Color.Secondary"
            Title="Configuration"
            Description="Configure your Azure DevOps connection settings and Personal Access Token."
            ButtonText="Go to Config"
            ButtonColor="Color.Secondary"
            Href="/tfsconfig" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Help"
            IconColor="Color.Info"
            Title="Help & Data Requirements"
            Description="Learn about data requirements and validation rules for getting the most from PO Companion features."
            ButtonText="View Help"
            ButtonColor="Color.Info"
            Href="/help" />
    </MudGrid>

    <MudPaper Elevation="0" Class="pa-6 mt-8">
        <MudText Typo="Typo.h5" GutterBottom="true">Getting Started</MudText>
        <MudStack Spacing="2" Class="mt-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>Configure your Azure DevOps connection in the Configuration page</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>View and explore your work items in the Work Items page</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>Use filters to find specific work items quickly</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private List<string> _homeBestPractices = new()
    {
        "Start by configuring your Azure DevOps connection with a valid Personal Access Token (PAT)",
        "Ensure your PAT has 'Work Items (Read)' permissions at minimum",
        "Perform a full sync on first use to populate all work items",
        "Use incremental sync for daily updates to save time",
        "Explore each feature to understand data quality requirements",
        "Check the Help page for detailed information about TFS data requirements"
    };
}
