@page "/"
@using PoTool.Client.Components.Common
@inject NavigationManager Navigation

<PageTitle>PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
        Welcome to PO Companion
    </MudText>
    <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-8" Color="Color.Secondary">
        Your Azure DevOps work item management companion
    </MudText>

    <MudGrid Spacing="4" Justify="Justify.Center">
        <FeatureCard 
            Icon="@Icons.Material.Filled.List"
            IconColor="Color.Primary"
            Title="Work Items"
            Description="View and manage your work items in a hierarchical tree structure with real-time sync."
            ButtonText="Go to Work Items"
            ButtonColor="Color.Primary"
            Href="/workitems" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Insights"
            IconColor="Color.Tertiary"
            Title="PR Insight"
            Description="Analyze pull request metrics, track iteration patterns, and identify bottlenecks with visual dashboards."
            ButtonText="Go to PR Insights"
            ButtonColor="Color.Tertiary"
            Href="/pr-insights" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Settings"
            IconColor="Color.Secondary"
            Title="Configuration"
            Description="Configure your Azure DevOps connection settings and Personal Access Token."
            ButtonText="Go to Config"
            ButtonColor="Color.Secondary"
            Href="/tfsconfig" />

        <FeatureCard 
            Icon="@Icons.Material.Filled.Sync"
            IconColor="Color.Info"
            Title="Real-time Sync"
            Description="Automatically synchronize work items with Azure DevOps via SignalR."
            ButtonText="Coming Soon"
            ButtonColor="Color.Info"
            Href="#"
            IsDisabled="true" />
    </MudGrid>

    <MudPaper Elevation="0" Class="pa-6 mt-8">
        <MudText Typo="Typo.h5" GutterBottom="true">Getting Started</MudText>
        <MudStack Spacing="2" Class="mt-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>Configure your Azure DevOps connection in the Configuration page</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>View and explore your work items in the Work Items page</MudText>
            </MudStack>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                <MudText>Use filters to find specific work items quickly</MudText>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudContainer>
