@page "/onboarding"
@using PoTool.Client.Services
@inject IDialogService DialogService
@inject StartupGateNotificationService StartupGateNotificationService

<MudContainer MaxWidth="MaxWidth.False" Style="height: 100vh; display: flex; align-items: center; justify-content: center;">
    <!-- Wizard will be shown as dialog automatically -->
</MudContainer>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ShowOnboardingWizardAsync();
        }
    }

    private async Task ShowOnboardingWizardAsync()
    {
        var options = new DialogOptions 
        { 
            CloseButton = false,
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        
        var dialogReference = await DialogService.ShowAsync<PoTool.Client.Components.Onboarding.OnboardingWizard>("Getting Started", options);
        await dialogReference.Result;
        StartupGateNotificationService.RequestReevaluation();
    }
}
