@using MudBlazor

@* Bar chart showing time open distribution for pull requests *@

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" GutterBottom="true">Time Open Distribution</MudText>
    <MudChart ChartType="ChartType.Bar" 
              Width="100%" 
              Height="300px"
              InputData="@TimeOpenData" 
              InputLabels="@TimeOpenLabels"
              ChartOptions="@ChartOptions">
    </MudChart>
</MudPaper>

@code {
    /// <summary>
    /// Data values for the time open chart
    /// </summary>
    [Parameter]
    public double[] TimeOpenData { get; set; } = Array.Empty<double>();

    /// <summary>
    /// Labels for the time open chart
    /// </summary>
    [Parameter]
    public string[] TimeOpenLabels { get; set; } = Array.Empty<string>();

    /// <summary>
    /// Chart options for customizing the appearance
    /// </summary>
    [Parameter]
    public ChartOptions? ChartOptions { get; set; }
}
