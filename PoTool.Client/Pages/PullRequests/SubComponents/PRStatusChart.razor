@using MudBlazor

@* Donut chart showing PR status distribution *@

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" GutterBottom="true">PR Status Distribution</MudText>
    <MudChart ChartType="ChartType.Donut" 
              Width="300px" 
              Height="300px"
              InputData="@StatusData" 
              InputLabels="@StatusLabels">
    </MudChart>
</MudPaper>

@code {
    /// <summary>
    /// Data values for the status chart
    /// </summary>
    [Parameter]
    public double[] StatusData { get; set; } = Array.Empty<double>();

    /// <summary>
    /// Labels for the status chart
    /// </summary>
    [Parameter]
    public string[] StatusLabels { get; set; } = Array.Empty<string>();
}
