@page "/pr-insights"
@implements IDisposable
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Components.Common
@using PoTool.Client.Pages.PullRequests.SubComponents
@using static PoTool.Client.Components.Common.PageHelp
@inject PullRequestService PullRequestService
@inject PullRequestMetricsService MetricsService
@inject ErrorMessageService ErrorMessageService
@inject ProductService ProductService
@inject ProfileService ProfileService
@inject IPreferencesService PreferencesService

<PageTitle>PR Insight Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Pull Request Insights Guide"
              Description="The PR Insights Dashboard analyzes pull request metrics to help identify bottlenecks in your code review process. Track metrics like time open, iteration counts, and file changes to optimize your development workflow."
              Class="mb-4"
              DataRequirements="@_prDataRequirements"
              BestPractices="@_prBestPractices"
              CommonIssues="@_prCommonIssues">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
            <strong>Linking PRs to Work Items:</strong> Use "AB#[WorkItemId]" in commit messages or PR descriptions to link pull requests to work items (e.g., "Fix login bug AB#12345"). This enables better traceability and sprint analysis.
        </MudAlert>
    </PageHelp>
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" /> PR Insight Dashboard
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        Pull request metrics and analytics for the last 6 months
    </MudText>

    @* Product Selector *@
    @if (_products.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
                <MudSelect T="int" 
                           Value="@_selectedProductId"
                           ValueChanged="OnProductChanged"
                           Label="Filter by Product"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 300px;">
                    <MudSelectItem T="int" Value="@AllProductsId">All products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Showing PRs for: @GetProductScopeDescription() (last 6 months)
                </MudText>
            </MudStack>
        </MudPaper>
    }

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && !_metrics.Any())
    {
        @if (_selectedProductId != AllProductsId)
        {
            @* Show product-specific message *@
            var product = _products.FirstOrDefault(p => p.Id == _selectedProductId);
            var hasRepositories = product?.Repositories?.Any() ?? false;

            if (!hasRepositories)
            {
                <EmptyStateDisplay Title="No Repositories Configured"
                                   Message="@($"The product '{product?.Name}' has no repositories configured. To view PR insights, configure at least one repository in the product settings. PR data is automatically synced when the product is synced.")">
                    <MudButton Color="Color.Primary" 
                               Variant="Variant.Filled"
                               Href="/settings/products"
                               StartIcon="@Icons.Material.Filled.Settings">
                        Configure Repositories
                    </MudButton>
                </EmptyStateDisplay>
            }
            else
            {
                <EmptyStateDisplay Title="No Pull Request Data Available"
                                   Message="There are no pull requests to display. PR data is automatically synced when the product is synced. If you just configured repositories, please sync the product from the Product Home page." />
            }
        }
        else
        {
            @* All products view *@
            var anyProductsWithRepositories = _products.Any(p => p.Repositories?.Any() ?? false);

            if (!anyProductsWithRepositories)
            {
                <EmptyStateDisplay Title="No Repositories Configured"
                                   Message="None of the products have repositories configured. To view PR insights, configure at least one repository in the product settings. PR data is automatically synced when products are synced.">
                    <MudButton Color="Color.Primary" 
                               Variant="Variant.Filled"
                               Href="/settings/products"
                               StartIcon="@Icons.Material.Filled.Settings">
                        Configure Repositories
                    </MudButton>
                </EmptyStateDisplay>
            }
            else
            {
                <EmptyStateDisplay Title="No Pull Request Data Available"
                                   Message="There are no pull requests to display. PR data is automatically synced when products are synced." />
            }
        }
    }
    else
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />
        
        <!-- Top Metrics Cards -->
        <PRMetricsSummaryPanel TotalPRs="@_metrics.Count().ToString()"
                              AvgTimeOpen="@GetAverageTimeOpen()"
                              AvgIterations="@GetAverageIterations()"
                              AvgFiles="@GetAverageFiles()" />

        <!-- Date Range Filter -->
        <PRDateRangeFilter DateRange="@_dateRange"
                          OnApplyFilter="@ApplyDateFilter"
                          OnClearFilter="@ClearDateFilter" />

        <!-- Tabs for different views -->
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <PRStatusChart StatusData="@GetStatusData()" 
                                      StatusLabels="@GetStatusLabels()" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PRTimeOpenChart TimeOpenData="@GetTimeOpenData()" 
                                        TimeOpenLabels="@GetTimeOpenLabels()"
                                        ChartOptions="@_barChartOptions" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="By User" Icon="@Icons.Material.Filled.People">
                <PRUserChart UserData="@GetPRsByUserData()" 
                            UserLabels="@GetUserLabels()"
                            ChartOptions="@_barChartOptions" />
            </MudTabPanel>

            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.List">
                <MudDataGrid Items="@_metrics" 
                             Filterable="true" 
                             SortMode="SortMode.Multiple"
                             Dense="true"
                             Hover="true">
                    <Columns>
                        <PropertyColumn Property="x => x.Title" Title="Title" />
                        <PropertyColumn Property="x => x.CreatedBy" Title="Author" />
                        <PropertyColumn Property="x => x.Status" Title="Status">
                            <CellTemplate>
                                <MudChip Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">
                                    @context.Item.Status
                                </MudChip>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.TotalTimeOpen" Title="Time Open" Format="d\d\ hh\h\ mm\m" />
                        <PropertyColumn Property="x => x.IterationCount" Title="Iterations" />
                        <PropertyColumn Property="x => x.TotalFileCount" Title="Files" />
                        <PropertyColumn Property="x => x.CommentCount" Title="Comments" />
                    </Columns>
                </MudDataGrid>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private List<PullRequestMetricsDto> _metrics = new();
    private List<PullRequestMetricsDto> _allMetrics = new();
    private bool _isLoading = true;
    private DateRange? _dateRange;
    private ErrorResponse? _errorResponse;

    // Product filtering state
    private const int AllProductsId = 0;
    private List<ProductDto> _products = new();
    private int _selectedProductId = AllProductsId;
    private CancellationTokenSource? _dataLoadCts;

    private ChartOptions _barChartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10
    };
    
    // Cached chart data for memoization
    private int _cachedMetricsHashCode = 0;
    private double[]? _cachedStatusData;
    private string[]? _cachedStatusLabels;
    private double[]? _cachedTimeOpenData;
    private string[]? _cachedTimeOpenLabels;
    private double[]? _cachedPRsByUserData;
    private string[]? _cachedUserLabels;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
        await LoadSelectedProductIdAsync();
        
        // Create initial cancellation token source
        _dataLoadCts = new CancellationTokenSource();
        
        try
        {
            await LoadData(_dataLoadCts.Token);
        }
        catch (OperationCanceledException)
        {
            Console.WriteLine("[PRInsight] Initial data load cancelled");
        }
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile != null)
            {
                var products = await ProductService.GetProductsByOwnerAsync(activeProfile.Id);
                _products = products.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PRInsight] Error loading products: {ex.Message}");
            _products = new List<ProductDto>();
        }
    }

    private async Task LoadSelectedProductIdAsync()
    {
        try
        {
            var savedProductId = await PreferencesService.GetIntAsync("PRInsight_SelectedProductId");
            if (savedProductId.HasValue)
            {
                // Validate that the product still exists
                if (savedProductId.Value == AllProductsId || _products.Any(p => p.Id == savedProductId.Value))
                {
                    _selectedProductId = savedProductId.Value;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PRInsight] Error loading saved product selection: {ex.Message}");
        }
    }

    private async Task OnProductChanged(int newProductId)
    {
        if (_selectedProductId == newProductId)
        {
            return; // No change
        }

        _selectedProductId = newProductId;

        // Cancel any pending data load to prevent race conditions
        _dataLoadCts?.Cancel();
        _dataLoadCts?.Dispose();
        _dataLoadCts = new CancellationTokenSource();

        // Save preference
        await PreferencesService.SetIntAsync("PRInsight_SelectedProductId", _selectedProductId);

        // Show loading indicator while reloading data
        _isLoading = true;
        StateHasChanged();

        try
        {
            // Reload data with new filter
            await LoadData(_dataLoadCts.Token);
        }
        catch (OperationCanceledException)
        {
            // Ignore cancellation - user switched products again
            Console.WriteLine("[PRInsight] Data load cancelled due to product change");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private string GetProductScopeDescription()
    {
        if (_selectedProductId == AllProductsId)
        {
            return "All products";
        }

        var product = _products.FirstOrDefault(p => p.Id == _selectedProductId);
        return product?.Name ?? "Unknown product";
    }

    private async Task LoadData(CancellationToken cancellationToken = default)
    {
        _isLoading = true;
        try
        {
            ClearError();
            
            // Build product IDs parameter for filtering
            string? productIdsParam = null;
            if (_selectedProductId == AllProductsId && _products.Any())
            {
                productIdsParam = string.Join(",", _products.Select(p => p.Id));
            }
            else if (_selectedProductId != AllProductsId)
            {
                productIdsParam = _selectedProductId.ToString();
            }
            
            // Note: The backend now enforces a 6-month time window by default
            // No need to pass fromDate explicitly - the handler applies the cutoff automatically
            var metrics = await PullRequestService.GetMetricsAsync(productIdsParam);
            
            // Check if cancelled before updating state
            cancellationToken.ThrowIfCancellationRequested();
            
            _allMetrics = metrics.ToList();
            _metrics = _allMetrics;
            InvalidateCache();
            
            // Log for debugging
            Console.WriteLine($"[PRInsight] Loaded {_metrics.Count} PR metrics for product scope: {GetProductScopeDescription()}");
        }
        catch (OperationCanceledException)
        {
            // Re-throw to let caller handle
            throw;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PRInsight] Error loading pull request metrics: {ex.Message}");
            ShowError(ex, "Error loading pull request metrics");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyDateFilter()
    {
        if (_dateRange == null || (!_dateRange.Start.HasValue && !_dateRange.End.HasValue))
        {
            _metrics = _allMetrics;
            InvalidateCache();
            return;
        }

        _metrics = MetricsService.FilterByDateRange(
            _allMetrics,
            _dateRange.Start,
            _dateRange.End).ToList();

        InvalidateCache();
        StateHasChanged();
    }

    private void ClearDateFilter()
    {
        _dateRange = null;
        _metrics = _allMetrics;
        InvalidateCache();
        StateHasChanged();
    }
    
    private void InvalidateCache()
    {
        _cachedMetricsHashCode = MetricsService.CalculateMetricsHashCode(_metrics);
        _cachedStatusData = null;
        _cachedStatusLabels = null;
        _cachedTimeOpenData = null;
        _cachedTimeOpenLabels = null;
        _cachedPRsByUserData = null;
        _cachedUserLabels = null;
    }
    
    private bool IsCacheValid()
    {
        var currentHash = MetricsService.CalculateMetricsHashCode(_metrics);
        return currentHash == _cachedMetricsHashCode;
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    // Metrics calculations
    private string GetAverageTimeOpen()
    {
        return MetricsService.CalculateAverageTimeOpen(_metrics);
    }

    private string GetAverageIterations()
    {
        return MetricsService.CalculateAverageIterations(_metrics);
    }

    private string GetAverageFiles()
    {
        return MetricsService.CalculateAverageFiles(_metrics);
    }

    // Chart data methods with memoization
    private double[] GetStatusData()
    {
        if (IsCacheValid() && _cachedStatusData != null)
            return _cachedStatusData;
        
        var (data, _) = MetricsService.GetStatusChartData(_metrics);
        _cachedStatusData = data;
        return _cachedStatusData;
    }

    private string[] GetStatusLabels()
    {
        if (IsCacheValid() && _cachedStatusLabels != null)
            return _cachedStatusLabels;
        
        var (_, labels) = MetricsService.GetStatusChartData(_metrics);
        _cachedStatusLabels = labels;
        return _cachedStatusLabels;
    }

    private double[] GetTimeOpenData()
    {
        if (IsCacheValid() && _cachedTimeOpenData != null)
            return _cachedTimeOpenData;
        
        var (data, _) = MetricsService.GetTimeOpenChartData(_metrics);
        _cachedTimeOpenData = data;
        return _cachedTimeOpenData;
    }

    private string[] GetTimeOpenLabels()
    {
        if (IsCacheValid() && _cachedTimeOpenLabels != null)
            return _cachedTimeOpenLabels;
        
        var (_, labels) = MetricsService.GetTimeOpenChartData(_metrics);
        _cachedTimeOpenLabels = labels;
        return _cachedTimeOpenLabels;
    }

    private double[] GetPRsByUserData()
    {
        if (IsCacheValid() && _cachedPRsByUserData != null)
            return _cachedPRsByUserData;
        
        var (data, _) = MetricsService.GetPRsByUserChartData(_metrics);
        _cachedPRsByUserData = data;
        return _cachedPRsByUserData;
    }

    private string[] GetUserLabels()
    {
        if (IsCacheValid() && _cachedUserLabels != null)
            return _cachedUserLabels;
        
        var (_, labels) = MetricsService.GetPRsByUserChartData(_metrics);
        _cachedUserLabels = labels;
        return _cachedUserLabels;
    }

    private Color GetStatusColor(string status)
    {
        return status.ToLower() switch
        {
            "completed" => Color.Success,
            "active" => Color.Info,
            "abandoned" => Color.Error,
            _ => Color.Default
        };
    }

    private List<DataRequirement> _prDataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Pull Request Data", 
            Description = "Azure DevOps automatically captures PR creation, completion, and update timestamps",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Work Item Links", 
            Description = "Link PRs to work items using 'AB#[ID]' syntax in commits or PR descriptions for iteration analysis",
            IsRequired = false 
        },
        new DataRequirement 
        { 
            Field = "File Changes", 
            Description = "Number of files changed per PR, automatically tracked by Azure DevOps",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Review Iterations", 
            Description = "Each push to a PR branch after initial creation counts as an iteration",
            IsRequired = true 
        }
    };

    private List<string> _prBestPractices = new()
    {
        "Keep PRs small (10-20 files) for faster review times",
        "Aim for 1-3 day PR cycle time from creation to merge",
        "Target 1-2 iterations per PR - more indicates unclear requirements or scope issues",
        "Link PRs to work items using 'AB#[ID]' syntax for better traceability",
        "Review PRs within 24 hours to prevent blocking other work",
        "Use PR templates to ensure consistent descriptions and context",
        "Break large features into smaller, focused PRs",
        "Monitor outliers (>5 days open) to identify and resolve blockers"
    };

    private List<CommonIssue> _prCommonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "No PR data showing after sync",
            Solution = "Ensure you have pull requests in your Azure DevOps project and that your PAT has permissions to read them. Check the repository/project settings."
        },
        new CommonIssue 
        { 
            Problem = "PRs taking too long to close (>5 days average)",
            Solution = "Review team availability for code reviews, consider reducing PR size, implement clearer acceptance criteria, or schedule dedicated review time."
        },
        new CommonIssue 
        { 
            Problem = "High iteration count (>3 per PR)",
            Solution = "May indicate unclear requirements, insufficient testing before PR, or communication gaps. Improve pre-PR testing and requirement clarity."
        },
        new CommonIssue 
        { 
            Problem = "Large variation in PR size (files changed)",
            Solution = "Establish team guidelines for PR size. Break large features into smaller PRs. Target 10-20 files per PR for optimal review efficiency."
        }
    };

    public void Dispose()
    {
        _dataLoadCts?.Cancel();
        _dataLoadCts?.Dispose();
    }
}

