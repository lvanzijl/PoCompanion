@page "/pr-insights"
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Components.Common
@inject PullRequestService PullRequestService
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar

<PageTitle>PR Insight Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" /> PR Insight Dashboard
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Pull request metrics and analytics for better team insights
    </MudText>

    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (!_metrics.Any())
    {
        <MudAlert Severity="Severity.Info" Class="my-7">
            <MudText Typo="Typo.h6" Class="mb-2">No Pull Request Data Available</MudText>
            <MudText>There are no pull requests to display. Click the "Sync PRs" button below to fetch pull request data from Azure DevOps.</MudText>
        </MudAlert>
        
        <!-- Sync Button for Empty State -->
        <MudFab Color="Color.Primary" 
                StartIcon="@Icons.Material.Filled.Sync" 
                Label="Sync PRs" 
                Class="mt-4"
                OnClick="@SyncPullRequests"
                Disabled="@_isSyncing" />
    }
    else
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />
        <!-- Top Metrics Cards -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total PRs</MudText>
                                <MudText Typo="Typo.h4">@_metrics.Count()</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.CallMerge" Size="Size.Large" Color="Color.Primary" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Avg Time Open</MudText>
                                <MudText Typo="Typo.h4">@GetAverageTimeOpen()</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Large" Color="Color.Info" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Avg Iterations</MudText>
                                <MudText Typo="Typo.h4">@GetAverageIterations()</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Loop" Size="Size.Large" Color="Color.Warning" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Avg Files/PR</MudText>
                                <MudText Typo="Typo.h4">@GetAverageFiles()</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" Size="Size.Large" Color="Color.Success" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- Date Range Filter -->
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudDateRangePicker @bind-DateRange="_dateRange" 
                                   Label="Filter by Date Range" 
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   HelperText="Select a date range to filter pull requests" />
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          OnClick="ApplyDateFilter"
                          StartIcon="@Icons.Material.Filled.FilterAlt">
                    Apply Filter
                </MudButton>
                @if (_dateRange != null && (_dateRange.Start.HasValue || _dateRange.End.HasValue))
                {
                    <MudButton Variant="Variant.Outlined" 
                              Color="Color.Default" 
                              OnClick="ClearDateFilter"
                              StartIcon="@Icons.Material.Filled.Clear">
                        Clear
                    </MudButton>
                }
            </MudStack>
        </MudPaper>

        <!-- Tabs for different views -->
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.h6" GutterBottom="true">PR Status Distribution</MudText>
                            <MudChart ChartType="ChartType.Donut" 
                                      Width="300px" 
                                      Height="300px"
                                      InputData="@GetStatusData()" 
                                      InputLabels="@GetStatusLabels()">
                            </MudChart>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Elevation="1" Class="pa-4">
                            <MudText Typo="Typo.h6" GutterBottom="true">Time Open Distribution</MudText>
                            <MudChart ChartType="ChartType.Bar" 
                                      Width="100%" 
                                      Height="300px"
                                      InputData="@GetTimeOpenData()" 
                                      InputLabels="@GetTimeOpenLabels()"
                                      ChartOptions="@_barChartOptions">
                            </MudChart>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="By User" Icon="@Icons.Material.Filled.People">
                <MudPaper Elevation="1" Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">PRs by User</MudText>
                    <MudChart ChartType="ChartType.Bar" 
                              Width="100%" 
                              Height="400px"
                              InputData="@GetPRsByUserData()" 
                              InputLabels="@GetUserLabels()"
                              ChartOptions="@_barChartOptions">
                    </MudChart>
                </MudPaper>
            </MudTabPanel>

            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.List">
                <MudDataGrid Items="@_metrics" 
                             Filterable="true" 
                             SortMode="SortMode.Multiple"
                             Dense="true"
                             Hover="true">
                    <Columns>
                        <PropertyColumn Property="x => x.Title" Title="Title" />
                        <PropertyColumn Property="x => x.CreatedBy" Title="Author" />
                        <PropertyColumn Property="x => x.Status" Title="Status">
                            <CellTemplate>
                                <MudChip Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">
                                    @context.Item.Status
                                </MudChip>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.TotalTimeOpen" Title="Time Open" Format="d\d\ hh\h\ mm\m" />
                        <PropertyColumn Property="x => x.IterationCount" Title="Iterations" />
                        <PropertyColumn Property="x => x.TotalFileCount" Title="Files" />
                        <PropertyColumn Property="x => x.CommentCount" Title="Comments" />
                    </Columns>
                </MudDataGrid>
            </MudTabPanel>
        </MudTabs>

        <!-- Sync Button -->
        <MudFab Color="Color.Primary" 
                StartIcon="@Icons.Material.Filled.Sync" 
                Label="Sync PRs" 
                Class="mt-4"
                OnClick="@SyncPullRequests"
                Disabled="@_isSyncing" />
    }
</MudContainer>

@code {
    private List<PullRequestMetricsDto> _metrics = new();
    private List<PullRequestMetricsDto> _allMetrics = new();
    private bool _isLoading = true;
    private bool _isSyncing = false;
    private DateRange? _dateRange;
    private ErrorResponse? _errorResponse;

    private ChartOptions _barChartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            ClearError();
            var metrics = await PullRequestService.GetMetricsAsync();
            _allMetrics = metrics.ToList();
            _metrics = _allMetrics;
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading pull request metrics");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ApplyDateFilter()
    {
        if (_dateRange == null || (!_dateRange.Start.HasValue && !_dateRange.End.HasValue))
        {
            _metrics = _allMetrics;
            return;
        }

        _metrics = _allMetrics.Where(m =>
        {
            // Assuming metrics have a CreatedDate property - adjust as needed
            var createdDate = m.CreatedDate;
            
            if (_dateRange.Start.HasValue && createdDate < _dateRange.Start.Value)
                return false;
            
            if (_dateRange.End.HasValue && createdDate > _dateRange.End.Value)
                return false;
            
            return true;
        }).ToList();

        StateHasChanged();
    }

    private void ClearDateFilter()
    {
        _dateRange = null;
        _metrics = _allMetrics;
        StateHasChanged();
    }

    private async Task SyncPullRequests()
    {
        _isSyncing = true;
        try
        {
            ClearError();
            var count = await PullRequestService.SyncAsync();
            Snackbar.Add($"Synced {count} pull requests successfully", Severity.Success);
            await LoadData();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error syncing pull requests");
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    // Metrics calculations
    private string GetAverageTimeOpen()
    {
        if (!_metrics.Any()) return "0d";
        var avgDays = _metrics.Average(m => m.TotalTimeOpen.TotalDays);
        return $"{avgDays:F1}d";
    }

    private string GetAverageIterations()
    {
        if (!_metrics.Any()) return "0";
        var avg = _metrics.Average(m => m.IterationCount);
        return avg.ToString("F1");
    }

    private string GetAverageFiles()
    {
        if (!_metrics.Any()) return "0";
        var avg = _metrics.Average(m => m.TotalFileCount);
        return avg.ToString("F0");
    }

    // Chart data methods
    private double[] GetStatusData()
    {
        var grouped = _metrics.GroupBy(m => m.Status).Select(g => (double)g.Count()).ToArray();
        return grouped.Length > 0 ? grouped : new[] { 0.0 };
    }

    private string[] GetStatusLabels()
    {
        var labels = _metrics.GroupBy(m => m.Status).Select(g => g.Key).ToArray();
        return labels.Length > 0 ? labels : new[] { "No data" };
    }

    private double[] GetTimeOpenData()
    {
        return _metrics.OrderByDescending(m => m.TotalTimeOpen)
            .Take(10)
            .Select(m => m.TotalTimeOpen.TotalDays)
            .ToArray();
    }

    private string[] GetTimeOpenLabels()
    {
        return _metrics.OrderByDescending(m => m.TotalTimeOpen)
            .Take(10)
            .Select(m => m.Title.Length > 30 ? m.Title.Substring(0, 27) + "..." : m.Title)
            .ToArray();
    }

    private double[] GetPRsByUserData()
    {
        return _metrics.GroupBy(m => m.CreatedBy)
            .Select(g => (double)g.Count())
            .ToArray();
    }

    private string[] GetUserLabels()
    {
        return _metrics.GroupBy(m => m.CreatedBy)
            .Select(g => g.Key)
            .ToArray();
    }

    private Color GetStatusColor(string status)
    {
        return status.ToLower() switch
        {
            "completed" => Color.Success,
            "active" => Color.Info,
            "abandoned" => Color.Error,
            _ => Color.Default
        };
    }
}
