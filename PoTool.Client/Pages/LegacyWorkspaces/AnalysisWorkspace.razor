@page "/workspace/analysis"
@page "/workspace/analysis/{Mode}"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.BacklogHealth
@using PoTool.Client.Components.EffortDistribution
@using PoTool.Client.Components.Flow
@using PoTool.Client.Components.Forecast
@using PoTool.Client.Components.Dependencies
@using PoTool.Client.Components.Timeline
@using PoTool.Client.ApiClient
@using PoTool.Shared.Contracts
@using NavigationContext = PoTool.Client.Models.NavigationContext
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Analysis Workspace - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header with Context Info *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Analysis Workspace
                    </MudText>
                </MudStack>
                
                @* Context Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Context Info Badge *@
                @if (_currentContext != null)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Psychology" 
                             Size="Size.Small"
                             Color="Color.Secondary">
                        Begrijpen
                    </MudChip>
                }
                
                @* Navigation *@
                @if (_currentContext?.Trigger?.SourceLabel != null)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="NavigateBack">
                        Back
                    </MudButton>
                }
                
                @* Back to Home *@
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Mode Switcher Tabs *@
        <MudPaper Elevation="1" Class="pa-2 mb-4">
            <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                <MudButton Variant="@GetModeVariant("health")" OnClick='() => SwitchMode("health")' StartIcon="@Icons.Material.Filled.HealthAndSafety">Health</MudButton>
                <MudButton Variant="@GetModeVariant("effort")" OnClick='() => SwitchMode("effort")' StartIcon="@Icons.Material.Filled.Timer">Effort</MudButton>
                <MudButton Variant="@GetModeVariant("flow")" OnClick='() => SwitchMode("flow")' StartIcon="@Icons.Material.Filled.MergeType">Flow</MudButton>
                <MudButton Variant="@GetModeVariant("forecast")" OnClick='() => SwitchMode("forecast")' StartIcon="@Icons.Material.Filled.TrendingUp">Forecast</MudButton>
                <MudButton Variant="@GetModeVariant("dependencies")" OnClick='() => SwitchMode("dependencies")' StartIcon="@Icons.Material.Filled.AccountTree">Dependencies</MudButton>
                <MudButton Variant="@GetModeVariant("timeline")" OnClick='() => SwitchMode("timeline")' StartIcon="@Icons.Material.Filled.Timeline">Timeline</MudButton>
            </MudButtonGroup>
        </MudPaper>

        @* Mode Content *@
        @if (_currentMode == "health")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2" />
                        Backlog Health Analysis
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/backlog-health">
                        Full Dashboard
                    </MudButton>
                </MudStack>
                
                @* Embedded Backlog Health Panel *@
                <BacklogHealthPanel MaxIterations="5" />
            </MudPaper>
        }
        else if (_currentMode == "effort")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Class="mr-2" />
                        Effort Distribution Analysis
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/effort-distribution">
                        Full Dashboard
                    </MudButton>
                </MudStack>
                
                @* Embedded Effort Distribution Panel *@
                <EffortDistributionPanel MaxIterations="6" />
            </MudPaper>
        }
        else if (_currentMode == "flow")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.MergeType" Class="mr-2" />
                        Flow Analysis
                    </MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/pr-insights">
                            PR Dashboard
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Secondary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/pipeline-insights">
                            Pipelines
                        </MudButton>
                    </MudStack>
                </MudStack>
                
                @* Embedded Flow Panel *@
                <FlowPanel />
            </MudPaper>
        }
        else if (_currentMode == "forecast")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" />
                        Forecast Analysis
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/epic-forecast">
                        Full Forecast
                    </MudButton>
                </MudStack>
                
                @* Embedded Forecast Panel *@
                <ForecastPanel />
            </MudPaper>
        }
        else if (_currentMode == "dependencies")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-2" />
                        Dependency Analysis
                    </MudText>
                </MudStack>
                
                @* Embedded Dependencies Panel *@
                <DependenciesPanel />
            </MudPaper>
        }
        else if (_currentMode == "timeline")
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.Timeline" Class="mr-2" />
                        Timeline Analysis
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" EndIcon="@Icons.Material.Filled.ArrowForward" Href="/state-timeline">
                        Full Timeline
                    </MudButton>
                </MudStack>
                
                @* Embedded Timeline Panel *@
                <TimelinePanel />
            </MudPaper>
        }

        @* Cross-Workspace Actions *@
        <MudPaper Elevation="2" Class="pa-4 mt-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="mr-2" />
                Actions
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.CalendarMonth" OnClick="NavigateToPlanning">
                    Plan
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Inventory2" OnClick="NavigateToProduct">
                    Product Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
    }
</style>

@code {
    [Parameter]
    public string? Mode { get; set; }
    
    private bool _isLoading = true;
    private NavigationContext? _currentContext;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string _currentMode = "health";
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get current context
            _currentContext = NavigationContextService.CurrentOrDefault;
            
            // Validate profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo(WorkspaceRoutes.Profiles);
                return;
            }
            
            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            
            // If no context exists, create one for Begrijpen intent
            if (_currentContext == null)
            {
                NavigationContextService.SetInitialContext(Intent.Begrijpen, activeProfile.Id);
                _currentContext = NavigationContextService.CurrentOrDefault;
            }
            
            // Set mode from URL parameter or context
            SetModeFromParameter();
            
            // Build breadcrumbs
            UpdateBreadcrumbs();
        }
        catch (Exception)
        {
            // Graceful degradation
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    protected override void OnParametersSet()
    {
        SetModeFromParameter();
        UpdateBreadcrumbs();
    }
    
    private void SetModeFromParameter()
    {
        if (!string.IsNullOrEmpty(Mode))
        {
            _currentMode = Mode.ToLowerInvariant();
        }
        else if (!string.IsNullOrEmpty(_currentContext?.Mode))
        {
            _currentMode = _currentContext.Mode.ToLowerInvariant();
        }
        else
        {
            _currentMode = "health";
        }
    }
    
    private void SwitchMode(string mode)
    {
        _currentMode = mode;
        NavigationManager.NavigateTo($"{WorkspaceRoutes.AnalysisWorkspace}/{mode}");
    }
    
    private Variant GetModeVariant(string mode)
    {
        return _currentMode == mode ? Variant.Filled : Variant.Outlined;
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Analysis", null, disabled: true, icon: Icons.Material.Filled.Psychology)
        };
        
        var modeName = _currentMode switch
        {
            "health" => "Health",
            "effort" => "Effort",
            "flow" => "Flow",
            "forecast" => "Forecast",
            "dependencies" => "Dependencies",
            "timeline" => "Timeline",
            _ => "Health"
        };
        _breadcrumbs.Add(new(modeName, null, disabled: true));
    }
    
    private void NavigateToHome()
    {
        NavigationContextService.ClearContext();
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
    
    private async Task NavigateBack()
    {
        await NavigationContextService.NavigateBackAsync();
    }
    
    private void NavigateToLegacy(string route)
    {
        NavigationManager.NavigateTo(route);
    }
    
    private async Task NavigateToPlanning()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Plannen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Analysis Workspace" },
            TimeHorizon = TimeHorizon.Future
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.PlanningWorkspace, newContext);
    }
    
    private async Task NavigateToProduct()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Overzien,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Analysis Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.ProductWorkspace, newContext);
    }
}
