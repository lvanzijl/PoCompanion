@page "/workspace/communication"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Shared.Contracts
@using NavigationContext = PoTool.Client.Models.NavigationContext
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject IClipboardService ClipboardService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Communication Workspace - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    @* Workspace Header with Context Info *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Share" Color="Color.Warning" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Communication Workspace
                    </MudText>
                </MudStack>
                
                @* Context Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Context Info Badge *@
                @if (_currentContext != null)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Share" 
                             Size="Size.Small"
                             Color="Color.Warning">
                        Delen
                    </MudChip>
                }
                
                @* Navigation *@
                @if (_sourceLabel != null)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="NavigateBack">
                        Back
                    </MudButton>
                }
                
                @* Back to Landing *@
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToLanding">
                    Landing
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Template Selection *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Article" Class="mr-2" />
                Report Template
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="@(_selectedTemplate == "status" ? 3 : 1)" 
                             Style="@GetTemplateCardStyle("status")" 
                             Class="mud-card-hover" 
                             @onclick='() => SelectTemplate("status")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="@GetTemplateColor("status")" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Status Report</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Sprint/iteration status summary
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="@(_selectedTemplate == "health" ? 3 : 1)" 
                             Style="@GetTemplateCardStyle("health")" 
                             Class="mud-card-hover" 
                             @onclick='() => SelectTemplate("health")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="@GetTemplateColor("health")" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Health Summary</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Backlog health overview
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="@(_selectedTemplate == "planning" ? 3 : 1)" 
                             Style="@GetTemplateCardStyle("planning")" 
                             Class="mud-card-hover" 
                             @onclick='() => SelectTemplate("planning")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="@GetTemplateColor("planning")" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Planning Summary</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Release planning snapshot
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Current Context Summary *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Summarize" Class="mr-2" />
                    Context Summary
                </MudText>
                @if (_currentContext != null)
                {
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="RefreshPreview">
                        Refresh
                    </MudButton>
                }
            </MudStack>
            
            @if (_currentContext != null)
            {
                <MudGrid>
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Elevation="1">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Intent</MudText>
                                <MudText Typo="Typo.h6">@_currentContext.Intent.ToString()</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Elevation="1">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Scope Level</MudText>
                                <MudText Typo="Typo.h6">@_currentContext.Scope.Level.ToString()</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Elevation="1">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Time Horizon</MudText>
                                <MudText Typo="Typo.h6">@_currentContext.TimeHorizon.ToString()</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Elevation="1">
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Source</MudText>
                                <MudText Typo="Typo.h6">@(_currentContext.Trigger?.SourceLabel ?? "Direct")</MudText>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>
                </MudGrid>
                
                @* Generated Report Preview *@
                <MudPaper Elevation="1" Class="pa-3 mt-4" Style="background-color: var(--mud-palette-background-gray);">
                    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-2">Report Preview</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; white-space: pre-wrap;">
                        @_reportPreview
                    </MudText>
                </MudPaper>
            }
            else
            {
                <MudAlert Severity="Severity.Info">
                    No navigation context available. Navigate from another workspace to share context.
                </MudAlert>
            }
        </MudPaper>

        @* Export Actions *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.FileDownload" Class="mr-2" />
                Export & Share
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="CopyToClipboard">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Copy to Clipboard</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Copy formatted report
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="CopyDeepLink">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Link" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Copy Deep Link</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Shareable URL with context
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="ExportAsMarkdown">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Export Markdown</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Copy as Markdown format
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="ShareViaEmail">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Warning" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Email Report</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                                Open in email client
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Quick Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="mr-2" />
                Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Inventory2" OnClick="NavigateToProduct">
                    Product
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Groups" OnClick="NavigateToTeam">
                    Team
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Psychology" OnClick="NavigateToAnalysis">
                    Analyze
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.CalendarMonth" OnClick="NavigateToPlanning">
                    Plan
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private NavigationContext? _currentContext;
    private string? _sourceLabel;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string _selectedTemplate = "status";
    private string _reportPreview = "";
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get current context
            _currentContext = NavigationContextService.CurrentOrDefault;
            _sourceLabel = _currentContext?.Trigger?.SourceLabel;
            
            // Validate profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo(WorkspaceRoutes.Profiles);
                return;
            }
            
            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            
            // If no context exists, create one for Delen intent
            if (_currentContext == null)
            {
                NavigationContextService.SetInitialContext(Intent.Delen, activeProfile.Id);
                _currentContext = NavigationContextService.CurrentOrDefault;
            }
            
            // Build breadcrumbs and generate preview
            UpdateBreadcrumbs();
            GenerateReportPreview();
        }
        catch (Exception)
        {
            // Graceful degradation
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Landing", WorkspaceRoutes.Landing, icon: Icons.Material.Filled.Home),
            new("Communication", null, disabled: true, icon: Icons.Material.Filled.Share)
        };
        
        if (_sourceLabel != null)
        {
            _breadcrumbs.Insert(1, new(_sourceLabel, null, disabled: true));
        }
    }
    
    private void SelectTemplate(string template)
    {
        _selectedTemplate = template;
        GenerateReportPreview();
    }
    
    private string GetTemplateCardStyle(string template)
    {
        var baseStyle = "cursor: pointer; transition: all 0.2s;";
        if (_selectedTemplate == template)
        {
            return $"{baseStyle} border: 2px solid var(--mud-palette-primary);";
        }
        return baseStyle;
    }
    
    private Color GetTemplateColor(string template)
    {
        return _selectedTemplate == template ? Color.Primary : Color.Default;
    }
    
    private void GenerateReportPreview()
    {
        if (_currentContext == null)
        {
            _reportPreview = "No context available";
            return;
        }
        
        var lines = new List<string>();
        var timestamp = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
        
        switch (_selectedTemplate)
        {
            case "status":
                lines.Add("═══════════════════════════════════════");
                lines.Add("         STATUS REPORT");
                lines.Add("═══════════════════════════════════════");
                lines.Add($"Generated: {timestamp}");
                lines.Add("");
                lines.Add($"Intent:      {_currentContext.Intent}");
                lines.Add($"Scope:       {_currentContext.Scope.Level}");
                lines.Add($"Time Period: {_currentContext.TimeHorizon}");
                if (_currentContext.Scope.ProductId.HasValue)
                    lines.Add($"Product ID:  {_currentContext.Scope.ProductId}");
                if (_currentContext.Scope.TeamId.HasValue)
                    lines.Add($"Team ID:     {_currentContext.Scope.TeamId}");
                lines.Add("");
                lines.Add("───────────────────────────────────────");
                lines.Add("This report was generated from PO Companion.");
                break;
                
            case "health":
                lines.Add("═══════════════════════════════════════");
                lines.Add("       HEALTH SUMMARY");
                lines.Add("═══════════════════════════════════════");
                lines.Add($"Generated: {timestamp}");
                lines.Add("");
                lines.Add("Analysis Focus: Backlog Health");
                lines.Add($"Scope:          {_currentContext.Scope.Level}");
                lines.Add($"Time Horizon:   {_currentContext.TimeHorizon}");
                lines.Add("");
                lines.Add("Key Metrics:");
                lines.Add("  • Health Score: [Navigate to dashboard]");
                lines.Add("  • Issues Found: [Navigate to dashboard]");
                lines.Add("  • Trend:        [Navigate to dashboard]");
                lines.Add("");
                lines.Add("───────────────────────────────────────");
                lines.Add("Open the Health Dashboard for details.");
                break;
                
            case "planning":
                lines.Add("═══════════════════════════════════════");
                lines.Add("      PLANNING SUMMARY");
                lines.Add("═══════════════════════════════════════");
                lines.Add($"Generated: {timestamp}");
                lines.Add("");
                lines.Add("Planning Focus: Release Planning");
                lines.Add($"Scope:          {_currentContext.Scope.Level}");
                lines.Add($"Time Horizon:   Future");
                lines.Add("");
                lines.Add("Release Status:");
                lines.Add("  • Planned Items:  [Navigate to board]");
                lines.Add("  • Capacity:       [Navigate to board]");
                lines.Add("  • Forecast:       [Navigate to board]");
                lines.Add("");
                lines.Add("───────────────────────────────────────");
                lines.Add("Open the Planning Board for details.");
                break;
        }
        
        _reportPreview = string.Join(Environment.NewLine, lines);
    }
    
    private void RefreshPreview()
    {
        GenerateReportPreview();
        Snackbar.Add("Preview refreshed", Severity.Info);
    }
    
    private void NavigateToLanding()
    {
        NavigationContextService.ClearContext();
        NavigationManager.NavigateTo(WorkspaceRoutes.Landing);
    }
    
    private async Task NavigateBack()
    {
        await NavigationContextService.NavigateBackAsync();
    }
    
    private async Task CopyToClipboard()
    {
        if (string.IsNullOrEmpty(_reportPreview))
        {
            Snackbar.Add("No report to copy", Severity.Warning);
            return;
        }
        
        await ClipboardService.CopyToClipboardAsync(_reportPreview);
        Snackbar.Add("Report copied to clipboard!", Severity.Success);
    }
    
    private async Task CopyDeepLink()
    {
        if (_currentContext == null)
        {
            Snackbar.Add("No context to share", Severity.Warning);
            return;
        }
        
        var queryString = NavigationContextService.ToQueryString(_currentContext);
        var baseUrl = NavigationManager.BaseUri.TrimEnd('/');
        var sourceRoute = GetSourceRoute();
        var deepLink = $"{baseUrl}{sourceRoute}?{queryString}";
        
        await ClipboardService.CopyToClipboardAsync(deepLink);
        Snackbar.Add("Deep link copied to clipboard!", Severity.Success);
    }
    
    private async Task ExportAsMarkdown()
    {
        if (_currentContext == null)
        {
            Snackbar.Add("No context to export", Severity.Warning);
            return;
        }
        
        var markdown = BuildMarkdownReport();
        await ClipboardService.CopyToClipboardAsync(markdown);
        Snackbar.Add("Markdown report copied to clipboard!", Severity.Success);
    }
    
    private async Task ShareViaEmail()
    {
        if (_currentContext == null)
        {
            Snackbar.Add("No context to share", Severity.Warning);
            return;
        }
        
        var subject = Uri.EscapeDataString($"PO Companion - {GetTemplateDisplayName()} Report");
        var body = Uri.EscapeDataString(_reportPreview);
        var mailtoUrl = $"mailto:?subject={subject}&body={body}";
        
        await JSRuntime.InvokeVoidAsync("open", mailtoUrl, "_blank");
        Snackbar.Add("Opening email client...", Severity.Info);
    }
    
    private string GetTemplateDisplayName()
    {
        return _selectedTemplate switch
        {
            "status" => "Status",
            "health" => "Health",
            "planning" => "Planning",
            _ => "Report"
        };
    }
    
    private string BuildMarkdownReport()
    {
        if (_currentContext == null) return "";
        
        var lines = new List<string>
        {
            $"# {GetTemplateDisplayName()} Report",
            "",
            $"**Generated:** {DateTime.Now:yyyy-MM-dd HH:mm}",
            "",
            "## Context",
            "",
            $"| Property | Value |",
            $"|----------|-------|",
            $"| Intent | {_currentContext.Intent} |",
            $"| Scope | {_currentContext.Scope.Level} |",
            $"| Time Horizon | {_currentContext.TimeHorizon} |"
        };
        
        if (_currentContext.Scope.ProductId.HasValue)
            lines.Add($"| Product ID | {_currentContext.Scope.ProductId} |");
        if (_currentContext.Scope.TeamId.HasValue)
            lines.Add($"| Team ID | {_currentContext.Scope.TeamId} |");
        
        lines.Add("");
        lines.Add("---");
        lines.Add("*Generated by PO Companion*");
        
        return string.Join(Environment.NewLine, lines);
    }
    
    private string GetSourceRoute()
    {
        if (_currentContext == null) return WorkspaceRoutes.Landing;
        
        return _currentContext.Scope.Level switch
        {
            ScopeLevel.Team => WorkspaceRoutes.TeamWorkspace,
            ScopeLevel.Product => WorkspaceRoutes.ProductWorkspace,
            _ => WorkspaceRoutes.ProductWorkspace
        };
    }
    
    private async Task NavigateToProduct()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Overzien,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Communication Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.ProductWorkspace, newContext);
    }
    
    private async Task NavigateToTeam()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Overzien,
            Scope = new Scope
            {
                Level = ScopeLevel.Team,
                ProfileId = _currentContext.Scope.ProfileId,
                ProductId = _currentContext.Scope.ProductId
            },
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Communication Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.TeamWorkspace, newContext);
    }
    
    private async Task NavigateToAnalysis()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Begrijpen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Communication Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.AnalysisWorkspace, newContext);
    }
    
    private async Task NavigateToPlanning()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Plannen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Communication Workspace" },
            TimeHorizon = TimeHorizon.Future
        };
        
        await NavigationContextService.NavigateWithContextAsync(WorkspaceRoutes.PlanningWorkspace, newContext);
    }
}
