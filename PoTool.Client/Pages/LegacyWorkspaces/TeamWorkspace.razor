@page "/workspace/team"
@page "/workspace/team/{TeamId:int}"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Velocity
@using PoTool.Client.ApiClient
@using NavigationContext = PoTool.Client.Models.NavigationContext
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject TeamService TeamService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Team Workspace - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header with Context Info *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        @if (_selectedTeam != null)
                        {
                            @_selectedTeam.Name
                        }
                        else
                        {
                            <text>Team Workspace</text>
                        }
                    </MudText>
                </MudStack>
                
                @* Context Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Context Info Badge *@
                @if (_currentContext != null)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Visibility" 
                             Size="Size.Small"
                             Color="Color.Success">
                        Team Scope
                    </MudChip>
                }
                
                @* Back to Product Workspace *@
                @if (_currentContext?.Scope.ProductId != null)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Inventory2"
                               OnClick="NavigateToProduct">
                        Product
                    </MudButton>
                }
                
                @* Back to Home *@
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (_errorMessage != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @_errorMessage
        </MudAlert>
    }
    else
    {
        @* Team Selector Section *@
        @if (_teams.Count > 0)
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Secondary" />
                    <MudSelect T="int?" 
                               Value="@_selectedTeamId"
                               ValueChanged="OnTeamChanged"
                               Label="Select Team"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Style="min-width: 300px;">
                        @foreach (var team in _teams)
                        {
                            <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_teams.Count teams available
                    </MudText>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">
                No teams configured for this product. 
                <MudLink Href="/settings/teams" Color="Color.Primary">Configure teams</MudLink> to enable team-scoped features.
            </MudAlert>
        }

        @* Sprint Navigation *@
        @if (_selectedTeam != null)
        {
            <MudPaper Elevation="2" Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                        Sprint Navigation
                    </MudText>
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Today" 
                             Size="Size.Small"
                             Color="Color.Info">
                        @GetTimeHorizonLabel()
                    </MudChip>
                </MudStack>

                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    <MudButton Variant="@GetTimeHorizonVariant(TimeHorizon.Historical)" 
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.History"
                               OnClick="@(() => SetTimeHorizon(TimeHorizon.Historical))">
                        Historical
                    </MudButton>
                    <MudButton Variant="@GetTimeHorizonVariant(TimeHorizon.Current)" 
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Today"
                               OnClick="@(() => SetTimeHorizon(TimeHorizon.Current))">
                        Current Sprint
                    </MudButton>
                    <MudButton Variant="@GetTimeHorizonVariant(TimeHorizon.Future)" 
                               Color="Color.Info"
                               StartIcon="@Icons.Material.Filled.EventNote"
                               OnClick="@(() => SetTimeHorizon(TimeHorizon.Future))">
                        Future
                    </MudButton>
                </MudStack>
            </MudPaper>
        }

        @* Quick Actions *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="mr-2" />
                Team Actions
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="NavigateToVelocity">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Velocity</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Team velocity trends</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="NavigateToAnalysis">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Analyze</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Team health insights</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="NavigateToPlanning">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Plan</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Sprint planning</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick="NavigateToCommunication">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Share" Color="Color.Warning" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Share</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Export team data</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Embedded Velocity Panel *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
                    Team Velocity
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           Href="/velocity">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            @* Velocity Panel - filtered by selected team *@
            <VelocityPanel TeamAreaPath="@_selectedTeam?.TeamAreaPath" MaxSprints="6" />
        </MudPaper>

        @* Quick Links *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Related Dashboards
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Timeline"
                           Href="/state-timeline">
                    State Timeline
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           Href="/backlog-health">
                    Backlog Health
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
    }
</style>

@code {
    [Parameter]
    public int? TeamId { get; set; }
    
    private bool _isLoading = true;
    private string? _errorMessage;
    private NavigationContext? _currentContext;
    private List<TeamDto> _teams = new();
    private TeamDto? _selectedTeam;
    private int? _selectedTeamId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get current context or create a new one
            _currentContext = NavigationContextService.CurrentOrDefault;
            
            // Validate profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo(WorkspaceRoutes.Profiles);
                return;
            }
            
            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            
            // If no context exists, create one for Overzien intent at Team level
            if (_currentContext == null)
            {
                NavigationContextService.SetInitialContext(Intent.Overzien, activeProfile.Id);
                _currentContext = NavigationContextService.CurrentOrDefault;
            }
            
            // Load teams for this profile's products
            var products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            var allTeamIds = products.SelectMany(p => p.TeamIds ?? Enumerable.Empty<int>()).Distinct().ToList();
            
            foreach (var teamId in allTeamIds)
            {
                var team = await TeamService.GetTeamByIdAsync(teamId);
                if (team != null)
                {
                    _teams.Add(team);
                }
            }
            
            // Set selected team from URL parameter or context
            if (TeamId.HasValue)
            {
                _selectedTeamId = TeamId.Value;
                _selectedTeam = _teams.FirstOrDefault(t => t.Id == TeamId.Value);
            }
            else if (_currentContext?.Scope.TeamId.HasValue == true)
            {
                _selectedTeamId = _currentContext.Scope.TeamId;
                _selectedTeam = _teams.FirstOrDefault(t => t.Id == _selectedTeamId);
            }
            else if (_teams.Any())
            {
                _selectedTeamId = _teams.First().Id;
                _selectedTeam = _teams.First();
            }
            
            // Build breadcrumbs
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading workspace: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Product", WorkspaceRoutes.ProductWorkspace, icon: Icons.Material.Filled.Inventory2),
            new("Team Workspace", null, disabled: true, icon: Icons.Material.Filled.Groups)
        };
        
        if (_selectedTeam != null)
        {
            _breadcrumbs.Add(new(_selectedTeam.Name, null, disabled: true));
        }
    }
    
    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        _selectedTeam = teamId.HasValue 
            ? _teams.FirstOrDefault(t => t.Id == teamId) 
            : null;
        
        // Update context with new team scope
        if (_currentContext != null && _selectedTeamId.HasValue)
        {
            var newContext = _currentContext with
            {
                Scope = new Scope
                {
                    Level = ScopeLevel.Team,
                    ProfileId = _currentContext.Scope.ProfileId,
                    ProductId = _currentContext.Scope.ProductId,
                    TeamId = _selectedTeamId
                }
            };
            
            await NavigationContextService.NavigateWithContextAsync(
                $"{WorkspaceRoutes.TeamWorkspace}/{_selectedTeamId}", 
                newContext);
        }
        
        UpdateBreadcrumbs();
        StateHasChanged();
    }
    
    private void SetTimeHorizon(TimeHorizon horizon)
    {
        if (_currentContext == null) return;
        
        // Update context with new time horizon (local state only for now)
        _currentContext = _currentContext with { TimeHorizon = horizon };
        StateHasChanged();
    }
    
    private string GetTimeHorizonLabel()
    {
        return _currentContext?.TimeHorizon switch
        {
            TimeHorizon.Historical => "Historical View",
            TimeHorizon.Current => "Current Sprint",
            TimeHorizon.Future => "Future Planning",
            _ => "Current"
        };
    }
    
    private Variant GetTimeHorizonVariant(TimeHorizon horizon)
    {
        return _currentContext?.TimeHorizon == horizon ? Variant.Filled : Variant.Outlined;
    }
    
    private void NavigateToHome()
    {
        NavigationContextService.ClearContext();
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
    
    private async Task NavigateToProduct()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Scope = new Scope
            {
                Level = ScopeLevel.Product,
                ProfileId = _currentContext.Scope.ProfileId,
                ProductId = _currentContext.Scope.ProductId
            }
        };
        
        var route = _currentContext.Scope.ProductId.HasValue
            ? $"{WorkspaceRoutes.ProductWorkspace}/{_currentContext.Scope.ProductId}"
            : WorkspaceRoutes.ProductWorkspace;
            
        await NavigationContextService.NavigateWithContextAsync(route, newContext);
    }
    
    private void NavigateToVelocity()
    {
        NavigationManager.NavigateTo("/velocity");
    }
    
    private async Task NavigateToAnalysis()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Begrijpen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Team Workspace" },
            Mode = "health"
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.AnalysisWorkspace, 
            newContext);
    }
    
    private async Task NavigateToPlanning()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Plannen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Team Workspace" },
            TimeHorizon = TimeHorizon.Future
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.PlanningWorkspace, 
            newContext);
    }
    
    private async Task NavigateToCommunication()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Delen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Team Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.CommunicationWorkspace, 
            newContext);
    }
}
