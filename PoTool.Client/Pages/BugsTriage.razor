@page "/bugs-triage"
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.BugTriage
@using PoTool.Shared.BugTriage
@using MudBlazor
@inject WorkItemService WorkItemService
@inject IBugTriageClient BugTriageClient
@inject BugTreeBuilderService TreeBuilderService
@inject TriageTagService TriageTagService
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject ILogger<BugsTriage> Logger
@inject NavigationManager NavigationManager
@implements IAsyncDisposable

<PageTitle>Bugs Triage</PageTitle>

<div class="bugs-triage-page">
    <div class="bugs-triage-toolbar">
        <MudStack Spacing="0" Style="flex: 1;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Class="mr-2" />
                    Bugs Triage
                </MudText>
                
                @if (!_isLoading && _bugs.Any())
                {
                    <MudText Typo="Typo.body2" Class="ml-3">
                        @_bugs.Count bugs total | @_untriagedCount untriaged
                    </MudText>
                }
            </MudStack>
            @* Suggestion 1: Consistent breadcrumb on every page *@
            <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
        </MudStack>
        
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Home"
                   OnClick="@(() => NavigationManager.NavigateTo("/home"))">
            Home
        </MudButton>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state pa-4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            <MudText Typo="Typo.body2" Class="mt-2">Loading bugs...</MudText>
        </div>
    }
    else if (_errorMessage != null)
    {
        <MudAlert Severity="Severity.Error" Class="ma-4" CloseIcon="true" CloseIconClicked="ClearError">
            @_errorMessage
        </MudAlert>
    }
    else if (!_bugs.Any())
    {
        <div class="empty-state pa-4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-2" />
            <MudText Typo="Typo.h6" Class="mb-2">No bugs found</MudText>
            <MudText Typo="Typo.body2">There are no bug work items in your backlog, or they have all been resolved.</MudText>
        </div>
    }
    else
    {
        <div class="content" tabindex="0">
            <ResizableSplitter StorageKey="bugs-triage-splitter" 
                              DefaultLeftWidth="60" 
                              MinLeftWidth="30" 
                              MaxLeftWidth="80">
                <LeftContent>
                    <div class="bugs-tree-panel">
                        @* Tag Filters *@
                        @if (_enabledTags.Any())
                        {
                            <div class="tag-filters-section pa-2">
                                <MudText Typo="Typo.body2" Class="mb-1">Filter by Tags:</MudText>
                                <MudStack Row="true" Spacing="1" Class="mb-2">
                                    @foreach (var tag in _enabledTags)
                                    {
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Variant="@(IsTagSelected(tag.Name) ? Variant.Filled : Variant.Outlined)"
                                                 Color="@(IsTagSelected(tag.Name) ? Color.Primary : Color.Default)"
                                                 OnClick="@(() => ToggleTagFilter(tag.Name))">
                                            @tag.Name
                                        </MudChip>
                                    }
                                </MudStack>
                                @if (_selectedTags.Any())
                                {
                                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                        <MudText Typo="Typo.caption">Match:</MudText>
                                        <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                                            <MudButton Color="@(_tagMatchMode == TagMatchMode.Any ? Color.Primary : Color.Default)"
                                                      OnClick="@(() => SetTagMatchMode(TagMatchMode.Any))">
                                                Any
                                            </MudButton>
                                            <MudButton Color="@(_tagMatchMode == TagMatchMode.All ? Color.Primary : Color.Default)"
                                                      OnClick="@(() => SetTagMatchMode(TagMatchMode.All))">
                                                All
                                            </MudButton>
                                        </MudButtonGroup>
                                        <MudButton Size="Size.Small" 
                                                   Variant="Variant.Text" 
                                                   OnClick="ClearTagFilters"
                                                   StartIcon="@Icons.Material.Filled.Clear">
                                            Clear
                                        </MudButton>
                                    </MudStack>
                                }
                            </div>
                        }
                        
                        @* Bug Tree Grid *@
                        <BugTriageTreeGrid IsLoading="@_isLoading"
                                          TreeRoots="@_treeRoots"
                                          SelectedId="@_selectedBugId"
                                          OnNodeToggled="HandleNodeToggled"
                                          OnNodeSelected="HandleNodeSelected" />
                    </div>
                </LeftContent>
                <RightContent>
                    <div class="bug-details-panel">
                        @if (_selectedBug != null)
                        {
                            <BugTriageDetailsPanel Bug="@_selectedBug"
                                                  EnabledTags="@_enabledTags"
                                                  IsTriaged="@(!_untriagedBugIds.Contains(_selectedBug.TfsId))"
                                                  OnSeverityChanged="@(async (args) => await HandleSeverityChanged(args.BugId, args.NewSeverity))"
                                                  OnTagToggled="@(async (args) => await HandleTagToggled(args.BugId, args.TagName, args.IsAdded))"
                                                  OnMarkedAsTriaged="@(async (bugId) => await HandleMarkAsTriaged(bugId))" />
                        }
                        else
                        {
                            <div class="empty-selection pa-4">
                                <MudIcon Icon="@Icons.Material.Filled.TouchApp" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                                <MudText Typo="Typo.body1">Select a bug to view details</MudText>
                            </div>
                        }
                    </div>
                </RightContent>
            </ResizableSplitter>
        </div>
    }
</div>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private List<WorkItemWithValidationDto> _bugs = new();
    private HashSet<int> _untriagedBugIds = new();
    private int _untriagedCount => _untriagedBugIds.Count;
    private List<TriageTagDto> _enabledTags = new();
    private List<TreeNode> _treeRoots = new();
    private Dictionary<int, bool> _expandedState = new();
    
    private int? _selectedBugId;
    private WorkItemWithValidationDto? _selectedBug;
    
    private List<string> _selectedTags = new();
    private TagMatchMode _tagMatchMode = TagMatchMode.Any;
    
    // Suggestion 1: Breadcrumbs for consistent navigation
    private List<BreadcrumbItem> _breadcrumbs = new List<BreadcrumbItem>
    {
        new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
        new("Bug Triage", null, disabled: true, icon: Icons.Material.Filled.BugReport)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadExpandedStateAsync();
        await LoadEnabledTagsAsync();
        await LoadBugsAsync();
    }

    private async Task LoadBugsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // Get products for the active profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                _errorMessage = "No active profile selected. Please select a profile first.";
                _bugs = new List<WorkItemWithValidationDto>();
                _isLoading = false;
                return;
            }

            var profileProducts = await ProductService.GetProductsByOwnerAsync(activeProfile.Id);
            var productIds = profileProducts.Select(p => p.Id).ToArray();

            Logger.LogInformation("Loading bugs for {Count} products", productIds.Length);

            // Load all work items
            var allWorkItems = (await WorkItemService.GetAllWithValidationAsync(productIds)).ToList();
            
            // Filter to bugs only
            _bugs = allWorkItems
                .Where(wi => wi.Type.Equals("Bug", StringComparison.OrdinalIgnoreCase))
                .ToList();

            Logger.LogInformation("Loaded {Count} bugs", _bugs.Count);

            // Get untriaged bug IDs
            var bugIds = _bugs.Select(b => b.TfsId).ToList();
            _untriagedBugIds = new HashSet<int>(await BugTriageClient.GetUntriagedBugIdsAsync(bugIds, CancellationToken.None));
            
            Logger.LogInformation("Found {Count} untriaged bugs", _untriagedBugIds.Count);

            // Record first seen for untriaged bugs
            foreach (var bug in _bugs.Where(b => _untriagedBugIds.Contains(b.TfsId)))
            {
                var severity = GetBugSeverity(bug);
                // Use null-coalescing to provide "Unknown" if severity is null
                await BugTriageClient.RecordFirstSeenAsync(bug.TfsId, severity ?? "Unknown", CancellationToken.None);
            }

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load bugs");
            _errorMessage = $"Failed to load bugs: {ex.Message}";
            _bugs = new List<WorkItemWithValidationDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadEnabledTagsAsync()
    {
        try
        {
            _enabledTags = await TriageTagService.GetEnabledTagsAsync();
            Logger.LogInformation("Loaded {Count} enabled triage tags", _enabledTags.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load enabled tags");
            _enabledTags = new List<TriageTagDto>();
        }
    }

    private void ApplyFilters()
    {
        var filteredBugs = _bugs.AsEnumerable();

        // Apply tag filters if any are selected
        if (_selectedTags.Any())
        {
            filteredBugs = TreeBuilderService.ApplyTagFilters(
                filteredBugs,
                _selectedTags,
                _tagMatchMode,
                GetBugTags);
        }

        // Build tree with grouping
        _treeRoots = TreeBuilderService.BuildBugTriageTree(
            filteredBugs,
            _untriagedBugIds,
            _expandedState,
            GetBugSeverity);

        StateHasChanged();
    }

    private async Task HandleNodeToggled(TreeNode node)
    {
        node.IsExpanded = !node.IsExpanded;
        _expandedState[node.Id] = node.IsExpanded;
        await SaveExpandedStateAsync();
        StateHasChanged();
    }

    private void HandleNodeSelected(TreeNode node)
    {
        // Don't select group nodes
        if (node.Type == "(group)")
        {
            return;
        }

        _selectedBugId = node.Id;
        _selectedBug = _bugs.FirstOrDefault(b => b.TfsId == node.Id);
        StateHasChanged();
    }

    private async Task HandleSeverityChanged(int bugId, string newSeverity)
    {
        var oldSeverity = _selectedBug != null ? GetBugSeverity(_selectedBug) : null;
        Logger.LogInformation("Severity change requested for bug {BugId}: {OldSeverity} -> {NewSeverity}", 
            bugId, oldSeverity ?? "(null)", newSeverity);
        
        try
        {
            // Mark as triaged and update TFS
            var request = new Shared.BugTriage.UpdateBugTriageStateRequest(
                bugId,
                NewSeverity: newSeverity);
            
            var response = await BugTriageClient.MarkAsTriagedAsync(request, CancellationToken.None);
            
            if (response.Success)
            {
                // Remove from untriaged set
                _untriagedBugIds.Remove(bugId);
                
                // Refresh the work item from cache to get the true server state
                try
                {
                    var activeProfile = await ProfileService.GetActiveProfileAsync();
                    if (activeProfile != null)
                    {
                        var profileProducts = await ProductService.GetProductsByOwnerAsync(activeProfile.Id);
                        var productIds = profileProducts.Select(p => p.Id).ToArray();
                        
                        var refreshedBug = await WorkItemService.GetByTfsIdWithValidationAsync(bugId, productIds);
                        
                        if (refreshedBug != null)
                        {
                            var refreshedSeverity = GetBugSeverity(refreshedBug);
                            Logger.LogInformation("Retrieved refreshed bug {BugId} from API: severity = {Severity}", 
                                bugId, refreshedSeverity);
                            
                            // Update the bug in local list
                            var existingBugIndex = _bugs.FindIndex(b => b.TfsId == bugId);
                            if (existingBugIndex >= 0)
                            {
                                _bugs[existingBugIndex] = refreshedBug;
                                Logger.LogInformation("Updated bug {BugId} in _bugs list at index {Index}", bugId, existingBugIndex);
                            }
                            
                            // Update selected bug if it's the one being edited
                            if (_selectedBug?.TfsId == bugId)
                            {
                                _selectedBug = refreshedBug;
                                Logger.LogInformation("Updated _selectedBug reference for bug {BugId}", bugId);
                            }
                            
                            Logger.LogInformation("Successfully refreshed bug {BugId} from cache with server state", bugId);
                            
                            // Force Blazor to detect the change in the details panel
                            StateHasChanged();
                        }
                        else
                        {
                            Logger.LogWarning("Failed to refresh bug {BugId} - not found in cache", bugId);
                        }
                    }
                }
                catch (Exception refreshEx)
                {
                    Logger.LogWarning(refreshEx, "Failed to refresh bug {BugId} after severity update - keeping optimistic value", bugId);
                }
                
                // Rebuild tree with updated data
                Logger.LogInformation("Rebuilding tree for bug {BugId} after severity change", bugId);
                ApplyFilters();
                
                Snackbar.Add($"Severity updated to {newSeverity}", Severity.Success);
            }
            else
            {
                // Show error message
                var errorMsg = response.Message ?? "Failed to update severity";
                Logger.LogError("Failed to update severity for bug {BugId}: {Error}", bugId, errorMsg);
                Snackbar.Add(errorMsg, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating severity for bug {BugId}", bugId);
            Snackbar.Add($"Error updating bug {bugId}: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleTagToggled(int bugId, string tagName, bool isAdded)
    {
        Logger.LogInformation("Tag {Action} for bug {BugId}: {Tag}", 
            isAdded ? "added" : "removed", bugId, tagName);
        
        try
        {
            // Mark as triaged
            var request = new Shared.BugTriage.UpdateBugTriageStateRequest(
                bugId,
                TagsAdded: isAdded ? new List<string> { tagName } : null,
                TagsRemoved: !isAdded ? new List<string> { tagName } : null);
            
            var response = await BugTriageClient.MarkAsTriagedAsync(request, CancellationToken.None);
            
            if (response.Success)
            {
                // Remove from untriaged set
                _untriagedBugIds.Remove(bugId);
                
                // Refresh the work item from cache to get the updated tags
                try
                {
                    var activeProfile = await ProfileService.GetActiveProfileAsync();
                    if (activeProfile != null)
                    {
                        var profileProducts = await ProductService.GetProductsByOwnerAsync(activeProfile.Id);
                        var productIds = profileProducts.Select(p => p.Id).ToArray();
                        
                        var refreshedBug = await WorkItemService.GetByTfsIdWithValidationAsync(bugId, productIds);
                        
                        if (refreshedBug != null)
                        {
                            Logger.LogInformation("Retrieved refreshed bug {BugId} from API: tags = {Tags}", 
                                bugId, string.Join("; ", GetBugTags(refreshedBug)));
                            
                            // Update the bug in local list
                            var existingBugIndex = _bugs.FindIndex(b => b.TfsId == bugId);
                            if (existingBugIndex >= 0)
                            {
                                _bugs[existingBugIndex] = refreshedBug;
                                Logger.LogInformation("Updated bug {BugId} in _bugs list at index {Index}", bugId, existingBugIndex);
                            }
                            
                            // Update selected bug if it's the one being edited
                            if (_selectedBug?.TfsId == bugId)
                            {
                                _selectedBug = refreshedBug;
                                Logger.LogInformation("Updated _selectedBug reference for bug {BugId}", bugId);
                            }
                            
                            Logger.LogInformation("Successfully refreshed bug {BugId} from cache with server state", bugId);
                            
                            // Force Blazor to detect the change in the details panel
                            StateHasChanged();
                        }
                        else
                        {
                            Logger.LogWarning("Failed to refresh bug {BugId} - not found in cache", bugId);
                        }
                    }
                }
                catch (Exception refreshEx)
                {
                    Logger.LogWarning(refreshEx, "Failed to refresh bug {BugId} after tag update - keeping optimistic value", bugId);
                }
                
                // Rebuild tree
                ApplyFilters();
                
                var action = isAdded ? "added" : "removed";
                Snackbar.Add($"Tag '{tagName}' {action}", Severity.Success);
            }
            else
            {
                // Show error message
                var errorMsg = response.Message ?? "Failed to update tag";
                Logger.LogError("Failed to update tag for bug {BugId}: {Error}", bugId, errorMsg);
                Snackbar.Add(errorMsg, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error updating tag for bug {BugId}", bugId);
            Snackbar.Add($"Error updating bug {bugId}: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleMarkAsTriaged(int bugId)
    {
        Logger.LogInformation("Marking bug {BugId} as triaged without changes", bugId);
        
        try
        {
            // Mark as triaged without any changes
            var request = new Shared.BugTriage.UpdateBugTriageStateRequest(bugId);
            
            var response = await BugTriageClient.MarkAsTriagedAsync(request, CancellationToken.None);
            
            if (response.Success)
            {
                // Remove from untriaged set
                _untriagedBugIds.Remove(bugId);
                
                // Rebuild tree
                ApplyFilters();
                
                Snackbar.Add("Bug marked as triaged", Severity.Success);
            }
            else
            {
                // Show error message
                var errorMsg = response.Message ?? "Failed to mark bug as triaged";
                Logger.LogError("Failed to mark bug {BugId} as triaged: {Error}", bugId, errorMsg);
                throw new Exception(errorMsg);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error marking bug {BugId} as triaged", bugId);
            throw; // Re-throw to let the details panel show the error
        }
    }

    private void ToggleTagFilter(string tagName)
    {
        if (_selectedTags.Contains(tagName))
        {
            _selectedTags.Remove(tagName);
        }
        else
        {
            _selectedTags.Add(tagName);
        }
        ApplyFilters();
    }

    private void SetTagMatchMode(TagMatchMode mode)
    {
        _tagMatchMode = mode;
        ApplyFilters();
    }

    private void ClearTagFilters()
    {
        _selectedTags.Clear();
        ApplyFilters();
    }

    private bool IsTagSelected(string tagName) => _selectedTags.Contains(tagName);

    private string? GetBugSeverity(WorkItemWithValidationDto bug)
    {
        // Get severity directly from cached field - no TFS field parsing needed
        return bug.Severity;
    }

    private List<string> GetBugTags(WorkItemWithValidationDto bug)
    {
        // Parse tags directly from the typed Tags property
        if (string.IsNullOrWhiteSpace(bug.Tags))
        {
            return new List<string>();
        }

        // TFS tags are semicolon-separated
        return bug.Tags
            .Split(';', StringSplitOptions.RemoveEmptyEntries)
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();
    }

    private async Task LoadExpandedStateAsync()
    {
        try
        {
            _expandedState.Clear();
            var stateJson = await JS.InvokeAsync<string?>("localStorage.getItem", "bugs-triage-expanded-state");
            if (!string.IsNullOrEmpty(stateJson))
            {
                var loadedState = System.Text.Json.JsonSerializer.Deserialize<Dictionary<int, bool>>(stateJson);
                if (loadedState != null)
                {
                    foreach (var kv in loadedState)
                    {
                        _expandedState[kv.Key] = kv.Value;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading expanded state");
        }
    }

    private async Task SaveExpandedStateAsync()
    {
        try
        {
            var stateJson = System.Text.Json.JsonSerializer.Serialize(_expandedState);
            await JS.InvokeVoidAsync("localStorage.setItem", "bugs-triage-expanded-state", stateJson);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving expanded state");
        }
    }

    private void ClearError()
    {
        _errorMessage = null;
    }

    public async ValueTask DisposeAsync()
    {
        await Task.CompletedTask;
    }
}
