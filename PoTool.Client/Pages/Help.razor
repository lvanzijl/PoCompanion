@page "/help"
@using PoTool.Client.Components.Common

<PageTitle>Help & Data Requirements</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" /> Help & Data Requirements
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Understanding data requirements and validation rules for PO Companion features
    </MudText>

    <!-- Introduction -->
    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
                    Why Data Quality Matters
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Paragraph="true">
                PO Companion provides powerful analytics and insights based on your Azure DevOps work items. 
                To get the most value from these features, certain data fields must be consistently filled in TFS/Azure DevOps.
            </MudText>
            <MudText Typo="Typo.body1" Paragraph="true">
                This page explains what data is required for each feature and provides validation rules to help you maintain data quality.
            </MudText>
        </MudCardContent>
    </MudCard>

    <!-- Feature Requirements -->
    <MudExpansionPanels MultiExpansion="true">
        
        <!-- Velocity Dashboard -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" />
                    <MudText Typo="Typo.h6">Velocity Dashboard</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Iteration Path:</strong> Must be set for all work items to group them by sprint
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Effort (Story Points):</strong> Required for PBIs and tasks to calculate velocity
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State:</strong> Must be "Done", "Closed", "Completed", or "Resolved" for items to count as completed
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Type:</strong> Work item type (PBI, Bug, Task) must be set correctly
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Warning" GutterBottom="true" Class="mt-4">Data Quality Impact:</MudText>
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    <strong>Missing Effort:</strong> Work items without effort estimates won't contribute to velocity calculations
                </MudAlert>
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    <strong>Missing Iteration Path:</strong> Work items won't appear in any sprint metrics
                </MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true">
                    <strong>Tip:</strong> Use consistent iteration path naming (e.g., "Project\2025\Q1\Sprint 1") for better organization
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Work Item Explorer -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Work Item Explorer</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Title:</strong> Clear, descriptive titles for all work items
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Area Path:</strong> Must be set for filtering and organization
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Parent Work Item:</strong> Set for Features and PBIs to build hierarchy
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State:</strong> Current state (New, In Progress, Done, etc.)
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Error" GutterBottom="true" Class="mt-4">Validation Rules:</MudText>
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                    <strong>Rule 1:</strong> Work items "In Progress" must have an effort estimate
                </MudAlert>
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                    <strong>Rule 2:</strong> If a child work item is "In Progress", its parent must also be "In Progress" or "Done"
                </MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true">
                    <strong>Tip:</strong> Use the validation panel in Work Item Explorer to identify and fix data quality issues
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- PR Insights -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Tertiary" />
                    <MudText Typo="Typo.h6">PR Insights</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Iteration Path:</strong> Link PRs to work items with iteration paths for sprint analysis
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Created Date:</strong> Automatically captured by TFS
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Completed Date:</strong> Set when PR is completed/merged
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Best Practices:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Link pull requests to work items using "AB#123" syntax in commit messages or PR descriptions
                </MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true">
                    Complete PRs promptly to get accurate cycle time metrics
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Backlog Health Dashboard -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" />
                    <MudText Typo="Typo.h6">Backlog Health Dashboard</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Iteration Path:</strong> Required for all work items to group by sprint and track health trends
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Effort:</strong> Used to detect missing effort issues, especially for 'In Progress' items
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State:</strong> Used for parent-child state consistency validation
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Parent Link:</strong> Required for hierarchy validation
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Feature Description:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Monitors backlog health across multiple iterations, calculates health scores (% of items without issues), and identifies trends (improving/stable/degrading).
                </MudAlert>
                <MudAlert Severity="Severity.Success" Dense="true">
                    <strong>Target:</strong> Aim for 90%+ health score indicating good data quality and process discipline
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Dependency Graph -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Primary" />
                    <MudText Typo="Typo.h6">Dependency Chain Visualization</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Parent-Child Links:</strong> Automatically created hierarchy relationships (Epic → Feature → PBI)
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Circle">
                        <strong>Related Links:</strong> Optional manual dependency links like 'Predecessor' (blocks)
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State:</strong> Used to identify blocking items and critical path bottlenecks
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Effort:</strong> Required for critical path calculation
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Feature Description:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Visualizes work item dependencies, identifies critical paths (longest dependency chain), and detects blocking items that prevent progress on other work.
                </MudAlert>
                <MudAlert Severity="Severity.Warning" Dense="true">
                    <strong>Tip:</strong> Items blocking 3+ others should be highest priority. Critical path length determines minimum release time.
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Epic Forecast -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Info" />
                    <MudText Typo="Typo.h6">Epic/Feature Completion Forecast</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Effort:</strong> Required for all child work items to calculate total and remaining effort
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State:</strong> Used to determine completed vs remaining work
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Parent-Child Links:</strong> Required to identify all child work items
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Iteration Path:</strong> Used for historical velocity calculation
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Feature Description:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Forecasts Epic/Feature completion based on historical velocity with best/likely/worst case scenarios. Provides confidence levels based on velocity consistency.
                </MudAlert>
                <MudAlert Severity="Severity.Success" Dense="true">
                    <strong>Best Practice:</strong> Use 3-5 historical sprints for velocity calculation. High confidence (>75%) indicates reliable forecast.
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- State Timeline -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Secondary" />
                    <MudText Typo="Typo.h6">Work Item State Timeline</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>State History:</strong> Azure DevOps automatically tracks all state changes with timestamps
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Changed Date:</strong> Timestamp of each field change (automatic)
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Created Date:</strong> Work item creation date for lead time calculation
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Circle">
                        <strong>Closed Date:</strong> Optional - completion date for total cycle time
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Feature Description:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Analyzes work item lifecycle by tracking state transitions. Identifies bottlenecks (states taking 2x+ team average) and compares with team metrics.
                </MudAlert>
                <MudAlert Severity="Severity.Info" Dense="true">
                    <strong>Definitions:</strong> Lead Time = Created to Done (total time). Cycle Time = In Progress to Done (active work time).
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

        <!-- Effort Distribution -->
        <MudExpansionPanel>
            <TitleContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.GridOn" Color="Color.Tertiary" />
                    <MudText Typo="Typo.h6">Effort Distribution Heat Map</MudText>
                </MudStack>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true">Required Fields:</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Iteration Path:</strong> Required to group work items by sprint (horizontal axis)
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Area Path:</strong> Required to group work items by team/component (vertical axis)
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle">
                        <strong>Effort:</strong> Used to calculate total effort and capacity utilization
                    </MudListItem>
                    <MudListItem T="string" Icon="@Icons.Material.Filled.Circle">
                        <strong>State:</strong> Optional - filter to only planned work for future sprints
                    </MudListItem>
                </MudList>

                <MudText Typo="Typo.subtitle2" Color="Color.Info" GutterBottom="true" Class="mt-4">Feature Description:</MudText>
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    Visual capacity planning showing effort distribution across area paths and iterations. Color-coded heat map (red over 95%, green 60-95%, yellow under 60%) for quick identification of over/under-allocation.
                </MudAlert>
                <MudAlert Severity="Severity.Success" Dense="true">
                    <strong>Target:</strong> Aim for 75-85% capacity utilization (green zone) to allow buffer for unexpected work.
                </MudAlert>
            </ChildContent>
        </MudExpansionPanel>

    </MudExpansionPanels>

    <!-- Common Validation Rules -->
    <MudCard Elevation="2" Class="mt-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Rule" Class="mr-2" />
                    Common Validation Rules
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudSimpleTable Striped="true">
                <thead>
                    <tr>
                        <th>Rule</th>
                        <th>Severity</th>
                        <th>Description</th>
                        <th>Impact</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>In Progress → Effort Required</td>
                        <td><MudChip T="string" Color="Color.Error" Size="Size.Small">Error</MudChip></td>
                        <td>Work items in "In Progress" state must have an effort estimate</td>
                        <td>Prevents incomplete velocity data and sprint planning issues</td>
                    </tr>
                    <tr>
                        <td>Parent-Child State Consistency</td>
                        <td><MudChip T="string" Color="Color.Error" Size="Size.Small">Error</MudChip></td>
                        <td>If a child is "In Progress", parent must be "In Progress" or "Done"</td>
                        <td>Maintains hierarchy consistency and accurate progress tracking</td>
                    </tr>
                    <tr>
                        <td>Iteration Path Format</td>
                        <td><MudChip T="string" Color="Color.Warning" Size="Size.Small">Warning</MudChip></td>
                        <td>Use consistent naming: "Project\Year\Quarter\Sprint X"</td>
                        <td>Improves sprint grouping and trend analysis</td>
                    </tr>
                    <tr>
                        <td>Effort Value Range</td>
                        <td><MudChip T="string" Color="Color.Warning" Size="Size.Small">Warning</MudChip></td>
                        <td>Story points should typically be between 1 and 13</td>
                        <td>Ensures realistic estimates and velocity calculations</td>
                    </tr>
                </tbody>
            </MudSimpleTable>
        </MudCardContent>
    </MudCard>

    <!-- Quick Reference -->
    <MudCard Elevation="2" Class="mt-6 mb-6">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Class="mr-2" />
                    Quick Reference: Required Fields by Work Item Type
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.h6" Color="Color.Primary">Epic</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Title</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Area Path</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">State</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Iteration Path (optional)</MudListItem>
                    </MudList>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.h6" Color="Color.Primary">Feature / PBI</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Title</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Area Path</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Iteration Path</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">State</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Effort (Story Points)</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Parent Work Item</MudListItem>
                    </MudList>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudText Typo="Typo.h6" Color="Color.Primary">Bug / Task</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Title</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Area Path</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Iteration Path</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">State</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Effort (if applicable)</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Circle" IconSize="Size.Small">Parent Work Item</MudListItem>
                    </MudList>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <!-- Profile Management -->
    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="mr-2" />
                    Profile Management
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Paragraph="true">
                Profiles allow you to manage multiple product ownership contexts with distinct area paths, team assignments, and goal selections. 
                This is particularly useful when managing multiple products or teams within the same Azure DevOps project.
            </MudText>

            <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true" Class="mt-4">What are Profiles?</MudText>
            <MudText Typo="Typo.body2" Paragraph="true">
                A profile contains:
            </MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Folder">
                    <strong>Area Paths:</strong> Work items are automatically filtered to show only items matching these area paths
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Group">
                    <strong>Team Name:</strong> The team responsible for the area paths
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Flag">
                    <strong>Goals:</strong> Specific goals (work items) relevant to this profile
                </MudListItem>
            </MudList>

            <MudText Typo="Typo.subtitle2" Color="Color.Primary" GutterBottom="true" Class="mt-4">Creating and Managing Profiles:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.Add">
                    <strong>During Onboarding:</strong> Create your first profile in the onboarding wizard (Step 3)
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.Settings">
                    <strong>Manage Profiles:</strong> Click the "Manage Profiles" button in the top navigation bar
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.SwapHoriz">
                    <strong>Switch Profiles:</strong> Use the profile selector dropdown in the top-left corner
                </MudListItem>
            </MudList>

            <MudText Typo="Typo.subtitle2" Color="Color.Success" GutterBottom="true" Class="mt-4">Area Path Filtering:</MudText>
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                <strong>Hierarchical Matching:</strong> Area paths support parent/child relationships. For example, if your profile includes 
                "MyProject\\ProductA", it will also match "MyProject\\ProductA\\FeatureX" and all other child paths.
            </MudAlert>
            <MudAlert Severity="Severity.Success" Dense="true" Class="mb-2">
                <strong>Automatic Filtering:</strong> When a profile is active, all work item queries automatically filter to show only 
                items matching the profile's area paths. This includes the Work Item Explorer, Goals, and validation views.
            </MudAlert>
            <MudAlert Severity="Severity.Warning" Dense="true">
                <strong>No Active Profile:</strong> If no profile is selected, all work items are shown (no filtering applied). 
                This maintains backward compatibility with existing usage.
            </MudAlert>

            <MudText Typo="Typo.subtitle2" Color="Color.Warning" GutterBottom="true" Class="mt-4">Best Practices:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string" Icon="@Icons.Material.Filled.TipsAndUpdates">
                    Use descriptive profile names (e.g., "Product A - Team Alpha", "Mobile Apps Team")
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.TipsAndUpdates">
                    Include all relevant area paths to ensure complete visibility of work items
                </MudListItem>
                <MudListItem T="string" Icon="@Icons.Material.Filled.TipsAndUpdates">
                    Update profiles when your team structure or area paths change
                </MudListItem>
