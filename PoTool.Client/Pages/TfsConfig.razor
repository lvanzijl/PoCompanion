@page "/tfsconfig"
@inject HttpClient Http
@inject ISnackbar Snackbar

<PageTitle>TFS Configuration</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4">
        <MudText Typo="Typo.h4" Class="mb-4">TFS Configuration</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Configure your Azure DevOps / TFS connection settings. Your Personal Access Token (PAT) will be encrypted and stored securely.
        </MudText>

        <MudForm @ref="_form" @bind-IsValid="_formValid">
            <MudTextField @bind-Value="_url" 
                         Label="Organization URL" 
                         Placeholder="https://dev.azure.com/yourorg"
                         Required="true"
                         Variant="Variant.Outlined"
                         Margin="Margin.Normal"
                         HelperText="The URL of your Azure DevOps organization" />

            <MudTextField @bind-Value="_project" 
                         Label="Project Name" 
                         Placeholder="MyProject"
                         Required="true"
                         Variant="Variant.Outlined"
                         Margin="Margin.Normal"
                         HelperText="The name of your project" />

            <MudTextField @bind-Value="_pat" 
                         Label="Personal Access Token (PAT)" 
                         Placeholder="Your PAT"
                         Required="true"
                         Variant="Variant.Outlined"
                         Margin="Margin.Normal"
                         InputType="InputType.Password"
                         HelperText="Your PAT will be encrypted at rest" />

            <MudStack Row="true" Class="mt-4">
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          OnClick="SaveConfig"
                          Disabled="@(!_formValid || _isSaving)"
                          StartIcon="@Icons.Material.Filled.Save">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Configuration</span>
                    }
                </MudButton>

                <MudButton Variant="Variant.Filled" 
                          Color="Color.Secondary" 
                          OnClick="TestConnection"
                          Disabled="@(!_formValid || _isTesting)"
                          StartIcon="@Icons.Material.Filled.Check">
                    @if (_isTesting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Testing...</span>
                    }
                    else
                    {
                        <span>Test Connection</span>
                    }
                </MudButton>
            </MudStack>
        </MudForm>

        @if (!string.IsNullOrEmpty(_currentUrl))
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Current Configuration</MudText>
            <MudText Typo="Typo.body2">
                <strong>URL:</strong> @_currentUrl<br />
                <strong>Project:</strong> @_currentProject
            </MudText>
        }
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private bool _formValid;
    private bool _isSaving;
    private bool _isTesting;

    private string _url = string.Empty;
    private string _project = string.Empty;
    private string _pat = string.Empty;

    private string _currentUrl = string.Empty;
    private string _currentProject = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentConfig();
    }

    private async Task LoadCurrentConfig()
    {
        try
        {
            var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            var response = await Http.GetAsync($"{apiBase}/api/tfsconfig");
            
            if (response.IsSuccessStatusCode)
            {
                var config = await response.Content.ReadFromJsonAsync<TfsConfigResponse>();
                if (config != null)
                {
                    _currentUrl = config.Url ?? string.Empty;
                    _currentProject = config.Project ?? string.Empty;
                    _url = _currentUrl;
                    _project = _currentProject;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading configuration: {ex.Message}", Severity.Error);
        }
    }

    private async Task SaveConfig()
    {
        if (!_formValid) return;

        _isSaving = true;
        try
        {
            var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            var payload = new { Url = _url, Project = _project, Pat = _pat };
            var response = await Http.PostAsJsonAsync($"{apiBase}/api/tfsconfig", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Configuration saved successfully", Severity.Success);
                _currentUrl = _url;
                _currentProject = _project;
                _pat = string.Empty; // Clear PAT after saving
            }
            else
            {
                Snackbar.Add($"Error saving configuration: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task TestConnection()
    {
        if (!_formValid) return;

        _isTesting = true;
        try
        {
            // First save the config
            var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            var payload = new { Url = _url, Project = _project, Pat = _pat };
            var saveResponse = await Http.PostAsJsonAsync($"{apiBase}/api/tfsconfig", payload);

            if (!saveResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Error saving configuration before testing", Severity.Error);
                return;
            }

            // Then test the connection
            var testResponse = await Http.GetAsync($"{apiBase}/api/tfsvalidate");

            if (testResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Connection test successful!", Severity.Success);
                _currentUrl = _url;
                _currentProject = _project;
                _pat = string.Empty; // Clear PAT after successful test
            }
            else
            {
                Snackbar.Add("Connection test failed. Please check your credentials.", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error testing connection: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isTesting = false;
        }
    }

    private class TfsConfigResponse
    {
        public string? Url { get; set; }
        public string? Project { get; set; }
    }
}
