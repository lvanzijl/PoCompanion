@* Note: This page is no longer accessible via direct route. TFS configuration should be accessed through Settings (/settings/tfs) *@
@* @page "/tfsconfig" *@
@using PoTool.Client.Services
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Settings
@using PoTool.Client.ApiClient
@using PoTool.Client.Helpers
@using PoTool.Shared.Settings
@using Microsoft.Extensions.Logging
@using static PoTool.Client.Components.Common.PageHelp
@inject TfsConfigService TfsConfigService
@inject IStartupOrchestratorService StartupOrchestrator
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject HttpClient HttpClient
@inject ILogger<TfsConfig> _logger

<PageTitle>TFS Configuration</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    
    @* Startup Readiness Banner *@
    @if (_startupReadiness != null && !string.IsNullOrEmpty(_startupReadiness.MissingRequirementMessage))
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true" Icon="@Icons.Material.Filled.Info">
            <MudText Typo="Typo.subtitle2">@_startupReadiness.MissingRequirementMessage</MudText>
        </MudAlert>
    }
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Azure DevOps / TFS Configuration"
              Description="Configure your connection to Azure DevOps or on-premises TFS. This page allows you to set up authentication, test the connection, and ensure PO Companion can access your work item data."
              Class="mb-4"
              DataRequirements="@_configDataRequirements"
              BestPractices="@_configBestPractices"
              CommonIssues="@_configCommonIssues">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
            <strong>Authentication:</strong> This application uses Windows credentials (NTLM) of the current user to connect to TFS/Azure DevOps Server.
        </MudAlert>
    </PageHelp>
    
    <MudPaper Elevation="2" Class="pa-4">
        <MudText Typo="Typo.h4" Class="mb-4">TFS Configuration</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            Configure your Azure DevOps / TFS connection settings. Authentication uses Windows credentials (NTLM) of the current user.
        </MudText>

        @if (_isLoading)
        {
            <div class="d-flex justify-center align-center pa-4">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else
        {
            <MudForm @ref="_form" @bind-IsValid="_formValid">
            <CompactTextField Value="@_url" 
                         ValueChanged="@(async (string value) => await OnUrlChanged(value))"
                         Label="Organization URL" 
                         Placeholder="https://dev.azure.com/yourorg"
                         Required="true"
                         Immediate="true"
                         HelperText="The URL of your Azure DevOps organization" />

            @if (_isLoadingProjects)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    <MudText>Loading projects from TFS...</MudText>
                </MudStack>
            }
            else if (_tfsProjects != null && _tfsProjects.Any())
            {
                <MudAutocomplete T="TfsProjectDto"
                          Label="Project Name" 
                          Value="_selectedProject"
                          SearchFunc="@SearchProjects"
                          ToStringFunc="@(project => project?.Name ?? "")"
                          ValueChanged="@OnProjectSelected"
                          Required="true"
                          ResetValueOnEmptyText="true"
                          CoerceText="true"
                          HelperText="Choose your project from Azure DevOps (type to filter)">
                    <ItemTemplate Context="project">
                        <MudText>@project.Name</MudText>
                        @if (!string.IsNullOrEmpty(project.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@project.Description</MudText>
                        }
                    </ItemTemplate>
                </MudAutocomplete>
            }
            else
            {
                <CompactTextField @bind-Value="_project" 
                             Label="Project Name" 
                             Placeholder="MyProject"
                             Required="true"
                             Immediate="true"
                             HelperText="@(_url != string.Empty ? "Enter project name manually (could not load projects)" : "The name of your project")" />
            }

            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                <strong>Authentication:</strong> Uses Windows credentials (NTLM) of the current user. No additional configuration required.
            </MudAlert>

            <MudNumericField @bind-Value="_timeoutSeconds" 
                            Label="Timeout (seconds)" 
                            Variant="Variant.Outlined"
                            Margin="Margin.Normal"
                            Min="5"
                            Max="300"
                            HelperText="HTTP request timeout in seconds (5-300)" />

            <CompactTextField @bind-Value="_apiVersion" 
                         Label="API Version" 
                         ReadOnly="true"
                         HelperText="TFS/Azure DevOps API version (read-only)" />

            <MudStack Row="true" Class="mt-4">
                <CompactButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          OnClick="SaveConfig"
                          Disabled="@(!_formValid || _isSaving)"
                          StartIcon="@Icons.Material.Filled.Save">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Configuration</span>
                    }
                </CompactButton>

                <CompactButton Variant="Variant.Filled" 
                          Color="Color.Secondary" 
                          OnClick="TestConnection"
                          Disabled="@(!_formValid || _isTesting)"
                          StartIcon="@Icons.Material.Filled.Check">
                    @if (_isTesting)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Testing...</span>
                    }
                    else
                    {
                        <span>Test Connection</span>
                    }
                </CompactButton>

                <CompactButton Variant="Variant.Filled" 
                          Color="Color.Info" 
                          OnClick="VerifyTfsApi"
                          Disabled="@(!_formValid || _isVerifying)"
                          StartIcon="@Icons.Material.Filled.Verified">
                    @if (_isVerifying)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Verifying...</span>
                    }
                    else
                    {
                        <span>Verify TFS API</span>
                    }
                </CompactButton>
            </MudStack>

            @* Optional write verification controls *@
            <MudExpansionPanels Class="mt-3" Elevation="0">
                <MudExpansionPanel Text="Advanced Verification Options" Dense="true">
                    <MudCheckBox @bind-Value="_includeWriteChecks" 
                                Label="Include write capability checks"
                                Color="Color.Primary"
                                Class="mb-2">
                        Verify write operations (requires work item ID)
                    </MudCheckBox>

                    @if (_includeWriteChecks)
                    {
                        <CompactTextField @bind-Value="_writeCheckWorkItemId" 
                                     Label="Work Item ID for Write Check" 
                                     Placeholder="e.g., 1234"
                                     HelperText="Provide an existing work item ID for safe write verification" />
                    }
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudForm>

        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mt-4"
                      OnDismiss="ClearError" />

        @if (!string.IsNullOrEmpty(_currentUrl))
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-2">Current Configuration</MudText>
            <MudText Typo="Typo.body2">
                <strong>URL:</strong> @_currentUrl<br />
                <strong>Project:</strong> @_currentProject<br />
                <strong>Authentication:</strong> Windows (NTLM)<br />
                <strong>Timeout:</strong> @_timeoutSeconds seconds<br />
                <strong>API Version:</strong> @_apiVersion
                @if (_lastValidated.HasValue)
                {
                    <br /><strong>Last Validated:</strong> @_lastValidated.Value.ToLocalTime().ToString("g")
                }
            </MudText>
        }
        }
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private bool _formValid;
    private bool _isSaving;
    private bool _isTesting;
    private bool _isVerifying;
    private bool _isLoading = true;

    private string _url = string.Empty;
    private string _project = string.Empty;
    private bool _isLoadingProjects;
    private List<TfsProjectDto>? _tfsProjects;
    private TfsProjectDto? _selectedProject;
    private bool _useDefaultCredentials = true;
    private int _timeoutSeconds = 30;
    private string _apiVersion = "7.0";

    // Write verification options
    private bool _includeWriteChecks = false;
    private string _writeCheckWorkItemId = string.Empty;

    private string _currentUrl = string.Empty;
    private string _currentProject = string.Empty;
    private DateTimeOffset? _lastValidated;

    // Verification report
    private TfsVerificationReport? _verificationReport;

    // Error display
    private ErrorResponse? _errorResponse;
    
    // Startup readiness state
    private PoTool.Client.Services.StartupReadinessDto? _startupReadiness;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentConfig();
        await LoadStartupReadiness();
    }
    
    private async Task LoadStartupReadiness()
    {
        try
        {
            _startupReadiness = await StartupOrchestrator.GetStartupReadinessAsync();
        }
        catch (Exception)
        {
            // Graceful degradation - don't block the page
        }
    }

    private async Task OnUrlChanged(string value)
    {
        _url = value;
        
        // Trigger form validation
        if (_form != null)
        {
            await _form.Validate();
        }

        // Load projects when URL is entered
        if (!string.IsNullOrWhiteSpace(value))
        {
            await LoadTfsProjects(value);
        }
        else
        {
            _tfsProjects = null;
            _selectedProject = null;
            _project = string.Empty;
        }
        
        StateHasChanged();
    }

    private void OnProjectSelected(TfsProjectDto? project)
    {
        _selectedProject = project;
        _project = project?.Name ?? string.Empty;
        StateHasChanged();
    }

    private async Task LoadTfsProjects(string organizationUrl)
    {
        _isLoadingProjects = true;
        StateHasChanged();

        try
        {
            var encodedUrl = Uri.EscapeDataString(organizationUrl);
            var response = await HttpClient.GetAsync($"/api/startup/tfs-projects?organizationUrl={encodedUrl}");
            
            if (response.IsSuccessStatusCode)
            {
                _tfsProjects = await response.Content.ReadFromJsonAsync<List<TfsProjectDto>>(JsonHelper.CaseInsensitiveOptions);
            }
            else
            {
                _logger.LogWarning("Failed to load TFS projects: {StatusCode}", response.StatusCode);
                _tfsProjects = null;
            }
        }
        catch (Exception ex)
        {
            _logger.LogWarning(ex, "Error loading TFS projects");
            _tfsProjects = null;
        }
        finally
        {
            _isLoadingProjects = false;
            StateHasChanged();
        }
    }

    private Task<IEnumerable<TfsProjectDto>> SearchProjects(string? searchText, CancellationToken cancellationToken)
    {
        if (_tfsProjects == null || !_tfsProjects.Any())
            return Task.FromResult(Enumerable.Empty<TfsProjectDto>());

        if (string.IsNullOrWhiteSpace(searchText))
            return Task.FromResult(_tfsProjects.AsEnumerable());

        var filtered = _tfsProjects.Where(project => 
            project.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (!string.IsNullOrEmpty(project.Description) && project.Description.Contains(searchText, StringComparison.OrdinalIgnoreCase))
        );

        return Task.FromResult(filtered);
    }

    private async Task LoadCurrentConfig()
    {
        try
        {
            _isLoading = true;
            ClearError();
            var config = await TfsConfigService.GetConfigAsync();
            if (config != null)
            {
                _currentUrl = config.Url ?? string.Empty;
                _currentProject = config.Project ?? string.Empty;
                _url = _currentUrl;
                _project = _currentProject;
                _useDefaultCredentials = config.UseDefaultCredentials;
                _timeoutSeconds = config.TimeoutSeconds;
                _apiVersion = config.ApiVersion;
                _lastValidated = config.LastValidated;
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading configuration");
        }
        finally
        {
            _isLoading = false;
            // Trigger form validation after loading to enable buttons if form is valid
            if (_form != null)
            {
                await _form.Validate();
            }
        }
    }

    private async Task SaveConfig()
    {
        if (!_formValid) return;

        _isSaving = true;
        ClearError();
        try
        {
            // DefaultAreaPath is derived from Project name, pass project as parameter
            await TfsConfigService.SaveConfigAsync(_url, _project, _project, _useDefaultCredentials, _timeoutSeconds, _apiVersion);
            Snackbar.Add("Configuration saved successfully", Severity.Success);
            _currentUrl = _url;
            _currentProject = _project;
            await LoadCurrentConfig(); // Reload to get LastValidated
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error saving configuration");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task TestConnection()
    {
        if (!_formValid) return;

        _isTesting = true;
        ClearError();
        try
        {
            // First save the config
            // DefaultAreaPath is derived from Project name
            await TfsConfigService.SaveConfigAsync(_url, _project, _project, _useDefaultCredentials, _timeoutSeconds, _apiVersion);

            // Then test the connection (throws on failure with detailed error information)
            var isValid = await TfsConfigService.ValidateConnectionAsync();

            if (isValid)
            {
                Snackbar.Add("Connection test successful!", Severity.Success);
                _currentUrl = _url;
                _currentProject = _project;
                await LoadCurrentConfig(); // Reload to get updated LastValidated
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Connection test failed");
        }
        finally
        {
            _isTesting = false;
        }
    }

    private async Task VerifyTfsApi()
    {
        if (!_formValid) return;

        _isVerifying = true;
        ClearError();
        _verificationReport = null; // Clear previous report
        
        try
        {
            // First save the config
            // DefaultAreaPath is derived from Project name
            await TfsConfigService.SaveConfigAsync(_url, _project, _project, _useDefaultCredentials, _timeoutSeconds, _apiVersion);

            // Parse work item ID if provided
            int? workItemId = null;
            if (_includeWriteChecks && !string.IsNullOrWhiteSpace(_writeCheckWorkItemId))
            {
                if (int.TryParse(_writeCheckWorkItemId, out var parsedId))
                {
                    workItemId = parsedId;
                }
                else
                {
                    _errorResponse = new ErrorResponse
                    {
                        UserMessage = "Invalid Work Item ID",
                        Suggestion = "Please enter a valid numeric work item ID for write verification."
                    };
                    _isVerifying = false;
                    StateHasChanged();
                    return;
                }
            }

            // Open the modal dialog immediately (shows loading state)
            var dialogOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseOnEscapeKey = false
            };

            var parameters = new DialogParameters<TfsVerificationModal>
            {
                { x => x.IsVerifying, true },
                { x => x.InitialReport, null },
                { x => x.ErrorMessage, null }
            };

            var dialogRef = await DialogService.ShowAsync<TfsVerificationModal>("TFS API Verification", parameters, dialogOptions);

            // Run verification while modal is open
            TfsVerificationReport? report = null;
            string? errorMessage = null;
            
            try
            {
                report = await TfsConfigService.VerifyTfsApiAsync(_includeWriteChecks, workItemId);
                
                if (report == null)
                {
                    errorMessage = "TFS API verification failed. Please check your configuration and try again.";
                }
            }
            catch (Exception verifyEx)
            {
                errorMessage = $"Verification failed: {verifyEx.Message}";
            }

            // Update the modal with the results
            // Unfortunately MudBlazor doesn't support updating dialog parameters after open,
            // so we need to close and reopen the dialog with results
            dialogRef.Close();

            // Reopen with results
            var resultParameters = new DialogParameters<TfsVerificationModal>
            {
                { x => x.IsVerifying, false },
                { x => x.InitialReport, report },
                { x => x.ErrorMessage, errorMessage }
            };

            var resultDialogOptions = new DialogOptions
            {
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                CloseOnEscapeKey = true
            };

            await DialogService.ShowAsync<TfsVerificationModal>("TFS API Verification", resultParameters, resultDialogOptions);

            // Update state based on results
            _verificationReport = report;
            
            if (report != null)
            {
                if (report.Success)
                {
                    Snackbar.Add("TFS API verification completed successfully!", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"TFS API verification completed with {report.Checks.Count(c => !c.Success)} failures", Severity.Warning);
                }
                
                _currentUrl = _url;
                _currentProject = _project;
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error verifying TFS API");
        }
        finally
        {
            _isVerifying = false;
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private List<DataRequirement> _configDataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Organization URL", 
            Description = "The URL of your Azure DevOps organization (e.g., https://dev.azure.com/yourorg) or on-premises TFS server",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Project Name", 
            Description = "The exact name of your Azure DevOps project as it appears in the organization",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Default Area Path", 
            Description = "The area path used for work item queries (e.g., 'ProjectName\\Team A'). This must match an existing area path in your Azure DevOps project",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Personal Access Token (PAT)", 
            Description = "Required for PAT authentication mode. Must have at least 'Work Items (Read)' permission",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Authentication Mode", 
            Description = "PAT for Azure DevOps cloud, NTLM for on-premises TFS with Windows authentication",
            IsRequired = true 
        }
    };

    private List<string> _configBestPractices = new()
    {
        "Use Personal Access Token (PAT) authentication for Azure DevOps cloud instances",
        "Create a dedicated PAT for PO Companion with minimal required permissions (Work Items Read)",
        "Set PAT expiration to a reasonable timeframe (90-180 days) and renew before expiration",
        "Test the connection after saving configuration to verify settings",
        "For on-premises TFS, use NTLM authentication with your Windows credentials",
        "Set timeout to 60+ seconds if working with large projects or slow network connections",
        "Keep your Organization URL exact - include 'https://' and avoid trailing slashes"
    };

    private List<CommonIssue> _configCommonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "Connection test fails with 'Unauthorized' error",
            Solution = "Verify your PAT is valid, not expired, and has 'Work Items (Read)' permission. Create a new PAT if needed."
        },
        new CommonIssue 
        { 
            Problem = "Cannot connect to on-premises TFS server",
            Solution = "Ensure you're using NTLM authentication mode, the server URL is accessible from your network, and your Windows credentials have access."
        },
        new CommonIssue 
        { 
            Problem = "Connection times out",
            Solution = "Increase the timeout value to 60 or more seconds. Check network connectivity and firewall settings."
        },
        new CommonIssue 
        { 
            Problem = "Project not found error",
            Solution = "Verify the project name is spelled exactly as it appears in Azure DevOps, including capitalization."
        },
        new CommonIssue 
        { 
            Problem = "PAT expired message",
            Solution = "Generate a new PAT in Azure DevOps (User Settings → Personal Access Tokens → New Token) and update the configuration."
        }
    };
}
