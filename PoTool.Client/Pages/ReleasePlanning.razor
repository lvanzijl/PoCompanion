@page "/release-planning"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.ReleasePlanning
@using PoTool.Client.Services
@using PoTool.Shared.ReleasePlanning
@using static PoTool.Client.Components.Common.PageHelp
@inject ReleasePlanningService ReleasePlanningService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Release Planning Board - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Release Planning Board"
              Description="Plan and visualize Epic ordering across Objectives using a git-style flow diagram. Place Epics from the unplanned list onto the board to define delivery sequence."
              Class="mb-4"
              BestPractices="@_bestPractices">
        <MudText Typo="Typo.body2">
            <strong>Key Concepts:</strong>
        </MudText>
        <MudList T="string" Dense="true">
            <MudListItem T="string" Icon="@Icons.Material.Filled.ViewColumn">
                <strong>Lanes:</strong> Each lane represents an Objective. Epics can only be placed in their parent Objective's lane.
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.TableRows">
                <strong>Rows:</strong> Rows represent relative time/ordering. Lower rows are delivered before higher rows.
            </MudListItem>
            <MudListItem T="string" Icon="@Icons.Material.Filled.CallSplit">
                <strong>Connectors:</strong> Git-style lines show ordering flow between Epics (splits, merges, parallel work).
            </MudListItem>
        </MudList>
    </PageHelp>

    <!-- Toolbar -->
    <MudPaper Class="pa-2 mb-4" Elevation="1">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Row="true" Spacing="2">
                <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                           Size="Size.Small"
                           Variant="Variant.Outlined"
                           OnClick="@HandleRefreshValidation">
                    Refresh Validation
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           Variant="Variant.Outlined"
                           OnClick="@HandleAddLane">
                    Add Lane
                </MudButton>
            </MudStack>

            <MudStack Row="true" Spacing="2">
                <MudButton StartIcon="@Icons.Material.Filled.Timeline"
                           Size="Size.Small"
                           Variant="Variant.Text"
                           OnClick="@HandleAddMilestone">
                    Add Milestone
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Schedule"
                           Size="Size.Small"
                           Variant="Variant.Text"
                           OnClick="@HandleAddIteration">
                    Add Iteration
                </MudButton>
                <MudButton StartIcon="@Icons.Material.Filled.Download"
                           Size="Size.Small"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="@HandleExport">
                    Export
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <!-- Release Planning Board -->
    <ReleasePlanningBoard />

</MudContainer>

@code {
    private ReleasePlanningBoardDto? _board;

    private List<string> _bestPractices = new()
    {
        "Drag Epics from the Unplanned list to place them on the board",
        "Epics can only be moved within their parent Objective's lane",
        "Use Milestone Lines to mark release boundaries",
        "Use Iteration Lines to mark sprint boundaries",
        "Validation indicators show data quality issues that need attention",
        "Export the board as PNG or PDF for stakeholder communication"
    };

    protected override async Task OnInitializedAsync()
    {
        _board = await ReleasePlanningService.GetBoardAsync();
    }

    private async Task HandleRefreshValidation()
    {
        var result = await ReleasePlanningService.RefreshValidationAsync();
        // TODO: Show snackbar with result
    }

    private void HandleAddLane()
    {
        // TODO: Open dialog to select Objective
    }

    private void HandleAddMilestone()
    {
        // TODO: Open dialog to create milestone line
    }

    private void HandleAddIteration()
    {
        // TODO: Open dialog to create iteration line
    }

    private async Task HandleExport()
    {
        var parameters = new DialogParameters<ExportDialog>
        {
            { x => x.Board, _board }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<ExportDialog>("Export", parameters, options);
    }
}
