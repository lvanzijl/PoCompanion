@page "/landing"
@using PoTool.Client.Components.Common
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>PO Companion - Landing</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-8">
    <MudStack AlignItems="AlignItems.Center" Spacing="6">
        @* Header *@
        <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
            What would you like to do?
        </MudText>
        
        <MudText Typo="Typo.subtitle1" Align="Align.Center" Class="mb-4" Style="color: var(--mud-palette-text-secondary);">
            Choose your intent to get started
        </MudText>

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        }
        else
        {
            @* Intent Cards Grid *@
            <MudGrid Spacing="4" Justify="Justify.Center">
                @* Overzien Card *@
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="intent-card" 
                             Elevation="4"
                             Style="cursor: pointer; height: 100%; min-height: 280px; transition: all 0.3s ease; border: 2px solid transparent;"
                             @onclick="@(() => SelectIntent(Intent.Overzien))">
                        <MudCardContent Class="d-flex flex-column align-center justify-center pa-6" Style="height: 100%;">
                            <MudIcon Icon="@Icons.Material.Filled.Visibility" 
                                     Color="Color.Primary" 
                                     Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h5" Class="mt-4 text-center" Style="font-weight: 600;">
                                Overzien
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                                Build context and choose scope
                            </MudText>
                            <MudDivider Class="my-4" Light="true" />
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="color: var(--mud-palette-text-secondary); font-style: italic;">
                                "What am I looking at?"
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Begrijpen Card *@
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="intent-card" 
                             Elevation="4"
                             Style="cursor: pointer; height: 100%; min-height: 280px; transition: all 0.3s ease; border: 2px solid transparent;"
                             @onclick="@(() => SelectIntent(Intent.Begrijpen))">
                        <MudCardContent Class="d-flex flex-column align-center justify-center pa-6" Style="height: 100%;">
                            <MudIcon Icon="@Icons.Material.Filled.Psychology" 
                                     Color="Color.Secondary" 
                                     Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h5" Class="mt-4 text-center" Style="font-weight: 600;">
                                Begrijpen
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                                Analyze, diagnose, reflect
                            </MudText>
                            <MudDivider Class="my-4" Light="true" />
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="color: var(--mud-palette-text-secondary); font-style: italic;">
                                "Why is this happening?"
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Plannen Card *@
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="intent-card" 
                             Elevation="4"
                             Style="cursor: pointer; height: 100%; min-height: 280px; transition: all 0.3s ease; border: 2px solid transparent;"
                             @onclick="@(() => SelectIntent(Intent.Plannen))">
                        <MudCardContent Class="d-flex flex-column align-center justify-center pa-6" Style="height: 100%;">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" 
                                     Color="Color.Info" 
                                     Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h5" Class="mt-4 text-center" Style="font-weight: 600;">
                                Plannen
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                                Structure and look ahead
                            </MudText>
                            <MudDivider Class="my-4" Light="true" />
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="color: var(--mud-palette-text-secondary); font-style: italic;">
                                "What should happen next?"
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Delen Card *@
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="intent-card" 
                             Elevation="4"
                             Style="cursor: pointer; height: 100%; min-height: 280px; transition: all 0.3s ease; border: 2px solid transparent;"
                             @onclick="@(() => SelectIntent(Intent.Delen))">
                        <MudCardContent Class="d-flex flex-column align-center justify-center pa-6" Style="height: 100%;">
                            <MudIcon Icon="@Icons.Material.Filled.Share" 
                                     Color="Color.Success" 
                                     Style="font-size: 4rem;" />
                            <MudText Typo="Typo.h5" Class="mt-4 text-center" Style="font-weight: 600;">
                                Delen
                            </MudText>
                            <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-2" Style="color: var(--mud-palette-text-secondary);">
                                Communicate and export
                            </MudText>
                            <MudDivider Class="my-4" Light="true" />
                            <MudText Typo="Typo.caption" Align="Align.Center" Style="color: var(--mud-palette-text-secondary); font-style: italic;">
                                "Who needs to know?"
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>

            @* Quick Actions *@
            <MudStack Row="true" Spacing="2" Class="mt-8">
                <MudButton Variant="Variant.Text" 
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.SwapHoriz"
                           OnClick="SwitchProfile">
                    Switch Profile
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudContainer>

<style>
    .intent-card:hover {
        border-color: var(--mud-palette-primary) !important;
        transform: translateY(-4px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.3) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        
        try
        {
            // Get the active profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                // No profile selected, redirect to profiles
                NavigationManager.NavigateTo("/profiles");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectIntent(Intent intent)
    {
        if (_profileId == null)
        {
            Snackbar.Add("Please select a profile first", Severity.Warning);
            NavigationManager.NavigateTo("/profiles");
            return;
        }

        // Set the initial navigation context
        NavigationContextService.SetInitialContext(intent, _profileId.Value);

        // Navigate to the appropriate workspace based on intent
        var route = intent switch
        {
            Intent.Overzien => "/workspace/product",
            Intent.Begrijpen => "/workspace/analysis",
            Intent.Plannen => "/workspace/planning",
            Intent.Delen => "/workspace/communication",
            _ => "/landing"
        };

        // For now, since workspaces are not yet implemented, navigate to existing pages
        // This will be updated as workspaces are implemented
        var temporaryRoute = intent switch
        {
            Intent.Overzien => "/product-home",       // Product Workspace (Phase 3)
            Intent.Begrijpen => "/backlog-health",    // Analysis Workspace (Phase 5)
            Intent.Plannen => "/release-planning",    // Planning Workspace (Phase 6)
            Intent.Delen => "/product-home",          // Communication Workspace (Phase 4) - no equivalent yet
            _ => "/landing"
        };

        // Use temporary routes until workspaces are implemented
        NavigationManager.NavigateTo(temporaryRoute);
    }

    private void SwitchProfile()
    {
        NavigationContextService.ClearContext();
        NavigationManager.NavigateTo("/profiles");
    }
}
