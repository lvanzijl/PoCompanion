@using PoTool.Client.ApiClient
@using PoTool.Client.Models
@using PoTool.Client.Services
@using PoTool.Shared.BugTriage
@using MudBlazor
@inject TfsFieldParserService TfsFieldParser
@inject WorkItemService WorkItemService
@inject ILogger<BugTriageDetailsPanel> Logger

<div class="bug-details-content pa-3">
    <MudStack Spacing="3">
        @* Bug Header *@
        <div>
            <MudText Typo="Typo.h6" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.BugReport" Size="Size.Small" Class="mr-1" />
                Bug #@Bug.TfsId
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-2">@Bug.Title</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Default">@Bug.State</MudChip>
        </div>

        @* Severity Selector *@
        <MudPaper Class="pa-3" Elevation="1">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Severity</MudText>
            
            @* Show error if severity is missing or invalid *@
            @if (!string.IsNullOrEmpty(_severityError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">
                    @_severityError
                </MudAlert>
            }
            
            @if (_severityOptions.Any())
            {
                @if (string.IsNullOrEmpty(_currentSeverity))
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-2" Dense="true">
                        No severity value found for this bug.
                    </MudAlert>
                }
                else if (!_severityOptions.Contains(_currentSeverity))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-2" Dense="true">
                        Invalid severity: "@_currentSeverity" (not in allowed values: @string.Join(", ", _severityOptions))
                    </MudAlert>
                }
                
                <MudSelect T="string"
                          Value="@_currentSeverity"
                          ValueChanged="@HandleSeverityChanged"
                          Variant="Variant.Outlined"
                          Dense="true"
                          Disabled="@(string.IsNullOrEmpty(_currentSeverity))">
                    @foreach (var severity in _severityOptions)
                    {
                        <MudSelectItem Value="@severity">@severity</MudSelectItem>
                    }
                </MudSelect>
            }
            else
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">Loading severity options...</MudText>
            }
        </MudPaper>

        @* Triage Tags *@
        @if (EnabledTags.Any())
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Triage Tags</MudText>
                <MudStack Spacing="1">
                    @foreach (var tag in EnabledTags)
                    {
                        var isActive = _activeTags.Contains(tag.Name);
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                 Color="@(isActive ? Color.Primary : Color.Default)"
                                 OnClick="@(() => ToggleTag(tag.Name))">
                            @tag.Name
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

        @* Bug Metadata *@
        <MudPaper Class="pa-3" Elevation="1">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Details</MudText>
            <MudStack Spacing="1">
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Area Path:</MudText>
                    <MudText Typo="Typo.body2">@Bug.AreaPath</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Iteration:</MudText>
                    <MudText Typo="Typo.body2">@Bug.IterationPath</MudText>
                </div>
                @if (Bug.CreatedDate.HasValue)
                {
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Created:</MudText>
                        <MudText Typo="Typo.body2">@Bug.CreatedDate.Value.ToString("yyyy-MM-dd")</MudText>
                    </div>
                }
            </MudStack>
        </MudPaper>

        @* Description *@
        @if (!string.IsNullOrWhiteSpace(Bug.Description))
        {
            <MudPaper Class="pa-3" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Description</MudText>
                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Bug.Description</MudText>
            </MudPaper>
        }
    </MudStack>
</div>

@code {
    [Parameter]
    public WorkItemWithValidationDto Bug { get; set; } = null!;

    [Parameter]
    public List<TriageTagDto> EnabledTags { get; set; } = new();

    [Parameter]
    public EventCallback<(int BugId, string NewSeverity)> OnSeverityChanged { get; set; }

    [Parameter]
    public EventCallback<(int BugId, string TagName, bool IsAdded)> OnTagToggled { get; set; }

    private string? _currentSeverity = null; // No default - must come from TFS
    private HashSet<string> _activeTags = new();
    private List<string> _severityOptions = new();
    private string? _severityError = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeverityOptionsAsync();
    }

    protected override void OnParametersSet()
    {
        if (Bug != null)
        {
            // Reset error state
            _severityError = null;
            
            // Get severity directly from TFS payload - NO FALLBACKS
            _currentSeverity = TfsFieldParser.GetSeverity(Bug);
            
            // Log and set error if severity is missing
            if (string.IsNullOrEmpty(_currentSeverity))
            {
                var availableFields = GetAvailableFieldsSummary(Bug);
                Logger.LogError("Bug {BugId} has NO Severity field (Microsoft.VSTS.Common.Severity). Available fields: {Fields}", 
                    Bug.TfsId, availableFields);
                _severityError = $"Severity field (Microsoft.VSTS.Common.Severity) is missing from bug {Bug.TfsId}";
            }
            // Check if severity value is in allowed list
            else if (_severityOptions.Any() && !_severityOptions.Contains(_currentSeverity))
            {
                Logger.LogError("Bug {BugId} has INVALID Severity value: '{Severity}'. Allowed values: {AllowedValues}", 
                    Bug.TfsId, _currentSeverity, string.Join(", ", _severityOptions));
                _severityError = $"Invalid severity value: '{_currentSeverity}'";
            }
            
            _activeTags = new HashSet<string>(GetBugTags(Bug), StringComparer.OrdinalIgnoreCase);
        }
    }

    private async Task LoadSeverityOptionsAsync()
    {
        try
        {
            var options = await WorkItemService.GetBugSeverityOptionsAsync();
            _severityOptions = options.ToList();
            Logger.LogInformation("Loaded {Count} severity options from TFS", _severityOptions.Count);
            
            if (!_severityOptions.Any())
            {
                Logger.LogError("NO severity options returned from TFS - this is a critical configuration error");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "CRITICAL: Failed to load severity options from TFS");
            _severityOptions = new List<string>(); // Empty list - no fallback
        }
    }

    private async Task HandleSeverityChanged(string newSeverity)
    {
        if (_currentSeverity != newSeverity)
        {
            _currentSeverity = newSeverity;
            await OnSeverityChanged.InvokeAsync((Bug.TfsId, newSeverity));
        }
    }

    private async Task ToggleTag(string tagName)
    {
        var isAdded = !_activeTags.Contains(tagName);
        
        if (isAdded)
        {
            _activeTags.Add(tagName);
        }
        else
        {
            _activeTags.Remove(tagName);
        }
        
        await OnTagToggled.InvokeAsync((Bug.TfsId, tagName, isAdded));
    }

    private List<string> GetBugTags(WorkItemWithValidationDto bug)
    {
        return TfsFieldParser.GetTags(bug);
    }
    
    private string GetAvailableFieldsSummary(WorkItemWithValidationDto bug)
    {
        if (string.IsNullOrEmpty(bug.JsonPayload))
        {
            return "JsonPayload is empty";
        }
        
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(bug.JsonPayload);
            var fieldNames = doc.RootElement.EnumerateObject().Select(p => p.Name).ToList();
            return string.Join(", ", fieldNames.Take(10)) + (fieldNames.Count > 10 ? $" ... ({fieldNames.Count} total)" : "");
        }
        catch
        {
            return "Unable to parse JSON payload";
        }
    }
}
