@page "/velocity"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using static PoTool.Client.Components.Common.PageHelp
@inject IMetricsClient MetricsClient
@inject ISnackbar Snackbar

<PageTitle>Velocity Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Velocity Dashboard Guide"
              Description="The Velocity Dashboard tracks your team's completed story points per sprint, helping you forecast future work and plan sprints more accurately. Velocity is calculated based on completed work items with effort estimates in each iteration."
              Class="mb-4"
              DataRequirements="@_velocityDataRequirements"
              BestPractices="@_velocityBestPractices"
              CommonIssues="@_velocityCommonIssues" />
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" /> Velocity Dashboard
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Track team velocity and sprint metrics for data-driven planning
    </MudText>

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && _velocityTrend == null)
    {
        <EmptyStateDisplay Title="No Velocity Data Available"
                          Message="There are no sprints with completed work items to display velocity metrics."
                          AdditionalInfo="Make sure you have synced work items from Azure DevOps with iteration paths and completed story points." />
    }
    else
    {
        <!-- Velocity Summary Cards -->
        <MudGrid Class="mb-6">
            <MetricSummaryCard Label="Average Velocity"
                              Value="@_velocityTrend.AverageVelocity.ToString("F1")"
                              SubLabel="story points"
                              Icon="@Icons.Material.Filled.Speed"
                              IconColor="Color.Primary" />
            
            <MetricSummaryCard Label="Last 3 Sprints"
                              Value="@_velocityTrend.ThreeSprintAverage.ToString("F1")"
                              SubLabel="average velocity"
                              Icon="@Icons.Material.Filled.CalendarMonth"
                              IconColor="Color.Info" />

            <MetricSummaryCard Label="Total Sprints"
                              Value="@_velocityTrend.TotalSprints.ToString()"
                              SubLabel="tracked"
                              Icon="@Icons.Material.Filled.Timeline"
                              IconColor="Color.Success" />

            <MetricSummaryCard Label="Total Completed"
                              Value="@_velocityTrend.TotalCompletedStoryPoints.ToString()"
                              SubLabel="story points"
                              Icon="@Icons.Material.Filled.CheckCircle"
                              IconColor="Color.Tertiary" />
        </MudGrid>

        <!-- Velocity Chart -->
        <MudCard Elevation="2" Class="mb-6">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Velocity Trend</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (_velocityTrend.Sprints.Any())
                {
                    <MudChart ChartType="ChartType.Line" 
                              ChartSeries="@_chartSeries" 
                              XAxisLabels="@_xAxisLabels.ToArray()"
                              Width="100%" 
                              Height="350px"
                              ChartOptions="@_chartOptions" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="py-8">
                        No sprint data available for chart
                    </MudText>
                }
            </MudCardContent>
        </MudCard>

        <!-- Sprint Details Table -->
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Sprint Details</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudTable Items="@_velocityTrend.Sprints" 
                          Hover="true" 
                          Striped="true" 
                          Dense="true"
                          Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh>Sprint</MudTh>
                        <MudTh>Completed Points</MudTh>
                        <MudTh>Planned Points</MudTh>
                        <MudTh>Completion %</MudTh>
                        <MudTh>Completed Items</MudTh>
                        <MudTh>PBIs</MudTh>
                        <MudTh>Bugs</MudTh>
                        <MudTh>Tasks</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Sprint">
                            <MudText Typo="Typo.body2"><strong>@context.SprintName</strong></MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.IterationPath</MudText>
                        </MudTd>
                        <MudTd DataLabel="Completed Points">
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small">@context.CompletedStoryPoints</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Planned Points">@context.PlannedStoryPoints</MudTd>
                        <MudTd DataLabel="Completion %">
                            @{
                                var completionPercent = context.PlannedStoryPoints > 0 
                                    ? (context.CompletedStoryPoints * 100.0 / context.PlannedStoryPoints) 
                                    : 0;
                                var color = completionPercent >= 90 ? Color.Success : 
                                           completionPercent >= 70 ? Color.Warning : Color.Error;
                            }
                            <MudProgressLinear Color="@color" 
                                             Value="@completionPercent" 
                                             Class="my-2" 
                                             Size="Size.Small" />
                            <MudText Typo="Typo.caption">@completionPercent.ToString("F0")%</MudText>
                        </MudTd>
                        <MudTd DataLabel="Completed Items">
                            @context.CompletedWorkItemCount / @context.TotalWorkItemCount
                        </MudTd>
                        <MudTd DataLabel="PBIs">@context.CompletedPBIs</MudTd>
                        <MudTd DataLabel="Bugs">@context.CompletedBugs</MudTd>
                        <MudTd DataLabel="Tasks">@context.CompletedTasks</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    }

    <!-- Refresh Button -->
    <MudFab Color="Color.Primary" 
            StartIcon="@Icons.Material.Filled.Refresh" 
            Label="Refresh Metrics" 
            Class="mt-4"
            OnClick="@LoadVelocityData"
            Disabled="@_isLoading" />
</MudContainer>

@code {
    private bool _isLoading = true;
    private VelocityTrendDto? _velocityTrend;
    private List<ChartSeries> _chartSeries = new();
    private List<string> _xAxisLabels = new();
    private ChartOptions _chartOptions = new() 
    { 
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        YAxisLines = true,
        XAxisLines = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadVelocityData();
    }

    private async Task LoadVelocityData()
    {
        _isLoading = true;
        StateHasChanged();

        try
        {
            // Get velocity trend for last 10 sprints
            _velocityTrend = await MetricsClient.GetVelocityTrendAsync(areaPath: null, maxSprints: 10);
            
            if (_velocityTrend?.Sprints.Any() == true)
            {
                PrepareChartData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading velocity data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void PrepareChartData()
    {
        if (_velocityTrend == null || !_velocityTrend.Sprints.Any())
            return;

        // Reverse sprints to show oldest to newest (left to right)
        var sprints = _velocityTrend.Sprints.Reverse().ToList();

        _xAxisLabels = sprints.Select(s => s.SprintName).ToList();

        _chartSeries = new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Completed Story Points",
                Data = sprints.Select(s => (double)s.CompletedStoryPoints).ToArray()
            },
            new ChartSeries
            {
                Name = "Planned Story Points",
                Data = sprints.Select(s => (double)s.PlannedStoryPoints).ToArray()
            },
            new ChartSeries
            {
                Name = "Average Velocity",
                Data = Enumerable.Repeat(_velocityTrend.AverageVelocity, sprints.Count).ToArray()
            }
        };
    }

    private List<DataRequirement> _velocityDataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Iteration Path", 
            Description = "Must be set for all work items to group them by sprint. Use consistent naming like 'Project\\2025\\Sprint 1'",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Effort (Story Points)", 
            Description = "Required for PBIs, Bugs, and Tasks to calculate velocity. Use Fibonacci scale (1,2,3,5,8,13) for consistency",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "State", 
            Description = "Must be 'Done', 'Closed', 'Completed', or 'Resolved' for items to count as completed",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Work Item Type", 
            Description = "Used to classify work (PBI, Bug, Task) and show effort distribution",
            IsRequired = true 
        }
    };

    private List<string> _velocityBestPractices = new()
    {
        "Use the 3-sprint average for most accurate short-term forecasting",
        "Plan to 80-85% of velocity to allow buffer for unexpected work",
        "Stable velocity is better than high velocity - consistency enables predictability",
        "Update effort estimates before marking items as 'Done' for accurate velocity",
        "Use velocity for planning, not for comparing teams (velocity is team-relative)",
        "Re-evaluate velocity after significant team changes (new members, departures)",
        "Track completion percentage - consistently below 90% indicates over-commitment",
        "Use effort distribution to ensure balance between features, bugs, and technical work"
    };

    private List<CommonIssue> _velocityCommonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "Velocity shows 0 or no data",
            Solution = "Ensure work items have: 1) Iteration Path set, 2) Effort values assigned, 3) State marked as 'Done', and 4) Data has been synced."
        },
        new CommonIssue 
        { 
            Problem = "Velocity is highly inconsistent between sprints",
            Solution = "Review effort estimation practices, check for incomplete items, and ensure consistent 'Done' criteria. Large swings may indicate over/under commitment."
        },
        new CommonIssue 
        { 
            Problem = "Planned vs Completed shows large gaps",
            Solution = "Team may be over-committing. Reduce planned work to 80-85% of recent velocity average, or investigate blockers causing incomplete work."
        },
        new CommonIssue 
        { 
            Problem = "Some sprints missing from dashboard",
            Solution = "Check that sprints have iteration paths in TFS and contain completed work items with effort. Empty sprints won't appear."
        },
        new CommonIssue 
        { 
            Problem = "Effort distribution shows too many bugs",
            Solution = "High bug percentage (>30%) may indicate quality issues. Review development practices, add automated testing, or improve code review process."
        }
    };
}

