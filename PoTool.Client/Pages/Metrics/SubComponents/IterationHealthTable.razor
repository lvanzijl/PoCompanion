@using PoTool.Client.ApiClient
@using PoTool.Client.Services

@* Grid of iteration health cards showing validation issues and metrics *@

<MudGrid>
    @foreach (var iteration in Iterations)
    {
        <MudItem xs="12" md="6" lg="4">
            @if (iteration.SprintName == "[undefined]")
            {
                @* Placeholder card for undefined future sprint *@
                <MudCard Elevation="2" Class="mud-height-full" Style="opacity: 0.6;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Secondary">@iteration.SprintName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@iteration.IterationPath</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Color="Color.Default" Size="Size.Medium" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 200px;">
                            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center">
                                newer sprints aren't available
                            </MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                @* Regular sprint card *@
                <MudCard Elevation="2" Class="mud-height-full">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@iteration.SprintName</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@iteration.IterationPath</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            @{
                                var healthScore = GetHealthScore(iteration);
                            }
                            @if (healthScore < 70)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Medium" />
                            }
                            else if (healthScore < 90)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Size="Size.Medium" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" />
                            }
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Total Work Items</MudText>
                                <MudText Typo="Typo.body1" Color="Color.Primary">@iteration.TotalWorkItems</MudText>
                            </MudStack>
                            <MudDivider />
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Without Effort</MudText>
                                <MudText Typo="Typo.body1" Color="@(iteration.WorkItemsWithoutEffort > 0 ? Color.Warning : Color.Default)">
                                    @iteration.WorkItemsWithoutEffort
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">In Progress w/o Effort</MudText>
                                <MudText Typo="Typo.body1" Color="@(iteration.WorkItemsInProgressWithoutEffort > 0 ? Color.Error : Color.Default)">
                                    @iteration.WorkItemsInProgressWithoutEffort
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Parent Progress Issues</MudText>
                                <MudText Typo="Typo.body1" Color="@(iteration.ParentProgressIssues > 0 ? Color.Error : Color.Default)">
                                    @iteration.ParentProgressIssues
                                </MudText>
                            </MudStack>
                            <MudStack Row="true" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Blocked Items</MudText>
                                <MudText Typo="Typo.body1" Color="@(iteration.BlockedItems > 0 ? Color.Error : Color.Default)">
                                    @iteration.BlockedItems
                                </MudText>
                            </MudStack>
                            @if (iteration.InProgressAtIterationEnd > 0)
                            {
                                <MudDivider />
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">In Progress at End</MudText>
                                    <MudText Typo="Typo.body1" Color="Color.Warning">
                                        @iteration.InProgressAtIterationEnd
                                    </MudText>
                                </MudStack>
                            }
                        </MudStack>

                        @if (iteration.ValidationIssues.Any())
                        {
                            <MudDivider Class="my-3" />
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Validation Issues</MudText>
                            <MudStack Spacing="1">
                                @foreach (var issue in iteration.ValidationIssues)
                                {
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText Typo="Typo.caption">@issue.ValidationType</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(issue.ValidationType)">
                                            @issue.Count
                                        </MudChip>
                                    </MudStack>
                                }
                            </MudStack>
                        }
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>
    }
</MudGrid>

@code {
    [Inject]
    private BacklogHealthCalculationService HealthCalculationService { get; set; } = default!;

    /// <summary>
    /// List of iteration health data to display
    /// </summary>
    [Parameter]
    public List<BacklogHealthDto> Iterations { get; set; } = new();

    private Dictionary<string, int> _healthScores = new();

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();
        
        // Pre-calculate health scores for non-placeholder iterations only
        _healthScores.Clear();
        var index = 0;
        foreach (var iteration in Iterations)
        {
            // Skip placeholder sprints - use index as unique key since multiple placeholders have same name
            if (iteration.SprintName == "[undefined]")
            {
                _healthScores[$"[undefined]_{index}"] = 0;
            }
            else
            {
                var score = await HealthCalculationService.CalculateHealthScoreAsync(iteration);
                _healthScores[iteration.SprintName] = score;
            }
            index++;
        }
    }

    private int GetHealthScore(BacklogHealthDto iteration)
    {
        // Try exact match first
        if (_healthScores.TryGetValue(iteration.SprintName, out var score))
        {
            return score;
        }
        
        // For placeholders, find by index (fallback)
        if (iteration.SprintName == "[undefined]")
        {
            var index = Iterations.IndexOf(iteration);
            if (index >= 0 && _healthScores.TryGetValue($"[undefined]_{index}", out var placeholderScore))
            {
                return placeholderScore;
            }
        }
        
        return 0;
    }

    private Color GetSeverityColor(string severity)
    {
        return HealthCalculationService.GetSeverityColor(severity);
    }
}
