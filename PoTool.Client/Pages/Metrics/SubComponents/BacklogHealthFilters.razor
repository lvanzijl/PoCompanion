@* Filter controls for backlog health analysis *@

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
        <MudTextField @bind-Value="AreaPathFilter" 
                     Label="Area Path Filter" 
                     Variant="Variant.Outlined"
                     Adornment="Adornment.End"
                     AdornmentIcon="@Icons.Material.Filled.FilterAlt"
                     HelperText="Filter work items by area path" />
        <MudNumericField @bind-Value="MaxIterations" 
                        Label="Max Iterations" 
                        Variant="Variant.Outlined"
                        Min="1" Max="100"
                        HelperText="Number of iterations to analyze" />
        <MudButton Variant="Variant.Filled" 
                  Color="Color.Primary" 
                  OnClick="HandleRefresh"
                  StartIcon="@Icons.Material.Filled.Refresh">
            Refresh
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    private string? _areaPathFilter;
    private int _maxIterations = 5;
    
    /// <summary>
    /// Area path filter value
    /// </summary>
    [Parameter]
    public string? AreaPathFilter 
    { 
        get => _areaPathFilter; 
        set
        {
            if (_areaPathFilter != value)
            {
                _areaPathFilter = value;
                AreaPathFilterChanged.InvokeAsync(value);
            }
        }
    }
    
    [Parameter]
    public EventCallback<string?> AreaPathFilterChanged { get; set; }

    /// <summary>
    /// Maximum number of iterations to analyze
    /// </summary>
    [Parameter]
    public int MaxIterations 
    { 
        get => _maxIterations; 
        set
        {
            if (_maxIterations != value)
            {
                _maxIterations = value;
                MaxIterationsChanged.InvokeAsync(value);
            }
        }
    }
    
    [Parameter]
    public EventCallback<int> MaxIterationsChanged { get; set; }

    /// <summary>
    /// Callback invoked when Refresh button is clicked
    /// </summary>
    [Parameter]
    public EventCallback OnRefresh { get; set; }

    private async Task HandleRefresh()
    {
        await OnRefresh.InvokeAsync();
    }
}
