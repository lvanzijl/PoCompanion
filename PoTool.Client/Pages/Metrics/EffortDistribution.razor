@page "/effort-distribution"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using static PoTool.Client.Components.Common.PageHelp
@inject IMetricsClient MetricsClient
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar

<PageTitle>Effort Distribution Heat Map</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Effort Distribution Heat Map Guide"
              Description="Visual capacity planning tool showing effort distribution across area paths and iterations. Use color-coded heat map to identify over/under-allocated teams and balance workload across sprints for sustainable delivery."
              Class="mb-4"
              DataRequirements="@_distributionDataRequirements"
              BestPractices="@_distributionBestPractices"
              CommonIssues="@_distributionCommonIssues">
        <MudAlert Severity="Severity.Success" Dense="true" Class="mt-2">
            <strong>Capacity Target:</strong> Aim for 75-85% capacity utilization (green zone). This provides buffer for unexpected work, code reviews, meetings, and prevents team burnout.
        </MudAlert>
    </PageHelp>
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.GridOn" Class="mr-2" /> Effort Distribution Heat Map
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Visual capacity planning showing effort distribution across area paths and iterations
    </MudText>

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && _distributionData == null)
    {
        <EmptyStateDisplay Title="No Effort Distribution Data Available"
                          Message="No work items found to analyze. Please sync work items first." />
    }
    else if (!_isLoading && _distributionData != null)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />

        <!-- Summary Cards -->
        <MudGrid Class="mb-6">
            <MetricSummaryCard Label="Total Effort"
                              Value="@_distributionData.TotalEffort.ToString()"
                              Icon="@Icons.Material.Filled.Assignment"
                              IconColor="Color.Primary" />
            
            <MetricSummaryCard Label="Area Paths"
                              Value="@_distributionData.EffortByArea.Count.ToString()"
                              Icon="@Icons.Material.Filled.FolderOpen"
                              IconColor="Color.Info" />
            
            <MetricSummaryCard Label="Iterations"
                              Value="@_distributionData.EffortByIteration.Count.ToString()"
                              Icon="@Icons.Material.Filled.CalendarMonth"
                              IconColor="Color.Success" />
            
            <MetricSummaryCard Label="Avg Utilization"
                              Value="@($"{GetAverageUtilization()}%")"
                              Icon="@Icons.Material.Filled.Speed"
                              IconColor="@GetUtilizationColor()" />
        </MudGrid>

        <!-- Filters -->
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudTextField @bind-Value="_areaPathFilter" 
                              Label="Area Path Filter" 
                              Variant="Variant.Outlined"
                              Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.FilterAlt"
                              HelperText="Filter by area path" />
                <MudNumericField @bind-Value="_maxIterations" 
                                 Label="Max Iterations" 
                                 Variant="Variant.Outlined"
                                 Min="1" Max="100"
                                 HelperText="Number of iterations to analyze" />
                <MudNumericField @bind-Value="_defaultCapacity" 
                                 Label="Default Capacity" 
                                 Variant="Variant.Outlined"
                                 Min="0"
                                 HelperText="Default capacity per iteration" />
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           OnClick="LoadData"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    Refresh
                </MudButton>
            </MudStack>
        </MudPaper>

        <!-- Heat Map -->
        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Effort Heat Map (Area Path × Iteration)</MudText>
            @if (_distributionData.HeatMapData.Any())
            {
                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>Area Path</th>
                            @foreach (var iteration in _distributionData.EffortByIteration)
                            {
                                <th class="text-center">
                                    <div>@iteration.SprintName</div>
                                    @if (iteration.Capacity.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">Cap: @iteration.Capacity</MudText>
                                    }
                                </th>
                            }
                            <th class="text-center">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var areaPath in _distributionData.EffortByArea)
                        {
                            <tr>
                                <td><strong>@GetShortAreaPath(areaPath.AreaPath)</strong></td>
                                @foreach (var iteration in _distributionData.EffortByIteration)
                                {
                                    var cell = _distributionData.HeatMapData
                                        .FirstOrDefault(c => c.AreaPath == areaPath.AreaPath && c.IterationPath == iteration.IterationPath);
                                    <td class="text-center" style="@GetHeatMapCellStyle(cell)">
                                        @if (cell != null && cell.Effort > 0)
                                        {
                                            <div>
                                                <strong>@cell.Effort</strong>
                                                <MudText Typo="Typo.caption" Style="display: block;">(@cell.WorkItemCount items)</MudText>
                                            </div>
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                }
                                <td class="text-center"><strong>@areaPath.TotalEffort</strong></td>
                            </tr>
                        }
                        <tr style="background-color: var(--mud-palette-background-grey); font-weight: bold;">
                            <td>Total</td>
                            @foreach (var iteration in _distributionData.EffortByIteration)
                            {
                                <td class="text-center">@iteration.TotalEffort</td>
                            }
                            <td class="text-center">@_distributionData.TotalEffort</td>
                        </tr>
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info">No effort data available for heat map.</MudAlert>
            }
        </MudPaper>

        <!-- Effort by Iteration Chart -->
        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Effort by Iteration</MudText>
            <MudChart ChartType="ChartType.Bar" 
                      Width="100%" 
                      Height="400px"
                      ChartSeries="@GetIterationChartData()" 
                      XAxisLabels="@GetIterationLabels()"
                      ChartOptions="@_chartOptions">
            </MudChart>
        </MudPaper>

        <!-- Effort by Area Path Chart -->
        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Effort by Area Path</MudText>
            <MudChart ChartType="ChartType.Pie" 
                      Width="100%" 
                      Height="400px"
                      InputData="@GetAreaPathChartData()" 
                      InputLabels="@GetAreaPathLabels()">
            </MudChart>
        </MudPaper>

        <!-- Utilization Table -->
        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Iteration Utilization</MudText>
            <MudTable Items="@_distributionData.EffortByIteration" Dense="true" Hover="true" Bordered="true">
                <HeaderContent>
                    <MudTh>Sprint</MudTh>
                    <MudTh>Iteration Path</MudTh>
                    <MudTh class="text-right">Work Items</MudTh>
                    <MudTh class="text-right">Total Effort</MudTh>
                    <MudTh class="text-right">Capacity</MudTh>
                    <MudTh class="text-right">Utilization</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Sprint">@context.SprintName</MudTd>
                    <MudTd DataLabel="Iteration Path">@context.IterationPath</MudTd>
                    <MudTd DataLabel="Work Items" class="text-right">@context.WorkItemCount</MudTd>
                    <MudTd DataLabel="Total Effort" class="text-right">@context.TotalEffort</MudTd>
                    <MudTd DataLabel="Capacity" class="text-right">
                        @(context.Capacity?.ToString() ?? "N/A")
                    </MudTd>
                    <MudTd DataLabel="Utilization" class="text-right">
                        @context.UtilizationPercentage.ToString("F1")%
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.UtilizationPercentage > 100)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Error">Overcommitted</MudChip>
                        }
                        else if (context.UtilizationPercentage > 90)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Near Capacity</MudChip>
                        }
                        else if (context.UtilizationPercentage > 70)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">Normal</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">Underutilized</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <!-- Enhanced Analytics Section -->
        <MudText Typo="Typo.h5" Class="mt-8 mb-4">
            <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" /> Enhanced Analytics
        </MudText>

        <!-- Analytics Tabs -->
        <MudPaper Elevation="2" Class="pa-4">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Imbalance Detection" Icon="@Icons.Material.Filled.Balance">
                    @if (_imbalanceData != null)
                    {
                        <MudGrid Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Overall Risk</MudText>
                                        <MudChip T="string" Size="Size.Large" Color="@GetImbalanceRiskColor(_imbalanceData.OverallRiskLevel)">
                                            @_imbalanceData.OverallRiskLevel
                                        </MudChip>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Imbalance Score</MudText>
                                        <MudText Typo="Typo.h4">@_imbalanceData.ImbalanceScore.ToString("F1")%</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        @if (_imbalanceData.TeamImbalances.Any())
                        {
                            <MudText Typo="Typo.h6" GutterBottom="true">Team Imbalances</MudText>
                            <MudTable Items="@_imbalanceData.TeamImbalances" Dense="true" Hover="true" Class="mb-4">
                                <HeaderContent>
                                    <MudTh>Area Path</MudTh>
                                    <MudTh class="text-right">Total Effort</MudTh>
                                    <MudTh class="text-right">Average</MudTh>
                                    <MudTh class="text-right">Deviation</MudTh>
                                    <MudTh>Risk Level</MudTh>
                                    <MudTh>Description</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Area Path">@context.AreaPath</MudTd>
                                    <MudTd DataLabel="Total Effort" class="text-right">@context.TotalEffort</MudTd>
                                    <MudTd DataLabel="Average" class="text-right">@context.AverageEffortAcrossTeams</MudTd>
                                    <MudTd DataLabel="Deviation" class="text-right">@context.DeviationPercentage.ToString("F1")%</MudTd>
                                    <MudTd DataLabel="Risk Level">
                                        <MudChip T="string" Size="Size.Small" Color="@GetImbalanceRiskColor(context.RiskLevel)">
                                            @context.RiskLevel
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Description">@context.Description</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }

                        @if (_imbalanceData.Recommendations.Any())
                        {
                            <MudText Typo="Typo.h6" GutterBottom="true">Recommendations</MudText>
                            <MudList T="string" Dense="true">
                                @foreach (var rec in _imbalanceData.Recommendations)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Lightbulb" IconColor="@GetImbalanceRiskColor(rec.Priority)">
                                        <MudText Typo="Typo.subtitle2"><strong>@rec.Title</strong></MudText>
                                        <MudText Typo="Typo.body2">@rec.Description</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadImbalanceData" StartIcon="@Icons.Material.Filled.Analytics">
                            Analyze Imbalances
                        </MudButton>
                    }
                </MudTabPanel>

                <MudTabPanel Text="Trend Analysis" Icon="@Icons.Material.Filled.TrendingUp">
                    @if (_trendData != null)
                    {
                        <MudGrid Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Overall Trend</MudText>
                                        <MudChip T="string" Size="Size.Large" Color="@GetTrendColor(_trendData.OverallTrend)">
                                            @_trendData.OverallTrend
                                        </MudChip>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Trend Slope</MudText>
                                        <MudText Typo="Typo.h4">@_trendData.TrendSlope.ToString("F2")</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        <MudText Typo="Typo.h6" GutterBottom="true">Sprint Trends</MudText>
                        <MudChart ChartType="ChartType.Line" 
                                  Width="100%" 
                                  Height="350px"
                                  ChartSeries="@GetTrendChartData()" 
                                  XAxisLabels="@GetTrendLabels()">
                        </MudChart>

                        @if (_trendData.Forecasts.Any())
                        {
                            <MudText Typo="Typo.h6" GutterBottom="true" Class="mt-4">Forecasts (Next 3 Sprints)</MudText>
                            <MudTable Items="@_trendData.Forecasts" Dense="true" Hover="true">
                                <HeaderContent>
                                    <MudTh>Sprint</MudTh>
                                    <MudTh class="text-right">Forecasted Effort</MudTh>
                                    <MudTh class="text-right">Low Estimate</MudTh>
                                    <MudTh class="text-right">High Estimate</MudTh>
                                    <MudTh class="text-right">Confidence</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Sprint">@context.SprintName</MudTd>
                                    <MudTd DataLabel="Forecasted" class="text-right"><strong>@context.ForecastedEffort</strong></MudTd>
                                    <MudTd DataLabel="Low" class="text-right">@context.LowEstimate</MudTd>
                                    <MudTd DataLabel="High" class="text-right">@context.HighEstimate</MudTd>
                                    <MudTd DataLabel="Confidence" class="text-right">@((context.ConfidenceLevel * 100).ToString("F0"))%</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadTrendData" StartIcon="@Icons.Material.Filled.TrendingUp">
                            Analyze Trends
                        </MudButton>
                    }
                </MudTabPanel>

                <MudTabPanel Text="Concentration Risk" Icon="@Icons.Material.Filled.Warning">
                    @if (_concentrationData != null)
                    {
                        <MudGrid Class="mb-4">
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Risk Level</MudText>
                                        <MudChip T="string" Size="Size.Large" Color="@GetConcentrationRiskColor(_concentrationData.OverallRiskLevel)">
                                            @_concentrationData.OverallRiskLevel
                                        </MudChip>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                            <MudItem xs="12" sm="6" md="3">
                                <MudCard>
                                    <MudCardContent>
                                        <MudText Typo="Typo.h6">Concentration Index</MudText>
                                        <MudText Typo="Typo.h4">@_concentrationData.ConcentrationIndex.ToString("F1")</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>

                        @if (_concentrationData.AreaPathRisks.Any())
                        {
                            <MudText Typo="Typo.h6" GutterBottom="true">Area Path Concentration</MudText>
                            <MudTable Items="@_concentrationData.AreaPathRisks" Dense="true" Hover="true" Class="mb-4">
                                <HeaderContent>
                                    <MudTh>Area</MudTh>
                                    <MudTh class="text-right">Effort</MudTh>
                                    <MudTh class="text-right">% of Total</MudTh>
                                    <MudTh>Risk Level</MudTh>
                                    <MudTh>Description</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Area">@context.Name</MudTd>
                                    <MudTd DataLabel="Effort" class="text-right">@context.EffortAmount</MudTd>
                                    <MudTd DataLabel="% of Total" class="text-right">@context.PercentageOfTotal.ToString("F1")%</MudTd>
                                    <MudTd DataLabel="Risk Level">
                                        <MudChip T="string" Size="Size.Small" Color="@GetConcentrationRiskColor(context.RiskLevel)">
                                            @context.RiskLevel
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="Description">@context.Description</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }

                        @if (_concentrationData.Recommendations.Any())
                        {
                            <MudText Typo="Typo.h6" GutterBottom="true">Mitigation Recommendations</MudText>
                            <MudList T="string" Dense="true">
                                @foreach (var rec in _concentrationData.Recommendations)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Security" IconColor="@GetConcentrationRiskColor(rec.Priority)">
                                        <MudText Typo="Typo.subtitle2"><strong>@rec.Title</strong></MudText>
                                        <MudText Typo="Typo.body2">@rec.Description</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    }
                    else
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadConcentrationData" StartIcon="@Icons.Material.Filled.Warning">
                            Analyze Concentration Risk
                        </MudButton>
                    }
                </MudTabPanel>
            </MudTabs>
        </MudPaper>
    }
</MudContainer>

@code {
    private EffortDistributionDto? _distributionData;
    private EffortImbalanceDto? _imbalanceData;
    private EffortDistributionTrendDto? _trendData;
    private EffortConcentrationRiskDto? _concentrationData;
    private bool _isLoading = true;
    private ErrorResponse? _errorResponse;
    private string? _areaPathFilter;
    private int _maxIterations = 10;
    private int? _defaultCapacity = 40;
    private double _imbalanceThreshold = 0.3;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.NaturalSpline
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            ClearError();
            _distributionData = await MetricsClient.GetEffortDistributionAsync(
                _areaPathFilter, 
                _maxIterations,
                _defaultCapacity);
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading effort distribution data");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadImbalanceData()
    {
        try
        {
            ClearError();
            _imbalanceData = await MetricsClient.GetEffortImbalanceAsync(
                _areaPathFilter,
                _maxIterations,
                _defaultCapacity,
                _imbalanceThreshold);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading imbalance analysis");
        }
    }

    private async Task LoadTrendData()
    {
        try
        {
            ClearError();
            _trendData = await MetricsClient.GetEffortDistributionTrendAsync(
                _areaPathFilter,
                _maxIterations,
                _defaultCapacity);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading trend analysis");
        }
    }

    private async Task LoadConcentrationData()
    {
        try
        {
            ClearError();
            _concentrationData = await MetricsClient.GetEffortConcentrationRiskAsync(
                _areaPathFilter,
                _maxIterations,
                0.5);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading concentration risk");
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private string GetAverageUtilization()
    {
        if (_distributionData == null || !_distributionData.EffortByIteration.Any())
            return "0.0";
        
        var avg = _distributionData.EffortByIteration.Average(i => i.UtilizationPercentage);
        return avg.ToString("F1");
    }

    private Color GetUtilizationColor()
    {
        if (_distributionData == null || !_distributionData.EffortByIteration.Any())
            return Color.Default;
        
        var avg = _distributionData.EffortByIteration.Average(i => i.UtilizationPercentage);
        return avg switch
        {
            > 100 => Color.Error,
            > 90 => Color.Warning,
            > 70 => Color.Success,
            _ => Color.Info
        };
    }

    private Color GetImbalanceRiskColor(ImbalanceRiskLevel risk)
    {
        return risk switch
        {
            ImbalanceRiskLevel.Critical => Color.Error,
            ImbalanceRiskLevel.High => Color.Warning,
            ImbalanceRiskLevel.Medium => Color.Info,
            _ => Color.Success
        };
    }

    private Color GetConcentrationRiskColor(ConcentrationRiskLevel risk)
    {
        return risk switch
        {
            ConcentrationRiskLevel.Critical => Color.Error,
            ConcentrationRiskLevel.High => Color.Warning,
            ConcentrationRiskLevel.Medium => Color.Info,
            ConcentrationRiskLevel.Low => Color.Success,
            _ => Color.Default
        };
    }

    private Color GetTrendColor(EffortTrendDirection trend)
    {
        return trend switch
        {
            EffortTrendDirection.Volatile => Color.Error,
            EffortTrendDirection.Increasing => Color.Warning,
            EffortTrendDirection.Decreasing => Color.Info,
            _ => Color.Success
        };
    }

    private List<ChartSeries> GetTrendChartData()
    {
        if (_trendData == null) return new List<ChartSeries>();

        return new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Total Effort",
                Data = _trendData.TrendBySprint.Select(t => (double)t.TotalEffort).ToArray()
            }
        };
    }

    private string[] GetTrendLabels()
    {
        if (_trendData == null) return Array.Empty<string>();
        
        return _trendData.TrendBySprint
            .Select(t => t.SprintName)
            .ToArray();
    }

    private string GetHeatMapCellStyle(EffortHeatMapCell? cell)
    {
        if (cell == null || cell.Effort == 0)
            return "background-color: var(--mud-palette-background-grey); color: var(--mud-palette-text-disabled);";

        var color = cell.Status switch
        {
            CapacityStatus.OverCapacity => "background-color: rgba(244, 67, 54, 0.3);",  // Red
            CapacityStatus.NearCapacity => "background-color: rgba(255, 152, 0, 0.3);", // Orange
            CapacityStatus.Normal => "background-color: rgba(76, 175, 80, 0.3);",       // Green
            CapacityStatus.Underutilized => "background-color: rgba(33, 150, 243, 0.2);", // Blue
            _ => "background-color: var(--mud-palette-background);"
        };

        return $"{color} font-weight: 500;";
    }

    private string GetShortAreaPath(string areaPath)
    {
        var parts = areaPath.Split('\\');
        return parts.Length > 2 ? string.Join("\\", parts.Skip(parts.Length - 2)) : areaPath;
    }

    private List<ChartSeries> GetIterationChartData()
    {
        if (_distributionData == null) return new List<ChartSeries>();

        return new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Total Effort",
                Data = _distributionData.EffortByIteration.Select(i => (double)i.TotalEffort).ToArray()
            },
            new ChartSeries
            {
                Name = "Capacity",
                Data = _distributionData.EffortByIteration.Select(i => (double)(i.Capacity ?? 0)).ToArray()
            }
        };
    }

    private string[] GetIterationLabels()
    {
        if (_distributionData == null) return Array.Empty<string>();
        
        return _distributionData.EffortByIteration
            .Select(i => i.SprintName)
            .ToArray();
    }

    private double[] GetAreaPathChartData()
    {
        if (_distributionData == null) return Array.Empty<double>();
        
        return _distributionData.EffortByArea
            .Select(a => (double)a.TotalEffort)
            .ToArray();
    }

    private string[] GetAreaPathLabels()
    {
        if (_distributionData == null) return Array.Empty<string>();
        
        return _distributionData.EffortByArea
            .Select(a => GetShortAreaPath(a.AreaPath))
            .ToArray();
    }

