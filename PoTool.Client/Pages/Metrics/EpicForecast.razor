@page "/epic-forecast"
@page "/epic-forecast/{epicId:int}"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Client.Models
@using PoTool.Shared.Metrics
@using static PoTool.Client.Components.Common.PageHelp
@inject IMetricsClient MetricsClient
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Epic Completion Forecast</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Epic/Feature Completion Forecast Guide"
              Description="Forecast when an Epic or Feature will be completed based on historical velocity and remaining work. Uses your team's actual delivery data to provide realistic completion estimates with best/likely/worst case scenarios."
              Class="mb-4"
              DataRequirements="@_forecastDataRequirements"
              BestPractices="@_forecastBestPractices"
              CommonIssues="@_forecastCommonIssues">
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
            <strong>Forecast Accuracy:</strong> Forecasts are most accurate when velocity is consistent (low standard deviation) and scope is frozen. Re-forecast after significant scope changes or team adjustments.
        </MudAlert>
    </PageHelp>
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2" /> Epic/Feature Completion Forecast
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Velocity-based forecasting for Epic and Feature completion using historical sprint data
    </MudText>

    <!-- Epic Selection -->
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudNumericField @bind-Value="_selectedEpicId" 
                             Label="Epic/Feature ID" 
                             Variant="Variant.Outlined"
                             Min="1"
                             HelperText="Enter Epic or Feature work item ID" 
                             Style="max-width: 250px;" />
            <MudNumericField @bind-Value="_maxSprintsForVelocity" 
                             Label="Historical Sprints" 
                             Variant="Variant.Outlined"
                             Min="1" Max="20"
                             HelperText="Sprints to use for velocity calculation"
                             Style="max-width: 250px;" />
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       OnClick="LoadForecast"
                       Disabled="@(!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0)"
                       StartIcon="@Icons.Material.Filled.Calculate">
                Calculate
            </MudButton>
        </MudStack>
    </MudPaper>

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && _forecastData != null)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />

        <!-- Epic Info Card -->
        <MudCard Elevation="3" Class="mb-6">
            <MudCardContent>
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.h5">@_forecastData.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            ID: @_forecastData.EpicId | Type: @_forecastData.Type | Area: @_forecastData.AreaPath
                        </MudText>
                    </div>
                    <MudStack Spacing="2">
                        <MudChip T="string" Size="Size.Large" Color="@GetConfidenceColor(_forecastData.Confidence)">
                            @_forecastData.Confidence Confidence
                        </MudChip>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>

        <!-- Progress Summary -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Effort</MudText>
                                <MudText Typo="Typo.h5">@_forecastData.TotalEffort</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.Flag" Size="Size.Large" Color="Color.Primary" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Completed</MudText>
                                <MudText Typo="Typo.h5" Color="Color.Success">@_forecastData.CompletedEffort</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Remaining</MudText>
                                <MudText Typo="Typo.h5" Color="Color.Warning">@_forecastData.RemainingEffort</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Size="Size.Large" Color="Color.Warning" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudCard Elevation="2">
                    <MudCardContent>
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Sprints Remaining</MudText>
                                <MudText Typo="Typo.h5">@_forecastData.SprintsRemaining</MudText>
                            </div>
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Large" Color="Color.Info" />
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        <!-- Estimated Completion -->
        @if (_forecastData.EstimatedCompletionDate.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mb-6">
                <MudText Typo="Typo.h6">Estimated Completion Date</MudText>
                <MudText Typo="Typo.h5">@_forecastData.EstimatedCompletionDate.Value.LocalDateTime.ToString("MMMM dd, yyyy")</MudText>
                <MudText Typo="Typo.body2">
                    Based on average velocity of @_forecastData.EstimatedVelocity.ToString("F1") points per sprint
                </MudText>
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Class="mb-6">
                <MudText Typo="Typo.h6">Cannot Estimate Completion Date</MudText>
                <MudText>Insufficient historical data or no remaining work.</MudText>
            </MudAlert>
        }

        <!-- Progress Chart -->
        <MudPaper Elevation="2" Class="pa-4 mb-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Progress Overview</MudText>
            <MudProgressLinear Color="Color.Success" 
                              Value="@GetProgressPercentage()" 
                              Size="Size.Large" 
                              Class="mb-2" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @GetProgressPercentage().ToString("F1")% Complete
            </MudText>
        </MudPaper>

        <!-- Sprint Forecast Timeline -->
        @if (_forecastData.ForecastByDate.Any())
        {
            <MudPaper Elevation="2" Class="pa-4 mb-6">
                <MudText Typo="Typo.h6" GutterBottom="true">Sprint-by-Sprint Forecast</MudText>
                <MudTable Items="@_forecastData.ForecastByDate" Dense="true" Hover="true" Bordered="true">
                    <HeaderContent>
                        <MudTh>Sprint</MudTh>
                        <MudTh>Start Date</MudTh>
                        <MudTh>End Date</MudTh>
                        <MudTh class="text-right">Expected Completed</MudTh>
                        <MudTh class="text-right">Remaining After</MudTh>
                        <MudTh class="text-right">Progress</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Sprint">@context.SprintName</MudTd>
                        <MudTd DataLabel="Start Date">@context.SprintStartDate.LocalDateTime.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd DataLabel="End Date">@context.SprintEndDate.LocalDateTime.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd DataLabel="Expected Completed" class="text-right">@context.ExpectedCompletedEffort</MudTd>
                        <MudTd DataLabel="Remaining After" class="text-right">@context.RemainingEffortAfterSprint</MudTd>
                        <MudTd DataLabel="Progress" class="text-right">
                            <MudProgressLinear Color="Color.Primary" 
                                              Value="@context.ProgressPercentage" 
                                              Size="Size.Small" />
                            @context.ProgressPercentage.ToString("F1")%
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>

            <!-- Burndown Chart -->
            <MudPaper Elevation="2" Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">Effort Burndown Forecast</MudText>
                <MudChart ChartType="ChartType.Line" 
                          Width="100%" 
                          Height="400px"
                          ChartSeries="@GetBurndownChartData()" 
                          XAxisLabels="@GetSprintLabels()"
                          ChartOptions="@_chartOptions">
                </MudChart>
            </MudPaper>
        }
    }
    else if (_errorResponse != null)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />
    }
    else if (!_isLoading && !_selectedEpicId.HasValue)
    {
        <MudPaper Elevation="2" Class="pa-8 text-center">
            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Large" Color="Color.Secondary" Class="mb-4" />
            <MudText Typo="Typo.h5" GutterBottom="true">Forecast Epic Completion</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Enter an Epic or Feature ID above to calculate velocity-based completion forecasts.
            </MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    [Parameter]
    public int? EpicId { get; set; }

    private EpicCompletionForecastDto? _forecastData;
    private bool _isLoading = false;
    private ErrorResponse? _errorResponse;
    private int? _selectedEpicId;
    private int _maxSprintsForVelocity = 5;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.Straight
    };

    protected override async Task OnInitializedAsync()
    {
        if (EpicId.HasValue && EpicId.Value > 0)
        {
            _selectedEpicId = EpicId.Value;
            await LoadForecast();
        }
    }

    private async Task LoadForecast()
    {
        if (!_selectedEpicId.HasValue || _selectedEpicId.Value <= 0)
        {
            Snackbar.Add("Please enter a valid Epic/Feature ID", Severity.Warning);
            return;
        }

        _isLoading = true;
        try
        {
            ClearError();
            _forecastData = await MetricsClient.GetEpicForecastAsync(_selectedEpicId.Value, _maxSprintsForVelocity);
            
            if (_forecastData == null)
            {
                ShowError(new Exception($"Epic/Feature {_selectedEpicId} not found"), "Epic/Feature not found");
            }
            else
            {
                // Update URL without reload
                NavigationManager.NavigateTo($"/epic-forecast/{_selectedEpicId.Value}", false);
            }
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading Epic forecast");
            _forecastData = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private double GetProgressPercentage()
    {
        if (_forecastData == null || _forecastData.TotalEffort == 0)
            return 0;
        
        return (_forecastData.CompletedEffort / (double)_forecastData.TotalEffort) * 100;
    }

    private Color GetConfidenceColor(ForecastConfidence confidence)
    {
        return confidence switch
        {
            ForecastConfidence.High => Color.Success,
            ForecastConfidence.Medium => Color.Warning,
            ForecastConfidence.Low => Color.Error,
            _ => Color.Default
        };
    }

    private List<ChartSeries> GetBurndownChartData()
    {
        if (_forecastData == null || !_forecastData.ForecastByDate.Any())
            return new List<ChartSeries>();

        var remaining = new List<double> { _forecastData.RemainingEffort };
        remaining.AddRange(_forecastData.ForecastByDate.Select(f => (double)f.RemainingEffortAfterSprint));

        return new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Remaining Effort",
                Data = remaining.ToArray()
            }
        };
    }

    private string[] GetSprintLabels()
    {
        if (_forecastData == null || !_forecastData.ForecastByDate.Any())
            return Array.Empty<string>();

        var labels = new List<string> { "Now" };
        labels.AddRange(_forecastData.ForecastByDate.Select(f => f.SprintName));
        
        return labels.ToArray();
    }

    private List<DataRequirement> _forecastDataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Effort (Story Points)", 
            Description = "Required for all child work items to calculate total and remaining effort",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "State", 
            Description = "Used to determine completed vs remaining work. 'Done' items don't count toward remaining effort",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Parent-Child Links", 
            Description = "Required to identify all child work items of the Epic/Feature",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Iteration Path", 
            Description = "Used for historical velocity calculation from completed sprints",
            IsRequired = true 
        }
    };

    private List<string> _forecastBestPractices = new()
    {
        "Use 3-5 historical sprints for velocity calculation - balance between recent and stable",
        "Plan to 'likely case' scenario, but buffer for 'worst case'",
        "Re-forecast weekly as work progresses and scope changes",
        "Freeze scope before forecasting for most accurate predictions",
        "High confidence (>75%) indicates consistent velocity - trust the forecast",
        "Low confidence (<60%) means volatile velocity - add more buffer time",
        "Track forecast vs actual completion to calibrate future estimates",
        "Use for stakeholder communication and release planning"
    };

    private List<CommonIssue> _forecastCommonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "Forecast shows low confidence (<60%)",
            Solution = "Velocity is inconsistent. Review team capacity changes, scope variations, or estimation accuracy. Consider using more historical sprints or stabilizing team size."
        },
        new CommonIssue 
        { 
            Problem = "Forecast completion date keeps moving",
            Solution = "Scope is changing or velocity is declining. Freeze scope, investigate velocity drops, or re-baseline the forecast. Communicate changes to stakeholders early."
        },
        new CommonIssue 
        { 
            Problem = "Large gap between best case and worst case",
            Solution = "High velocity variability. Review estimation practices, check for external dependencies affecting delivery, or investigate team disruptions."
        },
        new CommonIssue 
        { 
            Problem = "No forecast shown",
            Solution = "Ensure: 1) Epic has child items, 2) Child items have effort estimates, 3) Historical sprints have completed work, 4) Iteration paths are set correctly."
        }
    };
}

