@page "/backlog-health"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@inject MetricsClient MetricsClient
@inject ErrorMessageService ErrorMessageService
@inject ISnackbar Snackbar

<PageTitle>Backlog Health Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2" /> Backlog Health Dashboard
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        Multi-iteration backlog health analysis showing validation issues, effort tracking, and trends
    </MudText>

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && (_healthData == null || !_healthData.IterationHealth.Any()))
    {
        <EmptyStateDisplay Title="No Backlog Health Data Available"
                          Message="No work items found to analyze. Please sync work items first." />
    }
    else
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />

        <!-- Trend Summary Card -->
        <MudCard Elevation="3" Class="mb-6">
            <MudCardContent>
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.h5">@_healthData.Trend.Summary</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Based on @_healthData.IterationHealth.Count iteration(s) | Total: @_healthData.TotalWorkItems work items | @_healthData.TotalIssues issues found
                        </MudText>
                    </div>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.caption">
                            <MudIcon Icon="@GetTrendIcon(_healthData.Trend.EffortTrend)" Size="Size.Small" Color="@GetTrendColor(_healthData.Trend.EffortTrend)" />
                            Effort: @_healthData.Trend.EffortTrend
                        </MudText>
                        <MudText Typo="Typo.caption">
                            <MudIcon Icon="@GetTrendIcon(_healthData.Trend.ValidationTrend)" Size="Size.Small" Color="@GetTrendColor(_healthData.Trend.ValidationTrend)" />
                            Validation: @_healthData.Trend.ValidationTrend
                        </MudText>
                        <MudText Typo="Typo.caption">
                            <MudIcon Icon="@GetTrendIcon(_healthData.Trend.BlockerTrend)" Size="Size.Small" Color="@GetTrendColor(_healthData.Trend.BlockerTrend)" />
                            Blockers: @_healthData.Trend.BlockerTrend
                        </MudText>
                    </MudStack>
                </MudStack>
            </MudCardContent>
        </MudCard>

        <!-- Filters -->
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudTextField @bind-Value="_areaPathFilter" 
                             Label="Area Path Filter" 
                             Variant="Variant.Outlined"
                             Adornment="Adornment.End"
                             AdornmentIcon="@Icons.Material.Filled.FilterAlt"
                             HelperText="Filter work items by area path" />
                <MudNumericField @bind-Value="_maxIterations" 
                                Label="Max Iterations" 
                                Variant="Variant.Outlined"
                                Min="1" Max="20"
                                HelperText="Number of iterations to analyze" />
                <MudButton Variant="Variant.Filled" 
                          Color="Color.Primary" 
                          OnClick="LoadData"
                          StartIcon="@Icons.Material.Filled.Refresh">
                    Refresh
                </MudButton>
            </MudStack>
        </MudPaper>

        <!-- Iteration Health Cards -->
        <MudGrid>
            @foreach (var iteration in _healthData.IterationHealth)
            {
                <MudItem xs="12" md="6" lg="4">
                    <MudCard Elevation="2" Class="mud-height-full">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">@iteration.SprintName</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@iteration.IterationPath</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                @{
                                    var healthScore = GetHealthScore(iteration);
                                }
                                @if (healthScore < 70)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Error" Size="Size.Medium" />
                                }
                                else if (healthScore < 90)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Warning" Size="Size.Medium" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium" />
                                }
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudStack Spacing="2">
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Total Work Items</MudText>
                                    <MudText Typo="Typo.body1" Color="Color.Primary">@iteration.TotalWorkItems</MudText>
                                </MudStack>
                                <MudDivider />
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Without Effort</MudText>
                                    <MudText Typo="Typo.body1" Color="@(iteration.WorkItemsWithoutEffort > 0 ? Color.Warning : Color.Default)">
                                        @iteration.WorkItemsWithoutEffort
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">In Progress w/o Effort</MudText>
                                    <MudText Typo="Typo.body1" Color="@(iteration.WorkItemsInProgressWithoutEffort > 0 ? Color.Error : Color.Default)">
                                        @iteration.WorkItemsInProgressWithoutEffort
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Parent Progress Issues</MudText>
                                    <MudText Typo="Typo.body1" Color="@(iteration.ParentProgressIssues > 0 ? Color.Error : Color.Default)">
                                        @iteration.ParentProgressIssues
                                    </MudText>
                                </MudStack>
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2">Blocked Items</MudText>
                                    <MudText Typo="Typo.body1" Color="@(iteration.BlockedItems > 0 ? Color.Error : Color.Default)">
                                        @iteration.BlockedItems
                                    </MudText>
                                </MudStack>
                                @if (iteration.InProgressAtIterationEnd > 0)
                                {
                                    <MudDivider />
                                    <MudStack Row="true" Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.body2">In Progress at End</MudText>
                                        <MudText Typo="Typo.body1" Color="Color.Warning">
                                            @iteration.InProgressAtIterationEnd
                                        </MudText>
                                    </MudStack>
                                }
                            </MudStack>

                            @if (iteration.ValidationIssues.Any())
                            {
                                <MudDivider Class="my-3" />
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Validation Issues</MudText>
                                <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                    @foreach (var issue in iteration.ValidationIssues)
                                    {
                                        <MudBadge Color="@GetSeverityColor(issue.ValidationType)" Content="@issue.Count" Overlap="true">
                                            <MudText Typo="Typo.caption">@issue.ValidationType</MudText>
                                        </MudBadge>
                                    }
                                </MudStack>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        <!-- Comparison Chart -->
        <MudPaper Elevation="2" Class="pa-4 mt-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Issue Comparison Across Iterations</MudText>
            <MudChart ChartType="ChartType.Bar" 
                      Width="100%" 
                      Height="400px"
                      ChartSeries="@GetComparisonData()" 
                      XAxisLabels="@GetIterationLabels()"
                      ChartOptions="@_chartOptions">
            </MudChart>
        </MudPaper>
    }
</MudContainer>

@code {
    private MultiIterationBacklogHealthDto? _healthData;
    private bool _isLoading = true;
    private ErrorResponse? _errorResponse;
    private string? _areaPathFilter;
    private int _maxIterations = 5;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.NaturalSpline
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            ClearError();
            _healthData = await MetricsClient.GetMultiIterationBacklogHealthAsync(
                _areaPathFilter, 
                _maxIterations);
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading backlog health data");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private int GetHealthScore(BacklogHealthDto iteration)
    {
        if (iteration.TotalWorkItems == 0) return 100;

        var issues = iteration.WorkItemsWithoutEffort + 
                    iteration.WorkItemsInProgressWithoutEffort + 
                    iteration.ParentProgressIssues + 
                    iteration.BlockedItems;
        
        var issuePercentage = (double)issues / iteration.TotalWorkItems;
        return (int)Math.Max(0, 100 - (issuePercentage * 100));
    }

    private Color GetTrendColor(TrendDirection trend)
    {
        return trend switch
        {
            TrendDirection.Improving => Color.Success,
            TrendDirection.Stable => Color.Info,
            TrendDirection.Degrading => Color.Error,
            _ => Color.Default
        };
    }

    private string GetTrendIcon(TrendDirection trend)
    {
        return trend switch
        {
            TrendDirection.Improving => Icons.Material.Filled.TrendingUp,
            TrendDirection.Stable => Icons.Material.Filled.TrendingFlat,
            TrendDirection.Degrading => Icons.Material.Filled.TrendingDown,
            _ => Icons.Material.Filled.HelpOutline
        };
    }

    private Color GetSeverityColor(string severity)
    {
        return severity.ToLower() switch
        {
            "error" => Color.Error,
            "warning" => Color.Warning,
            _ => Color.Info
        };
    }

    private List<ChartSeries> GetComparisonData()
    {
        if (_healthData == null) return new List<ChartSeries>();

        return new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Without Effort",
                Data = _healthData.IterationHealth.Select(i => (double)i.WorkItemsWithoutEffort).ToArray()
            },
            new ChartSeries
            {
                Name = "Parent Issues",
                Data = _healthData.IterationHealth.Select(i => (double)i.ParentProgressIssues).ToArray()
            },
            new ChartSeries
            {
                Name = "Blocked",
                Data = _healthData.IterationHealth.Select(i => (double)i.BlockedItems).ToArray()
            }
        };
    }

    private string[] GetIterationLabels()
    {
        if (_healthData == null) return Array.Empty<string>();
        
        return _healthData.IterationHealth
            .Select(i => i.SprintName)
            .ToArray();
    }
}
