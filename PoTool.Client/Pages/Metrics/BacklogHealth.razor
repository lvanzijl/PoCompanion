@page "/backlog-health"
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Client.Pages.Metrics.SubComponents
@using static PoTool.Client.Components.Common.PageHelp
@using System.Net.Http.Json
@inject IMetricsClient MetricsClient
@inject BacklogHealthCalculationService HealthCalculationService
@inject ErrorMessageService ErrorMessageService
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject ISnackbar Snackbar
@inject IPreferencesService PreferencesService
@inject HttpClient Http

<PageTitle>Backlog Health Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Backlog Health Dashboard Guide"
              Description="Monitor the health of your backlog across multiple iterations. This dashboard identifies validation issues, tracks trends, and helps maintain data quality over time. Health scores are calculated based on the percentage of work items without validation issues."
              Class="mb-4"
              DataRequirements="@_healthDataRequirements"
              BestPractices="@_healthBestPractices"
              CommonIssues="@_healthCommonIssues" />
    
    @* Product Selector Section - Always visible when products exist *@
    @if (_products.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
                <MudSelect T="int" 
                           Value="@_selectedProductId"
                           ValueChanged="OnProductChanged"
                           Label="Select Product"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 300px;">
                    <MudSelectItem T="int" Value="@AllProductsId">All products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @_products.Count products available
                </MudText>
            </MudStack>
        </MudPaper>
    }
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Class="mr-2" /> 
        @if (_selectedProductId == AllProductsId && _products.Count > 0)
        {
            <text>Backlog Health — All products</text>
        }
        else if (_selectedProduct != null)
        {
            <text>Backlog Health — @_selectedProduct.Name</text>
        }
        else
        {
            <text>Backlog Health Dashboard</text>
        }
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
        @if (_selectedProductId == AllProductsId && _products.Count > 0)
        {
            <text>Multi-iteration backlog health analysis across @_products.Count product(s) showing validation issues, effort tracking, and trends</text>
        }
        else if (_selectedProduct != null)
        {
            <text>Multi-iteration backlog health analysis for @_selectedProduct.Name showing validation issues, effort tracking, and trends</text>
        }
        else
        {
            <text>Multi-iteration backlog health analysis showing validation issues, effort tracking, and trends</text>
        }
    </MudText>

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && (_healthData == null || !_healthData.IterationHealth.Any()))
    {
        <EmptyStateDisplay Title="No Backlog Health Data Available"
                          Message="No work items found to analyze. Please sync work items first." />
    }
    else if (!_isLoading && _healthData != null)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />

        <!-- Trend Summary Card -->
        <BacklogHealthTrendCard TrendSummary="@_healthData.Trend.Summary"
                               IterationCount="@_healthData.IterationHealth.Count"
                               TotalWorkItems="@_healthData.TotalWorkItems"
                               TotalIssues="@_healthData.TotalIssues"
                               EffortTrend="@_healthData.Trend.EffortTrend"
                               ValidationTrend="@_healthData.Trend.ValidationTrend"
                               BlockerTrend="@_healthData.Trend.BlockerTrend" />

        <!-- Filters -->
        <BacklogHealthFilters @bind-AreaPathFilter="@_areaPathFilter"
                             @bind-MaxIterations="@_maxIterations"
                             OnRefresh="@LoadData" />

        <!-- Iteration Health Cards -->
        <IterationHealthTable Iterations="@_healthData.IterationHealth.ToList()" />

        <!-- Comparison Chart -->
        <MudPaper Elevation="2" Class="pa-4 mt-6">
            <MudText Typo="Typo.h6" GutterBottom="true">Issue Comparison Across Iterations</MudText>
            <MudChart ChartType="ChartType.Bar" 
                      Width="100%" 
                      Height="400px"
                      ChartSeries="@GetComparisonData()" 
                      XAxisLabels="@GetIterationLabels()"
                      ChartOptions="@_chartOptions">
            </MudChart>
        </MudPaper>
    }
</MudContainer>

@code {
    // Product scope constants
    private const int AllProductsId = 0; // Synthetic ID representing "All products" aggregate view
    private const string PreferenceKey_SelectedProductId = "BacklogHealth_SelectedProductId";
    private const string ApiEndpoint_MultiIterationHealth = "api/Metrics/multi-iteration-health";
    
    private MultiIterationBacklogHealthDto? _healthData;
    private bool _isLoading = true;
    private ErrorResponse? _errorResponse;
    private string? _areaPathFilter = null;
    private int _maxIterations = 5;
    
    // Product context
    private ProfileDto? _activeProfile;
    private List<ProductDto> _products = new();
    private int _selectedProductId = AllProductsId;
    private ProductDto? _selectedProduct;

    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 5,
        MaxNumYAxisTicks = 10,
        InterpolationOption = InterpolationOption.NaturalSpline
    };

    protected override async Task OnInitializedAsync()
    {
        // Load active profile and products
        await LoadProductContext();
        
        // Restore selected product from preferences
        await RestoreProductSelection();
        
        // Load data with current product scope
        await LoadData();
    }
    
    private async Task LoadProductContext()
    {
        try
        {
            _activeProfile = await ProfileService.GetActiveProfileAsync();
            
            if (_activeProfile != null)
            {
                // Get products for this profile
                var products = await ProductService.GetProductsByOwnerAsync(_activeProfile.Id);
                _products = products.OrderBy(p => p.Order).ToList();
            }
        }
        catch (Exception)
        {
            // Continue without product context - will show global data
            // Error is not critical as the view can still function without product context
            _products = new List<ProductDto>();
        }
    }
    
    private async Task RestoreProductSelection()
    {
        try
        {
            // Try to restore selected product from preferences
            var savedProductId = await PreferencesService.GetIntAsync(PreferenceKey_SelectedProductId);
            
            if (savedProductId.HasValue)
            {
                // Validate that the saved product still exists or is AllProductsId
                if (savedProductId.Value == AllProductsId || _products.Any(p => p.Id == savedProductId.Value))
                {
                    _selectedProductId = savedProductId.Value;
                }
            }
            
            // If "All products" is selected, clear _selectedProduct
            if (_selectedProductId == AllProductsId)
            {
                _selectedProduct = null;
            }
            else
            {
                _selectedProduct = _products.FirstOrDefault(p => p.Id == _selectedProductId);
            }
        }
        catch (Exception)
        {
            // If restoration fails, default to AllProductsId
            _selectedProductId = AllProductsId;
            _selectedProduct = null;
        }
    }
    
    private async Task OnProductChanged(int newProductId)
    {
        if (_selectedProductId == newProductId)
        {
            return; // No change
        }
        
        _selectedProductId = newProductId;
        
        // Save selection to preferences
        try
        {
            await PreferencesService.SetIntAsync(PreferenceKey_SelectedProductId, _selectedProductId);
        }
        catch (Exception)
        {
            // Non-critical failure
        }
        
        // Update selected product reference
        if (_selectedProductId == AllProductsId)
        {
            _selectedProduct = null;
        }
        else
        {
            _selectedProduct = _products.FirstOrDefault(p => p.Id == _selectedProductId);
        }
        
        // Reload data with new product scope
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            ClearError();
            
            // Determine product scope for API call
            // AllProductsId (0) means aggregate view - pass all product IDs
            // Specific product ID means filter to that product's hierarchy
            // If no products exist, pass null to get global/unfiltered data
            int[]? productIdsForQuery = null;
            
            if (_products.Any())
            {
                productIdsForQuery = _selectedProductId == AllProductsId 
                    ? _products.Select(p => p.Id).ToArray()
                    : new[] { _selectedProductId };
            }
            
            // Call API with multiple product IDs using manual HttpClient
            // (NSwag doesn't handle array parameters well)
            _healthData = await GetMultiIterationBacklogHealthAsync(
                productIdsForQuery, 
                _areaPathFilter, 
                _maxIterations);
        }
        catch (Exception ex)
        {
            ShowError(ex, "Error loading backlog health data");
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    /// <summary>
    /// Calls the multi-iteration backlog health API with support for multiple product IDs.
    /// Constructs the URL manually to support array query parameters which NSwag doesn't handle well.
    /// </summary>
    private async Task<MultiIterationBacklogHealthDto?> GetMultiIterationBacklogHealthAsync(
        int[]? productIds,
        string? areaPath,
        int maxIterations)
    {
        var queryParams = new List<string>();
        
        if (productIds != null && productIds.Length > 0)
        {
            foreach (var id in productIds)
            {
                queryParams.Add($"productIds={id}");
            }
        }
        
        if (!string.IsNullOrWhiteSpace(areaPath))
        {
            queryParams.Add($"areaPath={Uri.EscapeDataString(areaPath)}");
        }
        
        queryParams.Add($"maxIterations={maxIterations}");
        
        var url = $"{ApiEndpoint_MultiIterationHealth}?{string.Join("&", queryParams)}";
        
        try
        {
            return await Http.GetFromJsonAsync<MultiIterationBacklogHealthDto>(url);
        }
        catch (HttpRequestException ex)
        {
            // Provide context about which API call failed
            throw new Exception($"Failed to retrieve multi-iteration backlog health data from {url}: {ex.Message}", ex);
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private List<ChartSeries> GetComparisonData()
    {
        if (_healthData == null) return new List<ChartSeries>();
        return HealthCalculationService.GenerateComparisonChartData(_healthData);
    }

    private string[] GetIterationLabels()
    {
        if (_healthData == null) return Array.Empty<string>();
        return HealthCalculationService.GetIterationLabels(_healthData);
    }

    private List<DataRequirement> _healthDataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Iteration Path", 
            Description = "Required for all work items to group by sprint and track health trends over time",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Effort (Story Points)", 
            Description = "Used to detect missing effort issues, especially for 'In Progress' items",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "State", 
            Description = "Used for parent-child state consistency validation",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Parent Link", 
            Description = "Required for hierarchy validation and parent-child state consistency checks",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Area Path", 
            Description = "Optional - used for filtering health analysis by team or component",
            IsRequired = false 
        }
    };

    private List<string> _healthBestPractices = new()
    {
        "Review backlog health weekly during sprint planning to identify issues early",
        "Aim for 90%+ health score - indicates good data quality and process discipline",
        "Fix 'Missing Effort' issues immediately for items in 'In Progress' state",
        "Monitor health trends - declining trends indicate process issues that need attention",
        "Use declining health as a trigger for team retrospective discussions",
        "Address parent-child state inconsistencies before sprint start",
        "Consistent 80%+ health across sprints indicates mature backlog management",
        "Track issue types to identify systemic problems (e.g., always missing effort)"
    };

    private List<CommonIssue> _healthCommonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "Health score consistently below 80%",
            Solution = "Review data entry practices with the team. Establish clear rules for when to set effort, states, and iteration paths. Consider adding validation in Azure DevOps work item templates."
        },
        new CommonIssue 
        { 
            Problem = "Many 'Missing Effort' issues",
            Solution = "Enforce effort estimation during sprint planning. Create a team agreement that items cannot move to 'In Progress' without effort estimates. Use Azure DevOps rules to prevent state transitions without effort."
        },
        new CommonIssue 
        { 
            Problem = "Parent-child state inconsistencies",
            Solution = "When moving child items to 'In Progress', also update parent to 'In Progress'. Educate team on hierarchy flow. Consider using Azure DevOps automation rules for parent state updates."
        },
        new CommonIssue 
        { 
            Problem = "Health improving then degrading repeatedly",
            Solution = "Indicates inconsistent process adherence. Review and simplify team processes, provide clearer guidance, and assign a team member as 'data quality champion' to monitor."
        }
    };
}

