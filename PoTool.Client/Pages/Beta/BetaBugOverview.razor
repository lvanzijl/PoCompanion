@page "/beta/bugs"
@using PoTool.Client.Components.Common
@using PoTool.Client.ApiClient
@using PoTool.Client.Services
@using PoTool.Client.Pages.Beta.Components
@using System.Web
@inject IProfileService ProfileService
@inject WorkItemService WorkItemService
@inject ProductService ProductService
@inject TeamService TeamService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Bug Insights - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Bug Insights
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.Home"
                       OnClick="NavigateToBetaHome">
                Beta Home
            </MudButton>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => _errorMessage = null)">
            @_errorMessage
            <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@LoadBugDataAsync" Class="ml-2">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        @* Team & Product Selectors *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.FilterAlt" Class="mr-2" />
                    Filters
                </MudText>
                
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedTeamId"
                                   Label="Team"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnTeamChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Teams</MudSelectItem>
                            @foreach (var team in _teams)
                            {
                                <MudSelectItem T="int?" Value="@team.Id">@team.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    
                    <MudItem xs="12" sm="6">
                        <MudSelect T="int?"
                                   Value="_selectedProductId"
                                   Label="Product"
                                   Variant="Variant.Outlined"
                                   Clearable="true"
                                   ValueChanged="OnProductChanged">
                            <MudSelectItem T="int?" Value="@((int?)null)">All Products</MudSelectItem>
                            @foreach (var product in _products)
                            {
                                <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>
        </MudPaper>

        @* Metrics Grid *@
        <MudGrid Spacing="3">
            @* Total Open Bugs *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Total Open Bugs"
                           Result="_totalOpenBugs"
                           ValueFormat="MetricValueFormat.Count"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Bugs Created Per Period *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Bugs Created (Last 6 Months)"
                           Result="_bugsCreated"
                           ValueFormat="MetricValueFormat.Count"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Bugs Resolved Per Period *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Bugs Resolved (Last 6 Months)"
                           Result="_bugsResolved"
                           ValueFormat="MetricValueFormat.Count"
                           IsLoading="_metricsLoading" />
            </MudItem>

            @* Bug Resolution Time *@
            <MudItem xs="12" sm="6" md="4">
                <MetricCard Title="Bug Resolution Time"
                           Result="_resolutionTime"
                           ValueFormat="MetricValueFormat.Hours"
                           IsLoading="_metricsLoading" />
            </MudItem>
        </MudGrid>

        @* Bugs by Severity Distribution *@
        <MudPaper Elevation="2" Class="pa-4 mt-3">
            <MudStack Spacing="3">
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.PieChart" Class="mr-2" />
                    Bugs by Severity Distribution
                </MudText>
                
                @if (_metricsLoading)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="200px" />
                }
                else if (_severityDistribution.Count == 0)
                {
                    <MudAlert Severity="Severity.Info">
                        No severity data available.
                    </MudAlert>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var (severity, data) in _severityDistribution)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudChip T="string" 
                                         Size="Size.Small" 
                                         Color="@GetSeverityColor(severity)"
                                         Style="min-width: 120px;">
                                    @severity
                                </MudChip>
                                <MudProgressLinear Color="@GetSeverityColor(severity)" 
                                                  Value="@data.Percentage" 
                                                  Size="Size.Large"
                                                  Class="flex-grow-1" />
                                <MudText Typo="Typo.body2" Style="min-width: 100px;">
                                    @data.Count (@($"{data.Percentage:F1}") %)
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        @* Empty State *@
        @if (_allBugs.Count == 0 && !_metricsLoading)
        {
            <MudPaper Elevation="2" Class="pa-6 mt-4">
                <MudAlert Severity="Severity.Info">
                    No bug data found for the selected team/product and time range.
                </MudAlert>
            </MudPaper>
        }
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private bool _metricsLoading = false;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Selectors
    private int? _selectedTeamId;
    private int? _selectedProductId;
    private List<TeamDto> _teams = new();
    private List<ProductDto> _products = new();
    
    // Bug Data
    private List<WorkItemDto> _allBugs = new();
    
    // Calculated Metrics
    private MetricResult? _totalOpenBugs;
    private MetricResult? _bugsCreated;
    private MetricResult? _bugsResolved;
    private MetricResult? _resolutionTime;
    private Dictionary<string, (int Count, double Percentage)> _severityDistribution = new();
    
    // Calculator
    private readonly BugInsightsCalculator _calculator = new();
    
    // Time window (6 months by default)
    private readonly DateTimeOffset _fromDate = DateTimeOffset.UtcNow.AddMonths(-6);
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Load teams and products
            _teams = (await TeamService.GetAllTeamsAsync(includeArchived: false)).ToList();
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            // Parse URL parameters
            ParseQueryParameters();
            
            // Load bug data and calculate metrics
            await LoadBugDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading bug insights: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        // Parse teamId
        var teamIdStr = queryParams["teamId"];
        if (!string.IsNullOrEmpty(teamIdStr) && int.TryParse(teamIdStr, out var teamId))
        {
            _selectedTeamId = teamId;
        }
        
        // Parse productId
        var productIdStr = queryParams["productId"];
        if (!string.IsNullOrEmpty(productIdStr) && int.TryParse(productIdStr, out var productId))
        {
            _selectedProductId = productId;
        }
    }
    
    private async Task LoadBugDataAsync()
    {
        _metricsLoading = true;
        _errorMessage = null;
        StateHasChanged();
        
        try
        {
            // Load all work items
            var allWorkItems = await WorkItemService.GetAllAsync();
            
            // Filter to bugs only
            var bugs = allWorkItems.Where(wi => wi.Type.Equals("Bug", StringComparison.OrdinalIgnoreCase)).ToList();
            
            // Apply product filter if selected
            // Note: Full product-team filtering requires ProductTeamLink relationships
            // which would need to be implemented similar to PR/Pipeline insights
            if (_selectedProductId.HasValue)
            {
                // For now, show all bugs when a product is selected
                // TODO: Implement proper product filtering using area path or ProductTeamLink
                bugs = bugs.ToList();
            }
            
            // Apply team filter if selected
            if (_selectedTeamId.HasValue)
            {
                // For now, show all bugs when a team is selected
                // TODO: Implement proper team filtering using team area paths
                bugs = bugs.ToList();
            }
            
            _allBugs = bugs;
            
            // Calculate metrics
            CalculateMetrics();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load bug data: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
        }
        finally
        {
            _metricsLoading = false;
            StateHasChanged();
        }
    }
    
    private void CalculateMetrics()
    {
        _totalOpenBugs = _calculator.CalculateTotalOpenBugs(_allBugs);
        _bugsCreated = _calculator.CalculateBugsCreatedPerPeriod(_allBugs, _fromDate);
        _bugsResolved = _calculator.CalculateBugsResolvedPerPeriod(_allBugs, _fromDate);
        _resolutionTime = _calculator.CalculateBugResolutionTime(_allBugs);
        _severityDistribution = _calculator.CalculateBugsBySeverityDistribution(_allBugs);
    }
    
    private async Task OnTeamChanged(int? teamId)
    {
        _selectedTeamId = teamId;
        UpdateUrlParameters();
        await LoadBugDataAsync();
    }
    
    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        UpdateUrlParameters();
        await LoadBugDataAsync();
    }
    
    private void UpdateUrlParameters()
    {
        var queryParams = new List<string>();
        
        if (_selectedTeamId.HasValue)
        {
            queryParams.Add($"teamId={_selectedTeamId.Value}");
        }
        
        if (_selectedProductId.HasValue)
        {
            queryParams.Add($"productId={_selectedProductId.Value}");
        }
        
        var queryString = queryParams.Count > 0 ? "?" + string.Join("&", queryParams) : "";
        var newUrl = $"{WorkspaceRoutes.BetaBugOverview}{queryString}";
        
        NavigationManager.NavigateTo(newUrl, forceLoad: false);
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Bug Insights", null, disabled: true, icon: Icons.Material.Filled.Insights)
        };
    }
    
    private Color GetSeverityColor(string severity)
    {
        // ExtractSeverity returns "1 - Critical", "2 - High", etc., or "Unknown"
        if (severity.StartsWith("1"))
        {
            return Color.Error;
        }
        if (severity.StartsWith("2"))
        {
            return Color.Warning;
        }
        if (severity.StartsWith("3"))
        {
            return Color.Info;
        }
        if (severity.StartsWith("4"))
        {
            return Color.Default;
        }
        return Color.Default; // Unknown
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
}
