@page "/beta/bugs"
@using PoTool.Client.Components.Common
@using System.Web
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Bug Overview - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Bug Overview
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Filter Status *@
                @if (!string.IsNullOrEmpty(_period))
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.DateRange" 
                             Size="Size.Small"
                             Color="Color.Info"
                             OnClose="ClearPeriodFilter">
                        Period: @_period
                    </MudChip>
                }
                @if (_allProducts && _allTeams)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Public" 
                             Size="Size.Small"
                             Color="Color.Default">
                        All Products / All Teams
                    </MudChip>
                }
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Bug List Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.List" Class="mr-2" />
                    Bugs
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Click a bug to view details and edit
                </MudText>
            </MudStack>
            
            @* Bug Table *@
            <MudTable Items="@_sampleBugs" Hover="true" Striped="true" Dense="true" OnRowClick="OnBugRowClick" T="BugItem" RowClass="cursor-pointer">
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Severity</MudTh>
                    <MudTh>State</MudTh>
                    <MudTh>Created</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ID">@context.Id</MudTd>
                    <MudTd DataLabel="Title">@context.Title</MudTd>
                    <MudTd DataLabel="Severity">
                        <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(context.Severity)">@context.Severity</MudChip>
                    </MudTd>
                    <MudTd DataLabel="State">@context.State</MudTd>
                    <MudTd DataLabel="Created">@context.Created.ToString("MMM dd, yyyy")</MudTd>
                </RowTemplate>
            </MudTable>
            
            @* Available End-Station Actions *@
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                Available Edits
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.PriorityHigh">Bug Severity</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Label">Tags</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.PlaylistAddCheck">Batch Edits</MudChip>
            </MudStack>
        </MudPaper>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .cursor-pointer {
        cursor: pointer;
    }
    .cursor-pointer:hover {
        background-color: rgba(255, 255, 255, 0.04) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Filter parameters
    private string? _period;
    private bool _allProducts;
    private bool _allTeams;
    
    // Sample data for display
    private List<BugItem> _sampleBugs = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            ParseQueryParameters();
            UpdateBreadcrumbs();
            LoadSampleBugs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        _period = queryParams["period"];
        
        var allProducts = queryParams["allProducts"];
        if (!string.IsNullOrEmpty(allProducts))
        {
            _allProducts = bool.TryParse(allProducts, out var result) && result;
        }
        
        var allTeams = queryParams["allTeams"];
        if (!string.IsNullOrEmpty(allTeams))
        {
            _allTeams = bool.TryParse(allTeams, out var result) && result;
        }
    }
    
    private void LoadSampleBugs()
    {
        // Sample data - in real implementation, would load from backend
        _sampleBugs = new List<BugItem>
        {
            new BugItem { Id = 1001, Title = "Login fails on mobile devices", Severity = "Critical", State = "Active", Created = DateTime.Now.AddDays(-5) },
            new BugItem { Id = 1002, Title = "Dashboard charts not rendering", Severity = "High", State = "Active", Created = DateTime.Now.AddDays(-3) },
            new BugItem { Id = 1003, Title = "Export to PDF missing header", Severity = "Medium", State = "New", Created = DateTime.Now.AddDays(-1) }
        };
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Bug Overview", null, disabled: true, icon: Icons.Material.Filled.BugReport)
        };
    }
    
    private Color GetSeverityColor(string severity)
    {
        return severity switch
        {
            "Critical" => Color.Error,
            "High" => Color.Warning,
            "Medium" => Color.Info,
            "Low" => Color.Default,
            _ => Color.Default
        };
    }
    
    private void OnBugRowClick(TableRowClickEventArgs<BugItem> args)
    {
        NavigateToBugDetail(args.Item!.Id);
    }
    
    private void NavigateToBugDetail(int bugId)
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaBugDetail}?bugId={bugId}");
    }
    
    private void ClearPeriodFilter()
    {
        _period = null;
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaBugOverview);
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHealthWorkspace);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaTrendsWorkspace);
    }
    
    private class BugItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Severity { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public DateTime Created { get; set; }
    }
}
