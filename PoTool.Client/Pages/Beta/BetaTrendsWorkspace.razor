@page "/beta/trends"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Velocity
@using PoTool.Client.Pages.Beta.Components
@inherits BetaWorkspaceBase
@inject INavigationContextService NavigationContextService
@inject WorkItemService WorkItemService

@* 
    Decision #3: Time Horizon Default - Always 6 months per user decision
    Decision #12: Trend Chart Interaction - Hover highlight, click to filter (Option D)
*@

<PageTitle>Trends (Past) - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Trends (Past)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.History" 
                         Size="Size.Small"
                         Color="Color.Info">
                    Last 6 Months
                </MudChip>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Trend Signals Grid *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
                Trend Signals
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Structural behavior over time — click to explore details
            </MudText>
            
            <MudGrid>
                @* Velocity Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToVelocityDetails">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Velocity Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Team delivery patterns</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @* Bug Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBugTrend">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bug Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bug patterns over time</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* PR Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPrOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">PR Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pull request insights</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Pipeline Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPipelineOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Pipeline Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Build & deployment health</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Information Notice *@
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Note:</strong> Charts show max 10 bars (Decision #3: 6 month time horizon). 
                PRs and Pipelines are insight-only. Bugs may navigate to editable detail.
                <br/>
                <strong>Interaction:</strong> Hover to highlight, click to filter by that period (Decision #12).
            </MudText>
        </MudAlert>

        @* Bug Trend Chart with Interactive Click-to-Filter *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <BetaTrendChart 
                Title="Bug Trend (Last 6 Months)"
                Icon="@Icons.Material.Filled.BugReport"
                Data="@_bugTrendData"
                BarColor="Color.Error"
                OnPeriodClick="OnBugTrendPeriodClick"
                MaxBars="6" />
        </MudPaper>

        @* Velocity Overview Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
                    Velocity Overview
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/velocity">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            @* Embedded VelocityPanel component with max 10 bars *@
            <VelocityPanel MaxSprints="10" />
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Decision #12: Interactive trend chart data
    private Dictionary<string, int> _bugTrendData = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Parse context from query string (inherited from base class)
            ParseContextQueryParameters();
            
            if (!await EnsureProfileAsync(WorkspaceRoutes.BetaTrendsWorkspace))
            {
                return;
            }
            
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            
            // Load bug trend data (Decision #3: 6 month time horizon)
            await LoadBugTrendDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    /// <summary>
    /// Loads bug trend data for the last 6 months.
    /// Decision #3: Time horizon default is 6 months.
    /// </summary>
    private async Task LoadBugTrendDataAsync()
    {
        try
        {
            var workItems = await WorkItemService.GetAllWithValidationAsync();
            var bugs = workItems.Where(wi => wi.Type?.Equals("Bug", StringComparison.OrdinalIgnoreCase) == true).ToList();
            
            // Group bugs by month for the last 6 months using RetrievedAt date
            // In production, this would use actual CreatedDate from TFS
            var now = DateTime.UtcNow;
            _bugTrendData = new Dictionary<string, int>();
            
            for (var i = 5; i >= 0; i--)
            {
                var monthDate = now.AddMonths(-i);
                var periodKey = monthDate.ToString("yyyy-MM");
                
                // Count bugs with RetrievedAt in that month
                // This is a proxy - in production, use the actual bug creation date
                var monthBugCount = bugs.Count(b => 
                    b.RetrievedAt.Year == monthDate.Year && 
                    b.RetrievedAt.Month == monthDate.Month);
                
                _bugTrendData[periodKey] = monthBugCount;
            }
            
            // If all months have 0 (data hasn't spread over 6 months), show current distribution
            if (_bugTrendData.Values.All(v => v == 0) && bugs.Any())
            {
                // Show total current bugs in the most recent month
                var latestKey = now.ToString("yyyy-MM");
                if (_bugTrendData.ContainsKey(latestKey))
                {
                    _bugTrendData[latestKey] = bugs.Count;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load bug trend data: {ex.Message}");
            // Keep empty dictionary on failure
        }
    }
    
    /// <summary>
    /// Handles click on a trend chart bar.
    /// Decision #12: Click = filter to that period.
    /// </summary>
    private void OnBugTrendPeriodClick(string period)
    {
        // Navigate to bug overview filtered by the selected period
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaBugOverview}{BuildContextQuery($"period={period}")}");
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", null, disabled: true, icon: Icons.Material.Filled.Timeline)
        };
    }
    
    private void NavigateToVelocityDetails()
    {
        // Navigate to velocity dashboard for now
        NavigationManager.NavigateTo("/velocity");
    }
    
    private void NavigateToBugTrend()
    {
        // Navigate to bug overview with period scoped
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaBugOverview}{BuildContextQuery()}");
    }
    
    private void NavigateToPrOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPrOverview}{BuildContextQuery("insightOnly=true")}");
    }
    
    private void NavigateToPipelineOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPipelineOverview}{BuildContextQuery("insightOnly=true")}");
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaHealthWorkspace}{BuildContextQuery()}");
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPlanningWorkspace}{BuildContextQuery()}");
    }
}
