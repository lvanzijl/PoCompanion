@page "/beta/trends"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Velocity
@using PoTool.Client.Pages.Beta.Components
@using PoTool.Shared.Settings
@inherits BetaWorkspaceBase
@inject INavigationContextService NavigationContextService
@inject WorkItemService WorkItemService
@inject StateClassificationService StateClassificationService

@* 
    Decision #3: Time Horizon Default - Always 6 months per user decision
    Decision #12: Trend Chart Interaction - Hover highlight, click to filter (Option D)
*@

<PageTitle>Trends (Past) - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Trends (Past)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.History" 
                         Size="Size.Small"
                         Color="Color.Info">
                    Last 6 Months
                </MudChip>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Trend Signals Grid *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
                Trend Signals
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Structural behavior over time — click to explore details
            </MudText>
            
            <MudGrid>
                @* Velocity Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToVelocityDetails">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Velocity Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Team delivery patterns</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @* Bug Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBugTrend">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bug Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bug patterns over time</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* PR Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPrOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">PR Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pull request insights</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Pipeline Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPipelineOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Pipeline Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Build & deployment health</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Information Notice *@
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Note:</strong> Bug trend chart shows last 6 months (Decision #3: 6 month time horizon). 
                PRs and Pipelines are insight-only. Bugs may navigate to editable detail.
                <br/>
                <strong>Interaction:</strong> Hover to highlight, click to filter by that period (Decision #12).
            </MudText>
        </MudAlert>

        @* Bug Trend Chart with Interactive Click-to-Filter - 3 Series *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <BetaTrendMultiSeriesChart 
                Title="Bug Trend (Last 6 Months)"
                Icon="@Icons.Material.Filled.BugReport"
                SeriesTotal="@_bugTrendTotal"
                SeriesFixed="@_bugTrendFixed"
                SeriesAdded="@_bugTrendAdded"
                OnPeriodClick="OnBugTrendPeriodClick"
                MaxPeriods="6" />
        </MudPaper>

        @* Velocity Overview Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
                    Velocity Overview
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/velocity">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            @* Embedded VelocityPanel component with max 10 bars *@
            <VelocityPanel MaxSprints="10" />
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Decision #12: Interactive trend chart data - 3 series
    private Dictionary<string, int> _bugTrendTotal = new();   // Bugs existing/active in that month
    private Dictionary<string, int> _bugTrendFixed = new();   // Bugs moved to Done in that month
    private Dictionary<string, int> _bugTrendAdded = new();   // Bugs created in that month
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Parse context from query string (inherited from base class)
            ParseContextQueryParameters();
            
            if (!await EnsureProfileAsync(WorkspaceRoutes.BetaTrendsWorkspace))
            {
                return;
            }
            
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            _profileId = activeProfile?.Id;
            
            // Load bug trend data (Decision #3: 6 month time horizon)
            await LoadBugTrendDataAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    /// <summary>
    /// Loads bug trend data for the last 6 months with 3 series: Total, Fixed, Added.
    /// Decision #3: Time horizon default is 6 months.
    /// 
    /// Series 1 (Total): Bugs open at month-end (approximate using current state).
    /// Series 2 (Fixed): Bugs in "Done" state (approximate - no state transition history).
    /// Series 3 (Added): Bugs created in that month (accurate using System.CreatedDate).
    /// 
    /// Uses CreatedDate from TFS (System.CreatedDate) for accurate bug creation timing.
    /// Bugs without CreatedDate are excluded from trend calculations (DateTimeOffset.MinValue).
    /// </summary>
    private async Task LoadBugTrendDataAsync()
    {
        try
        {
            var workItems = await WorkItemService.GetAllWithValidationAsync();
            var bugs = workItems.Where(wi => wi.Type?.Equals("Bug", StringComparison.OrdinalIgnoreCase) == true).ToList();
            
            // Get state classifications for determining "Done" state
            var classifications = await StateClassificationService.GetClassificationsAsync();
            
            // Build lookup dictionary for O(1) state classification lookups
            var classificationLookup = classifications.Classifications
                .Where(c => c.WorkItemType.Equals("Bug", StringComparison.OrdinalIgnoreCase))
                .ToDictionary(
                    c => c.StateName,
                    c => c.Classification,
                    StringComparer.OrdinalIgnoreCase);
            
            var now = DateTime.UtcNow;
            _bugTrendTotal = new Dictionary<string, int>();
            _bugTrendFixed = new Dictionary<string, int>();
            _bugTrendAdded = new Dictionary<string, int>();
            
            // Process each of the last 6 months
            for (var i = 5; i >= 0; i--)
            {
                var monthDate = now.AddMonths(-i);
                var periodKey = monthDate.ToString("yyyy-MM");
                var monthStart = new DateTime(monthDate.Year, monthDate.Month, 1);
                var nextMonthStart = monthStart.AddMonths(1);
                
                // Series 3: Bugs Added - bugs created in this month (accurate)
                var addedCount = bugs.Count(b =>
                {
                    var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                    return effectiveDate >= monthStart && effectiveDate < nextMonthStart;
                });
                _bugTrendAdded[periodKey] = addedCount;
                
                // Series 2: Bugs Fixed - bugs in "Done" state created before/during this month
                // Note: This is an approximation as we don't track state transition history.
                // Without state history, we show bugs currently in "Done" state as a rough indicator.
                // See docs/bug_trend_followups.md for improvement plan.
                var fixedCount = bugs.Count(b =>
                {
                    var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                    var createdBeforeOrDuringMonth = effectiveDate < nextMonthStart && effectiveDate > DateTimeOffset.MinValue;
                    
                    if (!createdBeforeOrDuringMonth)
                        return false;
                    
                    classificationLookup.TryGetValue(b.State, out var classification);
                    return classification == StateClassification.Done;
                });
                _bugTrendFixed[periodKey] = fixedCount;
                
                // Series 1: Total Bugs - bugs open at month-end (approximate using current state)
                // Count bugs created before/during this month that are NOT in "Done" or "Removed" state
                var totalCount = bugs.Count(b =>
                {
                    var effectiveDate = b.CreatedDate ?? DateTimeOffset.MinValue;
                    var createdBeforeOrDuringMonth = effectiveDate < nextMonthStart && effectiveDate > DateTimeOffset.MinValue;
                    
                    if (!createdBeforeOrDuringMonth)
                        return false;
                    
                    classificationLookup.TryGetValue(b.State, out var classification);
                    
                    // Exclude bugs in "Done" or "Removed" state
                    return classification != StateClassification.Done &&
                           classification != StateClassification.Removed;
                });
                _bugTrendTotal[periodKey] = totalCount;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load bug trend data: {ex.Message}");
            // Keep empty dictionaries on failure
        }
    }
    
    /// <summary>
    /// Handles click on a trend chart bar.
    /// Decision #12: Click = filter to that period.
    /// </summary>
    private void OnBugTrendPeriodClick(string period)
    {
        // Navigate to bug overview filtered by the selected period
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaBugOverview}{BuildContextQuery($"period={period}")}");
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", null, disabled: true, icon: Icons.Material.Filled.Timeline)
        };
    }
    
    private void NavigateToVelocityDetails()
    {
        // Navigate to velocity dashboard for now
        NavigationManager.NavigateTo("/velocity");
    }
    
    private void NavigateToBugTrend()
    {
        // Navigate to bug overview with period scoped
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaBugOverview}{BuildContextQuery()}");
    }
    
    private void NavigateToPrOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPrOverview}{BuildContextQuery("insightOnly=true")}");
    }
    
    private void NavigateToPipelineOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPipelineOverview}{BuildContextQuery("insightOnly=true")}");
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaHealthWorkspace}{BuildContextQuery()}");
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPlanningWorkspace}{BuildContextQuery()}");
    }
}
