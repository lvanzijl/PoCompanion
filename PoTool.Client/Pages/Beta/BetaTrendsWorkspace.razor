@page "/beta/trends"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Velocity
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Trends (Past) - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Trends (Past)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.History" 
                         Size="Size.Small"
                         Color="Color.Info">
                    Last 6 Months
                </MudChip>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Trend Signals Grid *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
                Trend Signals
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Structural behavior over time — click to explore details
            </MudText>
            
            <MudGrid>
                @* Velocity Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToVelocityDetails">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Velocity Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Team delivery patterns</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @* Bug Trend Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBugTrend">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bug Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Bug patterns over time</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* PR Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPrOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.MergeType" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">PR Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Pull request insights</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Pipeline Trend Signal (Read-Only) *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToPipelineOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Pipeline Trend</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Build & deployment health</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="mt-1">Read-only</MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Information Notice *@
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Note:</strong> Charts show max 10 bars. PRs and Pipelines are insight-only (read-only). 
                Bugs may navigate further to editable bug detail.
            </MudText>
        </MudAlert>

        @* Velocity Overview Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" />
                    Velocity Overview
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/velocity">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            @* Embedded velocity component would go here *@
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Velocity trends for the last 6 months
            </MudText>
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(WorkspaceRoutes.BetaTrendsWorkspace)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", null, disabled: true, icon: Icons.Material.Filled.Timeline)
        };
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
    
    private void NavigateToVelocityDetails()
    {
        // Navigate to velocity dashboard for now
        NavigationManager.NavigateTo("/velocity");
    }
    
    private void NavigateToBugTrend()
    {
        // Navigate to bug overview with period scoped
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaBugOverview);
    }
    
    private void NavigateToPrOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPrOverview}?insightOnly=true");
    }
    
    private void NavigateToPipelineOverview()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaPipelineOverview}?insightOnly=true");
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHealthWorkspace);
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaPlanningWorkspace);
    }
}
