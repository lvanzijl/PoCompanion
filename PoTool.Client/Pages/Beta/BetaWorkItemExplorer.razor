@page "/beta/work-items"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.WorkItems
@using PoTool.Client.ApiClient
@using System.Web
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject WorkItemService WorkItemService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Work Item Explorer - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Work Item Explorer
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Filter Status *@
                @if (!string.IsNullOrEmpty(_validationType))
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.FilterAlt" 
                             Size="Size.Small"
                             Color="Color.Info"
                             OnClose="ClearValidationTypeFilter">
                        @GetValidationTypeLabel(_validationType)
                    </MudChip>
                }
                @if (_backlogDepthExceeded)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Layers" 
                             Size="Size.Small"
                             Color="Color.Error"
                             OnClose="ClearBacklogDepthFilter">
                        Backlog Depth Exceeded
                    </MudChip>
                }
                @if (_rootWorkItemId.HasValue)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.AccountTree" 
                             Size="Size.Small"
                             Color="Color.Secondary"
                             OnClose="ClearRootWorkItemFilter">
                        Root: @_rootWorkItemId
                    </MudChip>
                }
                @if (_allProducts && _allTeams)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Public" 
                             Size="Size.Small"
                             Color="Color.Default">
                        All Products / All Teams
                    </MudChip>
                }
                else
                {
                    @* View All Toggle - Show option to view all products/teams *@
                    <MudButton Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Public"
                               OnClick="NavigateToViewAll">
                        View All
                    </MudButton>
                }
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mb-4">
            @_errorMessage
        </MudAlert>
    }
    else
    {
        @* Filter Parameters Info *@
        @if (HasActiveFilters())
        {
            <MudAlert Severity="Severity.Info" Class="mb-4">
                <MudText Typo="Typo.body2">
                    <strong>Active Filters:</strong> 
                    @if (!string.IsNullOrEmpty(_validationType))
                    {
                        <text>Validation Type: @GetValidationTypeLabel(_validationType). </text>
                    }
                    @if (_backlogDepthExceeded)
                    {
                        <text>Showing items with exceeded backlog depth. </text>
                    }
                    @if (_rootWorkItemId.HasValue)
                    {
                        <text>Showing descendants of work item @_rootWorkItemId. </text>
                    }
                </MudText>
            </MudAlert>
        }

        @* Work Item Explorer Content *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.h5">
                        <MudIcon Icon="@Icons.Material.Filled.ListAlt" Class="mr-2" />
                        Work Items
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@_workItems.Count items</MudChip>
                </MudStack>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/work-items">
                    Full Work Item View
                </MudButton>
            </MudStack>
            
            @if (_workItems.Count == 0)
            {
                <MudAlert Severity="Severity.Info">
                    No work items found matching the current filters.
                </MudAlert>
            }
            else
            {
                @* Work Item Table *@
                <MudTable Items="@_workItems" Hover="true" Striped="true" Dense="true">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>State</MudTh>
                        <MudTh>Effort</MudTh>
                        <MudTh>Issues</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="ID">@context.Id</MudTd>
                        <MudTd DataLabel="Title">@context.Title</MudTd>
                        <MudTd DataLabel="Type">
                            <MudChip T="string" Size="Size.Small" Color="@GetTypeColor(context.Type)">@context.Type</MudChip>
                        </MudTd>
                        <MudTd DataLabel="State">@context.State</MudTd>
                        <MudTd DataLabel="Effort">@(context.Effort?.ToString() ?? "-")</MudTd>
                        <MudTd DataLabel="Issues">
                            @if (context.HasValidationIssues)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.Warning">
                                    @context.ValidationIssueCount
                                </MudChip>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }

            @* Available End-Station Actions *@
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" />
                Available Edits
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.SyncAlt">Work Item State</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Timer">Effort</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Description">Description</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.Label">Tags</MudChip>
                <MudChip T="string" Color="Color.Default" Size="Size.Small" Icon="@Icons.Material.Filled.PlaylistAddCheck">Batch Edits</MudChip>
            </MudStack>
        </MudPaper>

        @* Navigation Back Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private string? _errorMessage;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Filter parameters from deep links
    private string? _validationType;
    private bool _backlogDepthExceeded;
    private int? _rootWorkItemId;
    private bool _allProducts;
    private bool _allTeams;
    
    // Work item data
    private List<WorkItemExplorerItem> _workItems = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            // Parse query parameters
            ParseQueryParameters();
            
            // Load work items with applied filters
            await LoadWorkItemsAsync();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            Snackbar.Add($"Error loading work items: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        _validationType = queryParams["validationType"];
        
        var backlogDepth = queryParams["backlogDepthExceeded"];
        if (!string.IsNullOrEmpty(backlogDepth))
        {
            _backlogDepthExceeded = bool.TryParse(backlogDepth, out var result) && result;
        }
        
        var rootId = queryParams["rootWorkItemId"];
        if (!string.IsNullOrEmpty(rootId))
        {
            _rootWorkItemId = int.TryParse(rootId, out var id) ? id : null;
        }
        
        var allProducts = queryParams["allProducts"];
        if (!string.IsNullOrEmpty(allProducts))
        {
            _allProducts = bool.TryParse(allProducts, out var result) && result;
        }
        
        var allTeams = queryParams["allTeams"];
        if (!string.IsNullOrEmpty(allTeams))
        {
            _allTeams = bool.TryParse(allTeams, out var result) && result;
        }
    }
    
    private async Task LoadWorkItemsAsync()
    {
        try
        {
            var workItemsWithValidation = await WorkItemService.GetAllWithValidationAsync();
            
            // Apply validation type filter if specified
            if (!string.IsNullOrEmpty(_validationType))
            {
                workItemsWithValidation = FilterByValidationType(workItemsWithValidation);
            }
            
            // Apply root work item filter if specified (show descendants)
            if (_rootWorkItemId.HasValue)
            {
                workItemsWithValidation = FilterByRootWorkItem(workItemsWithValidation);
            }
            
            // Convert to display items
            _workItems = workItemsWithValidation.Select(wi => new WorkItemExplorerItem
            {
                Id = wi.TfsId,
                Title = wi.Title ?? "(No title)",
                Type = wi.Type ?? "Unknown",
                State = wi.State ?? "Unknown",
                Effort = wi.Effort,
                HasValidationIssues = wi.ValidationIssues?.Count > 0,
                ValidationIssueCount = wi.ValidationIssues?.Count ?? 0
            }).ToList();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load work items: {ex.Message}";
            _workItems = new List<WorkItemExplorerItem>();
        }
    }
    
    private IEnumerable<WorkItemWithValidationDto> FilterByValidationType(IEnumerable<WorkItemWithValidationDto> workItems)
    {
        return workItems.Where(wi =>
        {
            if (wi.ValidationIssues == null || wi.ValidationIssues.Count == 0)
                return false;
                
            return wi.ValidationIssues.Any(issue =>
            {
                var message = issue.Message?.ToLowerInvariant() ?? "";
                var ruleId = issue.RuleId?.ToLowerInvariant() ?? "";
                
                return _validationType switch
                {
                    "missing-effort" => message.Contains("effort") || ruleId.Contains("effort"),
                    "missing-description" => message.Contains("description") || ruleId.Contains("description"),
                    "invalid-state" => message.Contains("state") || ruleId.Contains("state"),
                    "missing-tags" => message.Contains("tag") || ruleId.Contains("tag"),
                    _ => false
                };
            });
        });
    }
    
    private IEnumerable<WorkItemWithValidationDto> FilterByRootWorkItem(IEnumerable<WorkItemWithValidationDto> workItems)
    {
        // Build a set of all descendants of the root work item
        var allWorkItemsList = workItems.ToList();
        var descendants = new HashSet<int>();
        var toProcess = new Queue<int>();
        
        if (_rootWorkItemId.HasValue)
        {
            descendants.Add(_rootWorkItemId.Value);
            toProcess.Enqueue(_rootWorkItemId.Value);
            
            while (toProcess.Count > 0)
            {
                var parentId = toProcess.Dequeue();
                var children = allWorkItemsList.Where(wi => wi.ParentTfsId == parentId);
                foreach (var child in children)
                {
                    if (descendants.Add(child.TfsId))
                    {
                        toProcess.Enqueue(child.TfsId);
                    }
                }
            }
        }
        
        return allWorkItemsList.Where(wi => descendants.Contains(wi.TfsId));
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Work Item Explorer", null, disabled: true, icon: Icons.Material.Filled.Search)
        };
    }
    
    private bool HasActiveFilters()
    {
        return !string.IsNullOrEmpty(_validationType) || _backlogDepthExceeded || _rootWorkItemId.HasValue;
    }
    
    private string GetActiveFilterDescription()
    {
        var filters = new List<string>();
        
        if (!string.IsNullOrEmpty(_validationType))
            filters.Add(GetValidationTypeLabel(_validationType));
        if (_backlogDepthExceeded)
            filters.Add("Backlog Depth Exceeded");
        if (_rootWorkItemId.HasValue)
            filters.Add($"Root: {_rootWorkItemId}");
        if (_allProducts && _allTeams)
            filters.Add("All Products / All Teams");
            
        return filters.Count > 0 ? string.Join(", ", filters) : "No filters applied";
    }
    
    private string GetValidationTypeLabel(string validationType)
    {
        return validationType switch
        {
            "missing-effort" => "Missing Effort",
            "missing-description" => "Missing Description",
            "invalid-state" => "Invalid State",
            "missing-tags" => "Missing Tags",
            _ => validationType
        };
    }
    
    private Color GetTypeColor(string type)
    {
        return type.ToLowerInvariant() switch
        {
            "bug" => Color.Error,
            "epic" => Color.Primary,
            "feature" => Color.Secondary,
            "user story" or "product backlog item" => Color.Info,
            "task" => Color.Success,
            _ => Color.Default
        };
    }
    
    private void ClearValidationTypeFilter()
    {
        _validationType = null;
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaWorkItemExplorer);
    }
    
    private void ClearBacklogDepthFilter()
    {
        _backlogDepthExceeded = false;
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaWorkItemExplorer);
    }
    
    private void ClearRootWorkItemFilter()
    {
        _rootWorkItemId = null;
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaWorkItemExplorer);
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
    
    private void NavigateToViewAll()
    {
        // Navigate to the same view with allProducts=true and allTeams=true
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaWorkItemExplorer}?allProducts=true&allTeams=true");
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHealthWorkspace);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaTrendsWorkspace);
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaPlanningWorkspace);
    }
    
    private class WorkItemExplorerItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string State { get; set; } = string.Empty;
        public int? Effort { get; set; }
        public bool HasValidationIssues { get; set; }
        public int ValidationIssueCount { get; set; }
    }
}
