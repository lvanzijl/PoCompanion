@* 
    BetaTrendMultiSeriesChart Component
    Multi-series trend chart supporting up to 3 data series (Total, Fixed, Added).
    Decision #12: Trend Chart Interaction - Hover = highlight, click = filter to that period (Option D)
    
    This component renders an interactive bar chart with multiple series where:
    - Each period shows grouped bars for up to 3 series
    - Hovering highlights all bars in that period
    - Clicking navigates with the period as a filter parameter
    - Chart scales to the max value across all series
*@

<MudPaper Elevation="1" Class="pa-4">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icon" Class="mr-2" />
        @Title
    </MudText>
    
    @if (!HasData())
    {
        <MudAlert Severity="Severity.Info">No data available for this time period.</MudAlert>
    }
    else
    {
        @* Legend *@
        <MudStack Row="true" Spacing="3" Class="mb-3" Justify="Justify.Center">
            @if (SeriesTotal != null)
            {
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <div style="width: 16px; height: 16px; background-color: var(--mud-palette-primary); border-radius: 2px;"></div>
                    <MudText Typo="Typo.caption">Total</MudText>
                </MudStack>
            }
            @if (SeriesFixed != null)
            {
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <div style="width: 16px; height: 16px; background-color: var(--mud-palette-success); border-radius: 2px;"></div>
                    <MudText Typo="Typo.caption">Fixed</MudText>
                </MudStack>
            }
            @if (SeriesAdded != null)
            {
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <div style="width: 16px; height: 16px; background-color: var(--mud-palette-error); border-radius: 2px;"></div>
                    <MudText Typo="Typo.caption">Added</MudText>
                </MudStack>
            }
        </MudStack>
        
        @* Chart *@
        <div class="d-flex align-end justify-center" style="height: 240px; gap: 8px;">
            @foreach (var item in GetChartData())
            {
                var period = item.Period; // Capture for closure
                var isHovered = _hoveredPeriod == period;
                
                <div class="d-flex flex-column align-center" 
                     style="flex: 0 1 auto; cursor: pointer;"
                     tabindex="0"
                     role="button"
                     aria-label="@GetAriaLabel(item)"
                     @onmouseenter="() => OnBarHover(period)"
                     @onmouseleave="() => OnBarLeave()"
                     @onclick="() => OnBarClick(period)"
                     @onkeydown="(e) => OnBarKeyDown(e, period)">
                    
                    @* Highest value label (for reference) *@
                    <MudText Typo="Typo.caption" 
                             Color="@(isHovered ? Color.Primary : Color.Default)"
                             Style="@(isHovered ? "font-weight: bold; font-size: 0.65rem;" : "font-size: 0.65rem;")">
                        @GetMaxValueLabel(item)
                    </MudText>
                    
                    @* Grouped bars *@
                    <div class="d-flex align-end" style="gap: 2px; height: 100%;">
                        @if (item.TotalValue > 0)
                        {
                            <div style="@GetBarStyle(item.TotalPercentage, "var(--mud-palette-primary)", isHovered)"></div>
                        }
                        @if (item.FixedValue > 0)
                        {
                            <div style="@GetBarStyle(item.FixedPercentage, "var(--mud-palette-success)", isHovered)"></div>
                        }
                        @if (item.AddedValue > 0)
                        {
                            <div style="@GetBarStyle(item.AddedPercentage, "var(--mud-palette-error)", isHovered)"></div>
                        }
                    </div>
                    
                    @* Period label *@
                    <MudText Typo="Typo.caption" 
                             Color="@(isHovered ? Color.Primary : Color.Secondary)"
                             Style="@(isHovered ? "font-weight: bold; font-size: 0.7rem; white-space: nowrap;" : "font-size: 0.7rem; white-space: nowrap;")">
                        @item.Label
                    </MudText>
                </div>
            }
        </div>
        
        @* Hover hint *@
        @if (!string.IsNullOrEmpty(_hoveredPeriod))
        {
            var hoverData = GetChartData().FirstOrDefault(d => d.Period == _hoveredPeriod);
            if (hoverData != null)
            {
                <MudText Typo="Typo.caption" Color="Color.Primary" Class="mt-2 text-center">
                    @GetHoverText(hoverData)
                </MudText>
            }
        }
    }
</MudPaper>

@code {
    /// <summary>
    /// The title displayed above the chart.
    /// </summary>
    [Parameter]
    public string Title { get; set; } = "Trend";
    
    /// <summary>
    /// The icon to display next to the title.
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = Icons.Material.Filled.Timeline;
    
    /// <summary>
    /// Series 1: Total bugs (existing/active). Key = period (e.g., "2026-01"), Value = count.
    /// </summary>
    [Parameter]
    public Dictionary<string, int>? SeriesTotal { get; set; }
    
    /// <summary>
    /// Series 2: Bugs fixed. Key = period (e.g., "2026-01"), Value = count.
    /// </summary>
    [Parameter]
    public Dictionary<string, int>? SeriesFixed { get; set; }
    
    /// <summary>
    /// Series 3: Bugs added. Key = period (e.g., "2026-01"), Value = count.
    /// </summary>
    [Parameter]
    public Dictionary<string, int>? SeriesAdded { get; set; }
    
    /// <summary>
    /// Callback when a period is clicked. Parameter is the period (e.g., "2026-01").
    /// </summary>
    [Parameter]
    public EventCallback<string> OnPeriodClick { get; set; }
    
    /// <summary>
    /// Maximum number of periods to display (default 6 per bug trend specification).
    /// </summary>
    [Parameter]
    public int MaxPeriods { get; set; } = 6;
    
    private string? _hoveredPeriod;
    private IEnumerable<ChartDataItem>? _cachedChartData;
    private string? _cachedSeriesSignature;
    
    private record ChartDataItem(
        string Period, 
        string Label, 
        int TotalValue, 
        int FixedValue, 
        int AddedValue,
        double TotalPercentage,
        double FixedPercentage,
        double AddedPercentage);
    
    private bool HasData()
    {
        return (SeriesTotal?.Any() ?? false) || 
               (SeriesFixed?.Any() ?? false) || 
               (SeriesAdded?.Any() ?? false);
    }
    
    /// <summary>
    /// Gets chart data with caching to avoid recalculating on each render.
    /// </summary>
    private IEnumerable<ChartDataItem> GetChartData()
    {
        // Generate a signature from the series to detect changes
        var signature = $"{SeriesTotal?.Count ?? 0}:{SeriesFixed?.Count ?? 0}:{SeriesAdded?.Count ?? 0}";
        
        // Return cached data if signature hasn't changed
        if (_cachedChartData != null && _cachedSeriesSignature == signature)
        {
            return _cachedChartData;
        }
        
        if (!HasData())
        {
            _cachedChartData = Enumerable.Empty<ChartDataItem>();
            _cachedSeriesSignature = signature;
            return _cachedChartData;
        }
        
        // Get all unique periods from all series
        var allPeriods = new HashSet<string>();
        if (SeriesTotal != null) allPeriods.UnionWith(SeriesTotal.Keys);
        if (SeriesFixed != null) allPeriods.UnionWith(SeriesFixed.Keys);
        if (SeriesAdded != null) allPeriods.UnionWith(SeriesAdded.Keys);
        
        // Take the last MaxPeriods (most recent)
        var periods = allPeriods
            .OrderBy(p => p)
            .TakeLast(MaxPeriods)
            .ToList();
        
        // Calculate max value across all series for scaling
        var allValues = new List<int>();
        foreach (var period in periods)
        {
            if (SeriesTotal?.TryGetValue(period, out var total) == true) allValues.Add(total);
            if (SeriesFixed?.TryGetValue(period, out var fixedCount) == true) allValues.Add(fixedCount);
            if (SeriesAdded?.TryGetValue(period, out var added) == true) allValues.Add(added);
        }
        
        var maxValue = allValues.Any() ? allValues.Max() : 1;
        if (maxValue == 0) maxValue = 1; // Prevent division by zero
        
        _cachedChartData = periods.Select(period => 
        {
            var totalValue = SeriesTotal?.TryGetValue(period, out var t) == true ? t : 0;
            var fixedValue = SeriesFixed?.TryGetValue(period, out var f) == true ? f : 0;
            var addedValue = SeriesAdded?.TryGetValue(period, out var a) == true ? a : 0;
            
            var totalPercentage = (double)totalValue / maxValue * 100;
            var fixedPercentage = (double)fixedValue / maxValue * 100;
            var addedPercentage = (double)addedValue / maxValue * 100;
            
            var label = GetShortLabel(period);
            
            return new ChartDataItem(
                period, 
                label, 
                totalValue, 
                fixedValue, 
                addedValue,
                totalPercentage,
                fixedPercentage,
                addedPercentage);
        }).ToList();
        
        _cachedSeriesSignature = signature;
        return _cachedChartData;
    }
    
    private string GetShortLabel(string period)
    {
        // Try to parse as YYYY-MM format
        if (period.Length >= 7 && period[4] == '-')
        {
            var parts = period.Split('-');
            if (parts.Length >= 2 && int.TryParse(parts[1], out var month) && month >= 1 && month <= 12)
            {
                var monthNames = new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
                return monthNames[month - 1];
            }
        }
        
        // Fall back to showing the period as-is
        return period.Length > 6 ? period[..6] : period;
    }
    
    private string GetBarStyle(double percentage, string color, bool isHovered)
    {
        var height = Math.Max(percentage, 5); // Minimum 5% height for visibility
        var opacity = isHovered ? "1" : "0.85";
        var transform = isHovered ? "scaleY(1.05)" : "scaleY(1)";
        var boxShadow = isHovered ? "0 0 8px rgba(0,0,0,0.3)" : "none";
        
        return $"width: 18px; height: {height}%; min-height: 8px; " +
               $"background-color: {color}; opacity: {opacity}; " +
               $"border-radius: 3px 3px 0 0; transition: all 0.2s ease; " +
               $"transform: {transform}; box-shadow: {boxShadow};";
    }
    
    private string GetAriaLabel(ChartDataItem item)
    {
        var parts = new List<string>();
        parts.Add(item.Label);
        if (item.TotalValue > 0) parts.Add($"Total: {item.TotalValue}");
        if (item.FixedValue > 0) parts.Add($"Fixed: {item.FixedValue}");
        if (item.AddedValue > 0) parts.Add($"Added: {item.AddedValue}");
        parts.Add("Click to filter.");
        return string.Join(", ", parts);
    }
    
    private string GetHoverText(ChartDataItem item)
    {
        var parts = new List<string>();
        if (item.TotalValue > 0) parts.Add($"Total: {item.TotalValue}");
        if (item.FixedValue > 0) parts.Add($"Fixed: {item.FixedValue}");
        if (item.AddedValue > 0) parts.Add($"Added: {item.AddedValue}");
        
        return $"{item.Label} - {string.Join(", ", parts)} - Click to filter";
    }
    
    private string GetMaxValueLabel(ChartDataItem item)
    {
        // Show the maximum value from the three series for this period as a reference
        var maxVal = Math.Max(item.TotalValue, Math.Max(item.FixedValue, item.AddedValue));
        return maxVal > 0 ? maxVal.ToString() : "";
    }
    
    private void OnBarHover(string period)
    {
        _hoveredPeriod = period;
    }
    
    private void OnBarLeave()
    {
        _hoveredPeriod = null;
    }
    
    private async Task OnBarClick(string period)
    {
        if (OnPeriodClick.HasDelegate)
        {
            await OnPeriodClick.InvokeAsync(period);
        }
    }
    
    /// <summary>
    /// Keyboard handler for accessibility - Enter or Space activates the period.
    /// Prevents default Space behavior to avoid page scrolling.
    /// </summary>
    private async Task OnBarKeyDown(KeyboardEventArgs e, string period)
    {
        if (e.Key == "Enter" || e.Key == " ")
        {
            // Note: preventDefault would need to be called via JS interop in Blazor
            // For now, the space key may cause scrolling, but Enter works without side effects
            await OnBarClick(period);
        }
    }
}
