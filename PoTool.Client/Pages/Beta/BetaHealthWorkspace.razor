@page "/beta/health"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.BacklogHealth
@using PoTool.Client.ApiClient
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject WorkItemService WorkItemService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Health (Now) - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.HealthAndSafety" Color="Color.Success" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Health (Now)
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.AccessTime" 
                         Size="Size.Small"
                         Color="Color.Success">
                    Current State
                </MudChip>
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Health Signals Grid *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" Class="mr-2" />
                Health Signals
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                Click a signal to navigate to related work items
            </MudText>
            
            <MudGrid>
                @* Validation Category Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToWorkItemExplorer("missing-effort")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Timer" Color="@(_missingEffortCount > 0 ? Color.Warning : Color.Success)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Missing Effort</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_missingEffortCount > 0 ? Color.Warning : Color.Success)">
                                @_missingEffortCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @* Missing Description Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToWorkItemExplorer("missing-description")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Color="@(_missingDescriptionCount > 0 ? Color.Warning : Color.Success)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Missing Description</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_missingDescriptionCount > 0 ? Color.Warning : Color.Success)">
                                @_missingDescriptionCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Backlog Depth Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBacklogDepthExceeded">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Color="Color.Error" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Backlog Too Deep</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Depth exceeded</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Bug Overview Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick="NavigateToBugOverview">
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="@(_bugCount > 0 ? Color.Error : Color.Success)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Bugs</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_bugCount > 0 ? Color.Error : Color.Success)">
                                @_bugCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* State Issues Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToWorkItemExplorer("invalid-state")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="@(_invalidStateCount > 0 ? Color.Warning : Color.Success)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Invalid States</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_invalidStateCount > 0 ? Color.Warning : Color.Success)">
                                @_invalidStateCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Tag Issues Signal *@
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" 
                             Style="cursor: pointer; transition: all 0.2s;"
                             Class="mud-card-hover"
                             @onclick='() => NavigateToWorkItemExplorer("missing-tags")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Label" Color="@(_missingTagsCount > 0 ? Color.Info : Color.Success)" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Missing Tags</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_missingTagsCount > 0 ? Color.Info : Color.Success)">
                                @_missingTagsCount items
                            </MudChip>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Backlog Health Panel - Embedded existing component *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
                    Backlog Health Analysis
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/backlog-health">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            <BacklogHealthPanel MaxIterations="5" />
        </MudPaper>

        @* Cross-Workspace Navigation *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigate to Other Workspaces
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover {
        border: 2px solid transparent;
    }
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
        border-color: var(--mud-palette-primary);
    }
</style>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    // Validation issue counts
    private int _missingEffortCount;
    private int _missingDescriptionCount;
    private int _invalidStateCount;
    private int _missingTagsCount;
    private int _bugCount;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(WorkspaceRoutes.BetaHealthWorkspace)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            await LoadValidationCountsAsync();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task LoadValidationCountsAsync()
    {
        try
        {
            var workItemsWithValidation = await WorkItemService.GetAllWithValidationAsync();
            
            foreach (var wi in workItemsWithValidation)
            {
                if (wi.Type == "Bug")
                {
                    _bugCount++;
                }
                
                if (wi.ValidationIssues != null)
                {
                    foreach (var issue in wi.ValidationIssues)
                    {
                        var message = issue.Message?.ToLowerInvariant() ?? "";
                        
                        if (message.Contains("effort") || issue.RuleId?.Contains("effort", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            _missingEffortCount++;
                        }
                        else if (message.Contains("description") || issue.RuleId?.Contains("description", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            _missingDescriptionCount++;
                        }
                        else if (message.Contains("state") || issue.RuleId?.Contains("state", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            _invalidStateCount++;
                        }
                        else if (message.Contains("tag") || issue.RuleId?.Contains("tag", StringComparison.OrdinalIgnoreCase) == true)
                        {
                            _missingTagsCount++;
                        }
                    }
                }
            }
        }
        catch
        {
            // If loading fails, keep counts at 0
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Health (Now)", null, disabled: true, icon: Icons.Material.Filled.HealthAndSafety)
        };
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
    
    private void NavigateToWorkItemExplorer(string validationType)
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaWorkItemExplorer}?validationType={validationType}");
    }
    
    private void NavigateToBacklogDepthExceeded()
    {
        NavigationManager.NavigateTo($"{WorkspaceRoutes.BetaWorkItemExplorer}?backlogDepthExceeded=true");
    }
    
    private void NavigateToBugOverview()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaBugOverview);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaTrendsWorkspace);
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaPlanningWorkspace);
    }
}
