@page "/home/plan-board"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.Planning
@using PoTool.Client.ApiClient
@using System.Web
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Plan Board - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Plan Board
                    </MudText>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (_allProducts)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Public" 
                             Size="Size.Small"
                             Color="Color.Default">
                        All Products
                    </MudChip>
                }
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToHome">
                    Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Planning Board Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="mr-2" />
                    Release Planning Board
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/release-planning">
                    Full Release Planning
                </MudButton>
            </MudStack>
            
            @* Embedded Planning Board component *@
            @if (_activeProfileId.HasValue)
            {
                <PlanningBoard 
                    ProductOwnerId="@_activeProfileId.Value"
                    Products="@_products"
                    SelectedProductId="@_selectedProductId"
                    OnProductSelectionChanged="OnProductChanged" />
            }
        </MudPaper>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary" 
                           StartIcon="@Icons.Material.Filled.CalendarMonth"
                           OnClick="NavigateToPlanning">
                    Planning (Future)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _activeProfileId;
    private int? _selectedProductId;
    private bool _allProducts;
    private List<ProductDto> _products = new();
    private List<BreadcrumbItem> _breadcrumbs = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _activeProfileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            
            ParseQueryParameters();
            
            // Load products
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        var allProducts = queryParams["allProducts"];
        if (!string.IsNullOrEmpty(allProducts))
        {
            _allProducts = bool.TryParse(allProducts, out var result) && result;
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", WorkspaceRoutes.Home, icon: Icons.Material.Filled.Home),
            new("Plan Board", null, disabled: true, icon: Icons.Material.Filled.ViewColumn)
        };
    }
    
    private Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        return Task.CompletedTask;
    }
    
    private void NavigateToHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.Home);
    }
    
    private void NavigateToPlanning()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.PlanningWorkspace2);
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.HealthWorkspace);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.TrendsWorkspace);
    }
}
