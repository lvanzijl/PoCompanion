@page "/beta/pipelines"
@using PoTool.Client.Components.Common
@using System.Web
@inject IProfileService ProfileService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Pipeline Overview - Beta - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small">BETA</MudChip>
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Color="Color.Secondary" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Pipeline Overview
                    </MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.VisibilityOff">Read-only</MudChip>
                </MudStack>
                
                @* Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @if (_insightOnly)
                {
                    <MudChip T="string" 
                             Icon="@Icons.Material.Filled.Insights" 
                             Size="Size.Small"
                             Color="Color.Info">
                        Insight Only
                    </MudChip>
                }
                
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToBetaHome">
                    Beta Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Read-Only Notice *@
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            <MudText Typo="Typo.body2">
                <strong>Read-only view.</strong> Pipelines are insight-only in the Beta navigation. 
                For full pipeline management, use the <MudLink Href="/pipeline-insights">Pipeline Insights dashboard</MudLink>.
            </MudText>
        </MudAlert>

        @* Pipeline Insights Section *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.Insights" Class="mr-2" />
                    Pipeline Insights
                </MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           EndIcon="@Icons.Material.Filled.OpenInNew" 
                           Href="/pipeline-insights">
                    Full Dashboard
                </MudButton>
            </MudStack>
            
            @* Sample Pipeline Data *@
            <MudTable Items="@_samplePipelines" Hover="true" Striped="true" Dense="true">
                <HeaderContent>
                    <MudTh>Pipeline</MudTh>
                    <MudTh>Last Run</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Duration</MudTh>
                    <MudTh>Success Rate</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Pipeline">@context.Name</MudTd>
                    <MudTd DataLabel="Last Run">@context.LastRun.ToString("MMM dd, HH:mm")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Duration">@context.Duration</MudTd>
                    <MudTd DataLabel="Success Rate">
                        <MudProgressLinear Color="@GetSuccessRateColor(context.SuccessRate)" Value="@context.SuccessRate" Class="my-1" />
                        <MudText Typo="Typo.caption">@context.SuccessRate%</MudText>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        @* Navigation Options *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Explore" Class="mr-2" />
                Navigation
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Info" 
                           StartIcon="@Icons.Material.Filled.Timeline"
                           OnClick="NavigateToTrends">
                    Trends (Past)
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Success" 
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           OnClick="NavigateToHealth">
                    Health (Now)
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

@code {
    private bool _isLoading = true;
    private int? _profileId;
    private bool _insightOnly;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private List<PipelineItem> _samplePipelines = new();
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo($"{WorkspaceRoutes.Profiles}?returnUrl={Uri.EscapeDataString(NavigationManager.Uri)}");
                return;
            }
            
            _profileId = activeProfile.Id;
            ProfileService.SetCachedActiveProfileId(_profileId);
            
            ParseQueryParameters();
            LoadSampleData();
            UpdateBreadcrumbs();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void ParseQueryParameters()
    {
        var uri = new Uri(NavigationManager.Uri);
        var queryParams = HttpUtility.ParseQueryString(uri.Query);
        
        var insightOnly = queryParams["insightOnly"];
        if (!string.IsNullOrEmpty(insightOnly))
        {
            _insightOnly = bool.TryParse(insightOnly, out var result) && result;
        }
    }
    
    private void LoadSampleData()
    {
        _samplePipelines = new List<PipelineItem>
        {
            new PipelineItem { Name = "Build - Main", LastRun = DateTime.Now.AddHours(-2), Status = "Succeeded", Duration = "4m 32s", SuccessRate = 95 },
            new PipelineItem { Name = "Build - Feature", LastRun = DateTime.Now.AddHours(-5), Status = "Failed", Duration = "2m 15s", SuccessRate = 78 },
            new PipelineItem { Name = "Deploy - Staging", LastRun = DateTime.Now.AddDays(-1), Status = "Succeeded", Duration = "8m 45s", SuccessRate = 100 }
        };
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Beta Home", WorkspaceRoutes.BetaHome, icon: Icons.Material.Filled.Home),
            new("Trends (Past)", WorkspaceRoutes.BetaTrendsWorkspace, icon: Icons.Material.Filled.Timeline),
            new("Pipeline Overview", null, disabled: true, icon: Icons.Material.Filled.AccountTree)
        };
    }
    
    private Color GetStatusColor(string status)
    {
        return status switch
        {
            "Succeeded" => Color.Success,
            "Failed" => Color.Error,
            "Running" => Color.Info,
            "Canceled" => Color.Warning,
            _ => Color.Default
        };
    }
    
    private Color GetSuccessRateColor(int rate)
    {
        return rate switch
        {
            >= 90 => Color.Success,
            >= 70 => Color.Warning,
            _ => Color.Error
        };
    }
    
    private void NavigateToBetaHome()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHome);
    }
    
    private void NavigateToTrends()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaTrendsWorkspace);
    }
    
    private void NavigateToHealth()
    {
        NavigationManager.NavigateTo(WorkspaceRoutes.BetaHealthWorkspace);
    }
    
    private class PipelineItem
    {
        public string Name { get; set; } = string.Empty;
        public DateTime LastRun { get; set; }
        public string Status { get; set; } = string.Empty;
        public string Duration { get; set; } = string.Empty;
        public int SuccessRate { get; set; }
    }
}
