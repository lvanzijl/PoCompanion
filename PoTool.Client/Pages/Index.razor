@page "/"
@using PoTool.Client.Services
@inject IOnboardingService OnboardingService
@inject IStartupOrchestratorService StartupOrchestrator
@inject NavigationManager NavigationManager

<MudContainer Class="d-flex justify-center align-center" Style="height: 100vh;">
    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
</MudContainer>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Check if onboarding is needed
        var readiness = await StartupOrchestrator.GetStartupReadinessAsync();
        
        // If backend has no TFS configuration or no profiles, reset onboarding state
        // This handles the case where the database was deleted
        if (readiness != null && (!readiness.HasSavedTfsConfig || !readiness.HasAnyProfile))
        {
            await OnboardingService.ResetOnboardingAsync();
        }
        
        var onboardingCompleted = await OnboardingService.HasCompletedOnboardingAsync();
        
        if (!onboardingCompleted)
        {
            // Redirect to onboarding for first-time users
            NavigationManager.NavigateTo("/onboarding", replace: true);
            return;
        }
        
        // If onboarding is complete, perform startup routing
        if (readiness != null)
        {
            var routingResult = StartupOrchestrator.DetermineRoute(readiness);
            
            // Route based on startup readiness
            switch (routingResult.Route)
            {
                case StartupRoute.Configuration:
                    NavigationManager.NavigateTo("/tfsconfig", replace: true);
                    break;
                case StartupRoute.CreateFirstProfile:
                case StartupRoute.ProfilesHome:
                    NavigationManager.NavigateTo("/profiles", replace: true);
                    break;
                default:
                    NavigationManager.NavigateTo("/home", replace: true);
                    break;
            }
        }
        else
        {
            // Fallback to home if readiness check fails
            NavigationManager.NavigateTo("/home", replace: true);
        }
    }
}
