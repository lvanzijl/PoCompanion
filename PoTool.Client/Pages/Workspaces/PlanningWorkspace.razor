@page "/workspace/planning"
@using PoTool.Client.Components.Common
@using PoTool.Client.Components.ReleasePlanning
@using PoTool.Client.ApiClient
@using PoTool.Shared.Contracts
@using PoTool.Shared.ReleasePlanning
@using NavigationContext = PoTool.Client.Models.NavigationContext
@inject INavigationContextService NavigationContextService
@inject IProfileService ProfileService
@inject ProductService ProductService
@inject ReleasePlanningService ReleasePlanningService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Planning Workspace - PO Companion</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    @* Workspace Header with Context Info *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <MudStack Spacing="1">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Info" Size="Size.Large" />
                    <MudText Typo="Typo.h4">
                        Planning Workspace
                    </MudText>
                </MudStack>
                
                @* Context Breadcrumb *@
                <MudBreadcrumbs Items="@_breadcrumbs" Class="pa-0" />
            </MudStack>
            
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                @* Time Horizon Badge *@
                <MudChip T="string" 
                         Icon="@Icons.Material.Filled.EventNote" 
                         Size="Size.Small"
                         Color="Color.Info">
                    Future Planning
                </MudChip>
                
                @* Navigation *@
                @if (_currentContext?.Trigger?.SourceLabel != null)
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ArrowBack"
                               OnClick="NavigateBack">
                        Back
                    </MudButton>
                }
                
                @* Back to Landing *@
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.Home"
                           OnClick="NavigateToLanding">
                    Landing
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_isLoading)
    {
        <LoadingIndicator IsLoading="true" />
    }
    else
    {
        @* Product Selector *@
        @if (_products.Count > 0)
        {
            <MudPaper Elevation="1" Class="pa-3 mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Secondary" />
                    <MudSelect T="int?" 
                               Value="@_selectedProductId"
                               ValueChanged="OnProductChanged"
                               Label="Select Product"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Style="min-width: 300px;">
                        <MudSelectItem T="int?" Value="@((int?)null)">All products</MudSelectItem>
                        @foreach (var product in _products)
                        {
                            <MudSelectItem T="int?" Value="@product.Id">@product.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudPaper>
        }

        @* Embedded Release Planning Board *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h5">
                    <MudIcon Icon="@Icons.Material.Filled.ViewColumn" Class="mr-2" />
                    Release Planning Board
                </MudText>
                
                @* Board Toolbar *@
                <MudStack Row="true" Spacing="2">
                    <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                               Size="Size.Small"
                               Variant="Variant.Outlined"
                               OnClick="HandleRefreshValidation">
                        Refresh Validation
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               Variant="Variant.Outlined"
                               OnClick="HandleAddLane">
                        Add Lane
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Timeline"
                               Size="Size.Small"
                               Variant="Variant.Text"
                               OnClick="HandleAddMilestone">
                        Add Milestone
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Schedule"
                               Size="Size.Small"
                               Variant="Variant.Text"
                               OnClick="HandleAddIteration">
                        Add Iteration
                    </MudButton>
                    <MudButton StartIcon="@Icons.Material.Filled.Download"
                               Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="HandleExport">
                        Export
                    </MudButton>
                </MudStack>
            </MudStack>
            
            @* Embedded Release Planning Board Component *@
            <ReleasePlanningBoard />
        </MudPaper>

        @* Quick Links to Related Dashboards *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
                Related Dashboards
            </MudText>
            
            <MudGrid>
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick='() => NavigateToLegacy("/epic-forecast")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Epic Forecast</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Completion predictions</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="1" Style="cursor: pointer; transition: all 0.2s;" Class="mud-card-hover" @onclick='() => NavigateToLegacy("/velocity")'>
                        <MudCardContent Class="d-flex flex-column align-center pa-4">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Info" Size="Size.Large" />
                            <MudText Typo="Typo.subtitle1" Class="mt-2">Velocity Data</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">Historical performance</MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @* Validation & Conflicts *@
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h5" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                Validation & Conflicts
            </MudText>
            
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
                Identify planning conflicts and validation issues before they become problems.
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Psychology"
                           OnClick="NavigateToAnalysisForConflicts">
                    Analyze Issues
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.HealthAndSafety"
                           Href="/backlog-health">
                    Health Dashboard
                </MudButton>
            </MudStack>
        </MudPaper>

        @* Cross-Workspace Actions *@
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Class="mr-2" />
                Actions
            </MudText>
            
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Psychology"
                           OnClick="NavigateToAnalysis">
                    Analyze
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Share"
                           OnClick="NavigateToCommunication">
                    Share Plan
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Inventory2"
                           OnClick="NavigateToProduct">
                    Product Workspace
                </MudButton>
            </MudStack>
        </MudPaper>
    }
</MudContainer>

<style>
    .mud-card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.2) !important;
    }
</style>

@code {
    private bool _isLoading = true;
    private NavigationContext? _currentContext;
    private List<BreadcrumbItem> _breadcrumbs = new();
    private List<ProductDto> _products = new();
    private int? _selectedProductId;
    
    // Release Planning Board state
    private PoTool.Shared.ReleasePlanning.ReleasePlanningBoardDto? _board;
    
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Get current context
            _currentContext = NavigationContextService.CurrentOrDefault;
            
            // Validate profile
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile == null)
            {
                NavigationManager.NavigateTo(WorkspaceRoutes.Profiles);
                return;
            }
            
            ProfileService.SetCachedActiveProfileId(activeProfile.Id);
            
            // If no context exists, create one for Plannen intent
            if (_currentContext == null)
            {
                NavigationContextService.SetInitialContext(Intent.Plannen, activeProfile.Id);
                _currentContext = NavigationContextService.CurrentOrDefault;
            }
            
            // Load products
            _products = (await ProductService.GetProductsByOwnerAsync(activeProfile.Id)).ToList();
            
            // Set selected product from context
            if (_currentContext?.Scope.ProductId.HasValue == true)
            {
                _selectedProductId = _currentContext.Scope.ProductId;
            }
            
            // Load Release Planning Board
            _board = await ReleasePlanningService.GetBoardAsync();
            
            // Build breadcrumbs
            UpdateBreadcrumbs();
        }
        catch (Exception)
        {
            // Graceful degradation
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private void UpdateBreadcrumbs()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Landing", WorkspaceRoutes.Landing, icon: Icons.Material.Filled.Home),
            new("Planning", null, disabled: true, icon: Icons.Material.Filled.CalendarMonth)
        };
    }
    
    #region Release Planning Board Handlers
    
    private async Task HandleRefreshValidation()
    {
        var result = await ReleasePlanningService.RefreshValidationAsync();
        
        if (result?.Success == true)
        {
            Snackbar.Add($"Validation refreshed: {result.ErrorCount} errors, {result.WarningCount} warnings", 
                result.ErrorCount > 0 ? Severity.Warning : Severity.Success);
            _board = await ReleasePlanningService.GetBoardAsync();
            StateHasChanged();
        }
        else
        {
            Snackbar.Add($"Failed to refresh validation: {result?.ErrorMessage ?? "Unknown error"}", Severity.Error);
        }
    }

    private async Task HandleAddLane()
    {
        if (_board == null) return;

        var existingObjectiveIds = _board.Lanes.Select(l => l.ObjectiveId).ToList();

        var parameters = new DialogParameters<AddLaneDialog>
        {
            { x => x.ExistingObjectiveIds, existingObjectiveIds }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddLaneDialog>("Add Lane", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: int objectiveId })
        {
            var displayOrder = _board.Lanes.Count;
            var createResult = await ReleasePlanningService.CreateLaneAsync(objectiveId, displayOrder);

            if (createResult?.Success == true)
            {
                Snackbar.Add("Lane added successfully", Severity.Success);
                _board = await ReleasePlanningService.GetBoardAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Failed to add lane: {createResult?.ErrorMessage ?? "Unknown error"}", Severity.Error);
            }
        }
    }

    private async Task HandleAddMilestone()
    {
        if (_board == null) return;

        var parameters = new DialogParameters<AddMilestoneLineDialog>
        {
            { x => x.MaxRowIndex, _board.MaxRowIndex }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddMilestoneLineDialog>("Add Milestone Line", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddMilestoneLineDialog.MilestoneLineData data })
        {
            var createResult = await ReleasePlanningService.CreateMilestoneLineAsync(
                data.Label, 
                data.VerticalPosition, 
                data.Type);

            if (createResult?.Success == true)
            {
                Snackbar.Add("Milestone line added successfully", Severity.Success);
                _board = await ReleasePlanningService.GetBoardAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Failed to add milestone line: {createResult?.ErrorMessage ?? "Unknown error"}", Severity.Error);
            }
        }
    }

    private async Task HandleAddIteration()
    {
        if (_board == null) return;

        var parameters = new DialogParameters<AddIterationLineDialog>
        {
            { x => x.MaxRowIndex, _board.MaxRowIndex }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<AddIterationLineDialog>("Add Iteration Line", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AddIterationLineDialog.IterationLineData data })
        {
            var createResult = await ReleasePlanningService.CreateIterationLineAsync(
                data.Label, 
                data.VerticalPosition);

            if (createResult?.Success == true)
            {
                Snackbar.Add("Iteration line added successfully", Severity.Success);
                _board = await ReleasePlanningService.GetBoardAsync();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Failed to add iteration line: {createResult?.ErrorMessage ?? "Unknown error"}", Severity.Error);
            }
        }
    }

    private async Task HandleExport()
    {
        var parameters = new DialogParameters<ExportDialog>
        {
            { x => x.Board, _board }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        await DialogService.ShowAsync<ExportDialog>("Export", parameters, options);
    }
    
    #endregion
    
    private async Task OnProductChanged(int? productId)
    {
        _selectedProductId = productId;
        
        if (_currentContext != null && productId.HasValue)
        {
            var newContext = _currentContext with
            {
                Scope = new Scope
                {
                    Level = ScopeLevel.Product,
                    ProfileId = _currentContext.Scope.ProfileId,
                    ProductId = productId
                }
            };
            
            await NavigationContextService.NavigateWithContextAsync(
                WorkspaceRoutes.PlanningWorkspace, 
                newContext);
        }
    }
    
    private void NavigateToLanding()
    {
        NavigationContextService.ClearContext();
        NavigationManager.NavigateTo(WorkspaceRoutes.Landing);
    }
    
    private async Task NavigateBack()
    {
        await NavigationContextService.NavigateBackAsync();
    }
    
    private void NavigateToLegacy(string route)
    {
        NavigationManager.NavigateTo(route);
    }
    
    private async Task NavigateToAnalysis()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Begrijpen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Planning Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.AnalysisWorkspace, 
            newContext);
    }
    
    private async Task NavigateToAnalysisForConflicts()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Begrijpen,
            Trigger = new Trigger { Type = TriggerType.Deviation, SourceLabel = "Planning Workspace" },
            Mode = "health"
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.AnalysisWorkspace, 
            newContext);
    }
    
    private async Task NavigateToCommunication()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Delen,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Planning Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.CommunicationWorkspace, 
            newContext);
    }
    
    private async Task NavigateToProduct()
    {
        if (_currentContext == null) return;
        
        var newContext = _currentContext with
        {
            Intent = Intent.Overzien,
            Trigger = new Trigger { Type = TriggerType.Choice, SourceLabel = "Planning Workspace" }
        };
        
        await NavigationContextService.NavigateWithContextAsync(
            WorkspaceRoutes.ProductWorkspace, 
            newContext);
    }
}
