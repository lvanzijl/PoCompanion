@using PoTool.Client.Models
@using MudBlazor

<div class="bug-tree-node">
    <div class="node-row @GetNodeClass()" style="padding-left:@(Node.Level * 1.25)rem">
        @* Expand/Collapse for group nodes or bugs with children *@
        @if (Node.Children.Any() || Node.Type == "(group)")
        {
            <button type="button" 
                    class="@GetCaretClass()" 
                    @onclick="HandleExpandClick">
                <span class="chev">➤</span>
            </button>
        }
        else
        {
            <span class="leaf-spacer"></span>
        }
        
        @* Node content *@
        @if (Node.Type == "(group)")
        {
            @* Group node *@
            <span class="group-label">@Node.Title</span>
        }
        else
        {
            @* Bug node with type indicator *@
            <span class="type-indicator" style="background-color: @Node.TypeColor" title="@Node.Type"></span>
            
            <span class="workitem-type">Bug</span>
            
            <div class="title-block">
                <span class="@GetTitleClass()" @onclick="HandleClick" @onclick:stopPropagation="true">
                    @Node.Title
                </span>
            </div>
            
            <span class="status-column">@Node.State</span>
            
            @if (Node.HasValidationIssues || Node.HasDescendantIssues)
            {
                <span class="validation-icon" title="@GetValidationTooltip()" role="img" aria-label="@GetValidationAriaLabel()">
                    @Node.ValidationIcon
                </span>
            }
        }
    </div>
    
    @* Children *@
    @if (Node.IsExpanded && Node.Children.Any())
    {
        @foreach (var child in Node.Children)
        {
            <BugTriageTreeNode Node="@child"
                              SelectedId="@SelectedId"
                              OnNodeToggled="@OnNodeToggled"
                              OnNodeSelected="@OnNodeSelected" />
        }
    }
</div>

@code {
    [Parameter]
    public TreeNode Node { get; set; } = null!;

    [Parameter]
    public int? SelectedId { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeToggled { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeSelected { get; set; }

    private async Task HandleExpandClick()
    {
        await OnNodeToggled.InvokeAsync(Node);
    }

    private async Task HandleClick()
    {
        if (Node.Type != "(group)")
        {
            await OnNodeSelected.InvokeAsync(Node);
        }
    }

    private string GetNodeClass()
    {
        if (Node.Type == "(group)")
        {
            return "group-node";
        }
        return "bug-node";
    }

    private string GetCaretClass()
    {
        return Node.IsExpanded ? "caret-button expanded" : "caret-button";
    }

    private string GetTitleClass()
    {
        var className = "workitem-title";
        if (SelectedId.HasValue && SelectedId.Value == Node.Id)
        {
            className += " selected";
        }
        return className;
    }

    private string GetValidationTooltip()
    {
        return string.Join("\n", Node.ValidationIssues);
    }

    private string GetValidationAriaLabel()
    {
        if (Node.HasValidationIssues)
        {
            var issueCount = Node.ValidationIssues.Count;
            var categoryName = Node.HighestCategory?.ToString() ?? "Unknown";
            return $"{categoryName}: {issueCount} validation issue{(issueCount != 1 ? "s" : "")}";
        }
        else if (Node.HasDescendantIssues)
        {
            return $"Descendant has validation issues";
        }
        return "No validation issues";
    }
}
