@using PoTool.Client.Models
@using MudBlazor

<div class="bug-tree-node">
    <div class="node-row @GetNodeClass()" @onclick="HandleClick">
        <div class="node-indent" style="width: @(Node.Level * 20)px"></div>
        
        @* Expand/Collapse for group nodes or bugs with children *@
        @if (Node.Children.Any() || Node.Type == "(group)")
        {
            <MudIconButton Icon="@(Node.IsExpanded ? Icons.Material.Filled.ExpandMore : Icons.Material.Filled.ChevronRight)"
                          Size="Size.Small"
                          Class="expand-button"
                          OnClick="HandleExpandClick" />
        }
        else
        {
            <span class="leaf-spacer"></span>
        }
        
        @* Node content *@
        @if (Node.Type == "(group)")
        {
            @* Group node *@
            <span class="group-label">@Node.Title</span>
        }
        else
        {
            @* Bug node *@
            <MudIcon Icon="@Icons.Material.Filled.BugReport" 
                    Size="Size.Small" 
                    Color="@GetBugColor()" 
                    Class="bug-icon" />
            <span class="bug-title">@Node.Title</span>
            <span class="bug-id">#@Node.Id</span>
        }
    </div>
    
    @* Children *@
    @if (Node.IsExpanded && Node.Children.Any())
    {
        @foreach (var child in Node.Children)
        {
            <BugTriageTreeNode Node="@child"
                              SelectedId="@SelectedId"
                              OnNodeToggled="@OnNodeToggled"
                              OnNodeSelected="@OnNodeSelected" />
        }
    }
</div>

@code {
    [Parameter]
    public TreeNode Node { get; set; } = null!;

    [Parameter]
    public int? SelectedId { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeToggled { get; set; }

    [Parameter]
    public EventCallback<TreeNode> OnNodeSelected { get; set; }

    private async Task HandleExpandClick()
    {
        await OnNodeToggled.InvokeAsync(Node);
    }

    private async Task HandleClick()
    {
        if (Node.Type != "(group)")
        {
            await OnNodeSelected.InvokeAsync(Node);
        }
    }

    private string GetNodeClass()
    {
        var classes = new List<string>();
        
        if (Node.Type == "(group)")
        {
            classes.Add("group-node");
        }
        else
        {
            classes.Add("bug-node");
            if (SelectedId == Node.Id)
            {
                classes.Add("selected");
            }
        }
        
        return string.Join(" ", classes);
    }

    private Color GetBugColor()
    {
        // Simple color coding - could be enhanced based on criticality
        return Color.Default;
    }
}
