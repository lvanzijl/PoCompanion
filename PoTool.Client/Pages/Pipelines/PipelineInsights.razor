@page "/pipeline-insights"
@using PoTool.Client.Services
@using PoTool.Client.ApiClient
@using PoTool.Client.Components.Common
@using PoTool.Client.Pages.Pipelines.SubComponents
@using static PoTool.Client.Components.Common.PageHelp
@inject PipelineService PipelineService
@inject ErrorMessageService ErrorMessageService
@inject ProductService ProductService
@inject IProfileService ProfileService
@inject IPreferencesService PreferencesService
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Pipeline Insights</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <!-- Context-Aware Help -->
    <PageHelp Title="Pipeline Insights Guide"
              Description="The Pipeline Insights Dashboard provides visibility into your build and release pipeline health. Track success rates, build durations, and identify failing pipelines to improve your CI/CD process."
              Class="mb-4"
              DataRequirements="@_dataRequirements"
              BestPractices="@_bestPractices"
              CommonIssues="@_commonIssues">
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
            <strong>Pipeline Data:</strong> View build and release metrics for your selected product scope. Data is automatically loaded from cached pipeline definitions and runs.
        </MudAlert>
    </PageHelp>
    
    <MudText Typo="Typo.h4" GutterBottom="true">
        <MudIcon Icon="@Icons.Material.Filled.Engineering" Class="mr-2" /> Pipeline Insights
    </MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        Build and release pipeline metrics and analytics
    </MudText>

    @* Product Selector *@
    @if (_products.Count > 0)
    {
        <MudPaper Elevation="1" Class="pa-3 mb-3">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
                <MudSelect T="int" 
                           Value="@_selectedProductId"
                           ValueChanged="OnProductChanged"
                           Label="Filter by Product"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 300px;">
                    <MudSelectItem T="int" Value="@AllProductsId">All products</MudSelectItem>
                    @foreach (var product in _products)
                    {
                        <MudSelectItem T="int" Value="@product.Id">@product.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Showing pipelines for: @GetProductScopeDescription()
                </MudText>
            </MudStack>
        </MudPaper>
    }

    <LoadingIndicator IsLoading="@_isLoading" />
    
    @if (!_isLoading && !_metrics.Any())
    {
        <EmptyStateDisplay Title="No Pipeline Data Available"
                          Message="There are no pipelines available for the selected product scope. Try selecting a different product or check that pipeline definitions exist in your Azure DevOps project." />
    }
    else if (!_isLoading)
    {
        <ErrorDisplay ErrorResponse="@_errorResponse" 
                      Class="mb-4"
                      OnDismiss="ClearError" />
        
        <!-- Top Metrics Cards -->
        <PipelineMetricsSummaryPanel Metrics="@_metrics" />

        <!-- Tabs for different views -->
        <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
            <MudTabPanel Text="Overview" Icon="@Icons.Material.Filled.Dashboard">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <PipelineSuccessRateChart Metrics="@_metrics" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <PipelineDurationChart Metrics="@_metrics" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Pipeline Health" Icon="@Icons.Material.Filled.HealthAndSafety">
                <PipelineHealthTable Metrics="@_metrics" />
            </MudTabPanel>

            <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.List">
                <MudDataGrid Items="@_metrics" 
                             Filterable="true" 
                             SortMode="SortMode.Multiple"
                             Dense="true"
                             Hover="true">
                    <Columns>
                        <PropertyColumn Property="x => x.PipelineName" Title="Pipeline" />
                        <PropertyColumn Property="x => x.Type" Title="Type">
                            <CellTemplate>
                                <MudChip Color="@GetTypeColor(context.Item.Type)" Size="Size.Small">
                                    @context.Item.Type
                                </MudChip>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.TotalRuns" Title="Total Runs" />
                        <PropertyColumn Property="x => x.SuccessfulRuns" Title="Successful" />
                        <PropertyColumn Property="x => x.FailedRuns" Title="Failed" />
                        <PropertyColumn Property="x => x.FailureRate" Title="Failure Rate" Format="P1" />
                        <PropertyColumn Property="x => x.AverageDuration" Title="Avg Duration" Format="hh\:mm\:ss" />
                        <PropertyColumn Property="x => x.LastRunResult" Title="Last Result">
                            <CellTemplate>
                                <MudChip Color="@GetResultColor(context.Item.LastRunResult)" Size="Size.Small">
                                    @(context.Item.LastRunResult?.ToString() ?? "N/A")
                                </MudChip>
                            </CellTemplate>
                        </PropertyColumn>
                        <PropertyColumn Property="x => x.ConsecutiveFailures" Title="Consecutive Failures">
                            <CellTemplate>
                                @if (context.Item.ConsecutiveFailures > 0)
                                {
                                    <MudChip Color="Color.Error" Size="Size.Small">@context.Item.ConsecutiveFailures</MudChip>
                                }
                                else
                                {
                                    <MudText>0</MudText>
                                }
                            </CellTemplate>
                        </PropertyColumn>
                    </Columns>
                </MudDataGrid>
            </MudTabPanel>
        </MudTabs>
    }
</MudContainer>

@code {
    private List<PipelineMetricsDto> _metrics = new();
    private bool _isLoading = true;
    private ErrorResponse? _errorResponse;
    private CancellationTokenSource? _loadCancellationTokenSource;

    // Product filtering state
    private const int AllProductsId = 0;
    private List<ProductDto> _products = new();
    private int _selectedProductId = AllProductsId;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
        await LoadSelectedProductIdAsync();
        await LoadData();
    }

    private async Task LoadProductsAsync()
    {
        try
        {
            var activeProfile = await ProfileService.GetActiveProfileAsync();
            if (activeProfile != null)
            {
                var products = await ProductService.GetProductsByOwnerAsync(activeProfile.Id);
                _products = products.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PipelineInsights] Error loading products: {ex.Message}");
            _products = new List<ProductDto>();
        }
    }

    private async Task LoadSelectedProductIdAsync()
    {
        try
        {
            var savedProductId = await PreferencesService.GetIntAsync("PipelineInsights_SelectedProductId");
            if (savedProductId.HasValue)
            {
                // Validate that the product still exists
                if (savedProductId.Value == AllProductsId || _products.Any(p => p.Id == savedProductId.Value))
                {
                    _selectedProductId = savedProductId.Value;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PipelineInsights] Error loading saved product selection: {ex.Message}");
        }
    }

    private async Task OnProductChanged(int newProductId)
    {
        if (_selectedProductId == newProductId)
        {
            return; // No change
        }

        _selectedProductId = newProductId;

        // Save preference
        await PreferencesService.SetIntAsync("PipelineInsights_SelectedProductId", _selectedProductId);

        // Cancel any in-flight load operation
        _loadCancellationTokenSource?.Cancel();
        _loadCancellationTokenSource?.Dispose();
        _loadCancellationTokenSource = null;

        // Reload data with new filter
        await LoadData();
    }

    private string GetProductScopeDescription()
    {
        if (_selectedProductId == AllProductsId)
        {
            return "All products";
        }

        var product = _products.FirstOrDefault(p => p.Id == _selectedProductId);
        return product?.Name ?? "Unknown product";
    }

    private async Task LoadData()
    {
        _isLoading = true;
        StateHasChanged(); // Notify UI of loading state
        
        // Create a new cancellation token for this load operation
        _loadCancellationTokenSource?.Cancel();
        _loadCancellationTokenSource?.Dispose();
        _loadCancellationTokenSource = new CancellationTokenSource();
        var cancellationToken = _loadCancellationTokenSource.Token;
        
        try
        {
            ClearError();
            
            // Build product IDs parameter for filtering
            string? productIdsParam = null;
            if (_selectedProductId == AllProductsId && _products.Any())
            {
                productIdsParam = string.Join(",", _products.Select(p => p.Id));
            }
            else if (_selectedProductId != AllProductsId)
            {
                productIdsParam = _selectedProductId.ToString();
            }
            
            var metrics = await PipelineService.GetMetricsAsync(productIdsParam);
            
            // Check if operation was cancelled
            if (cancellationToken.IsCancellationRequested)
            {
                Console.WriteLine("[PipelineInsights] Load operation cancelled");
                return;
            }
            
            _metrics = metrics.ToList();
            
            Console.WriteLine($"[PipelineInsights] Loaded {_metrics.Count} pipeline metrics for product scope: {GetProductScopeDescription()}");
        }
        catch (OperationCanceledException)
        {
            // Expected when switching scopes rapidly - ignore
            Console.WriteLine("[PipelineInsights] Load operation cancelled");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PipelineInsights] Error loading pipeline metrics: {ex.Message}");
            ShowError(ex, "Error loading pipeline metrics");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged(); // Ensure UI updates when loading completes
        }
    }

    private void ShowError(Exception ex, string context)
    {
        _errorResponse = ErrorMessageService.GetErrorResponse(ex, context);
        StateHasChanged();
    }

    private void ClearError()
    {
        _errorResponse = null;
    }

    private Color GetTypeColor(PipelineType type)
    {
        return type switch
        {
            PipelineType.Build => Color.Info,
            PipelineType.Release => Color.Success,
            _ => Color.Default
        };
    }

    private Color GetResultColor(PipelineRunResult? result)
    {
        return result switch
        {
            PipelineRunResult.Succeeded => Color.Success,
            PipelineRunResult.Failed => Color.Error,
            PipelineRunResult.PartiallySucceeded => Color.Warning,
            PipelineRunResult.Canceled => Color.Default,
            _ => Color.Default
        };
    }

    private List<DataRequirement> _dataRequirements = new()
    {
        new DataRequirement 
        { 
            Field = "Pipeline Definitions", 
            Description = "Azure DevOps automatically tracks build and release pipeline definitions",
            IsRequired = true 
        },
        new DataRequirement 
        { 
            Field = "Pipeline Runs", 
            Description = "Historical run data including duration, result, and trigger type",
            IsRequired = true 
        }
    };

    private List<string> _bestPractices = new()
    {
        "Keep failure rates below 10% for healthy pipelines",
        "Aim for build times under 15 minutes for fast feedback",
        "Investigate pipelines with 3+ consecutive failures immediately",
        "Monitor duration trends to catch performance regressions",
        "Use separate pipelines for CI and release deployments"
    };

    private List<CommonIssue> _commonIssues = new()
    {
        new CommonIssue 
        { 
            Problem = "No pipeline data available",
            Solution = "Ensure you have build/release pipelines in your Azure DevOps project and that pipeline definitions have been cached. Check that your product's repositories are correctly configured."
        },
        new CommonIssue 
        { 
            Problem = "High failure rate (>20%)",
            Solution = "Review failing tests, check for flaky tests, ensure infrastructure stability, and add retry logic for transient failures."
        },
        new CommonIssue 
        { 
            Problem = "Long build durations (>30 minutes)",
            Solution = "Optimize build steps, use caching, parallelize tasks, and consider incremental builds."
        }
    };

    public void Dispose()
    {
        _loadCancellationTokenSource?.Cancel();
        _loadCancellationTokenSource?.Dispose();
    }
}
