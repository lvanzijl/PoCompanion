@using PoTool.Client.Components.Common
@using PoTool.Client.Services
@using PoTool.Client.Helpers
@using PoTool.Client.Models
@inject ErrorMessageService ErrorMessageService
@inject NavigationManager NavigationManager

<CascadingValue Value="@_errorBoundary">
    <ErrorBoundary @ref="_errorBoundary">
        <ChildContent>
            <Router AppAssembly="@typeof(App).Assembly" NotFoundPage="@typeof(Pages.NotFound)">
                <Found Context="routeData">
                    <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
                    <FocusOnNavigate RouteData="@routeData" Selector="h1" />
                </Found>
            </Router>
        </ChildContent>
        <ErrorContent Context="exception">
            <MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
                <ErrorDisplay ErrorResponse="@CreateErrorResponse(exception)"
                              ShowTechnicalDetails="false"
                              Dismissible="false">
                    <Actions>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="RecoverCurrentPage">
                            Try again
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   Href="@WorkspaceRoutes.Home">
                            Home
                        </MudButton>
                    </Actions>
                </ErrorDisplay>
            </MudContainer>
        </ErrorContent>
    </ErrorBoundary>
</CascadingValue>

@code {
    private ErrorBoundary? _errorBoundary;

    protected override void OnParametersSet()
    {
        // Reset error boundary on navigation
        _errorBoundary?.Recover();
    }

    private ErrorResponse CreateErrorResponse(Exception exception)
    {
        var response = RouteStateGuard.CreateSafeErrorResponse(ErrorMessageService, exception, "This page");
        response.UserMessage = "This page couldn't be displayed.";
        response.Suggestion ??= "Retry the page or return to Home.";
        return response;
    }

    private void RecoverCurrentPage()
    {
        _errorBoundary?.Recover();
        NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
    }
}
