{
  "Logging": {
   "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
   }
  },
  "TfsIntegration": {
    "UseMockClient": false
  },
  "RevisionIngestionDiagnostics": {
    "Enabled": false,
    "LogPerPageSummary": true,
    "LogPerWorkItemHydration": false,
    "LogEfSaveChangesDetails": true,
    "SlowPageThresholdMs": 2000,
    "SlowDbThresholdMs": 1000,
    "SlowHttpThresholdMs": 1000,
    "SampleRate": 1.0
  }
}
