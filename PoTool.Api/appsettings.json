{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=potool.db"
  },
  "TfsIntegration": {
    "UseMockClient": true
  },
  "RevisionIngestionDiagnostics": {
    "Enabled": false,
    "LogPerPageSummary": true,
    "LogPerWorkItemHydration": false,
    "LogEfSaveChangesDetails": true,
    "LogGcStatsEveryNPages": 50,
    "SlowPageThresholdMs": 2000,
    "SlowDbThresholdMs": 1000,
    "SlowHttpThresholdMs": 1000,
    "SampleRate": 1.0,
    "MaxParseWarningsPerPage": 10
  },
  "RevisionIngestionPagination": {
    "ODataTop": 200,
    "ODataSeekPageSize": 200,
    "ODataSelectMode": "Minimal",
    "ODataOrderByEnabled": true,
    "ODataQuoteDateStrings": false,
    "ODataEnableSeekPagingFallback": true,
    "ODataScopeMode": "Range",
    "ODataMaxUrlLength": 1800,
    "MaxNoProgressPages": 2,
    "RetryEnabled": false,
    "RetryMaxIterations": 3,
    "RetryOverlapMinutes": 60,
    "ProgressEpsilonSeconds": 1,
    "MaxEmptyPages": 3,
    "MaxProgressWithoutDataPages": 3,
    "MaxTotalPages": 5000,
    "MaxTotalRows": 500000
  },
  "RevisionIngestionPersistenceOptimization": {
    "Enabled": true,
    "SqlitePragmasEnabled": true,
    "SqliteSynchronous": "NORMAL",
    "SqliteCacheSizeKb": 100000,
    "SqliteTempStoreMemory": true,
    "BatchPagesPerTransaction": 1,
    "MaxEntitiesPerFlush": 5000
  }
}
